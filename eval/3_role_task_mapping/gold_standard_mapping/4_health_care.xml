<?xml version="1.0" encoding="UTF-8"?>
<tasks>

  <task id="t1">
    <label>Provide consent</label>
    <performers>
      <performer><unit>Applicant / Representative</unit><role>Applicant / Representative</role></performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions/>
    <exceptions/>
    <source-ref article="UNKNOWN" paragraph="2"/>
  </task>

  <task id="t2">
    <label>Refuse consent</label>
    <performers>
      <performer><unit>Applicant / Representative</unit><role>Applicant / Representative</role></performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions/>
    <exceptions/>
    <source-ref article="UNKNOWN" paragraph="2"/>
  </task>

  <task id="t3">
    <label>Transmit to the Member State responsible information</label>
    <performers>
      <performer><unit>Transferring Member State</unit><role>Health Professional</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>for the sole purpose of the provision of medical care or treatment</condition>
      <condition>in so far as the information is available to the competent authority</condition>
      <condition>after having obtained the explicit consent of the applicant / representative or, if the applicant is physically or legally incapable of giving his or her consent, when such transmission is necessary to protect the vital interests of the applicant or of another person.</condition>
    </conditions>
    <exceptions>
      <exceptions ref="" description="The lack of consent, including a refusal to consent, shall not constitute an obstacle to the transfer."/>
    </exceptions>
    <source-ref article="UNKNOWN" paragraph="1"/>
  </task>

  <task id="t4">
    <label>Include information on physical or mental health</label>
    <performers>
      <performer>
        <unit>Transferring Member State</unit><role>Health Professional</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>in specific cases</condition>
    </conditions>
    <exceptions/>
    <source-ref article="UNKNOWN" paragraph="1"/>
  </task>

  <task id="t5">
    <label>Ensure that special needs are adequately addressed</label>
    <performers>
      <performer><unit>Member State Responsible</unit><role>Competent Authority</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="UNKNOWN" paragraph="1"/>
  </task>

  <task id="t6">
    <label>Draw up the common health certificate</label>
    <performers>
      <performer><unit>Commission</unit><role>Commission</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="UNKNOWN" paragraph="1"/>
  </task>

  <task id="t7">
    <label>Adopt implementing acts</label>
    <performers>
      <performer><unit>Commission</unit><role>Commission</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="UNKNOWN" paragraph="1"/>
  </task>

  <task id="t8">
    <label>Obtain explicit consent</label>
    <performers>
      <performer>
        <unit>Transferring Member State</unit><role>Health Professional</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>prior to transmitting the information referred to in paragraph 1</condition>
    </conditions>
    <exceptions>
      <exception description="if the applicant is physically or legally incapable of giving his or her consent, when such transmission is necessary to protect the vital interests of the applicant or of another person" ref="t8"/>
    </exceptions>
    <source-ref article="UNKNOWN" paragraph="2"/>
  </task>

  <task id="t9">
    <label>Carry out the processing of personal health data</label>
    <performers>
      <performer><unit>Member State Responsible</unit><role>Health Professional</role></performer>
      <performer><unit>Transferring Member State Member State</unit><role>Health Professional</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="UNKNOWN" paragraph="3"/>
  </task>

  <task id="t10">
    <label>Exchange information</label>
    <performers>
      <performer>
        <unit>Transferring Member State</unit><role>Health Professional</role>
      </performer>
      <performer>
        <unit>Member State Responsible</unit><role>Health Professional</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="UNKNOWN" paragraph="4"/>

  </task>
  <task id="t11">
    <label>Use exchanged information</label>
    <performers>
      <performer>
        <unit>Member State Responsible</unit><role>Health Professional</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>only for the purposes set out in paragraph 1</condition>
    </conditions>
    <exceptions/>
    <source-ref article="UNKNOWN" paragraph="4"/>
  </task>

  <task id="t12">
    <label>Further process the information</label>
    <performers>
      <performer><unit>Member State Responsible</unit><role>Health Professional</role></performer>
    </performers>
    <deontic type="prohibition" modality="shall not"/>
    <conditions/>
    <exceptions/>
    <source-ref article="UNKNOWN" paragraph="4"/>
  </task>

  <task id="t13">
    <label>Adopt uniform conditions and practical arrangements for exchanging the information</label>
    <performers>
      <performer><unit>Commission</unit><role>Commission</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="UNKNOWN" paragraph="5"/>
  </task>

  <task id="t14">
    <label>Adopt those implementing acts</label>
    <performers>
      <performer><unit>Commission</unit><role>Commission</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="UNKNOWN" paragraph="5"/>
  </task>
</tasks>
