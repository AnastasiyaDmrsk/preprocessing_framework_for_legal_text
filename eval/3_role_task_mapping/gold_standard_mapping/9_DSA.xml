<?xml version="1.0" encoding="UTF-8"?>
<tasks>

  <task id="t1">
    <label>take the necessary technical and organisational measures for notices</label>
    <performers>
      <performer><unit>Provider</unit><role>Online Platform Provider</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="1"/>
  </task>

    <task id="t2">
    <label>give priority for notices</label>
    <performers>
      <performer><unit>Provider</unit><role>Online Platform Provider</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>notices submitted within their designated area of expertise</condition>
      <condition>notices submitted through the mechanisms referred to in Article 16</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="1"/>
  </task>

  <task id="t3">
    <label>process notices</label>
    <performers>
      <performer><unit>Provider</unit><role>Online Platform Provider</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>notices submitted within their designated area of expertise</condition>
      <condition>notices submitted through the mechanisms referred to in Article 16</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="1"/>
  </task>

  <task id="t4">
    <label>decide upon notices</label>
    <performers>
      <performer><unit>Provider</unit><role>Online Platform Provider</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>notices acting within their designated area of expertise</condition>
      <condition>notices submitted through the mechanisms referred to in Article 16</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="1"/>
  </task>

  <task id="t5">
    <label>award the status of trusted flagger</label>
    <performers>
      <performer><unit>Member State</unit><role>Digital Services Coordinator</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>upon application by any entity</condition>
      <condition>applicant is established</condition>
      <condition>applicant meets all of the conditions</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="2"/>
  </task>

  <task id="t6">
    <label>publish reports on notices submitted</label>
    <performers>
      <performer><unit>Entity</unit><role>Trusted Flagger</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>at least once a year</condition>
      <condition>covering notices submitted during the relevant period</condition>
      <condition>reports shall include an explanation of the procedures in place to ensure that the trusted flagger retains its independence</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="3"/>
  </task>

  <task id="t7">
    <label>send reports to the Digital Services Coordinator</label>
    <performers>
      <performer><unit>Entity</unit><role>Trusted Flagger</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="3"/>
  </task>

  <task id="t8">
    <label>make reports publicly available</label>
    <performers>
      <performer><unit>Entity</unit><role>Trusted Flagger</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="3"/>
  </task>

  <task id="t9">
    <label>communicate to the Commission and the Board the names, addresses and email addresses of entities awarded, suspended, or revoked trusted flagger status</label>
    <performers>
      <performer><unit>Member State</unit><role>Digital Services Coordinator</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>following award of trusted flagger status in accordance with paragraph 2</condition>
      <condition>or following suspension of trusted flagger status in accordance with paragraph 6</condition>
      <condition>or following revocation of trusted flagger status in accordance with paragraph 7</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="4"/>
  </task>

  <task id="t10">
    <label>publish information in a publicly available database</label>
    <performers>
      <performer><unit>Commission</unit><role>Commission</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="5"/>
  </task>

  <task id="t11">
    <label>keep database up to date</label>
    <performers>
      <performer><unit>Commission</unit><role>Commission</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="5"/>
  </task>

  <task id="t12">
    <label>communicate information to the Digital Services Coordinator</label>
    <performers>
      <performer><unit>Provider</unit><role>Online Platform Provider</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>if a trusted flagger has submitted insufficiently precise, inaccurate or inadequately substantiated notices</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="6"/>
  </task>

  <task id="t13">
    <label>suspend the status of trusted flagger</label>
    <performers>
      <performer><unit>Member State</unit><role>Digital Services Coordinator</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>upon receiving information from a provider of online platforms</condition>
      <condition>if the Digital Services Coordinator considers that there are legitimate reasons to open an investigation</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="6"/>
  </task>

  <task id="t14">
    <label>carry out the investigation</label>
    <performers>
      <performer><unit>Member State</unit><role>Digital Services Coordinator</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>following suspension of trusted flagger status under paragraph 6</condition>
      <condition>without undue delay</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="6"/>
  </task>

  <task id="t15">
    <label>afford the entity an opportunity to react to the investigation findings</label>
    <performers>
      <performer><unit>Member State</unit><role>Digital Services Coordinator</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>before revoking the trusted flagger status of an entity</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="7"/>
  </task>

  <task id="t16">
    <label>react to the investigation findings</label>
    <performers>
      <performer><unit>Entity</unit><role>Trusted Flagger</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="7"/>
  </task>

  <task id="t17">
    <label>revoke the trusted flagger status</label>
    <performers>
      <performer><unit>Member State</unit><role>Digital Services Coordinator</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>if the entity no longer meets the conditions</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="7"/>
  </task>

  <task id="t18">
    <label>consult</label>
    <performers>
      <performer><unit>Commission</unit><role>Commission</role></performer>
      <performer><unit>Board</unit><role>Board</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>before issuing guidelines under paragraph 8</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="8"/>
  </task>

  <task id="t19">
    <label>issue guidelines</label>
    <performers>
      <performer><unit>Commission</unit><role>Commission</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>where necessary</condition>
      <condition>after consulting the Board</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="8"/>
  </task>

</tasks>
