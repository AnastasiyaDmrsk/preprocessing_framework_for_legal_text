<?xml version="1.0" ?>
<tasks>
  <task id="t1">
    <label>Transmit information on special needs to Member State responsible</label>
    <performers>
      <performer>
        <unit>Transferring Member State</unit>
        <role>Health Professional</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>for the sole purpose of provision of medical care or treatment</condition>
      <condition>in so far as available to the competent authority IAW national law</condition>
      <condition>after having obtained explicit consent of applicant and/or representative, OR if applicant is incapable of giving consent, when necessary to protect vital interests of applicant or another person</condition>
    </conditions>
    <exceptions/>
    <source-ref article="UNKNOWN" paragraph="1"/>
  </task>
