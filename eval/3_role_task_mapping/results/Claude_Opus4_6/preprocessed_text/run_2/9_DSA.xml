<?xml version="1.0" ?>
<tasks>
  <task id="t1">
    <label>Take necessary technical and organisational measures</label>
    <performers>
      <performer>
        <unit>Provider</unit>
        <role>Online Platform Provider</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="1"/>
  </task>
  <task id="t2">
    <label>Give priority to notices from trusted flaggers</label>
    <performers>
      <performer>
        <unit>Provider</unit>
        <role>Online Platform Provider</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="1"/>
  </task>
  <task id="t3">
    <label>Process notices from trusted flaggers</label>
    <performers>
      <performer>
        <unit>Provider</unit>
        <role>Online Platform Provider</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="1"/>
  </task>
  <task id="t4">
    <label>Decide upon notices from trusted flaggers</label>
    <performers>
      <performer>
        <unit>Provider</unit>
        <role>Online Platform Provider</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="1"/>
  </task>
  <task id="t5">
    <label>Award status of trusted flagger</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Digital Services Coordinator</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>upon application by any entity</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="2"/>
  </task>
  <task id="t6">
    <label>Publish reports on notices submitted</label>
    <performers>
      <performer>
        <unit>Entity</unit>
        <role>Trusted Flagger</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>at least once a year</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="3"/>
  </task>
  <task id="t7">
    <label>List notices by identity of provider of hosting services</label>
    <performers>
      <performer>
        <unit>Entity</unit>
        <role>Trusted Flagger</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="3(a)"/>
  </task>
  <task id="t8">
    <label>List notices by type of allegedly illegal content</label>
    <performers>
      <performer>
        <unit>Entity</unit>
        <role>Trusted Flagger</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="3(b)"/>
  </task>
  <task id="t9">
    <label>List notices by action taken by provider</label>
    <performers>
      <performer>
        <unit>Entity</unit>
        <role>Trusted Flagger</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="3(c)"/>
  </task>
  <task id="t10">
    <label>Include explanation of procedures in reports</label>
    <performers>
      <performer>
        <unit>Entity</unit>
        <role>Trusted Flagger</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="3"/>
  </task>
  <task id="t11">
    <label>Send reports to awarding Digital Services Coordinator</label>
    <performers>
      <performer>
        <unit>Entity</unit>
        <role>Trusted Flagger</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="3"/>
  </task>
  <task id="t12">
    <label>Make reports publicly available</label>
    <performers>
      <performer>
        <unit>Entity</unit>
        <role>Trusted Flagger</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="3"/>
  </task>
  <task id="t13">
    <label>Include personal data in reports</label>
    <performers>
      <performer>
        <unit>Entity</unit>
        <role>Trusted Flagger</role>
      </performer>
    </performers>
    <deontic type="prohibition" modality="shall not"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="3"/>
  </task>
  <task id="t14">
    <label>Communicate names, addresses and email addresses of entities to Commission and Board</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Digital Services Coordinator</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>when trusted flagger status has been awarded, suspended or revoked</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="4"/>
  </task>
  <task id="t15">
    <label>Publish information in publicly available database</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="5"/>
  </task>
  <task id="t16">
    <label>Keep database up to date</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="5"/>
  </task>
  <task id="t17">
    <label>Communicate information on insufficiently substantiated notices to Digital Services Coordinator</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>if a provider of online platforms has information indicating that a trusted flagger has submitted a significant number of insufficiently precise, inaccurate or inadequately substantiated notices</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="6"/>
  </task>
  <task id="t18">
    <label>Suspend status of trusted flagger</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>upon receiving information from the provider of online platforms</condition>
      <condition>if the Digital Services Coordinator considers there are legitimate reasons to open an investigation</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="6"/>
  </task>
  <task id="t19">
    <label>Carry out investigation</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="6"/>
  </task>
  <task id="t20">
    <label>Revoke status of trusted flagger</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Digital Services Coordinator</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>if the Digital Services Coordinator determines, following an investigation, that the entity no longer meets the conditions set out</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="7"/>
  </task>
  <task id="t21">
    <label>Afford entity opportunity to react to investigation findings</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Digital Services Coordinator</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>before revoking trusted flagger status</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="7"/>
  </task>
  <task id="t22">
    <label>Consult the Board</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="8"/>
  </task>
  <task id="t23">
    <label>Provide consultation to Commission on guidelines</label>
    <performers>
      <performer>
        <unit>Board</unit>
        <role>Board</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="8"/>
  </task>
  <task id="t24">
    <label>Issue guidelines to assist providers and Digital Services Coordinators</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>where necessary</condition>
      <condition>after consulting the Board</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="8"/>
  </task>
</tasks>