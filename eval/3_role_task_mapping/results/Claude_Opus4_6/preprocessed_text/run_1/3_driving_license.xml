<?xml version="1.0" ?>
<tasks>
  <task id="t1">
    <label>Ensure that applicants undergo a medical examination</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Member State</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>before a driving licence is issued for the first time</condition>
    </conditions>
    <exceptions/>
    <source-ref article="11" paragraph="1"/>
  </task>
  <task id="t2">
    <label>Undergo a medical examination</label>
    <performers>
      <performer>
        <unit>Applicant</unit>
        <role>Applicant</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>before a driving licence is issued for the first time</condition>
    </conditions>
    <exceptions/>
    <source-ref article="11" paragraph="1"/>
  </task>
  <task id="t3">
    <label>Require a medical examination for categories C, CE, C1, C1E, D, D1, DE or D1E</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Member State</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>regardless of whether a medical examination was undertaken for another category</condition>
    </conditions>
    <exceptions/>
    <source-ref article="11" paragraph="1"/>
  </task>
  <task id="t4">
    <label>Undergo a medical examination for categories C, CE, C1, C1E, D, D1, DE or D1E</label>
    <performers>
      <performer>
        <unit>Applicant</unit>
        <role>Applicant</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>when applying for driving licences of categories C, CE, C1, C1E, D, D1, DE or D1E</condition>
    </conditions>
    <exceptions/>
    <source-ref article="11" paragraph="1"/>
  </task>
  <task id="t5">
    <label>Undergo a medical examination for renewal</label>
    <performers>
      <performer>
        <unit>Applicant</unit>
        <role>Applicant</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>before a driving licence is renewed</condition>
    </conditions>
    <exceptions>
      <exception description="for category AM, applies only if so required by the Member State in question" ref="t5"/>
    </exceptions>
    <source-ref article="11" paragraph="2"/>
  </task>
  <task id="t6">
    <label>Require applicant or holder to fill in a self-assessment form</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Member State</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>for categories AM, A, A1, A2, B, B1 and BE</condition>
    </conditions>
    <exceptions>
      <exception description="notwithstanding paragraphs 1 and 2" ref="t6"/>
      <exception description="to the extent not otherwise provided for, such as appropriate assessment of eyesight" ref="t6"/>
    </exceptions>
    <source-ref article="11" paragraph="3(a)"/>
  </task>
  <task id="t7">
    <label>Fill in a self-assessment form</label>
    <performers>
      <performer>
        <unit>Applicant</unit>
        <role>Applicant</role>
      </performer>
      <performer>
        <unit>Applicant</unit>
        <role>Driving Licence Holder</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>if required by Member State</condition>
      <condition>when applying for the issuance or renewal of a driving licence</condition>
    </conditions>
    <exceptions/>
    <source-ref article="11" paragraph="3(a)"/>
  </task>
  <task id="t8">
    <label>Establish a national system of assessment of fitness to drive</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Member State</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>for categories AM, A, A1, A2, B, B1 and BE</condition>
    </conditions>
    <exceptions>
      <exception description="notwithstanding paragraphs 1 and 2" ref="t8"/>
      <exception description="to the extent not otherwise provided for, such as appropriate assessment of eyesight" ref="t8"/>
    </exceptions>
    <source-ref article="11" paragraph="3(b)"/>
  </task>
  <task id="t9">
    <label>Provide for appropriate measures</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Member State</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions/>
    <exceptions/>
    <source-ref article="11" paragraph="4"/>
  </task>
  <task id="t10">
    <label>Apply the alternative measure to allow monitoring of fitness to drive</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Member State</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>during periods of administrative validity</condition>
    </conditions>
    <exceptions/>
    <source-ref article="11" paragraph="5"/>
  </task>
  <task id="t11">
    <label>Ensure that applicant or holder undergoes a medical examination</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Member State</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>if it becomes apparent that the applicant or holder is likely to have one or more of the medical conditions listed</condition>
      <condition>on the basis of information acquired pursuant to the alternative measures</condition>
    </conditions>
    <exceptions/>
    <source-ref article="11" paragraph="6"/>
  </task>
  <task id="t12">
    <label>Undergo a medical examination prior to issuance or renewal</label>
    <performers>
      <performer>
        <unit>Applicant</unit>
        <role>Applicant</role>
      </performer>
      <performer>
        <unit>Applicant</unit>
        <role>Driving Licence Holder</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>if it becomes apparent that the applicant or holder is likely to have one or more of the medical conditions listed</condition>
      <condition>prior to issuing or renewing the driving licence</condition>
    </conditions>
    <exceptions/>
    <source-ref article="11" paragraph="6"/>
  </task>
  <task id="t13">
    <label>Adopt guidelines for medical practitioners</label>
    <performers>
      <performer>
