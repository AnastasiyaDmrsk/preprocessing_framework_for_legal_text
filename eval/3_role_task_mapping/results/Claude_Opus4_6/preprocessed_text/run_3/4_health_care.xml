<?xml version="1.0" ?>
<tasks>
  <task id="t1">
    <label>Transmit special needs information to Member State responsible</label>
    <performers>
      <performer>
        <unit>Transferring Member State</unit>
        <role>Health Professional</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>for the sole purpose of the provision of medical care or treatment</condition>
      <condition>in so far as information is available to the competent authority IAW national law</condition>
    </conditions>
    <exceptions/>
    <source-ref article="UNKNOWN" paragraph="1"/>
  </task>
