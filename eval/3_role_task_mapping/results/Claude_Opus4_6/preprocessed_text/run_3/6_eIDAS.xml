    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Supervisory Body</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="17" paragraph="1"/>
  </task>
  <task id="t2">
    <label>Provide necessary powers and adequate resources to supervisory body</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Supervisory Body</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="17" paragraph="1"/>
