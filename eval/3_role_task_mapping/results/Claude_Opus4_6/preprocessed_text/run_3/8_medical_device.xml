    <performers>
      <performer>
        <unit>Manufacturer</unit>
        <role>Manufacturer</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>Period starts after the last device covered by the EU declaration has been placed on the market</condition>
    </conditions>
    <exceptions>
      <exception description="For implantable devices the period shall be at least 15 years" ref="t15"/>
    </exceptions>
    <source-ref article="10" paragraph="8"/>
  </task>
