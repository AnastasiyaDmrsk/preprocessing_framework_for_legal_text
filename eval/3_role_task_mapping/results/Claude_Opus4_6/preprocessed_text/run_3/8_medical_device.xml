    <performers>
      <performer>
        <unit>Manufacturer</unit>
        <role>Manufacturer</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>QMS shall be proportionate to the risk class and type of device</condition>
      <condition>QMS shall address at least aspects set out in paragraph 9(a) through 9(m)</condition>
    </conditions>
    <exceptions>
      <exception description="Not applicable to investigational devices" ref="t21"/>
    </exceptions>
    <source-ref article="10" paragraph="9"/>
