    <label>Claim compensation for damage caused by a defective device</label>
    <performers>
      <performer>
        <unit>Natural / Legal Person</unit>
        <role>Patient / User</role>
      </performer>
      <performer>
        <unit>Natural / Legal Person</unit>
        <role>Successor</role>
      </performer>
      <performer>
        <unit>Natural / Legal Person</unit>
        <role>Health Insurance Company</role>
      </performer>
      <performer>
        <unit>Natural / Legal Person</unit>
        <role>Third Party</role>
