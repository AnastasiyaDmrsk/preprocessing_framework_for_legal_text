    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Competent Authority</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions/>
    <exceptions/>
    <source-ref article="10" paragraph="14"/>
  </task>
  <task id="t39">
    <label>Cooperate with competent authority on corrective action to eliminate or mitigate risks</label>
    <performers>
      <performer>
        <unit>Manufacturer</unit>
        <role>Manufacturer</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>Upon request by a competent authority</condition>
    </conditions>
    <exceptions/>
    <source-ref article="10" paragraph="14"/>
  </task>
  <task id="t40">
