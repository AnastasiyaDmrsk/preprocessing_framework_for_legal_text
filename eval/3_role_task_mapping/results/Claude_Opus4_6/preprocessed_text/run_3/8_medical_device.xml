    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Competent Authority</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>Competent authority considers or has reason to believe that a device has caused damage</condition>
    </conditions>
    <exceptions/>
    <source-ref article="10" paragraph="14"/>
  </task>
  <task id="t42">
    <label>Facilitate provision of information and documentation to potentially injured patient and affected parties</label>
    <performers>
      <performer>
        <unit>Manufacturer</unit>
        <role>Manufacturer</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>Competent authority considers or has reason to believe that a device has caused damage</condition>
      <condition>Upon request by competent authority</condition>
    </conditions>
    <exceptions>
      <exception description="Without prejudice to data protection rules" ref="t42"/>
      <exception description="Without prejudice to the protection of intellectual property rights unless there is an overriding public interest in disclosure" ref="t42"/>
    </exceptions>
    <source-ref article="10" paragraph="14"/>
  </task>
