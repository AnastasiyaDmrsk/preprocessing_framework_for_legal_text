    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Competent Authority</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>Manufacturer fails to cooperate or information and documentation provided is incomplete or incorrect</condition>
    </conditions>
    <exceptions/>
    <source-ref article="10" paragraph="14"/>
  </task>
  <task id="t41">
