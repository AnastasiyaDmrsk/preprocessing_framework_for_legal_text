<?xml version="1.0" ?>
<tasks>
  <task id="t1">
    <label>Take necessary technical and organisational measures</label>
    <performers>
      <performer>
        <unit>Provider</unit>
        <role>Online Platform Provider</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="1"/>
  </task>
  <task id="t2">
    <label>Give priority to trusted flagger notices</label>
    <performers>
      <performer>
        <unit>Provider</unit>
        <role>Online Platform Provider</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>notices submitted by trusted flaggers acting within their designated area of expertise</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="1"/>
  </task>
  <task id="t3">
    <label>Process trusted flagger notices</label>
    <performers>
      <performer>
        <unit>Provider</unit>
        <role>Online Platform Provider</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>notices submitted by trusted flaggers acting within their designated area of expertise</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="1"/>
  </task>
  <task id="t4">
    <label>Decide upon trusted flagger notices</label>
    <performers>
      <performer>
        <unit>Provider</unit>
        <role>Online Platform Provider</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>notices submitted by trusted flaggers acting within their designated area of expertise</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="1"/>
  </task>
  <task id="t5">
    <label>Apply for trusted flagger status</label>
    <performers>
      <performer>
        <unit>Entity</unit>
        <role>Trusted Flagger</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="2"/>
  </task>
  <task id="t6">
    <label>Award trusted flagger status</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Digital Services Coordinator</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>upon application by any entity that meets the conditions set out in 2(a), 2(b), 2(c)</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="2"/>
  </task>
  <task id="t7">
    <label>Publish reports on notices submitted</label>
    <performers>
      <performer>
        <unit>Entity</unit>
        <role>Trusted Flagger</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>at least once a year</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="3"/>
  </task>
  <task id="t8">
    <label>List notices categorised by identity of provider of hosting services</label>
    <performers>
      <performer>
        <unit>Entity</unit>
        <role>Trusted Flagger</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="3(a)"/>
  </task>
  <task id="t9">
    <label>List notices categorised by type of allegedly illegal content</label>
    <performers>
      <performer>
        <unit>Entity</unit>
        <role>Trusted Flagger</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="3(b)"/>
  </task>
  <task id="t10">
    <label>List notices categorised by action taken by provider</label>
    <performers>
      <performer>
        <unit>Entity</unit>
        <role>Trusted Flagger</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="3(c)"/>
  </task>
  <task id="t11">
    <label>Include explanation of procedures in reports</label>
    <performers>
      <performer>
        <unit>Entity</unit>
        <role>Trusted Flagger</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="3"/>
  </task>
  <task id="t12">
    <label>Send reports to awarding Digital Services Coordinator</label>
    <performers>
      <performer>
        <unit>Entity</unit>
        <role>Trusted Flagger</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="3"/>
  </task>
  <task id="t13">
    <label>Make reports publicly available</label>
    <performers>
      <performer>
        <unit>Entity</unit>
        <role>Trusted Flagger</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="3"/>
  </task>
  <task id="t14">
    <label>Not include personal data in reports</label>
    <performers>
      <performer>
        <unit>Entity</unit>
        <role>Trusted Flagger</role>
      </performer>
    </performers>
    <deontic type="prohibition" modality="shall not"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="3"/>
  </task>
  <task id="t15">
    <label>Communicate names, addresses and email addresses of trusted flaggers to Commission and Board</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Digital Services Coordinator</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>upon awarding, suspending or revoking trusted flagger status</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="4"/>
  </task>
  <task id="t16">
    <label>Publish information in publicly available database</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="5"/>
  </task>
  <task id="t17">
    <label>Keep database up to date</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="5"/>
  </task>
  <task id="t18">
    <label>Communicate information on inadequate trusted flagger notices to Digital Services Coordinator</label>
    <performers>
      <performer>
        <unit>Provider</unit>
        <role>Online Platform Provider</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>if the provider has information indicating that a trusted flagger has submitted a significant number of insufficiently precise, inaccurate or inadequately substantiated notices</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="6"/>
  </task>
  <task id="t19">
    <label>Consider whether there are legitimate reasons to open an investigation</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Digital Services Coordinator</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>upon receiving information from the provider of online platforms</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="6"/>
  </task>
  <task id="t20">
    <label>Suspend trusted flagger status during investigation</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>if the Digital Services Coordinator considers that there are legitimate reasons to open an investigation</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="6"/>
  </task>
  <task id="t21">
    <label>Carry out investigation</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="6"/>
  </task>
  <task id="t22">
    <label>Conduct investigation</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Digital Services Coordinator</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>on own initiative or on the basis of information received from third parties</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="7"/>
  </task>
  <task id="t23">
    <label>Revoke trusted flagger status</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Digital Services Coordinator</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>if the Digital Services Coordinator determines that the entity no longer meets the conditions set out, following an investigation</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="7"/>
  </task>
  <task id="t24">
    <label>Afford entity opportunity to react to findings and intention to revoke</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Digital Services Coordinator</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>before revoking trusted flagger status</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="7"/>
  </task>
  <task id="t25">
    <label>React to findings and intention to revoke</label>
    <performers>
      <performer>
        <unit>Entity</unit>
        <role>Trusted Flagger</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>if afforded opportunity by Digital Services Coordinator before revocation</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="7"/>
  </task>
  <task id="t26">
    <label>Consult the Board</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>before issuing guidelines on application of paragraphs 2, 6 and 7</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="8"/>
  </task>
  <task id="t27">
    <label>Provide consultation on guidelines</label>
    <performers>
      <performer>
        <unit>Board</unit>
        <role>Board</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>when consulted by Commission on guidelines for application of paragraphs 2, 6 and 7</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="8"/>
  </task>
</tasks>