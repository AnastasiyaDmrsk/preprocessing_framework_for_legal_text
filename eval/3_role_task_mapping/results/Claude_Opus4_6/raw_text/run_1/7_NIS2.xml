    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Competent Authority</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>CSIRT is not the initial recipient of the notification</condition>
    </conditions>
    <exceptions/>
    <source-ref article="23" paragraph="5"/>
  </task>
  <task id="t25">
    <label>Request additional technical support</label>
    <performers>
      <performer>
        <unit>Essential and Important Entity</unit>
        <role>Essential and Important Entity</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions/>
    <exceptions/>
    <source-ref article="23" paragraph="5"/>
  </task>
  <task id="t26">
    <label>Provide additional technical support</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>CSIRT</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>if the entity concerned so requests</condition>
    </conditions>
    <exceptions/>
    <source-ref article="23" paragraph="5"/>
  </task>
  <task id="t27">
    <label>Provide guidance on reporting significant incident to law enforcement authorities</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>CSIRT</role>
      </performer>
      <performer>
        <unit>Member State</unit>
        <role>Competent Authority</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
