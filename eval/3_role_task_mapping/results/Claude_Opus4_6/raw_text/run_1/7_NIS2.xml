    <performers>
      <performer>
        <unit>ENISA</unit>
        <role>ENISA</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions/>
    <exceptions/>
    <source-ref article="23" paragraph="9"/>
  </task>
