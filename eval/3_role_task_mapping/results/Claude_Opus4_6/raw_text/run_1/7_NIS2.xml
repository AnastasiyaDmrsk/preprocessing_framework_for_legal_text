    <conditions>
      <condition>public awareness is necessary to prevent or deal with significant incident, or disclosure is in the public interest</condition>
    </conditions>
    <exceptions/>
    <source-ref article="23" paragraph="7"/>
  </task>
  <task id="t33">
    <label>Inform the public about the significant incident</label>
    <performers>
      <performer>
        <unit>Essential and Important Entity</unit>
        <role>Essential and Important Entity</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
