<?xml version="1.0" ?>
<tasks>
  <task id="t1">
    <label>Ensure that entities notify CSIRT of significant incidents</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Competent Authority</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="23" paragraph="1"/>
  </task>
  <task id="t2">
    <label>Notify CSIRT of significant incident</label>
    <performers>
      <performer>
        <unit>Essential and Important Entity</unit>
        <role>Essential and Important Entity</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>incident has a significant impact on the provision of services</condition>
    </conditions>
    <exceptions/>
    <source-ref article="23" paragraph="1"/>
  </task>
  <task id="t3">
    <label>Notify recipients of significant incidents</label>
    <performers>
      <performer>
        <unit>Essential and Important Entity</unit>
        <role>Essential and Important Entity</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>where appropriate</condition>
      <condition>significant incidents are likely to adversely affect the provision of services</condition>
    </conditions>
    <exceptions/>
    <source-ref article="23" paragraph="1"/>
  </task>
  <task id="t4">
    <label>Ensure that entities report information enabling CSIRT to determine cross-border impact</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Competent Authority</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="23" paragraph="1"/>
  </task>
  <task id="t5">
    <label>Report information enabling CSIRT to determine cross-border impact</label>
    <performers>
      <performer>
        <unit>Essential and Important Entity</unit>
        <role>Essential and Important Entity</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="23" paragraph="1"/>
  </task>
  <task id="t6">
    <label>Ensure that competent authority forwards notification to CSIRT</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Competent Authority</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>entities notify the competent authority of a significant incident</condition>
    </conditions>
    <exceptions/>
    <source-ref article="23" paragraph="1"/>
  </task>
  <task id="t7">
    <label>Forward notification to CSIRT upon receipt</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Competent Authority</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>entities notify the competent authority of a significant incident</condition>
    </conditions>
    <exceptions/>
    <source-ref article="23" paragraph="1"/>
  </task>
  <task id="t8">
    <label>Ensure that single points of contact are provided with relevant information</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Competent Authority</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>cross-border or cross-sectoral significant incident</condition>
    </conditions>
    <exceptions/>
    <source-ref article="23" paragraph="1"/>
  </task>
  <task id="t9">
    <label>Ensure that entities communicate measures or remedies to recipients</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Competent Authority</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>where applicable</condition>
      <condition>significant cyber threat potentially affecting recipients</condition>
    </conditions>
    <exceptions/>
    <source-ref article="23" paragraph="2"/>
  </task>
  <task id="t10">
    <label>Communicate measures or remedies to recipients in response to significant cyber threat</label>
    <performers>
      <performer>
        <unit>Essential and Important Entity</unit>
        <role>Essential and Important Entity</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>where applicable</condition>
      <condition>recipients are potentially affected by a significant cyber threat</condition>
    </conditions>
    <exceptions/>
    <source-ref article="23" paragraph="2"/>
  </task>
  <task id="t11">
    <label>Inform recipients of the significant cyber threat itself</label>
    <performers>
      <performer>
        <unit>Essential and Important Entity</unit>
        <role>Essential and Important Entity</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>where appropriate</condition>
    </conditions>
    <exceptions/>
    <source-ref article="23" paragraph="2"/>
  </task>
  <task id="t12">
    <label>Ensure that entities submit notifications to CSIRT</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Competent Authority</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="23" paragraph="4"/>
  </task>
  <task id="t13">
    <label>Submit early warning to CSIRT</label>
    <performers>
      <performer>
        <unit>Essential and Important Entity</unit>
        <role>Essential and Important Entity</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>without undue delay and within 24 hours of becoming aware of the significant incident</condition>
    </conditions>
    <exceptions/>
    <source-ref article="23" paragraph="4(a)"/>
  </task>
  <task id="t14">
    <label>Submit incident notification to CSIRT</label>
    <performers>
      <performer>
        <unit>Essential and Important Entity</unit>
        <role>Essential and Important Entity</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>without undue delay and within 72 hours of becoming aware of the significant incident</condition>
    </conditions>
    <exceptions>
      <exception description="trust service providers shall notify within 24 hours instead" ref="t21"/>
    </exceptions>
    <source-ref article="23" paragraph="4(b)"/>
  </task>
  <task id="t15">
    <label>Request intermediate report</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>CSIRT</role>
      </performer>
      <performer>
        <unit>Member State</unit>
        <role>Competent Authority</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions/>
    <exceptions/>
    <source-ref article="23" paragraph="4(c)"/>
  </task>
  <task id="t16">
    <label>Submit intermediate report on relevant status updates</label>
    <performers>
      <performer>
        <unit>Essential and Important Entity</unit>
        <role>Essential and Important Entity</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>upon request of CSIRT or competent authority</condition>
    </conditions>
    <exceptions/>
    <source-ref article="23" paragraph="4(c)"/>
  </task>
  <task id="t17">
    <label>Submit final report</label>
    <performers>
      <performer>
        <unit>Essential and Important Entity</unit>
        <role>Essential and Important Entity</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>not later than one month after submission of the incident notification under point (b)</condition>
    </conditions>
    <exceptions>
      <exception description="if incident is ongoing at time of final report submission, provide progress report instead" ref="t18"/>
    </exceptions>
    <source-ref article="23" paragraph="4(d)"/>
  </task>
  <task id="t18">
    <label>Ensure that entities provide a progress report</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Competent Authority</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>ongoing incident at the time of submission of the final report referred to in point (d)</condition>
    </conditions>
    <exceptions/>
    <source-ref article="23" paragraph="4(e)"/>
  </task>
  <task id="t19">
    <label>Provide progress report</label>
    <performers>
      <performer>
        <unit>Essential and Important Entity</unit>
        <role>Essential and Important Entity</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>ongoing incident at the time of submission of the final report referred to in point (d)</condition>
    </conditions>
    <exceptions/>
    <source-ref article="23" paragraph="4(e)"/>
  </task>
  <task id="t20">
    <label>Provide final report within one month of handling the incident</label>
    <performers>
      <performer>
        <unit>Essential and Important Entity</unit>
        <role>Essential and Important Entity</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>ongoing incident at the time of submission of the final report referred to in point (d)</condition>
    </conditions>
    <exceptions/>
    <source-ref article="23" paragraph="4(e)"/>
  </task>
  <task id="t21">
    <label>Notify CSIRT of significant incident within 24 hours</label>
    <performers>
      <performer>
        <unit>Essential and Important Entity</unit>
        <role>Trust Service Provider</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>significant incident has an impact on the provision of trust services</condition>
      <condition>by way of derogation from point (b)</condition>
    </conditions>
    <exceptions/>
    <source-ref article="23" paragraph="4"/>
  </task>
  <task id="t22">
    <label>Provide response to notifying entity including initial feedback</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>CSIRT</role>
      </performer>
      <performer>
        <unit>Member State</unit>
        <role>Competent Authority</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>without undue delay and where possible within 24 hours of receiving the early warning</condition>
    </conditions>
    <exceptions/>
    <source-ref article="23" paragraph="5"/>
  </task>
  <task id="t23">
    <label>Request guidance or operational advice</label>
    <performers>
      <performer>
        <unit>Essential and Important Entity</unit>
        <role>Essential and Important Entity</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions/>
    <exceptions/>
    <source-ref article="23" paragraph="5"/>
  </task>
