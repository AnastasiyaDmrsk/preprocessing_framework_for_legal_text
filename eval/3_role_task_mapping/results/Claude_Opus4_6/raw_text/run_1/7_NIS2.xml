      <performer>
        <unit>Member State</unit>
        <role>CSIRT</role>
      </performer>
      <performer>
        <unit>Member State</unit>
        <role>Competent Authority</role>
      </performer>
      <performer>
        <unit>Other Member State Concerned</unit>
        <role>CSIRT</role>
      </performer>
      <performer>
        <unit>Other Member State Concerned</unit>
        <role>Competent Authority</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
