    <performers>
      <performer>
        <unit>Member State</unit>
        <role>CSIRT</role>
      </performer>
      <performer>
        <unit>Member State</unit>
        <role>Competent Authority</role>
      </performer>
      <performer>
        <unit>Member State</unit>
        <role>Single Point of Contact</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
