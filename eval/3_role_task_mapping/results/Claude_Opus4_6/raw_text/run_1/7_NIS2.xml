      <performer>
        <unit>Member State</unit>
        <role>Competent Authority</role>
      </performer>
      <performer>
        <unit>Other Member State Concerned</unit>
        <role>CSIRT</role>
      </performer>
      <performer>
        <unit>Other Member State Concerned</unit>
        <role>Competent Authority</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>public awareness is necessary to prevent or deal with significant incident, or disclosure is in the public interest</condition>
