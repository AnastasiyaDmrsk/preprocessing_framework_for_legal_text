<?xml version="1.0" ?>
<tasks>
  <task id="t1">
    <label>Request ENISA to prepare a candidate scheme</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>on the basis of the Union rolling work programme</condition>
    </conditions>
    <exceptions/>
    <source-ref article="48" paragraph="1"/>
  </task>
  <task id="t2">
    <label>Request ENISA to review an existing European cybersecurity certification scheme</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>on the basis of the Union rolling work programme</condition>
    </conditions>
    <exceptions/>
    <source-ref article="48" paragraph="1"/>
  </task>
  <task id="t3">
    <label>Review an existing European cybersecurity certification scheme</label>
    <performers>
      <performer>
        <unit>ENISA</unit>
        <role>ENISA</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>if requested by Commission</condition>
    </conditions>
    <exceptions/>
    <source-ref article="48" paragraph="1"/>
  </task>
  <task id="t4">
    <label>Request ENISA to prepare a candidate scheme</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
      <performer>
        <unit>ECCG</unit>
        <role>ECCG</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>in duly justified cases</condition>
      <condition>scheme not included in the Union rolling work programme</condition>
    </conditions>
    <exceptions/>
    <source-ref article="48" paragraph="2"/>
  </task>
  <task id="t5">
    <label>Request ENISA to review an existing European cybersecurity certification scheme</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
      <performer>
        <unit>ECCG</unit>
        <role>ECCG</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>in duly justified cases</condition>
      <condition>scheme not included in the Union rolling work programme</condition>
    </conditions>
    <exceptions/>
    <source-ref article="48" paragraph="2"/>
  </task>
  <task id="t6">
    <label>Review an existing European cybersecurity certification scheme</label>
    <performers>
      <performer>
        <unit>ENISA</unit>
        <role>ENISA</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>if requested by Commission or ECCG</condition>
      <condition>in duly justified cases</condition>
      <condition>scheme not included in the Union rolling work programme</condition>
    </conditions>
    <exceptions/>
    <source-ref article="48" paragraph="2"/>
  </task>
  <task id="t7">
    <label>Update the Union rolling work programme</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="48" paragraph="2"/>
  </task>
  <task id="t8">
    <label>Prepare a candidate scheme</label>
    <performers>
      <performer>
        <unit>ENISA</unit>
        <role>ENISA</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>following a request from Commission pursuant to Article 48</condition>
    </conditions>
    <exceptions/>
    <source-ref article="49" paragraph="1"/>
  </task>
  <task id="t9">
    <label>Prepare a candidate scheme</label>
    <performers>
      <performer>
        <unit>ENISA</unit>
        <role>ENISA</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>following a request from ECCG pursuant to Article 48(2)</condition>
    </conditions>
    <exceptions>
      <exception description="ENISA may refuse the request" ref="t9"/>
    </exceptions>
    <source-ref article="49" paragraph="2"/>
  </task>
  <task id="t10">
    <label>Give reasons for its refusal</label>
    <performers>
      <performer>
        <unit>ENISA</unit>
        <role>ENISA</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>if ENISA refuses a request from the ECCG</condition>
    </conditions>
    <exceptions/>
    <source-ref article="49" paragraph="2"/>
  </task>
  <task id="t11">
    <label>Take decision to refuse a request</label>
    <performers>
      <performer>
        <unit>ENISA</unit>
        <role>Management Board</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>if ENISA refuses a request from the ECCG</condition>
    </conditions>
    <exceptions/>
    <source-ref article="49" paragraph="2"/>
  </task>
  <task id="t12">
    <label>Consult all relevant stakeholders</label>
    <performers>
      <performer>
        <unit>ENISA</unit>
        <role>ENISA</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>when preparing a candidate scheme</condition>
    </conditions>
    <exceptions/>
    <source-ref article="49" paragraph="3"/>
  </task>
  <task id="t13">
    <label>Establish an ad hoc working group</label>
    <performers>
      <performer>
        <unit>ENISA</unit>
        <role>ENISA</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>for each candidate scheme</condition>
    </conditions>
    <exceptions/>
    <source-ref article="49" paragraph="4"/>
  </task>
  <task id="t14">
    <label>Closely cooperate with the ECCG</label>
    <performers>
      <performer>
        <unit>ENISA</unit>
        <role>ENISA</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="49" paragraph="5"/>
  </task>
  <task id="t15">
    <label>Provide ENISA with assistance and expert advice</label>
    <performers>
      <performer>
        <unit>ECCG</unit>
        <role>ECCG</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="49" paragraph="5"/>
  </task>
  <task id="t16">
    <label>Adopt an opinion on the candidate scheme</label>
    <performers>
      <performer>
        <unit>ECCG</unit>
        <role>ECCG</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="49" paragraph="5"/>
  </task>
  <task id="t17">
    <label>Take utmost account of the opinion of the ECCG</label>
    <performers>
      <performer>
        <unit>ENISA</unit>
        <role>ENISA</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>before transmitting the candidate scheme to the Commission</condition>
    </conditions>
    <exceptions>
      <exception description="the opinion of the ECCG shall not bind ENISA" ref="t17"/>
    </exceptions>
    <source-ref article="49" paragraph="6"/>
  </task>
  <task id="t18">
    <label>Transmit the candidate scheme to the Commission</label>
    <performers>
      <performer>
        <unit>ENISA</unit>
        <role>ENISA</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions>
      <exception description="the absence of an ECCG opinion shall not prevent transmission" ref="t18"/>
    </exceptions>
    <source-ref article="49" paragraph="6"/>
  </task>
  <task id="t19">
    <label>Adopt implementing acts providing for a European cybersecurity certification scheme</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>based on the candidate scheme prepared by ENISA</condition>
      <condition>in accordance with the examination procedure referred to in Article 66(2)</condition>
    </conditions>
    <exceptions/>
    <source-ref article="49" paragraph="7"/>
  </task>
  <task id="t20">
    <label>Evaluate each adopted European cybersecurity certification scheme</label>
    <performers>
      <performer>
        <unit>ENISA</unit>
        <role>ENISA</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>at least every five years</condition>
      <condition>taking into account feedback received from interested parties</condition>
    </conditions>
    <exceptions/>
    <source-ref article="49" paragraph="8"/>
  </task>
  <task id="t21">
    <label>Request ENISA to start developing a revised candidate scheme</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
      <performer>
        <unit>ECCG</unit>
        <role>ECCG</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>if necessary</condition>
    </conditions>
    <exceptions/>
    <source-ref article="49" paragraph="8"/>
  </task>
  <task id="t22">
    <label>Start developing a revised candidate scheme</label>
    <performers>
      <performer>
        <unit>ENISA</unit>
        <role>ENISA</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>if requested by Commission or ECCG</condition>
    </conditions>
    <exceptions/>
    <source-ref article="49" paragraph="8"/>
  </task>
</tasks>