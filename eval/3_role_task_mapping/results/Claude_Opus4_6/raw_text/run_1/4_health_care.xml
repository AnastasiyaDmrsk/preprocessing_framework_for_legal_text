<?xml version="1.0" ?>
<tasks>
  <task id="t1">
    <label>Transmit information on special needs to Member State responsible</label>
    <performers>
      <performer>
        <unit>Transferring Member State</unit>
        <role>Health Professional</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>information is available to competent authority in accordance with national law</condition>
      <condition>after having obtained explicit consent of applicant and/or representative</condition>
    </conditions>
    <exceptions>
      <exception description="consent not required if applicant is physically or legally incapable of giving consent and transmission is necessary to protect vital interests of applicant or another person" ref="t1"/>
    </exceptions>
    <source-ref article="44" paragraph="1"/>
  </task>
  <task id="t2">
    <label>Include information on person's physical or mental health</label>
    <performers>
      <performer>
        <unit>Transferring Member State</unit>
        <role>Health Professional</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>in specific cases</condition>
    </conditions>
    <exceptions/>
    <source-ref article="44" paragraph="1"/>
  </task>
  <task id="t3">
    <label>Transfer information in a common health certificate</label>
    <performers>
      <performer>
        <unit>Transferring Member State</unit>
        <role>Health Professional</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="44" paragraph="1"/>
  </task>
  <task id="t4">
    <label>Ensure that special needs are adequately addressed</label>
    <performers>
      <performer>
        <unit>Member State Responsible</unit>
        <role>Competent Authority</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="44" paragraph="1"/>
  </task>
  <task id="t5">
    <label>Address special needs including essential medical care</label>
    <performers>
      <performer>
        <unit>Member State Responsible</unit>
        <role>Health Professional</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="44" paragraph="1"/>
  </task>
  <task id="t6">
    <label>Draw up common health certificate</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>by means of implementing acts</condition>
      <condition>in accordance with examination procedure laid down in Article 44(2)</condition>
    </conditions>
    <exceptions/>
    <source-ref article="44" paragraph="1"/>
  </task>
  <task id="t7">
    <label>Obtain explicit consent of applicant and/or representative</label>
    <performers>
      <performer>
        <unit>Transferring Member State</unit>
        <role>Health Professional</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>before transmitting information referred to in paragraph 1</condition>
    </conditions>
    <exceptions>
      <exception description="not required if applicant is physically or legally incapable of giving consent and transmission is necessary to protect vital interests of applicant or another person" ref="t7"/>
    </exceptions>
    <source-ref article="44" paragraph="2"/>
  </task>
  <task id="t8">
    <label>Give explicit consent for transmission of health data</label>
    <performers>
      <performer>
        <unit>Applicant / Representative</unit>
        <role>Applicant / Representative</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>if requested by Transferring Member State</condition>
    </conditions>
    <exceptions/>
    <source-ref article="44" paragraph="2"/>
  </task>
  <task id="t9">
    <label>Not treat lack of consent as obstacle to transfer</label>
    <performers>
      <performer>
        <unit>Transferring Member State</unit>
        <role>Health Professional</role>
      </performer>
      <performer>
        <unit>Member State Responsible</unit>
        <role>Competent Authority</role>
      </performer>
    </performers>
    <deontic type="prohibition" modality="shall not"/>
    <conditions/>
    <exceptions/>
    <source-ref article="44" paragraph="2"/>
  </task>
  <task id="t10">
    <label>Process personal health data</label>
    <performers>
      <performer>
        <unit>Transferring Member State</unit>
        <role>Health Professional</role>
      </performer>
      <performer>
        <unit>Member State Responsible</unit>
        <role>Health Professional</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>only by health professional subject to professional secrecy under national law or by person subject to equivalent obligation</condition>
    </conditions>
    <exceptions/>
    <source-ref article="44" paragraph="3"/>
  </task>
  <task id="t11">
    <label>Exchange information only between health professionals</label>
    <performers>
      <performer>
        <unit>Transferring Member State</unit>
        <role>Health Professional</role>
      </performer>
      <performer>
        <unit>Member State Responsible</unit>
        <role>Health Professional</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>only between health professionals or other persons referred to in paragraph 3</condition>
    </conditions>
    <exceptions/>
    <source-ref article="44" paragraph="4"/>
  </task>
  <task id="t12">
    <label>Use exchanged information only for purposes set out in paragraph 1</label>
    <performers>
      <performer>
        <unit>Transferring Member State</unit>
        <role>Health Professional</role>
      </performer>
      <performer>
        <unit>Member State Responsible</unit>
        <role>Health Professional</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="44" paragraph="4"/>
  </task>
  <task id="t13">
    <label>Not further process exchanged information</label>
    <performers>
      <performer>
        <unit>Transferring Member State</unit>
        <role>Health Professional</role>
      </performer>
      <performer>
        <unit>Member State Responsible</unit>
        <role>Health Professional</role>
      </performer>
    </performers>
    <deontic type="prohibition" modality="shall not"/>
    <conditions/>
    <exceptions/>
    <source-ref article="44" paragraph="4"/>
  </task>
  <task id="t14">
    <label>Adopt uniform conditions and practical arrangements for exchanging information</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>by means of implementing acts</condition>
      <condition>in accordance with examination procedure laid down in Article 44(2)</condition>
    </conditions>
    <exceptions/>
    <source-ref article="44" paragraph="5"/>
  </task>
  <task id="t15">
    <label>Apply rules laid down in Article 34(8) to (12) to exchange of information</label>
    <performers>
      <performer>
        <unit>Transferring Member State</unit>
        <role>Health Professional</role>
      </performer>
      <performer>
        <unit>Member State Responsible</unit>
        <role>Health Professional</role>
      </performer>
      <performer>
        <unit>Member State Responsible</unit>
        <role>Competent Authority</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="44" paragraph="6"/>
  </task>
</tasks>