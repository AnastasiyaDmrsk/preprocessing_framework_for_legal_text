  <task id="t37">
    <label>Take measures to prevent and minimise the impact of security incidents</label>
    <performers>
      <performer>
        <unit>Trust Service Provider</unit>
        <role>Qualified Trust Service Provider</role>
      </performer>
      <performer>
        <unit>Trust Service Provider</unit>
        <role>Non-qualified Trust Service Provider</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="19" paragraph="1"/>
  </task>
  <task id="t38">
    <label>Inform stakeholders of adverse effects of security incidents</label>
    <performers>
      <performer>
        <unit>Trust Service Provider</unit>
        <role>Qualified Trust Service Provider</role>
      </performer>
      <performer>
        <unit>Trust Service Provider</unit>
        <role>Non-qualified Trust Service Provider</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="19" paragraph="1"/>
  </task>
  <task id="t39">
    <label>Notify the supervisory body of any breach of security or loss of integrity</label>
    <performers>
      <performer>
        <unit>Trust Service Provider</unit>
        <role>Qualified Trust Service Provider</role>
      </performer>
      <performer>
        <unit>Trust Service Provider</unit>
        <role>Non-qualified Trust Service Provider</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>without undue delay but within 24 hours after having become aware of it</condition>
      <condition>the breach has a significant impact on the trust service provided or on the personal data maintained therein</condition>
    </conditions>
    <exceptions/>
    <source-ref article="19" paragraph="2"/>
  </task>
  <task id="t40">
    <label>Notify the natural or legal person of the breach of security or loss of integrity</label>
    <performers>
      <performer>
        <unit>Trust Service Provider</unit>
        <role>Qualified Trust Service Provider</role>
      </performer>
      <performer>
        <unit>Trust Service Provider</unit>
        <role>Non-qualified Trust Service Provider</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>where the breach is likely to adversely affect a natural or legal person to whom the trusted service has been provided</condition>
      <condition>without undue delay</condition>
    </conditions>
    <exceptions/>
    <source-ref article="19" paragraph="2"/>
  </task>
  <task id="t41">
    <label>Inform supervisory bodies in other Member States concerned and ENISA</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Supervisory Body</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>where appropriate, in particular if a breach of security or loss of integrity concerns two or more Member States</condition>
    </conditions>
    <exceptions/>
    <source-ref article="19" paragraph="2"/>
  </task>
