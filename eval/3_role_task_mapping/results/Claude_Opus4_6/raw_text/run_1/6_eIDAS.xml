      <performer>
        <unit>Member State</unit>
        <role>Another Supervisory Body</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>the supervisory body is not competent to provide the requested assistance</condition>
      <condition>the requested assistance is not proportionate to supervisory activities carried out in accordance with Article 17</condition>
      <condition>providing the requested assistance would be incompatible with this Regulation</condition>
    </conditions>
    <exceptions/>
    <source-ref article="18" paragraph="2"/>
  </task>
