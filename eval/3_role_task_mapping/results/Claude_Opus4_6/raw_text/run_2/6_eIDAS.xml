<?xml version="1.0" ?>
<tasks>
  <task id="t1">
    <label>Designate a supervisory body</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Supervisory Body</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="17" paragraph="1"/>
  </task>
  <task id="t2">
    <label>Give supervisory bodies necessary powers and adequate resources</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Supervisory Body</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="17" paragraph="1"/>
  </task>
  <task id="t3">
    <label>Notify to the Commission the names and addresses of designated supervisory bodies</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Supervisory Body</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="17" paragraph="2"/>
  </task>
  <task id="t4">
    <label>Supervise qualified trust service providers</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Supervisory Body</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>through ex ante and ex post supervisory activities</condition>
    </conditions>
    <exceptions/>
    <source-ref article="17" paragraph="3(a)"/>
  </task>
  <task id="t5">
    <label>Take action in relation to non-qualified trust service providers</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Supervisory Body</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>if necessary</condition>
      <condition>through ex post supervisory activities</condition>
      <condition>when informed that non-qualified trust service providers or their services allegedly do not meet requirements</condition>
    </conditions>
    <exceptions/>
    <source-ref article="17" paragraph="3(b)"/>
  </task>
  <task id="t6">
    <label>Cooperate with other supervisory bodies</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Supervisory Body</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>in accordance with Article 18</condition>
    </conditions>
    <exceptions/>
    <source-ref article="17" paragraph="4(a)"/>
  </task>
  <task id="t7">
    <label>Provide assistance to other supervisory bodies</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Supervisory Body</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>in accordance with Article 18</condition>
    </conditions>
    <exceptions/>
    <source-ref article="17" paragraph="4(a)"/>
  </task>
  <task id="t8">
    <label>Analyse conformity assessment reports</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Supervisory Body</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>as referred to in Articles 20(1) and 21(1)</condition>
    </conditions>
    <exceptions/>
    <source-ref article="17" paragraph="4(b)"/>
  </task>
  <task id="t9">
    <label>Inform other supervisory bodies and the public about breaches of security or loss of integrity</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Supervisory Body</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>in accordance with Article 19(2)</condition>
    </conditions>
    <exceptions/>
    <source-ref article="17" paragraph="4(c)"/>
  </task>
  <task id="t10">
    <label>Report to the Commission about main activities</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Supervisory Body</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>in accordance with paragraph 6</condition>
    </conditions>
    <exceptions/>
    <source-ref article="17" paragraph="4(d)"/>
  </task>
  <task id="t11">
    <label>Carry out audits of qualified trust service providers</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Supervisory Body</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>in accordance with Article 20(2)</condition>
    </conditions>
    <exceptions/>
    <source-ref article="17" paragraph="4(e)"/>
  </task>
  <task id="t12">
    <label>Request conformity assessment body to perform conformity assessment</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Supervisory Body</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>in accordance with Article 20(2)</condition>
    </conditions>
    <exceptions/>
    <source-ref article="17" paragraph="4(e)"/>
  </task>
  <task id="t13">
    <label>Perform conformity assessment of qualified trust service providers</label>
    <performers>
      <performer>
        <unit>Conformity Assessment Body</unit>
        <role>Conformity Assessment Body</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>if requested by supervisory body</condition>
    </conditions>
    <exceptions/>
    <source-ref article="17" paragraph="4(e)"/>
  </task>
  <task id="t14">
    <label>Cooperate with data protection authorities</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Supervisory Body</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>in particular by informing them without undue delay about results of audits of qualified trust service providers where personal data protection rules appear to have been breached</condition>
    </conditions>
    <exceptions/>
    <source-ref article="17" paragraph="4(f)"/>
  </task>
  <task id="t15">
    <label>Grant qualified status to trust service providers and services</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Supervisory Body</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>in accordance with Articles 20 and 21</condition>
    </conditions>
    <exceptions/>
    <source-ref article="17" paragraph="4(g)"/>
  </task>
  <task id="t16">
    <label>Withdraw qualified status from trust service providers and services</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Supervisory Body</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>in accordance with Articles 20 and 21</condition>
    </conditions>
    <exceptions/>
    <source-ref article="17" paragraph="4(g)"/>
  </task>
  <task id="t17">
    <label>Inform body responsible for national trusted list about decisions to grant or withdraw qualified status</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Supervisory Body</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>as referred to in Article 22(3)</condition>
    </conditions>
    <exceptions>
      <exception description="unless that body is also the supervisory body" ref="t17"/>
    </exceptions>
    <source-ref article="17" paragraph="4(h)"/>
  </task>
  <task id="t18">
    <label>Verify existence and correct application of provisions on termination plans</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Supervisory Body</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>in cases where the qualified trust service provider ceases its activities</condition>
      <condition>in accordance with point (h) of Article 24(2)</condition>
    </conditions>
    <exceptions/>
    <source-ref article="17" paragraph="4(i)"/>
  </task>
  <task id="t19">
    <label>Require trust service providers to remedy any failure to fulfil requirements</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Supervisory Body</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="17" paragraph="4(j)"/>
  </task>
  <task id="t20">
    <label>Remedy any failure to fulfil requirements laid down in this Regulation</label>
    <performers>
      <performer>
        <unit>Trust Service Provider</unit>
        <role>Qualified Trust Service Provider</role>
      </performer>
      <performer>
        <unit>Trust Service Provider</unit>
        <role>Non-qualified Trust Service Provider</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>if required by supervisory body</condition>
    </conditions>
    <exceptions/>
    <source-ref article="17" paragraph="4(j)"/>
  </task>
  <task id="t21">
    <label>Require supervisory body to establish, maintain and update a trust infrastructure</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Supervisory Body</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>in accordance with conditions under national law</condition>
    </conditions>
    <exceptions/>
    <source-ref article="17" paragraph="5"/>
  </task>
  <task id="t22">
    <label>Establish a trust infrastructure</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Supervisory Body</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>if required by Member State</condition>
      <condition>in accordance with conditions under national law</condition>
    </conditions>
    <exceptions/>
    <source-ref article="17" paragraph="5"/>
  </task>
  <task id="t23">
    <label>Maintain a trust infrastructure</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Supervisory Body</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>if required by Member State</condition>
      <condition>in accordance with conditions under national law</condition>
    </conditions>
    <exceptions/>
    <source-ref article="17" paragraph="5"/>
  </task>
  <task id="t24">
    <label>Update a trust infrastructure</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Supervisory Body</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>if required by Member State</condition>
      <condition>in accordance with conditions under national law</condition>
    </conditions>
    <exceptions/>
    <source-ref article="17" paragraph="5"/>
  </task>
  <task id="t25">
    <label>Submit report on previous calendar year's main activities to the Commission</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Supervisory Body</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>by 31 March each year</condition>
      <condition>together with a summary of breach notifications received from trust service providers in accordance with Article 19(2)</condition>
    </conditions>
    <exceptions/>
    <source-ref article="17" paragraph="6"/>
  </task>
  <task id="t26">
    <label>Make annual report available to Member States</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="17" paragraph="7"/>
  </task>
  <task id="t27">
    <label>Define formats and procedures for the report referred to in paragraph 6</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>by means of implementing acts</condition>
      <condition>adopted in accordance with the examination procedure referred to in Article 48(2)</condition>
    </conditions>
    <exceptions/>
    <source-ref article="17" paragraph="8"/>
  </task>
  <task id="t28">
    <label>Cooperate to exchange good practice</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Supervisory Body</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="18" paragraph="1"/>
  </task>
  <task id="t29">
    <label>Provide assistance to another supervisory body</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Supervisory Body</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>upon receipt of a justified request from another supervisory body</condition>
    </conditions>
    <exceptions/>
    <source-ref article="18" paragraph="1"/>
  </task>
  <task id="t30">
    <label>Refuse request for assistance</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Supervisory Body</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>(a) the supervisory body is not competent to provide the requested assistance</condition>
      <condition>(b) the requested assistance is not proportionate to supervisory activities carried out in accordance with Article 17</condition>
      <condition>(c) providing the requested assistance would be incompatible with this Regulation</condition>
    </conditions>
    <exceptions/>
    <source-ref article="18" paragraph="2"/>
  </task>
  <task id="t31">
    <label>Authorise supervisory bodies to carry out joint investigations</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Supervisory Body</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>where appropriate</condition>
    </conditions>
    <exceptions/>
    <source-ref article="18" paragraph="3"/>
  </task>
  <task id="t32">
    <label>Carry out joint investigations</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Supervisory Body</role>
      </performer>
      <performer>
        <unit>Member State</unit>
        <role>Another Supervisory Body</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>if authorised by Member State</condition>
    </conditions>
    <exceptions/>
    <source-ref article="18" paragraph="3"/>
  </task>
  <task id="t33">
    <label>Agree upon arrangements and procedures for joint actions</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Supervisory Body</role>
      </performer>
      <performer>
        <unit>Member State</unit>
        <role>Another Supervisory Body</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>in accordance with national law</condition>
    </conditions>
    <exceptions/>
    <source-ref article="18" paragraph="3"/>
  </task>
  <task id="t34">
    <label>Establish arrangements and procedures for joint actions</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Supervisory Body</role>
      </performer>
      <performer>
        <unit>Member State</unit>
        <role>Another Supervisory Body</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>in accordance with national law</condition>
    </conditions>
    <exceptions/>
    <source-ref article="18" paragraph="3"/>
  </task>
  <task id="t35">
    <label>Take appropriate technical and organisational measures to manage risks to security</label>
    <performers>
      <performer>
        <unit>Trust Service Provider</unit>
        <role>Qualified Trust Service Provider</role>
      </performer>
      <performer>
        <unit>Trust Service Provider</unit>
        <role>Non-qualified Trust Service Provider</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="19" paragraph="1"/>
  </task>
  <task id="t36">
    <label>Ensure level of security is commensurate to degree of risk</label>
    <performers>
      <performer>
        <unit>Trust Service Provider</unit>
        <role>Qualified Trust Service Provider</role>
      </performer>
      <performer>
        <unit>Trust Service Provider</unit>
        <role>Non-qualified Trust Service Provider</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>having regard to the latest technological developments</condition>
    </conditions>
    <exceptions/>
    <source-ref article="19" paragraph="1"/>
  </task>
  <task id="t37">
    <label>Prevent the impact of security incidents</label>
    <performers>
      <performer>
        <unit>Trust Service Provider</unit>
        <role>Qualified Trust Service Provider</role>
      </performer>
      <performer>
        <unit>Trust Service Provider</unit>
        <role>Non-qualified Trust Service Provider</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="19" paragraph="1"/>
  </task>
  <task id="t38">
    <label>Minimise the impact of security incidents</label>
    <performers>
      <performer>
        <unit>Trust Service Provider</unit>
        <role>Qualified Trust Service Provider</role>
      </performer>
      <performer>
        <unit>Trust Service Provider</unit>
        <role>Non-qualified Trust Service Provider</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="19" paragraph="1"/>
  </task>
  <task id="t39">
    <label>Inform stakeholders of adverse effects of security incidents</label>
    <performers>
      <performer>
        <unit>Trust Service Provider</unit>
        <role>Qualified Trust Service Provider</role>
      </performer>
      <performer>
        <unit>Trust Service Provider</unit>
        <role>Non-qualified Trust Service Provider</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="19" paragraph="1"/>
  </task>
  <task id="t40">
    <label>Notify supervisory body and other relevant bodies of breach of security or loss of integrity</label>
    <performers>
      <performer>
        <unit>Trust Service Provider</unit>
        <role>Qualified Trust Service Provider</role>
      </performer>
      <performer>
        <unit>Trust Service Provider</unit>
        <role>Non-qualified Trust Service Provider</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>without undue delay, within 24 hours after having become aware of it</condition>
      <condition>breach has a significant impact on the trust service provided or on personal data maintained therein</condition>
    </conditions>
    <exceptions/>
    <source-ref article="19" paragraph="2"/>
  </task>
  <task id="t41">
    <label>Notify natural or legal person of breach of security or loss of integrity</label>
    <performers>
      <performer>
        <unit>Trust Service Provider</unit>
        <role>Qualified Trust Service Provider</role>
      </performer>
      <performer>
        <unit>Trust Service Provider</unit>
        <role>Non-qualified Trust Service Provider</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>where the breach is likely to adversely affect a natural or legal person to whom the trusted service has been provided</condition>
      <condition>without undue delay</condition>
    </conditions>
    <exceptions/>
    <source-ref article="19" paragraph="2"/>
  </task>
  <task id="t42">
    <label>Inform supervisory bodies in other Member States concerned and ENISA</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Supervisory Body</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>where appropriate</condition>
      <condition>in particular if a breach of security or loss of integrity concerns two or more Member States</condition>
    </conditions>
    <exceptions/>
    <source-ref article="19" paragraph="2"/>
  </task>
  <task id="t43">
    <label>Inform the public about breach of security or loss of integrity</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Supervisory Body</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>if it determines that disclosure of the breach is in the public interest</condition>
    </conditions>
    <exceptions/>
    <source-ref article="19" paragraph="2"/>
  </task>
  <task id="t44">
    <label>Require trust service provider to inform the public about breach</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Supervisory Body</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>if it determines that disclosure of the breach is in the public interest</condition>
    </conditions>
    <exceptions/>
    <source-ref article="19" paragraph="2"/>
  </task>
  <task id="t45">
    <label>Inform the public about breach of security or loss of integrity</label>
    <performers>
      <performer>
        <unit>Trust Service Provider</unit>
        <role>Qualified Trust Service Provider</role>
      </performer>
      <performer>
        <unit>Trust Service Provider</unit>
        <role>Non-qualified Trust Service Provider</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>if required by supervisory body</condition>
    </conditions>
    <exceptions/>
    <source-ref article="19" paragraph="2"/>
  </task>
  <task id="t46">
    <label>Provide ENISA with annual summary of breach notifications received from trust service providers</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Supervisory Body</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>once a year</condition>
    </conditions>
    <exceptions/>
    <source-ref article="19" paragraph="3"/>
  </task>
  <task id="t47">
    <label>Specify measures referred to in paragraph 1</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>by means of implementing acts</condition>
      <condition>adopted in accordance with the examination procedure referred to in Article 48(2)</condition>
    </conditions>
    <exceptions/>
    <source-ref article="19" paragraph="4(a)"/>
  </task>
  <task id="t48">
    <label>Define formats, procedures and deadlines for the purpose of paragraph 2</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>by means of implementing acts</condition>
      <condition>adopted in accordance with the examination procedure referred to in Article 48(2)</condition>
    </conditions>
    <exceptions/>
    <source-ref article="19" paragraph="4(b)"/>
  </task>
</tasks>