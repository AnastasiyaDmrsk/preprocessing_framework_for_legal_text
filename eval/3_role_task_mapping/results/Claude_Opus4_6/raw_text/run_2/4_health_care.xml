<?xml version="1.0" ?>
<tasks>
  <task id="t1">
    <label>Transmit information on special needs of the person to be transferred to the Member State responsible</label>
    <performers>
      <performer>
        <unit>Transferring Member State</unit>
        <role>Health Professional</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>for the sole purpose of the provision of medical care or treatment</condition>
      <condition>in so far as information is available to the competent authority in accordance with national law</condition>
    </conditions>
    <exceptions/>
    <source-ref article="44" paragraph="1"/>
  </task>
  <task id="t2">
    <label>Include information on physical or mental health of the person</label>
    <performers>
      <performer>
        <unit>Transferring Member State</unit>
        <role>Health Professional</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>in specific cases</condition>
    </conditions>
    <exceptions/>
    <source-ref article="44" paragraph="1"/>
  </task>
  <task id="t3">
    <label>Transfer information in a common health certificate with the necessary documents attached</label>
    <performers>
      <performer>
        <unit>Transferring Member State</unit>
        <role>Health Professional</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="44" paragraph="1"/>
  </task>
  <task id="t4">
    <label>Ensure that special needs are adequately addressed including essential medical care</label>
    <performers>
      <performer>
        <unit>Member State Responsible</unit>
        <role>Competent Authority</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="44" paragraph="1"/>
  </task>
  <task id="t5">
    <label>Address special needs including essential medical care</label>
    <performers>
      <performer>
        <unit>Member State Responsible</unit>
        <role>Health Professional</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="44" paragraph="1"/>
  </task>
  <task id="t6">
    <label>Draw up the common health certificate by means of implementing acts</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>in accordance with the examination procedure laid down in Article 44(2)</condition>
    </conditions>
    <exceptions/>
    <source-ref article="44" paragraph="1"/>
  </task>
  <task id="t7">
    <label>Obtain explicit consent of the applicant and/or representative</label>
    <performers>
      <performer>
        <unit>Transferring Member State</unit>
        <role>Health Professional</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>before transmitting the information referred to in paragraph 1</condition>
    </conditions>
    <exceptions>
      <exception description="if the applicant is physically or legally incapable of giving consent, when transmission is necessary to protect the vital interests of the applicant or another person" ref="t7"/>
    </exceptions>
    <source-ref article="44" paragraph="2"/>
  </task>
  <task id="t8">
    <label>Give explicit consent</label>
    <performers>
      <performer>
        <unit>Applicant / Representative</unit>
        <role>Applicant / Representative</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions/>
    <exceptions/>
    <source-ref article="44" paragraph="2"/>
  </task>
  <task id="t9">
    <label>Process personal health data only by a health professional subject to professional secrecy or equivalent obligation</label>
    <performers>
      <performer>
        <unit>Transferring Member State</unit>
        <role>Health Professional</role>
      </performer>
      <performer>
        <unit>Member State Responsible</unit>
        <role>Health Professional</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="44" paragraph="3"/>
  </task>
  <task id="t10">
    <label>Exchange information only between health professionals or persons referred to in paragraph 3</label>
    <performers>
      <performer>
        <unit>Transferring Member State</unit>
        <role>Health Professional</role>
      </performer>
      <performer>
        <unit>Member State Responsible</unit>
        <role>Health Professional</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="44" paragraph="4"/>
  </task>
  <task id="t11">
    <label>Use exchanged information only for the purposes set out in paragraph 1</label>
    <performers>
      <performer>
        <unit>Transferring Member State</unit>
        <role>Health Professional</role>
      </performer>
      <performer>
        <unit>Member State Responsible</unit>
        <role>Health Professional</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="44" paragraph="4"/>
  </task>
  <task id="t12">
    <label>Not further process exchanged information</label>
    <performers>
      <performer>
        <unit>Transferring Member State</unit>
        <role>Health Professional</role>
      </performer>
      <performer>
        <unit>Member State Responsible</unit>
        <role>Health Professional</role>
      </performer>
    </performers>
    <deontic type="prohibition" modality="shall not"/>
    <conditions/>
    <exceptions/>
    <source-ref article="44" paragraph="4"/>
  </task>
  <task id="t13">
    <label>Adopt uniform conditions and practical arrangements for exchanging information by means of implementing acts</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>in accordance with the examination procedure laid down in Article 44(2)</condition>
    </conditions>
    <exceptions/>
    <source-ref article="44" paragraph="5"/>
  </task>
  <task id="t14">
    <label>Apply rules laid down in Article 34(8) to (12) to the exchange of information</label>
    <performers>
      <performer>
        <unit>Transferring Member State</unit>
        <role>Health Professional</role>
      </performer>
      <performer>
        <unit>Member State Responsible</unit>
        <role>Health Professional</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="44" paragraph="6"/>
  </task>
</tasks>