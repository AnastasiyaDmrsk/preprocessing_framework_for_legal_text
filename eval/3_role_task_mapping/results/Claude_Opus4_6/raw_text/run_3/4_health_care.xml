<?xml version="1.0" ?>
<tasks>
  <task id="t1">
    <label>Transmit information on special needs of person to be transferred to Member State responsible</label>
    <performers>
      <performer>
        <unit>Transferring Member State</unit>
        <role>Health Professional</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>for the sole purpose of the provision of medical care or treatment</condition>
      <condition>in so far as information is available to the competent authority in accordance with national law</condition>
    </conditions>
    <exceptions/>
    <source-ref article="44" paragraph="1"/>
  </task>
  <task id="t2">
    <label>Transfer information in common health certificate with necessary documents attached</label>
    <performers>
      <performer>
        <unit>Transferring Member State</unit>
        <role>Health Professional</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="44" paragraph="1"/>
  </task>
  <task id="t3">
    <label>Ensure that special needs are adequately addressed including essential medical care</label>
    <performers>
      <performer>
        <unit>Member State Responsible</unit>
        <role>Competent Authority</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="44" paragraph="1"/>
  </task>
  <task id="t4">
    <label>Address special needs including essential medical care</label>
    <performers>
      <performer>
        <unit>Member State Responsible</unit>
        <role>Health Professional</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="44" paragraph="1"/>
  </task>
  <task id="t5">
    <label>Draw up common health certificate by means of implementing acts</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="44" paragraph="1"/>
  </task>
  <task id="t6">
    <label>Adopt implementing acts for common health certificate in accordance with examination procedure</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>in accordance with the examination procedure laid down in Article 44(2)</condition>
    </conditions>
    <exceptions/>
    <source-ref article="44" paragraph="1"/>
  </task>
  <task id="t7">
    <label>Obtain explicit consent of applicant and/or representative for transmission of health information</label>
    <performers>
      <performer>
        <unit>Transferring Member State</unit>
        <role>Health Professional</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions>
      <exception description="if applicant is physically or legally incapable of giving consent, when transmission is necessary to protect vital interests of applicant or another person" ref="t7"/>
    </exceptions>
    <source-ref article="44" paragraph="2"/>
  </task>
  <task id="t8">
    <label>Give explicit consent for transmission of health information</label>
    <performers>
      <performer>
        <unit>Applicant / Representative</unit>
        <role>Applicant / Representative</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions/>
    <exceptions/>
    <source-ref article="44" paragraph="2"/>
  </task>
  <task id="t9">
    <label>Carry out processing of personal health data</label>
    <performers>
      <performer>
        <unit>Transferring Member State</unit>
        <role>Health Professional</role>
      </performer>
      <performer>
        <unit>Member State Responsible</unit>
        <role>Health Professional</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>only by a health professional subject to obligation of professional secrecy under national law or by another person subject to an equivalent obligation</condition>
    </conditions>
    <exceptions/>
    <source-ref article="44" paragraph="3"/>
  </task>
  <task id="t10">
    <label>Exchange information only between health professionals or equivalent persons</label>
    <performers>
      <performer>
        <unit>Transferring Member State</unit>
        <role>Health Professional</role>
      </performer>
      <performer>
        <unit>Member State Responsible</unit>
        <role>Health Professional</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>only between health professionals or other persons referred to in paragraph 3</condition>
    </conditions>
    <exceptions/>
    <source-ref article="44" paragraph="4"/>
  </task>
  <task id="t11">
    <label>Use exchanged information only for purposes set out in paragraph 1</label>
    <performers>
      <performer>
        <unit>Transferring Member State</unit>
        <role>Health Professional</role>
      </performer>
      <performer>
        <unit>Member State Responsible</unit>
        <role>Health Professional</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="44" paragraph="4"/>
  </task>
  <task id="t12">
    <label>Further process exchanged information</label>
    <performers>
      <performer>
        <unit>Transferring Member State</unit>
        <role>Health Professional</role>
      </performer>
      <performer>
        <unit>Member State Responsible</unit>
        <role>Health Professional</role>
      </performer>
    </performers>
    <deontic type="prohibition" modality="shall not"/>
    <conditions/>
    <exceptions/>
    <source-ref article="44" paragraph="4"/>
  </task>
  <task id="t13">
    <label>Adopt uniform conditions and practical arrangements for exchanging information by means of implementing acts</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="44" paragraph="5"/>
  </task>
  <task id="t14">
    <label>Adopt implementing acts for uniform conditions in accordance with examination procedure</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>in accordance with the examination procedure laid down in Article 44(2)</condition>
    </conditions>
    <exceptions/>
    <source-ref article="44" paragraph="5"/>
  </task>
  <task id="t15">
    <label>Apply rules laid down in Article 34(8) to (12) to exchange of information</label>
    <performers>
      <performer>
        <unit>Transferring Member State</unit>
        <role>Health Professional</role>
      </performer>
      <performer>
        <unit>Member State Responsible</unit>
        <role>Health Professional</role>
      </performer>
      <performer>
        <unit>Member State Responsible</unit>
        <role>Competent Authority</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="44" paragraph="6"/>
  </task>
</tasks>