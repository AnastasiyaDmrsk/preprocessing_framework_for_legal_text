<?xml version="1.0" ?>
<tasks>
  <task id="t1">
    <label>request ENISA to prepare a candidate scheme</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>on the basis of the Union rolling work programme</condition>
    </conditions>
    <exceptions/>
    <source-ref article="48" paragraph="1"/>
  </task>
  <task id="t2">
    <label>request ENISA to review an existing European cybersecurity certification scheme</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>on the basis of the Union rolling work programme</condition>
    </conditions>
    <exceptions/>
    <source-ref article="48" paragraph="1"/>
  </task>
  <task id="t3">
    <label>request ENISA to prepare a candidate scheme not included in the Union rolling work programme</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
      <performer>
        <unit>ECCG</unit>
        <role>ECCG</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>In duly justified cases</condition>
    </conditions>
    <exceptions/>
    <source-ref article="48" paragraph="2"/>
  </task>
  <task id="t4">
    <label>request ENISA to review an existing European cybersecurity certification scheme not included in the Union rolling work programme</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
      <performer>
        <unit>ECCG</unit>
        <role>ECCG</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>In duly justified cases</condition>
    </conditions>
    <exceptions/>
    <source-ref article="48" paragraph="2"/>
  </task>
  <task id="t5">
    <label>update the Union rolling work programme accordingly</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>if a scheme not in the programme is requested</condition>
    </conditions>
    <exceptions/>
    <source-ref article="48" paragraph="2"/>
  </task>
  <task id="t6">
    <label>prepare a candidate scheme</label>
    <performers>
      <performer>
        <unit>ENISA</unit>
        <role>ENISA</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>Following a request from the Commission pursuant to Article 48</condition>
    </conditions>
    <exceptions/>
    <source-ref article="49" paragraph="1"/>
  </task>
  <task id="t7">
    <label>prepare a candidate scheme</label>
    <performers>
      <performer>
        <unit>ENISA</unit>
        <role>ENISA</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>Following a request from the ECCG pursuant to Article 48(2)</condition>
    </conditions>
    <exceptions/>
    <source-ref article="49" paragraph="2"/>
  </task>
  <task id="t8">
    <label>refuse request from the ECCG</label>
    <performers>
      <performer>
        <unit>ENISA</unit>
        <role>ENISA</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions/>
    <exceptions/>
    <source-ref article="49" paragraph="2"/>
  </task>
  <task id="t9">
    <label>give reasons for refusal</label>
    <performers>
      <performer>
        <unit>ENISA</unit>
        <role>ENISA</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>If ENISA refuses a request from the ECCG</condition>
    </conditions>
    <exceptions/>
    <source-ref article="49" paragraph="2"/>
  </task>
  <task id="t10">
    <label>take decision to refuse request</label>
    <performers>
      <performer>
        <unit>ENISA</unit>
        <role>Management Board</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>If ENISA refuses a request from the ECCG</condition>
    </conditions>
    <exceptions/>
    <source-ref article="49" paragraph="2"/>
  </task>
  <task id="t11">
    <label>consult all relevant stakeholders</label>
    <performers>
      <performer>
        <unit>ENISA</unit>
        <role>ENISA</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>When preparing a candidate scheme</condition>
      <condition>via formal, open, transparent and inclusive process</condition>
    </conditions>
    <exceptions/>
    <source-ref article="49" paragraph="3"/>
  </task>
  <task id="t12">
    <label>establish an ad hoc working group</label>
    <performers>
      <performer>
        <unit>ENISA</unit>
        <role>ENISA</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>For each candidate scheme</condition>
      <condition>in accordance with Article 20(4)</condition>
    </conditions>
    <exceptions/>
    <source-ref article="49" paragraph="4"/>
  </task>
  <task id="t13">
    <label>cooperate with the ECCG</label>
    <performers>
      <performer>
        <unit>ENISA</unit>
        <role>ENISA</role>
      </performer>
      <performer>
        <unit>ECCG</unit>
        <role>ECCG</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>closely</condition>
    </conditions>
    <exceptions/>
    <source-ref article="49" paragraph="5"/>
  </task>
  <task id="t14">
    <label>provide ENISA with assistance</label>
    <performers>
      <performer>
        <unit>ECCG</unit>
        <role>ECCG</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>in relation to the preparation of the candidate scheme</condition>
    </conditions>
    <exceptions/>
    <source-ref article="49" paragraph="5"/>
  </task>
  <task id="t15">
    <label>provide ENISA with expert advice</label>
    <performers>
      <performer>
        <unit>ECCG</unit>
        <role>ECCG</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>in relation to the preparation of the candidate scheme</condition>
    </conditions>
    <exceptions/>
    <source-ref article="49" paragraph="5"/>
  </task>
  <task id="t16">
    <label>adopt an opinion on the candidate scheme</label>
    <performers>
      <performer>
        <unit>ECCG</unit>
        <role>ECCG</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="49" paragraph="5"/>
  </task>
  <task id="t17">
    <label>take utmost account of the opinion of the ECCG</label>
    <performers>
      <performer>
        <unit>ENISA</unit>
        <role>ENISA</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>before transmitting the candidate scheme to the Commission</condition>
    </conditions>
    <exceptions/>
    <source-ref article="49" paragraph="6"/>
  </task>
  <task id="t18">
    <label>transmit the candidate scheme to the Commission</label>
    <performers>
      <performer>
        <unit>ENISA</unit>
        <role>ENISA</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions/>
    <exceptions>
      <exception description="absence of ECCG opinion shall not prevent transmission" ref="t18"/>
    </exceptions>
    <source-ref article="49" paragraph="6"/>
  </task>
  <task id="t19">
    <label>bind ENISA by opinion</label>
    <performers>
      <performer>
        <unit>ECCG</unit>
        <role>ECCG</role>
      </performer>
    </performers>
    <deontic type="prohibition" modality="shall not"/>
    <conditions/>
    <exceptions/>
    <source-ref article="49" paragraph="6"/>
  </task>
  <task id="t20">
    <label>adopt implementing acts providing for a European cybersecurity certification scheme</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>based on the candidate scheme prepared by ENISA</condition>
      <condition>in accordance with Article 66(2)</condition>
    </conditions>
    <exceptions/>
    <source-ref article="49" paragraph="7"/>
  </task>
  <task id="t21">
    <label>provide feedback on adopted schemes</label>
    <performers>
      <performer>
        <unit>Interested Party</unit>
        <role>Interested Party</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions/>
    <exceptions/>
    <source-ref article="49" paragraph="8"/>
  </task>
  <task id="t22">
    <label>evaluate each adopted European cybersecurity certification scheme</label>
    <performers>
      <performer>
        <unit>ENISA</unit>
        <role>ENISA</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>At least every five years</condition>
      <condition>taking into account feedback from interested parties</condition>
    </conditions>
    <exceptions/>
    <source-ref article="49" paragraph="8"/>
  </task>
  <task id="t23">
    <label>request ENISA to start the process of developing a revised candidate scheme</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
      <performer>
        <unit>ECCG</unit>
        <role>ECCG</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>If necessary</condition>
    </conditions>
    <exceptions/>
    <source-ref article="49" paragraph="8"/>
  </task>
  <task id="t24">
    <label>start the process of developing a revised candidate scheme</label>
    <performers>
      <performer>
        <unit>ENISA</unit>
        <role>ENISA</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>if requested by Commission or ECCG</condition>
    </conditions>
    <exceptions/>
    <source-ref article="49" paragraph="8"/>
  </task>
</tasks>