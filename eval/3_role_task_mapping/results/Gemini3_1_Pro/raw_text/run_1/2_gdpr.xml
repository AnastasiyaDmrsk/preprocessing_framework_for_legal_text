<?xml version="1.0" ?>
<tasks>
  <task id="t1">
    <label>Notify the personal data breach to the supervisory authority</label>
    <performers>
      <performer>
        <unit>Organization</unit>
        <role>Controller</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>In the case of a personal data breach</condition>
    </conditions>
    <exceptions>
      <exception description="The personal data breach is unlikely to result in a risk to the rights and freedoms of natural persons" ref="t1"/>
    </exceptions>
    <source-ref article="33" paragraph="1"/>
  </task>
  <task id="t2">
    <label>Provide reasons for the delay</label>
    <performers>
      <performer>
        <unit>Organization</unit>
        <role>Controller</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>Where the notification to the supervisory authority is not made within 72 hours</condition>
    </conditions>
    <exceptions/>
    <source-ref article="33" paragraph="1"/>
  </task>
  <task id="t3">
    <label>Notify the controller of a personal data breach</label>
    <performers>
      <performer>
        <unit>Organization</unit>
        <role>Processor</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>After becoming aware of a personal data breach</condition>
    </conditions>
    <exceptions/>
    <source-ref article="33" paragraph="2"/>
  </task>
  <task id="t4">
    <label>Describe the nature of the personal data breach</label>
    <performers>
      <performer>
        <unit>Organization</unit>
        <role>Controller</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>When notifying the supervisory authority</condition>
    </conditions>
    <exceptions/>
    <source-ref article="33" paragraph="3(a)"/>
  </task>
  <task id="t5">
    <label>Communicate the name and contact details of the data protection officer or other contact point</label>
    <performers>
      <performer>
        <unit>Organization</unit>
        <role>Controller</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>When notifying the supervisory authority</condition>
    </conditions>
    <exceptions/>
    <source-ref article="33" paragraph="3(b)"/>
  </task>
  <task id="t6">
    <label>Describe the likely consequences of the personal data breach</label>
    <performers>
      <performer>
        <unit>Organization</unit>
        <role>Controller</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>When notifying the supervisory authority</condition>
    </conditions>
    <exceptions/>
    <source-ref article="33" paragraph="3(c)"/>
  </task>
  <task id="t7">
    <label>Describe the measures taken or proposed to be taken to address the personal data breach</label>
    <performers>
      <performer>
        <unit>Organization</unit>
        <role>Controller</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>When notifying the supervisory authority</condition>
    </conditions>
    <exceptions/>
    <source-ref article="33" paragraph="3(d)"/>
  </task>
  <task id="t8">
    <label>Provide information in phases</label>
    <performers>
      <performer>
        <unit>Organization</unit>
        <role>Controller</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>Where it is not possible to provide the information at the same time</condition>
    </conditions>
    <exceptions/>
    <source-ref article="33" paragraph="4"/>
  </task>
  <task id="t9">
    <label>Document any personal data breaches</label>
    <performers>
      <performer>
        <unit>Organization</unit>
        <role>Controller</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="33" paragraph="5"/>
  </task>
  <task id="t10">
    <label>Verify compliance with this Article</label>
    <performers>
      <performer>
        <unit>Supervisory Authority</unit>
        <role>Supervisory Authority</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions/>
    <exceptions/>
    <source-ref article="33" paragraph="5"/>
  </task>
  <task id="t11">
    <label>Communicate the personal data breach to the data subject</label>
    <performers>
      <performer>
        <unit>Organization</unit>
        <role>Controller</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>When the personal data breach is likely to result in a high risk to the rights and freedoms of natural persons</condition>
    </conditions>
    <exceptions>
      <exception description="The controller has implemented appropriate technical and organisational protection measures" ref="t15"/>
      <exception description="The controller has taken subsequent measures which ensure that the high risk is no longer likely to materialise" ref="t15"/>
      <exception description="It would involve disproportionate effort" ref="t14"/>
    </exceptions>
    <source-ref article="34" paragraph="1"/>
  </task>
  <task id="t12">
    <label>Describe the nature of the personal data breach in clear and plain language</label>
    <performers>
      <performer>
        <unit>Organization</unit>
        <role>Controller</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>When communicating the personal data breach to the data subject</condition>
    </conditions>
    <exceptions/>
    <source-ref article="34" paragraph="2"/>
  </task>
  <task id="t13">
    <label>Provide the information and measures referred to in points (b), (c) and (d) of Article 33(3)</label>
    <performers>
      <performer>
        <unit>Organization</unit>
        <role>Controller</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>When communicating the personal data breach to the data subject</condition>
    </conditions>
    <exceptions/>
    <source-ref article="34" paragraph="2"/>
  </task>
  <task id="t14">
    <label>Make a public communication or similar measure</label>
    <performers>
      <performer>
        <unit>Organization</unit>
        <role>Controller</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>If communicating the breach to the data subject involves disproportionate effort</condition>
    </conditions>
    <exceptions/>
    <source-ref article="34" paragraph="3(c)"/>
  </task>
  <task id="t15">
    <label>Require the controller to communicate the personal data breach to the data subject</label>
    <performers>
      <performer>
        <unit>Supervisory Authority</unit>
        <role>Supervisory Authority</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>If the controller has not already communicated the personal data breach to the data subject</condition>
      <condition>Having considered the likelihood of the personal data breach resulting in a high risk</condition>
    </conditions>
    <exceptions/>
    <source-ref article="34" paragraph="4"/>
  </task>
  <task id="t16">
    <label>Communicate the personal data breach to the data subject</label>
    <performers>
      <performer>
        <unit>Organization</unit>
        <role>Controller</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>If required by the supervisory authority</condition>
    </conditions>
    <exceptions/>
    <source-ref article="34" paragraph="4"/>
  </task>
  <task id="t17">
    <label>Decide that any of the conditions referred to in paragraph 3 are met</label>
    <performers>
      <performer>
        <unit>Supervisory Authority</unit>
        <role>Supervisory Authority</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>If the controller has not already communicated the personal data breach to the data subject</condition>
    </conditions>
    <exceptions/>
    <source-ref article="34" paragraph="4"/>
  </task>
</tasks>