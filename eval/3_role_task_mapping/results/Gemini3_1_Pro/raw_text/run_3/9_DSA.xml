<?xml version="1.0" ?>
<tasks>
  <task id="t1">
    <label>Take necessary technical and organisational measures to ensure that notices are given priority, processed and decided upon</label>
    <performers>
      <performer>
        <unit>Provider</unit>
        <role>Online Platform Provider</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>Notices submitted by trusted flaggers acting within their designated area of expertise</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="1"/>
  </task>
  <task id="t2">
    <label>Apply for trusted flagger status</label>
    <performers>
      <performer>
        <unit>Entity</unit>
        <role>Trusted Flagger</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="2"/>
  </task>
  <task id="t3">
    <label>Award the status of trusted flagger</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Digital Services Coordinator</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>Upon application by any entity</condition>
      <condition>If the applicant has demonstrated that it meets all of the required conditions</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="2"/>
  </task>
  <task id="t4">
    <label>Publish easily comprehensible and detailed reports on submitted notices</label>
    <performers>
      <performer>
        <unit>Entity</unit>
        <role>Trusted Flagger</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>At least once a year</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="3"/>
  </task>
  <task id="t5">
    <label>List at least the number of notices categorised by identity, type, and action taken</label>
    <performers>
      <performer>
        <unit>Entity</unit>
        <role>Trusted Flagger</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="3"/>
  </task>
  <task id="t6">
    <label>Include an explanation of the procedures in place to ensure independence in the reports</label>
    <performers>
      <performer>
        <unit>Entity</unit>
        <role>Trusted Flagger</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="3"/>
  </task>
  <task id="t7">
    <label>Send those reports to the awarding Digital Services Coordinator</label>
    <performers>
      <performer>
        <unit>Entity</unit>
        <role>Trusted Flagger</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="3"/>
  </task>
  <task id="t8">
    <label>Make those reports publicly available</label>
    <performers>
      <performer>
        <unit>Entity</unit>
        <role>Trusted Flagger</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="3"/>
  </task>
  <task id="t9">
    <label>Include personal data in the reports</label>
    <performers>
      <performer>
        <unit>Entity</unit>
        <role>Trusted Flagger</role>
      </performer>
    </performers>
    <deontic type="prohibition" modality="shall not"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="3"/>
  </task>
  <task id="t10">
    <label>Communicate names, addresses and email addresses of awarded, suspended, or revoked entities to the Commission and the Board</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Digital Services Coordinator</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="4"/>
  </task>
  <task id="t11">
    <label>Publish the communicated information in a publicly available database in an easily accessible and machine-readable format</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="5"/>
  </task>
  <task id="t12">
    <label>Keep the database up to date</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="5"/>
  </task>
  <task id="t13">
    <label>Communicate information regarding inaccurate notices and provide necessary explanations and supporting documents</label>
    <performers>
      <performer>
        <unit>Provider</unit>
        <role>Online Platform Provider</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>Where a provider has information indicating that a trusted flagger has submitted a significant number of insufficiently precise, inaccurate or inadequately substantiated notices</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="6"/>
  </task>
  <task id="t14">
    <label>Suspend the status of trusted flagger</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Digital Services Coordinator</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>Upon receiving the information from the provider of online platforms</condition>
      <condition>If the Digital Services Coordinator considers that there are legitimate reasons to open an investigation</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="6"/>
  </task>
  <task id="t15">
    <label>Carry out the investigation</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Digital Services Coordinator</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>If there are legitimate reasons to open an investigation</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="6"/>
  </task>
  <task id="t16">
    <label>Afford the entity an opportunity to react to the findings of its investigation and its intention to revoke the status</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Digital Services Coordinator</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>Before revoking the trusted flagger status</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="7"/>
  </task>
  <task id="t17">
    <label>React to the findings of the investigation and the intention to revoke the status</label>
    <performers>
      <performer>
        <unit>Entity</unit>
        <role>Trusted Flagger</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>When afforded an opportunity before status is revoked</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="7"/>
  </task>
  <task id="t18">
    <label>Revoke the status of trusted flagger</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Digital Services Coordinator</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>If it determines, following an investigation, that the entity no longer meets the conditions set out in paragraph 2</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="7"/>
  </task>
  <task id="t19">
    <label>Consult the Board</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>Before issuing guidelines</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="8"/>
  </task>
  <task id="t20">
    <label>Consult the Commission</label>
    <performers>
      <performer>
        <unit>Board</unit>
        <role>Board</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>Before guidelines are issued</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="8"/>
  </task>
  <task id="t21">
    <label>Issue guidelines to assist providers of online platforms and Digital Services Coordinators</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>Where necessary</condition>
      <condition>After consulting the Board</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="8"/>
  </task>
</tasks>