<?xml version="1.0" ?>
<tasks>
  <task id="t1">
    <label>Transmit information on special needs</label>
    <performers>
      <performer>
        <unit>Transferring Member State</unit>
        <role>Health Professional</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>in so far as it is available to the competent authority in accordance with national law</condition>
      <condition>after having obtained the explicit consent of the applicant and/or of his or her representative</condition>
    </conditions>
    <exceptions>
      <exception description="if the applicant is physically or legally incapable of giving his or her consent, when such transmission is necessary to protect the vital interests of the applicant or of another person" ref="t1"/>
    </exceptions>
    <source-ref article="44" paragraph="1"/>
  </task>
  <task id="t2">
    <label>Include information on physical or mental health</label>
    <performers>
      <performer>
        <unit>Transferring Member State</unit>
        <role>Health Professional</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>in specific cases</condition>
    </conditions>
    <exceptions/>
    <source-ref article="44" paragraph="1"/>
  </task>
  <task id="t3">
    <label>Transfer information in a common health certificate</label>
    <performers>
      <performer>
        <unit>Transferring Member State</unit>
        <role>Health Professional</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>with the necessary documents attached</condition>
    </conditions>
    <exceptions/>
    <source-ref article="44" paragraph="1"/>
  </task>
  <task id="t4">
    <label>Ensure special needs are adequately addressed</label>
    <performers>
      <performer>
        <unit>Member State Responsible</unit>
        <role>Competent Authority</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="44" paragraph="1"/>
  </task>
  <task id="t5">
    <label>Address special needs adequately</label>
    <performers>
      <performer>
        <unit>Member State Responsible</unit>
        <role>Health Professional</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="44" paragraph="1"/>
  </task>
  <task id="t6">
    <label>Draw up the common health certificate</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>by means of implementing acts</condition>
    </conditions>
    <exceptions/>
    <source-ref article="44" paragraph="1"/>
  </task>
  <task id="t7">
    <label>Adopt implementing acts for the common health certificate</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>in accordance with the examination procedure laid down in Article 44(2)</condition>
    </conditions>
    <exceptions/>
    <source-ref article="44" paragraph="1"/>
  </task>
  <task id="t8">
    <label>Obtain explicit consent for transmission</label>
    <performers>
      <performer>
        <unit>Transferring Member State</unit>
        <role>Health Professional</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions>
      <exception description="if the applicant is physically or legally incapable of giving his or her consent, when such transmission is necessary to protect the vital interests of the applicant or of another person" ref="t8"/>
    </exceptions>
    <source-ref article="44" paragraph="2"/>
  </task>
  <task id="t9">
    <label>Give explicit consent for transmission</label>
    <performers>
      <performer>
        <unit>Applicant / Representative</unit>
        <role>Applicant / Representative</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions/>
    <exceptions/>
    <source-ref article="44" paragraph="2"/>
  </task>
  <task id="t10">
    <label>Process personal health data</label>
    <performers>
      <performer>
        <unit>Transferring Member State</unit>
        <role>Health Professional</role>
      </performer>
      <performer>
        <unit>Member State Responsible</unit>
        <role>Health Professional</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>subject to the obligation of professional secrecy</condition>
    </conditions>
    <exceptions/>
    <source-ref article="44" paragraph="3"/>
  </task>
  <task id="t11">
    <label>Exchange information</label>
    <performers>
      <performer>
        <unit>Transferring Member State</unit>
        <role>Health Professional</role>
      </performer>
      <performer>
        <unit>Member State Responsible</unit>
        <role>Health Professional</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>only between health professionals or other persons referred to in paragraph 3</condition>
    </conditions>
    <exceptions/>
    <source-ref article="44" paragraph="4"/>
  </task>
  <task id="t12">
    <label>Use exchanged information</label>
    <performers>
      <performer>
        <unit>Member State Responsible</unit>
        <role>Health Professional</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>only for the purposes set out in paragraph 1</condition>
    </conditions>
    <exceptions/>
    <source-ref article="44" paragraph="4"/>
  </task>
  <task id="t13">
    <label>Process exchanged information further</label>
    <performers>
      <performer>
        <unit>Member State Responsible</unit>
        <role>Health Professional</role>
      </performer>
    </performers>
    <deontic type="prohibition" modality="shall not"/>
    <conditions/>
    <exceptions/>
    <source-ref article="44" paragraph="4"/>
  </task>
  <task id="t14">
    <label>Adopt uniform conditions and practical arrangements for exchanging information</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>by means of implementing acts</condition>
    </conditions>
    <exceptions/>
    <source-ref article="44" paragraph="5"/>
  </task>
  <task id="t15">
    <label>Adopt implementing acts for uniform conditions</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>in accordance with the examination procedure laid down in Article 44(2)</condition>
    </conditions>
    <exceptions/>
    <source-ref article="44" paragraph="5"/>
  </task>
  <task id="t16">
    <label>Apply rules laid down in Article 34(8) to (12)</label>
    <performers>
      <performer>
        <unit>Transferring Member State</unit>
        <role>Health Professional</role>
      </performer>
      <performer>
        <unit>Member State Responsible</unit>
        <role>Health Professional</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>to the exchange of information pursuant to this Article</condition>
    </conditions>
    <exceptions/>
    <source-ref article="44" paragraph="6"/>
  </task>
</tasks>