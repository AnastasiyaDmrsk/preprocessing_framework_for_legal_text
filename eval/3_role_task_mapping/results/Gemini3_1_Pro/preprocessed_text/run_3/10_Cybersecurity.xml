    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>In duly justified cases</condition>
    </conditions>
    <exceptions/>
    <source-ref article="48" paragraph="2"/>
  </task>
  <task id="t6">
    <label>Review an existing European cybersecurity certification scheme</label>
    <performers>
      <performer>
        <unit>ENISA</unit>
        <role>ENISA</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>If requested by the Commission or the ECCG in duly justified cases</condition>
    </conditions>
    <exceptions/>
    <source-ref article="48" paragraph="2"/>
  </task>
  <task id="t7">
    <label>Update the Union rolling work programme</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
      <performer>
        <unit>ECCG</unit>
        <role>ECCG</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="48" paragraph="2"/>
  </task>
  <task id="t8">
    <label>Prepare a candidate scheme</label>
    <performers>
      <performer>
        <unit>ENISA</unit>
        <role>ENISA</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>Following a request from the Commission pursuant to Article 48</condition>
    </conditions>
    <exceptions/>
    <source-ref article="49" paragraph="1"/>
  </task>
  <task id="t9">
    <label>Prepare a candidate scheme</label>
    <performers>
      <performer>
        <unit>ENISA</unit>
        <role>ENISA</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>Following a request from the ECCG</condition>
    </conditions>
    <exceptions/>
    <source-ref article="49" paragraph="2"/>
  </task>
  <task id="t10">
    <label>Give reasons for refusal</label>
    <performers>
      <performer>
        <unit>ENISA</unit>
        <role>ENISA</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>If ENISA refuses a request to prepare a candidate scheme</condition>
    </conditions>
    <exceptions/>
    <source-ref article="49" paragraph="2"/>
  </task>
  <task id="t11">
    <label>Take decision to refuse request</label>
    <performers>
      <performer>
        <unit>ENISA</unit>
        <role>Management Board</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>If ENISA refuses a request to prepare a candidate scheme</condition>
    </conditions>
    <exceptions/>
    <source-ref article="49" paragraph="2"/>
  </task>
  <task id="t12">
    <label>Consult all relevant stakeholders</label>
    <performers>
      <performer>
        <unit>ENISA</unit>
        <role>ENISA</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>When preparing a candidate scheme</condition>
    </conditions>
    <exceptions/>
    <source-ref article="49" paragraph="3"/>
  </task>
  <task id="t13">
    <label>Establish an ad hoc working group</label>
    <performers>
      <performer>
        <unit>ENISA</unit>
        <role>ENISA</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>For each candidate scheme</condition>
    </conditions>
    <exceptions/>
    <source-ref article="49" paragraph="4"/>
  </task>
  <task id="t14">
    <label>Closely cooperate with the ECCG</label>
    <performers>
      <performer>
        <unit>ENISA</unit>
        <role>ENISA</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="49" paragraph="5"/>
  </task>
  <task id="t15">
    <label>Closely cooperate with ENISA</label>
    <performers>
      <performer>
        <unit>ECCG</unit>
        <role>ECCG</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="49" paragraph="5"/>
  </task>
  <task id="t16">
    <label>Provide ENISA with assistance and expert advice</label>
    <performers>
      <performer>
        <unit>ECCG</unit>
        <role>ECCG</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>In relation to the preparation of the candidate scheme</condition>
    </conditions>
    <exceptions/>
    <source-ref article="49" paragraph="5"/>
  </task>
  <task id="t17">
    <label>Adopt an opinion on the candidate scheme</label>
    <performers>
      <performer>
        <unit>ECCG</unit>
        <role>ECCG</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="49" paragraph="5"/>
  </task>
  <task id="t18">
    <label>Take utmost account of the opinion of the ECCG</label>
    <performers>
      <performer>
        <unit>ENISA</unit>
        <role>ENISA</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>Before transmitting the candidate scheme to the Commission</condition>
    </conditions>
    <exceptions/>
    <source-ref article="49" paragraph="6"/>
  </task>
  <task id="t19">
    <label>Bind ENISA</label>
    <performers>
      <performer>
        <unit>ECCG</unit>
        <role>ECCG</role>
      </performer>
    </performers>
    <deontic type="prohibition" modality="shall not"/>
    <conditions/>
    <exceptions/>
    <source-ref article="49" paragraph="6"/>
  </task>
  <task id="t20">
    <label>Transmit the candidate scheme to the Commission</label>
    <performers>
      <performer>
        <unit>ENISA</unit>
        <role>ENISA</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>Even in the absence of an opinion from the ECCG</condition>
    </conditions>
    <exceptions/>
    <source-ref article="49" paragraph="6"/>
  </task>
  <task id="t21">
    <label>Adopt implementing acts providing for a European cybersecurity certification scheme</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>Based on the candidate scheme prepared by ENISA</condition>
    </conditions>
    <exceptions/>
    <source-ref article="49" paragraph="7"/>
  </task>
  <task id="t22">
    <label>Adopt implementing acts IAW the examination procedure</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>If adopting implementing acts</condition>
    </conditions>
    <exceptions/>
    <source-ref article="49" paragraph="7"/>
  </task>
  <task id="t23">
    <label>Evaluate each adopted European cybersecurity certification scheme</label>
    <performers>
      <performer>
        <unit>ENISA</unit>
        <role>ENISA</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>At least every five years</condition>
      <condition>Taking into account the feedback received from interested parties</condition>
    </conditions>
    <exceptions/>
    <source-ref article="49" paragraph="8"/>
  </task>
  <task id="t24">
    <label>Provide feedback on adopted scheme</label>
    <performers>
      <performer>
        <unit>Interested Party</unit>
        <role>Interested Party</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions/>
    <exceptions/>
    <source-ref article="49" paragraph="8"/>
  </task>
  <task id="t25">
    <label>Request ENISA to start the process of developing a revised candidate scheme</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
      <performer>
        <unit>ECCG</unit>
        <role>ECCG</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>If necessary</condition>
    </conditions>
    <exceptions/>
    <source-ref article="49" paragraph="8"/>
  </task>
  <task id="t26">
    <label>Start the process of developing a revised candidate scheme</label>
    <performers>
      <performer>
        <unit>ENISA</unit>
        <role>ENISA</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>If requested by the Commission or the ECCG</condition>
      <condition>If necessary</condition>
    </conditions>
    <exceptions/>
    <source-ref article="49" paragraph="8"/>
  </task>
</tasks>