<tasks>
  <task id="t1">
    <label>Transmit information on any special needs</label>
    <performers>
      <performer>
        <unit>Transferring Member State</unit>
        <role>Health Professional</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>in so far as available to the competent authority IAW national law</condition>
      <condition>after having obtained the explicit consent of the applicant and/or of his or her representative OR when transmission is necessary to protect the vital interests of the applicant or of another person if the applicant is physically or legally incapable of giving consent</condition>
    </conditions>
    <exceptions/>
    <source-ref article="44" paragraph="UNKNOWN"/>
  </task>
