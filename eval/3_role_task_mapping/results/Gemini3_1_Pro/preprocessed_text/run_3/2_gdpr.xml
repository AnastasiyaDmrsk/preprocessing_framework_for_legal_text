<?xml version="1.0" ?>
<tasks>
  <task id="t1">
    <label>Notify personal data breach to supervisory authority</label>
    <performers>
      <performer>
        <unit>Organization</unit>
        <role>Controller</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>In the case of a personal data breach</condition>
    </conditions>
    <exceptions>
      <exception description="unless the personal data breach is unlikely to result in a risk to the rights and freedoms of natural persons" ref="t1"/>
    </exceptions>
    <source-ref article="33" paragraph="1"/>
  </task>
  <task id="t2">
    <label>Provide reasons for delay</label>
    <performers>
      <performer>
        <unit>Organization</unit>
        <role>Controller</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>IF the notification to the supervisory authority is not made within 72 hours</condition>
    </conditions>
    <exceptions/>
    <source-ref article="33" paragraph="1"/>
  </task>
  <task id="t3">
    <label>Notify personal data breach to controller</label>
    <performers>
      <performer>
        <unit>Organization</unit>
        <role>Processor</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>after becoming aware of a personal data breach</condition>
    </conditions>
    <exceptions/>
    <source-ref article="33" paragraph="2"/>
  </task>
  <task id="t4">
    <label>Describe nature of personal data breach</label>
    <performers>
      <performer>
        <unit>Organization</unit>
        <role>Controller</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="33" paragraph="3(a)"/>
  </task>
  <task id="t5">
    <label>Communicate name and contact details of data protection officer</label>
    <performers>
      <performer>
        <unit>Organization</unit>
        <role>Controller</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="33" paragraph="3(b)"/>
  </task>
  <task id="t6">
    <label>Describe likely consequences of personal data breach</label>
    <performers>
      <performer>
        <unit>Organization</unit>
        <role>Controller</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="33" paragraph="3(c)"/>
  </task>
  <task id="t7">
    <label>Describe measures taken or proposed to address personal data breach</label>
    <performers>
      <performer>
        <unit>Organization</unit>
        <role>Controller</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="33" paragraph="3(d)"/>
  </task>
  <task id="t8">
    <label>Provide information in phases</label>
    <performers>
      <performer>
        <unit>Organization</unit>
        <role>Controller</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>IF it is not possible to provide the information at the same time</condition>
    </conditions>
    <exceptions/>
    <source-ref article="33" paragraph="4"/>
  </task>
  <task id="t9">
    <label>Document personal data breaches</label>
    <performers>
      <performer>
        <unit>Organization</unit>
        <role>Controller</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="33" paragraph="5"/>
  </task>
  <task id="t10">
    <label>Communicate personal data breach to data subject</label>
    <performers>
      <performer>
        <unit>Organization</unit>
        <role>Controller</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>When the personal data breach is likely to result in a high risk to the rights and freedoms of natural persons</condition>
    </conditions>
    <exceptions>
      <exception description="if the controller has implemented appropriate technical and organisational protection measures" ref="t10"/>
      <exception description="if the controller has taken subsequent measures which ensure that the high risk is no longer likely to materialise" ref="t10"/>
      <exception description="if the communication would involve disproportionate effort" ref="t10"/>
    </exceptions>
    <source-ref article="34" paragraph="1"/>
  </task>
  <task id="t11">
    <label>Describe nature of personal data breach in clear and plain language</label>
    <performers>
      <performer>
        <unit>Organization</unit>
        <role>Controller</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="34" paragraph="2"/>
  </task>
  <task id="t12">
    <label>Include information and measures referred to in points b, c and d</label>
    <performers>
      <performer>
        <unit>Organization</unit>
        <role>Controller</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="34" paragraph="2"/>
  </task>
  <task id="t13">
    <label>Make public communication or similar measure</label>
    <performers>
      <performer>
        <unit>Organization</unit>
        <role>Controller</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>if communication to data subject would involve disproportionate effort</condition>
    </conditions>
    <exceptions/>
    <source-ref article="34" paragraph="3(c)"/>
  </task>
  <task id="t14">
    <label>Require controller to communicate personal data breach</label>
    <performers>
      <performer>
        <unit>Supervisory Authority</unit>
        <role>Supervisory Authority</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>IF the controller has not already communicated the personal data breach to the data subject AND likelihood of breach resulting in high risk</condition>
    </conditions>
    <exceptions/>
    <source-ref article="34" paragraph="4"/>
  </task>
  <task id="t15">
    <label>Communicate personal data breach to data subject</label>
    <performers>
      <performer>
        <unit>Organization</unit>
        <role>Controller</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>if required by Supervisory Authority</condition>
    </conditions>
    <exceptions/>
    <source-ref article="34" paragraph="4"/>
  </task>
  <task id="t16">
    <label>Decide that conditions are met</label>
    <performers>
      <performer>
        <unit>Supervisory Authority</unit>
        <role>Supervisory Authority</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>IF the controller has not already communicated the personal data breach to the data subject</condition>
    </conditions>
    <exceptions/>
    <source-ref article="34" paragraph="4"/>
  </task>
</tasks>