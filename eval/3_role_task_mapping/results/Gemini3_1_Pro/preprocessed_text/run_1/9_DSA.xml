<?xml version="1.0" ?>
<tasks>
  <task id="t1">
    <label>Take necessary technical and organisational measures</label>
    <performers>
      <performer>
        <unit>Provider</unit>
        <role>Online Platform Provider</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="1"/>
  </task>
  <task id="t2">
    <label>Give priority to notices</label>
    <performers>
      <performer>
        <unit>Provider</unit>
        <role>Online Platform Provider</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>If notices are submitted by trusted flaggers</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="1"/>
  </task>
  <task id="t3">
    <label>Process notices</label>
    <performers>
      <performer>
        <unit>Provider</unit>
        <role>Online Platform Provider</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>If notices are submitted by trusted flaggers</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="1"/>
  </task>
  <task id="t4">
    <label>Decide upon notices</label>
    <performers>
      <performer>
        <unit>Provider</unit>
        <role>Online Platform Provider</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>If notices are submitted by trusted flaggers</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="1"/>
  </task>
  <task id="t5">
    <label>Apply for the status of trusted flagger</label>
    <performers>
      <performer>
        <unit>Entity</unit>
        <role>Trusted Flagger</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="2(a)"/>
  </task>
  <task id="t6">
    <label>Award the status of trusted flagger</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Digital Services Coordinator</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>Upon application by any entity</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="2(a)"/>
  </task>
  <task id="t7">
    <label>Publish easily comprehensible and detailed reports on notices submitted</label>
    <performers>
      <performer>
        <unit>Entity</unit>
        <role>Trusted Flagger</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>At least once a year</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="3(a)"/>
  </task>
  <task id="t8">
    <label>Send reports to the awarding Digital Services Coordinator</label>
    <performers>
      <performer>
        <unit>Entity</unit>
        <role>Trusted Flagger</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="3(c)"/>
  </task>
  <task id="t9">
    <label>Make reports publicly available</label>
    <performers>
      <performer>
        <unit>Entity</unit>
        <role>Trusted Flagger</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="3(c)"/>
  </task>
  <task id="t10">
    <label>Communicate names, addresses and email addresses of the entities</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Digital Services Coordinator</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="4"/>
  </task>
  <task id="t11">
    <label>Publish the information in a publicly available database</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="5"/>
  </task>
  <task id="t12">
    <label>Keep the database up to date</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="5"/>
  </task>
  <task id="t13">
    <label>Provide information indicating inadequately substantiated notices</label>
    <performers>
      <performer>
        <unit>Provider</unit>
        <role>Online Platform Provider</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>If a provider of online platforms has information indicating that a trusted flagger has submitted a significant number of insufficiently precise, inaccurate or inadequately substantiated notices</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="6"/>
  </task>
  <task id="t14">
    <label>Communicate information to the Digital Services Coordinator</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>If a provider of online platforms has information indicating that a trusted flagger has submitted a significant number of insufficiently precise, inaccurate or inadequately substantiated notices</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="6"/>
  </task>
  <task id="t15">
    <label>Evaluate legitimate reasons to open an investigation</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Digital Services Coordinator</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>Upon receiving information from the provider of online platforms</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="6"/>
  </task>
  <task id="t16">
    <label>Suspend the status of trusted flagger</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>Upon receiving the information from the provider of online platforms and if the Digital Services Coordinator considers that there are legitimate reasons to open an investigation</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="6"/>
  </task>
  <task id="t17">
    <label>Carry out the investigation</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="6"/>
  </task>
  <task id="t18">
    <label>Afford the entity an opportunity to react to the findings and intention to revoke</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Digital Services Coordinator</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>Before revoking that status</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="7"/>
  </task>
  <task id="t19">
    <label>React to the findings and intention to revoke</label>
    <performers>
      <performer>
        <unit>Entity</unit>
        <role>Trusted Flagger</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>Upon being afforded the opportunity</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="7"/>
  </task>
  <task id="t20">
    <label>Revoke the status of trusted flagger</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Digital Services Coordinator</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>If the Digital Services Coordinator determines that the entity no longer meets the conditions set out</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="7"/>
  </task>
  <task id="t21">
    <label>Consult the Board</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>Before issuing guidelines</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="8"/>
  </task>
  <task id="t22">
    <label>Provide consultation on guidelines</label>
    <performers>
      <performer>
        <unit>Board</unit>
        <role>Board</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>When consulted by the Commission</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="8"/>
  </task>
  <task id="t23">
    <label>Issue guidelines</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>Where necessary</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="8"/>
  </task>
</tasks>