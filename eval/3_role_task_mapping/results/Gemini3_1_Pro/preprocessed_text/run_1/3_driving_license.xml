<?xml version="1.0" ?>
<tasks>
  <task id="t1">
    <label>Ensure applicants undergo medical examination</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Member State</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>before a driving licence is issued for the first time</condition>
    </conditions>
    <exceptions/>
    <source-ref article="11" paragraph="1"/>
  </task>
  <task id="t2">
    <label>Undergo medical examination</label>
    <performers>
      <performer>
        <unit>Applicant</unit>
        <role>Applicant</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>before a driving licence is issued for the first time</condition>
    </conditions>
    <exceptions/>
    <source-ref article="11" paragraph="1"/>
  </task>
  <task id="t3">
    <label>Apply minimum standards of physical and mental fitness</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Member State</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>during the medical examination</condition>
    </conditions>
    <exceptions/>
    <source-ref article="11" paragraph="1"/>
  </task>
  <task id="t4">
    <label>Require medical examination</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Member State</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>for applications for driving licences of categories C, CE, C1, C1E, D, D1, DE or D1E</condition>
    </conditions>
    <exceptions/>
    <source-ref article="11" paragraph="1"/>
  </task>
  <task id="t5">
    <label>Undergo medical examination</label>
    <performers>
      <performer>
        <unit>Applicant</unit>
        <role>Applicant</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>before a driving licence is renewed</condition>
      <condition>for category AM only if required by the Member State</condition>
    </conditions>
    <exceptions/>
    <source-ref article="11" paragraph="2"/>
  </task>
  <task id="t6">
    <label>Require medical examination</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Member State</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>for the renewal of driving licences in category AM</condition>
    </conditions>
    <exceptions/>
    <source-ref article="11" paragraph="2"/>
  </task>
  <task id="t7">
    <label>Require applicant or holder to fill in self-assessment form</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Member State</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>for categories AM, A, A1, A2, B, B1 and BE</condition>
      <condition>instead of requiring a medical examination</condition>
    </conditions>
    <exceptions>
      <exception description="to the extent otherwise provided for by" ref="t7"/>
    </exceptions>
    <source-ref article="11" paragraph="3(a)"/>
  </task>
  <task id="t8">
    <label>Fill in self-assessment form</label>
    <performers>
      <performer>
        <unit>Applicant</unit>
        <role>Applicant</role>
      </performer>
      <performer>
        <unit>Applicant</unit>
        <role>Driving Licence Holder</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>when applying for the issuance or renewal of a driving licence</condition>
      <condition>if required by Member State</condition>
    </conditions>
    <exceptions/>
    <source-ref article="11" paragraph="3(a)"/>
  </task>
  <task id="t9">
    <label>Establish national system of assessment of fitness to drive</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Member State</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>for categories AM, A, A1, A2, B, B1 and BE</condition>
      <condition>instead of requiring a medical examination</condition>
    </conditions>
    <exceptions>
      <exception description="to the extent otherwise provided for by" ref="t9"/>
    </exceptions>
    <source-ref article="11" paragraph="3(b)"/>
  </task>
  <task id="t10">
    <label>React to significant changes in physical or mental fitness</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Member State</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>after the driving licence has been issued following a medical examination or self-assessment</condition>
    </conditions>
    <exceptions/>
    <source-ref article="11" paragraph="3(b)"/>
  </task>
  <task id="t11">
    <label>Provide for appropriate measures</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Member State</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>for knowingly providing information in the self-assessment form or for failing to meet any requirement established</condition>
    </conditions>
    <exceptions/>
    <source-ref article="11" paragraph="4"/>
  </task>
  <task id="t12">
    <label>Apply alternative measure to allow monitoring of fitness to drive</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Member State</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>during periods of administrative validity</condition>
    </conditions>
    <exceptions/>
    <source-ref article="11" paragraph="5"/>
  </task>
  <task id="t13">
    <label>Ensure applicant or holder undergoes medical examination</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Member State</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>IF it becomes apparent that the applicant or holder is likely to have listed medical conditions</condition>
      <condition>prior to issuing or renewing the driving licence</condition>
    </conditions>
    <exceptions/>
    <source-ref article="11" paragraph="6"/>
  </task>
  <task id="t14">
    <label>Undergo medical examination</label>
    <performers>
      <performer>
        <unit>Applicant</unit>
        <role>Applicant</role>
      </performer>
      <performer>
        <unit>Applicant</unit>
        <role>Driving Licence Holder</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
