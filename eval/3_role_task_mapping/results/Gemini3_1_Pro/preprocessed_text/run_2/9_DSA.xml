<?xml version="1.0" ?>
<tasks>
  <task id="t1">
    <label>Take necessary technical and organisational measures</label>
    <performers>
      <performer>
        <unit>Provider</unit>
        <role>Online Platform Provider</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="1"/>
  </task>
  <task id="t2">
    <label>Give priority to notices</label>
    <performers>
      <performer>
        <unit>Provider</unit>
        <role>Online Platform Provider</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>for notices submitted by trusted flaggers</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="1"/>
  </task>
  <task id="t3">
    <label>Process notices</label>
    <performers>
      <performer>
        <unit>Provider</unit>
        <role>Online Platform Provider</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>for notices submitted by trusted flaggers</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="1"/>
  </task>
  <task id="t4">
    <label>Decide upon notices</label>
    <performers>
      <performer>
        <unit>Provider</unit>
        <role>Online Platform Provider</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>for notices submitted by trusted flaggers</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="1"/>
  </task>
  <task id="t5">
    <label>Apply for trusted flagger status</label>
    <performers>
      <performer>
        <unit>Entity</unit>
        <role>Trusted Flagger</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="2"/>
  </task>
  <task id="t6">
    <label>Award trusted flagger status</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Digital Services Coordinator</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>upon application by any entity</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="2"/>
  </task>
  <task id="t7">
    <label>Publish easily comprehensible and detailed reports on notices submitted</label>
    <performers>
      <performer>
        <unit>Entity</unit>
        <role>Trusted Flagger</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>at least once a year</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="3"/>
  </task>
  <task id="t8">
    <label>Send reports to awarding Digital Services Coordinator</label>
    <performers>
      <performer>
        <unit>Entity</unit>
        <role>Trusted Flagger</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="3(c)"/>
  </task>
  <task id="t9">
    <label>Make reports publicly available</label>
    <performers>
      <performer>
        <unit>Entity</unit>
        <role>Trusted Flagger</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="3(c)"/>
  </task>
  <task id="t10">
    <label>Communicate names, addresses and email addresses of trusted flaggers to Commission and Board</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Digital Services Coordinator</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="4"/>
  </task>
  <task id="t11">
    <label>Publish information in a publicly available database</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="5"/>
  </task>
  <task id="t12">
    <label>Keep the database up to date</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="5"/>
  </task>
  <task id="t13">
    <label>Send information indicating insufficiently precise, inaccurate or inadequately substantiated notices</label>
    <performers>
      <performer>
        <unit>Provider</unit>
        <role>Online Platform Provider</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>if the provider has such information</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="6"/>
  </task>
  <task id="t14">
    <label>Communicate information to the Digital Services Coordinator</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>if a provider of online platforms has information indicating that a trusted flagger has submitted a significant number of insufficiently precise, inaccurate or inadequately substantiated notices</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="6"/>
  </task>
  <task id="t15">
    <label>Assess legitimate reasons to open an investigation</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Digital Services Coordinator</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>upon receiving the information from the provider of online platforms</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="6"/>
  </task>
  <task id="t16">
    <label>Suspend trusted flagger status</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>upon receiving the information from the provider of online platforms</condition>
      <condition>if the Digital Services Coordinator considers that there are legitimate reasons to open an investigation</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="6"/>
  </task>
  <task id="t17">
    <label>Carry out investigation</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="22" paragraph="6"/>
  </task>
  <task id="t18">
    <label>Carry out investigation</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Digital Services Coordinator</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>either on own initiative or on the basis of information received from third parties</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="7"/>
  </task>
  <task id="t19">
    <label>Revoke trusted flagger status</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Digital Services Coordinator</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>if the Digital Services Coordinator determines, following an investigation, that the entity no longer meets the conditions set out</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="7"/>
  </task>
  <task id="t20">
    <label>Afford entity an opportunity to react to findings of investigation and intention to revoke status</label>
    <performers>
      <performer>
        <unit>Member State</unit>
        <role>Digital Services Coordinator</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>before revoking trusted flagger status</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="7"/>
  </task>
  <task id="t21">
    <label>React to findings of investigation and intention to revoke status</label>
    <performers>
      <performer>
        <unit>Entity</unit>
        <role>Trusted Flagger</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>before revocation of trusted flagger status</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="7"/>
  </task>
  <task id="t22">
    <label>Consult the Board</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>before issuing guidelines</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="8"/>
  </task>
  <task id="t23">
    <label>Consult the Commission</label>
    <performers>
      <performer>
        <unit>Board</unit>
        <role>Board</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>before the Commission issues guidelines</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="8"/>
  </task>
  <task id="t24">
    <label>Issue guidelines to assist providers of online platforms and Digital Services Coordinators</label>
    <performers>
      <performer>
        <unit>Commission</unit>
        <role>Commission</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>where necessary</condition>
    </conditions>
    <exceptions/>
    <source-ref article="22" paragraph="8"/>
  </task>
</tasks>