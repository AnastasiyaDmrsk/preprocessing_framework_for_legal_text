      <performer>
        <unit>Member State</unit>
        <role>Supervisory Body</role>
      </performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>the supervisory body is not competent to provide the requested assistance</condition>
