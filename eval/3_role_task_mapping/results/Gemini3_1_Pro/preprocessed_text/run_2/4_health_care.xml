<?xml version="1.0" ?>
<tasks>
  <task id="t1">
    <label>Transmit information on special needs</label>
    <performers>
      <performer>
        <unit>Transferring Member State</unit>
        <role>Health Professional</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>for the sole purpose of the provision of medical care or treatment concerning disabled persons, elderly people, pregnant women, minors and persons who have been subject to torture, rape or other serious forms of psychological, physical and sexual violence</condition>
      <condition>in so far as available to the competent authority</condition>
      <condition>after having obtained the explicit consent of the applicant or representative or when such transmission is necessary to protect vital interests</condition>
    </conditions>
    <exceptions/>
    <source-ref article="UNKNOWN" paragraph="1"/>
  </task>
