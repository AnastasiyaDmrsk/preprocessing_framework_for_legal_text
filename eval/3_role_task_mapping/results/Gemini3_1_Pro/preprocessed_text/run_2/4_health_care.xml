<?xml version="1.0" ?>
<tasks>
  <task id="t1">
    <label>Transmit information on any special needs to the Member State responsible</label>
    <performers>
      <performer>
        <unit>Transferring Member State</unit>
        <role>Health Professional</role>
      </performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>in so far as who is available to the competent authority IAW national law</condition>
      <condition>after having obtained the explicit consent of the applicant OR when transmission is necessary to protect vital interests of the applicant or another person</condition>
    </conditions>
    <exceptions/>
    <source-ref article="44" paragraph="UNKNOWN"/>
  </task>
