<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" 
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" 
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" 
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" 
             xmlns:signavio="http://www.signavio.com" 
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
             exporter="Signavio Process Editor, http://www.signavio.com" 
             exporterVersion="19.2.2" 
             id="sid-def-id" 
             targetNamespace="http://www.signavio.com">
   
   <collaboration id="collab_1">
      <participant id="p_ca" name="Competent Authority" processRef="pr_ca" />
      <participant id="p_eie" name="Essential and Important Entity" processRef="pr_eie" />
      <participant id="p_tsp" name="Trust Service Provider" processRef="pr_tsp" />
      <participant id="p_csirt" name="CSIRT" processRef="pr_csirt" />
      <participant id="p_spoc" name="Single Point of Contact" processRef="pr_spoc" />
      <participant id="p_enisa" name="ENISA" processRef="pr_enisa" />
      <participant id="p_com" name="Commission" processRef="pr_com" />
      <participant id="p_cg" name="Cooperation Group" processRef="pr_cg" />

      <!-- Message Flows -->
      <messageFlow id="mf_eie_ca" sourceRef="eie_t1" targetRef="ca_e1" />
      <messageFlow id="mf_eie_csirt" sourceRef="eie_t1" targetRef="p_csirt" />
      <messageFlow id="mf_tsp_ca" sourceRef="tsp_t1" targetRef="p_ca" />
      <messageFlow id="mf_ca_csirt" sourceRef="ca_t4" targetRef="p_csirt" />
      <messageFlow id="mf_tsp_csirt" sourceRef="tsp_t2" targetRef="csirt_e1" />
      <messageFlow id="mf_csirt_eie_int" sourceRef="csirt_t3" targetRef="eie_e1" />
      <messageFlow id="mf_eie_csirt_tech" sourceRef="eie_t10" targetRef="csirt_e2" />
      <messageFlow id="mf_csirt_eie_pub" sourceRef="csirt_t12" targetRef="eie_e2" />
      <messageFlow id="mf_csirt_spoc" sourceRef="csirt_t13" targetRef="spoc_e1" />
   </collaboration>

   <!-- 1. Competent Authority Process -->
   <process id="pr_ca" isClosed="false" isExecutable="false" name="Competent Authority" processType="None">
      <startEvent id="ca_s" name="Start">
         <outgoing>ca_sf1</outgoing>
      </startEvent>
      <task id="ca_t1" name="Ensure entities notify CSIRT">
         <incoming>ca_sf1</incoming>
         <outgoing>ca_sf2</outgoing>
      </task>
      <task id="ca_t2" name="Ensure entities report information for cross-border impact">
         <incoming>ca_sf2</incoming>
         <outgoing>ca_sf3</outgoing>
      </task>
      <intermediateCatchEvent id="ca_e1" name="Receive notification of significant incident">
         <extensionElements>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/>
         </extensionElements>
         <incoming>ca_sf3</incoming>
         <outgoing>ca_sf4</outgoing>
         <messageEventDefinition id="med_ca_e1"/>
      </intermediateCatchEvent>
      <task id="ca_t3" name="Ensure competent authority forwards notification to CSIRT">
         <incoming>ca_sf4</incoming>
         <outgoing>ca_sf5</outgoing>
      </task>
      <task id="ca_t4" name="Forward the notification to the CSIRT">
         <incoming>ca_sf5</incoming>
         <outgoing>ca_sf6</outgoing>
      </task>
      <exclusiveGateway id="ca_gw1_div" name="Assess cross-border or cross-sectoral" isMarkerVisible="true" gatewayDirection="Diverging">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements>
         <incoming>ca_sf6</incoming>
         <outgoing>ca_sf7_yes</outgoing>
         <outgoing>ca_sf7_no</outgoing>
      </exclusiveGateway>
      <task id="ca_t5" name="Ensure SPOCs are provided with information">
         <incoming>ca_sf7_yes</incoming>
         <outgoing>ca_sf8</outgoing>
      </task>
      <exclusiveGateway id="ca_gw1_conv" isMarkerVisible="true" gatewayDirection="Converging">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements>
         <incoming>ca_sf8</incoming>
         <incoming>ca_sf7_no</incoming>
         <outgoing>ca_sf9</outgoing>
      </exclusiveGateway>
      <exclusiveGateway id="ca_gw2_div" name="Assess whether applicable" isMarkerVisible="true" gatewayDirection="Diverging">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements>
         <incoming>ca_sf9</incoming>
         <outgoing>ca_sf10_yes</outgoing>
         <outgoing>ca_sf10_no</outgoing>
      </exclusiveGateway>
      <task id="ca_t6" name="Ensure entities communicate measures to recipients">
         <incoming>ca_sf10_yes</incoming>
         <outgoing>ca_sf11</outgoing>
      </task>
      <exclusiveGateway id="ca_gw2_conv" isMarkerVisible="true" gatewayDirection="Converging">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements>
         <incoming>ca_sf11</incoming>
         <incoming>ca_sf10_no</incoming>
         <outgoing>ca_sf12</outgoing>
      </exclusiveGateway>
      <task id="ca_t7" name="Ensure entities submit early warning">
         <incoming>ca_sf12</incoming>
         <outgoing>ca_sf13</outgoing>
      </task>
      <task id="ca_t8" name="Ensure entities submit incident notification">
         <incoming>ca_sf13</incoming>
         <outgoing>ca_sf14</outgoing>
      </task>
      <task id="ca_t9" name="Ensure entities submit intermediate report">
         <incoming>ca_sf14</incoming>
         <outgoing>ca_sf15</outgoing>
      </task>
      <task id="ca_t10" name="Ensure entities submit final report">
         <incoming>ca_sf15</incoming>
         <outgoing>ca_sf16</outgoing>
      </task>
      <exclusiveGateway id="ca_gw3_div" name="Assess incident ongoing" isMarkerVisible="true" gatewayDirection="Diverging">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements>
         <incoming>ca_sf16</incoming>
         <outgoing>ca_sf17_yes</outgoing>
         <outgoing>ca_sf17_no</outgoing>
      </exclusiveGateway>
      <task id="ca_t11" name="Ensure entities provide progress and final report">
         <incoming>ca_sf17_yes</incoming>
         <outgoing>ca_sf18</outgoing>
      </task>
      <exclusiveGateway id="ca_gw3_conv" isMarkerVisible="true" gatewayDirection="Converging">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements>
         <incoming>ca_sf18</incoming>
         <incoming>ca_sf17_no</incoming>
         <outgoing>ca_sf19</outgoing>
      </exclusiveGateway>
      <intermediateCatchEvent id="ca_e2" name="Receive request for guidance">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
         <incoming>ca_sf19</incoming>
         <outgoing>ca_sf20</outgoing>
         <messageEventDefinition id="med_ca_e2"/>
      </intermediateCatchEvent>
      <exclusiveGateway id="ca_gw4_div" name="Assess CSIRT not initial recipient" isMarkerVisible="true" gatewayDirection="Diverging">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements>
         <incoming>ca_sf20</incoming>
         <outgoing>ca_sf21_yes</outgoing>
         <outgoing>ca_sf21_no</outgoing>
      </exclusiveGateway>
      <task id="ca_t12" name="Cooperate with CSIRT on guidance">
         <incoming>ca_sf21_yes</incoming>
         <outgoing>ca_sf22</outgoing>
      </task>
      <exclusiveGateway id="ca_gw4_conv" isMarkerVisible="true" gatewayDirection="Converging">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements>
         <incoming>ca_sf22</incoming>
         <incoming>ca_sf21_no</incoming>
         <outgoing>ca_sf23</outgoing>
      </exclusiveGateway>
      <endEvent id="ca_end" name="CA obligations fulfilled">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
         <incoming>ca_sf23</incoming>
      </endEvent>

      <sequenceFlow id="ca_sf1" isImmediate="true" sourceRef="ca_s" targetRef="ca_t1" />
      <sequenceFlow id="ca_sf2" isImmediate="true" sourceRef="ca_t1" targetRef="ca_t2" />
      <sequenceFlow id="ca_sf3" isImmediate="true" sourceRef="ca_t2" targetRef="ca_e1" />
      <sequenceFlow id="ca_sf4" isImmediate="true" sourceRef="ca_e1" targetRef="ca_t3" />
      <sequenceFlow id="ca_sf5" isImmediate="true" sourceRef="ca_t3" targetRef="ca_t4" />
      <sequenceFlow id="ca_sf6" isImmediate="true" sourceRef="ca_t4" targetRef="ca_gw1_div" />
      <sequenceFlow id="ca_sf7_yes" name="yes" isImmediate="true" sourceRef="ca_gw1_div" targetRef="ca_t5" />
      <sequenceFlow id="ca_sf7_no" name="no" isImmediate="true" sourceRef="ca_gw1_div" targetRef="ca_gw1_conv" />
      <sequenceFlow id="ca_sf8" isImmediate="true" sourceRef="ca_t5" targetRef="ca_gw1_conv" />
      <sequenceFlow id="ca_sf9" isImmediate="true" sourceRef="ca_gw1_conv" targetRef="ca_gw2_div" />
      <sequenceFlow id="ca_sf10_yes" name="yes" isImmediate="true" sourceRef="ca_gw2_div" targetRef="ca_t6" />
      <sequenceFlow id="ca_sf10_no" name="no" isImmediate="true" sourceRef="ca_gw2_div" targetRef="ca_gw2_conv" />
      <sequenceFlow id="ca_sf11" isImmediate="true" sourceRef="ca_t6" targetRef="ca_gw2_conv" />
      <sequenceFlow id="ca_sf12" isImmediate="true" sourceRef="ca_gw2_conv" targetRef="ca_t7" />
      <sequenceFlow id="ca_sf13" isImmediate="true" sourceRef="ca_t7" targetRef="ca_t8" />
      <sequenceFlow id="ca_sf14" isImmediate="true" sourceRef="ca_t8" targetRef="ca_t9" />
      <sequenceFlow id="ca_sf15" isImmediate="true" sourceRef="ca_t9" targetRef="ca_t10" />
      <sequenceFlow id="ca_sf16" isImmediate="true" sourceRef="ca_t10" targetRef="ca_gw3_div" />
      <sequenceFlow id="ca_sf17_yes" name="yes" isImmediate="true" sourceRef="ca_gw3_div" targetRef="ca_t11" />
      <sequenceFlow id="ca_sf17_no" name="no" isImmediate="true" sourceRef="ca_gw3_div" targetRef="ca_gw3_conv" />
      <sequenceFlow id="ca_sf18" isImmediate="true" sourceRef="ca_t11" targetRef="ca_gw3_conv" />
      <sequenceFlow id="ca_sf19" isImmediate="true" sourceRef="ca_gw3_conv" targetRef="ca_e2" />
      <sequenceFlow id="ca_sf20" isImmediate="true" sourceRef="ca_e2" targetRef="ca_gw4_div" />
      <sequenceFlow id="ca_sf21_yes" name="yes" isImmediate="true" sourceRef="ca_gw4_div" targetRef="ca_t12" />
      <sequenceFlow id="ca_sf21_no" name="no" isImmediate="true" sourceRef="ca_gw4_div" targetRef="ca_gw4_conv" />
      <sequenceFlow id="ca_sf22" isImmediate="true" sourceRef="ca_t12" targetRef="ca_gw4_conv" />
      <sequenceFlow id="ca_sf23" isImmediate="true" sourceRef="ca_gw4_conv" targetRef="ca_end" />
   </process>

   <!-- 2. Essential and Important Entity Process -->
   <process id="pr_eie" isClosed="false" isExecutable="false" name="Essential and Important Entity" processType="None">
      <startEvent id="eie_s" name="Start">
         <outgoing>eie_sf1</outgoing>
      </startEvent>
      <exclusiveGateway id="eie_gw1_div" name="Assess incident severity" isMarkerVisible="true" gatewayDirection="Diverging">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements>
         <incoming>eie_sf1</incoming>
         <outgoing>eie_sf2_yes</outgoing>
         <outgoing>eie_sf2_no</outgoing>
      </exclusiveGateway>
      <task id="eie_t1" name="Notify CSIRT or CA">
         <incoming>eie_sf2_yes</incoming>
         <outgoing>eie_sf3</outgoing>
      </task>
      <exclusiveGateway id="eie_gw1_conv" isMarkerVisible="true" gatewayDirection="Converging">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements>
         <incoming>eie_sf3</incoming>
         <incoming>eie_sf2_no</incoming>
         <outgoing>eie_sf4</outgoing>
      </exclusiveGateway>
      <exclusiveGateway id="eie_gw2_div" name="Assess impact on services" isMarkerVisible="true" gatewayDirection="Diverging">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements>
         <incoming>eie_sf4</incoming>
         <outgoing>eie_sf5_yes</outgoing>
         <outgoing>eie_sf5_no</outgoing>
      </exclusiveGateway>
      <task id="eie_t2" name="Notify recipients of services">
         <incoming>eie_sf5_yes</incoming>
         <outgoing>eie_sf6</outgoing>
      </task>
      <exclusiveGateway id="eie_gw2_conv" isMarkerVisible="true" gatewayDirection="Converging">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements>
         <incoming>eie_sf6</incoming>
         <incoming>eie_sf5_no</incoming>
         <outgoing>eie_sf7</outgoing>
      </exclusiveGateway>
      <task id="eie_t3" name="Submit early warning">
         <incoming>eie_sf7</incoming>
         <outgoing>eie_sf8</outgoing>
      </task>
      <intermediateCatchEvent id="eie_e1" name="Receive request for intermediate report">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
         <incoming>eie_sf8</incoming>
         <outgoing>eie_sf9</outgoing>
         <messageEventDefinition id="med_eie_e1"/>
      </intermediateCatchEvent>
      <task id="eie_t4" name="Submit intermediate report">
         <incoming>eie_sf9</incoming>
         <outgoing>eie_sf10</outgoing>
      </task>
      <task id="eie_t5" name="Submit final report">
         <incoming>eie_sf10</incoming>
         <outgoing>eie_sf11</outgoing>
      </task>
      <exclusiveGateway id="eie_gw3_div" name="Request additional tech support" isMarkerVisible="true" gatewayDirection="Diverging">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements>
         <incoming>eie_sf11</incoming>
         <outgoing>eie_sf12_yes</outgoing>
         <outgoing>eie_sf12_no</outgoing>
      </exclusiveGateway>
      <task id="eie_t10" name="Request tech support">
         <incoming>eie_sf12_yes</incoming>
         <outgoing>eie_sf13</outgoing>
      </task>
      <exclusiveGateway id="eie_gw3_conv" isMarkerVisible="true" gatewayDirection="Converging">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements>
         <incoming>eie_sf13</incoming>
         <incoming>eie_sf12_no</incoming>
         <outgoing>eie_sf14</outgoing>
      </exclusiveGateway>
      <intermediateCatchEvent id="eie_e2" name="Receive request to inform public">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
         <incoming>eie_sf14</incoming>
         <outgoing>eie_sf15</outgoing>
         <messageEventDefinition id="med_eie_e2"/>
      </intermediateCatchEvent>
      <endEvent id="eie_end" name="Entity reporting completed">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
         <incoming>eie_sf15</incoming>
      </endEvent>

      <sequenceFlow id="eie_sf1" isImmediate="true" sourceRef="eie_s" targetRef="eie_gw1_div" />
      <sequenceFlow id="eie_sf2_yes" name="yes" isImmediate="true" sourceRef="eie_gw1_div" targetRef="eie_t1" />
      <sequenceFlow id="eie_sf2_no" name="no" isImmediate="true" sourceRef="eie_gw1_div" targetRef="eie_gw1_conv" />
      <sequenceFlow id="eie_sf3" isImmediate="true" sourceRef="eie_t1" targetRef="eie_gw1_conv" />
      <sequenceFlow id="eie_sf4" isImmediate="true" sourceRef="eie_gw1_conv" targetRef="eie_gw2_div" />
      <sequenceFlow id="eie_sf5_yes" name="yes" isImmediate="true" sourceRef="eie_gw2_div" targetRef="eie_t2" />
      <sequenceFlow id="eie_sf5_no" name="no" isImmediate="true" sourceRef="eie_gw2_div" targetRef="eie_gw2_conv" />
      <sequenceFlow id="eie_sf6" isImmediate="true" sourceRef="eie_t2" targetRef="eie_gw2_conv" />
      <sequenceFlow id="eie_sf7" isImmediate="true" sourceRef="eie_gw2_conv" targetRef="eie_t3" />
      <sequenceFlow id="eie_sf8" isImmediate="true" sourceRef="eie_t3" targetRef="eie_e1" />
      <sequenceFlow id="eie_sf9" isImmediate="true" sourceRef="eie_e1" targetRef="eie_t4" />
      <sequenceFlow id="eie_sf10" isImmediate="true" sourceRef="eie_t4" targetRef="eie_t5" />
      <sequenceFlow id="eie_sf11" isImmediate="true" sourceRef="eie_t5" targetRef="eie_gw3_div" />
      <sequenceFlow id="eie_sf12_yes" name="yes" isImmediate="true" sourceRef="eie_gw3_div" targetRef="eie_t10" />
      <sequenceFlow id="eie_sf12_no" name="no" isImmediate="true" sourceRef="eie_gw3_div" targetRef="eie_gw3_conv" />
      <sequenceFlow id="eie_sf13" isImmediate="true" sourceRef="eie_t10" targetRef="eie_gw3_conv" />
      <sequenceFlow id="eie_sf14" isImmediate="true" sourceRef="eie_gw3_conv" targetRef="eie_e2" />
      <sequenceFlow id="eie_sf15" isImmediate="true" sourceRef="eie_e2" targetRef="eie_end" />
   </process>

   <!-- 3. Trust Service Provider -->
   <process id="pr_tsp" isClosed="false" isExecutable="false" name="Trust Service Provider" processType="None">
      <startEvent id="tsp_s" name="Start">
         <outgoing>tsp_sf1</outgoing>
      </startEvent>
      <exclusiveGateway id="tsp_gw1_div" name="Assess impact" isMarkerVisible="true" gatewayDirection="Diverging">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements>
         <incoming>tsp_sf1</incoming>
         <outgoing>tsp_sf2_yes</outgoing>
         <outgoing>tsp_sf2_no</outgoing>
      </exclusiveGateway>
      <task id="tsp_t1" name="Notify CSIRT/CA">
         <incoming>tsp_sf2_yes</incoming>
         <outgoing>tsp_sf3</outgoing>
      </task>
      <exclusiveGateway id="tsp_gw1_conv" isMarkerVisible="true" gatewayDirection="Converging">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements>
         <incoming>tsp_sf3</incoming>
         <incoming>tsp_sf2_no</incoming>
         <outgoing>tsp_sf4</outgoing>
      </exclusiveGateway>
      <exclusiveGateway id="tsp_gw2_div" name="Request guidance" isMarkerVisible="true" gatewayDirection="Diverging">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements>
         <incoming>tsp_sf4</incoming>
         <outgoing>tsp_sf5_yes</outgoing>
         <outgoing>tsp_sf5_no</outgoing>
      </exclusiveGateway>
      <task id="tsp_t2" name="Request guidance">
         <incoming>tsp_sf5_yes</incoming>
         <outgoing>tsp_sf6</outgoing>
      </task>
      <exclusiveGateway id="tsp_gw2_conv" isMarkerVisible="true" gatewayDirection="Converging">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements>
         <incoming>tsp_sf6</incoming>
         <incoming>tsp_sf5_no</incoming>
         <outgoing>tsp_sf7</outgoing>
      </exclusiveGateway>
      <endEvent id="tsp_end" name="TSP completed">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
         <incoming>tsp_sf7</incoming>
      </endEvent>

      <sequenceFlow id="tsp_sf1" isImmediate="true" sourceRef="tsp_s" targetRef="tsp_gw1_div" />
      <sequenceFlow id="tsp_sf2_yes" name="yes" isImmediate="true" sourceRef="tsp_gw1_div" targetRef="tsp_t1" />
      <sequenceFlow id="tsp_sf2_no" name="no" isImmediate="true" sourceRef="tsp_gw1_div" targetRef="tsp_gw1_conv" />
      <sequenceFlow id="tsp_sf3" isImmediate="true" sourceRef="tsp_t1" targetRef="tsp_gw1_conv" />
      <sequenceFlow id="tsp_sf4" isImmediate="true" sourceRef="tsp_gw1_conv" targetRef="tsp_gw2_div" />
      <sequenceFlow id="tsp_sf5_yes" name="yes" isImmediate="true" sourceRef="tsp_gw2_div" targetRef="tsp_t2" />
      <sequenceFlow id="tsp_sf5_no" name="no" isImmediate="true" sourceRef="tsp_gw2_div" targetRef="tsp_gw2_conv" />
      <sequenceFlow id="tsp_sf6" isImmediate="true" sourceRef="tsp_t2" targetRef="tsp_gw2_conv" />
      <sequenceFlow id="tsp_sf7" isImmediate="true" sourceRef="tsp_gw2_conv" targetRef="tsp_end" />
   </process>

   <!-- 4. CSIRT -->
   <process id="pr_csirt" isClosed="false" isExecutable="false" name="CSIRT" processType="None">
      <startEvent id="csirt_s" name="Start">
         <outgoing>csirt_sf1</outgoing>
      </startEvent>
      <task id="csirt_t1" name="Determine cross-border impact">
         <incoming>csirt_sf1</incoming>
         <outgoing>csirt_sf2</outgoing>
      </task>
      <exclusiveGateway id="csirt_gw1_div" name="May request intermediate report" isMarkerVisible="true" gatewayDirection="Diverging">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements>
         <incoming>csirt_sf2</incoming>
         <outgoing>csirt_sf3_yes</outgoing>
         <outgoing>csirt_sf3_no</outgoing>
      </exclusiveGateway>
      <task id="csirt_t3" name="Request intermediate report">
         <incoming>csirt_sf3_yes</incoming>
         <outgoing>csirt_sf4</outgoing>
      </task>
      <exclusiveGateway id="csirt_gw1_conv" isMarkerVisible="true" gatewayDirection="Converging">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements>
         <incoming>csirt_sf4</incoming>
         <incoming>csirt_sf3_no</incoming>
         <outgoing>csirt_sf5</outgoing>
      </exclusiveGateway>
      <intermediateCatchEvent id="csirt_e1" name="Receive request for guidance">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
         <incoming>csirt_sf5</incoming>
         <outgoing>csirt_sf6</outgoing>
         <messageEventDefinition id="med_csirt_e1"/>
      </intermediateCatchEvent>
      <task id="csirt_t5" name="Provide guidance">
         <incoming>csirt_sf6</incoming>
         <outgoing>csirt_sf7</outgoing>
      </task>
      <intermediateCatchEvent id="csirt_e2" name="Receive request for tech support">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
         <incoming>csirt_sf7</incoming>
         <outgoing>csirt_sf8</outgoing>
         <messageEventDefinition id="med_csirt_e2"/>
      </intermediateCatchEvent>
      <task id="csirt_t6" name="Provide tech support">
         <incoming>csirt_sf8</incoming>
         <outgoing>csirt_sf9</outgoing>
      </task>
      <exclusiveGateway id="csirt_gw2_div" name="May require entity to inform public" isMarkerVisible="true" gatewayDirection="Diverging">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements>
         <incoming>csirt_sf9</incoming>
         <outgoing>csirt_sf10_yes</outgoing>
         <outgoing>csirt_sf10_no</outgoing>
      </exclusiveGateway>
      <task id="csirt_t12" name="Require entity to inform public">
         <incoming>csirt_sf10_yes</incoming>
         <outgoing>csirt_sf11</outgoing>
      </task>
      <exclusiveGateway id="csirt_gw2_conv" isMarkerVisible="true" gatewayDirection="Converging">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements>
         <incoming>csirt_sf11</incoming>
         <incoming>csirt_sf10_no</incoming>
         <outgoing>csirt_sf12</outgoing>
      </exclusiveGateway>
      <exclusiveGateway id="csirt_gw3_div" name="May request to forward notifications" isMarkerVisible="true" gatewayDirection="Diverging">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements>
         <incoming>csirt_sf12</incoming>
         <outgoing>csirt_sf13_yes</outgoing>
         <outgoing>csirt_sf13_no</outgoing>
      </exclusiveGateway>
      <task id="csirt_t13" name="Request to forward notifications">
         <incoming>csirt_sf13_yes</incoming>
         <outgoing>csirt_sf14</outgoing>
      </task>
      <exclusiveGateway id="csirt_gw3_conv" isMarkerVisible="true" gatewayDirection="Converging">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements>
         <incoming>csirt_sf14</incoming>
         <incoming>csirt_sf13_no</incoming>
         <outgoing>csirt_sf15</outgoing>
      </exclusiveGateway>
      <endEvent id="csirt_end" name="Incident handling completed">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
         <incoming>csirt_sf15</incoming>
      </endEvent>

      <sequenceFlow id="csirt_sf1" isImmediate="true" sourceRef="csirt_s" targetRef="csirt_t1" />
      <sequenceFlow id="csirt_sf2" isImmediate="true" sourceRef="csirt_t1" targetRef="csirt_gw1_div" />
      <sequenceFlow id="csirt_sf3_yes" name="yes" isImmediate="true" sourceRef="csirt_gw1_div" targetRef="csirt_t3" />
      <sequenceFlow id="csirt_sf3_no" name="no" isImmediate="true" sourceRef="csirt_gw1_div" targetRef="csirt_gw1_conv" />
      <sequenceFlow id="csirt_sf4" isImmediate="true" sourceRef="csirt_t3" targetRef="csirt_gw1_conv" />
      <sequenceFlow id="csirt_sf5" isImmediate="true" sourceRef="csirt_gw1_conv" targetRef="csirt_e1" />
      <sequenceFlow id="csirt_sf6" isImmediate="true" sourceRef="csirt_e1" targetRef="csirt_t5" />
      <sequenceFlow id="csirt_sf7" isImmediate="true" sourceRef="csirt_t5" targetRef="csirt_e2" />
      <sequenceFlow id="csirt_sf8" isImmediate="true" sourceRef="csirt_e2" targetRef="csirt_t6" />
      <sequenceFlow id="csirt_sf9" isImmediate="true" sourceRef="csirt_t6" targetRef="csirt_gw2_div" />
      <sequenceFlow id="csirt_sf10_yes" name="yes" isImmediate="true" sourceRef="csirt_gw2_div" targetRef="csirt_t12" />
      <sequenceFlow id="csirt_sf10_no" name="no" isImmediate="true" sourceRef="csirt_gw2_div" targetRef="csirt_gw2_conv" />
      <sequenceFlow id="csirt_sf11" isImmediate="true" sourceRef="csirt_t12" targetRef="csirt_gw2_conv" />
      <sequenceFlow id="csirt_sf12" isImmediate="true" sourceRef="csirt_gw2_conv" targetRef="csirt_gw3_div" />
      <sequenceFlow id="csirt_sf13_yes" name="yes" isImmediate="true" sourceRef="csirt_gw3_div" targetRef="csirt_t13" />
      <sequenceFlow id="csirt_sf13_no" name="no" isImmediate="true" sourceRef="csirt_gw3_div" targetRef="csirt_gw3_conv" />
      <sequenceFlow id="csirt_sf14" isImmediate="true" sourceRef="csirt_t13" targetRef="csirt_gw3_conv" />
      <sequenceFlow id="csirt_sf15" isImmediate="true" sourceRef="csirt_gw3_conv" targetRef="csirt_end" />
   </process>

   <!-- 5. Single Point of Contact -->
   <process id="pr_spoc" isClosed="false" isExecutable="false" name="Single Point of Contact" processType="None">
      <startEvent id="spoc_s" name="Start">
         <outgoing>spoc_sf1</outgoing>
      </startEvent>
      <intermediateCatchEvent id="spoc_e1" name="Receive request to forward">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
         <incoming>spoc_sf1</incoming>
         <outgoing>spoc_sf2</outgoing>
         <messageEventDefinition id="med_spoc_e1"/>
      </intermediateCatchEvent>
      <task id="spoc_t1" name="Forward notifications">
         <incoming>spoc_sf2</incoming>
         <outgoing>spoc_sf3</outgoing>
      </task>
      <task id="spoc_t2" name="Submit summary report">
         <incoming>spoc_sf3</incoming>
         <outgoing>spoc_sf4</outgoing>
      </task>
      <endEvent id="spoc_end" name="Reporting and forwarding completed">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
         <incoming>spoc_sf4</incoming>
      </endEvent>

      <sequenceFlow id="spoc_sf1" isImmediate="true" sourceRef="spoc_s" targetRef="spoc_e1" />
      <sequenceFlow id="spoc_sf2" isImmediate="true" sourceRef="spoc_e1" targetRef="spoc_t1" />
      <sequenceFlow id="spoc_sf3" isImmediate="true" sourceRef="spoc_t1" targetRef="spoc_t2" />
      <sequenceFlow id="spoc_sf4" isImmediate="true" sourceRef="spoc_t2" targetRef="spoc_end" />
   </process>

   <!-- 6. ENISA -->
