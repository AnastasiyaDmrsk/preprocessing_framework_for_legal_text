      <sequenceFlow id="sid-sa-e11" isImmediate="true" name="yes" sourceRef="sid-sa-gw-para3-div" targetRef="sid-sa-gw-para3-conv"/>
      <sequenceFlow id="sid-sa-e12" isImmediate="true" name="no" sourceRef="sid-sa-gw-para3-div" targetRef="sid-sa-task-require"/>
      <sequenceFlow id="sid-sa-e13" isImmediate="true" name="" sourceRef="sid-sa-task-require" targetRef="sid-sa-gw-para3-conv"/>
