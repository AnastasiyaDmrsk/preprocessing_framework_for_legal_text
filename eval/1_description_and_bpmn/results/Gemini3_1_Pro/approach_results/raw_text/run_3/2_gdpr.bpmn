<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" 
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" 
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" 
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" 
             xmlns:signavio="http://www.signavio.com" 
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
             exporter="Signavio Process Editor, http://www.signavio.com" 
             exporterVersion="19.2.2" 
             expressionLanguage="http://www.w3.org/TR/XPath" 
             id="sid-data-breach-process" 
             targetNamespace="http://www.signavio.com" 
             typeLanguage="http://www.w3.org/2001/XMLSchema" 
             xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd">
             
   <collaboration id="sid-collaboration">
      <participant id="sid-pool-proc" name="Processor" processRef="sid-process-proc">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffff"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
      </participant>
      <participant id="sid-pool-cont" name="Controller" processRef="sid-process-cont">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffff"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
      </participant>
      <participant id="sid-pool-sa" name="Supervisory Authority" processRef="sid-process-sa">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffff"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
      </participant>
      <messageFlow id="sid-msg-1" name="Notification of personal data breach" sourceRef="sid-proc-task1" targetRef="sid-cont-start">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
      </messageFlow>
      <messageFlow id="sid-msg-2" name="Notification to SA" sourceRef="sid-cont-task-notify" targetRef="sid-sa-start">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
      </messageFlow>
   </collaboration>

   <!-- PROCESSOR PROCESS -->
   <process id="sid-process-proc" isClosed="false" isExecutable="false" name="Processor" processType="None">
      <laneSet id="sid-laneset-proc">
         <lane id="sid-lane-proc">
            <extensionElements>
               <signavio:signavioMetaData metaKey="bgcolor" metaValue=""/>
               <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            </extensionElements>
            <flowNodeRef>sid-proc-start</flowNodeRef>
            <flowNodeRef>sid-proc-task1</flowNodeRef>
            <flowNodeRef>sid-proc-end</flowNodeRef>
         </lane>
      </laneSet>
      
      <startEvent id="sid-proc-start" name="Start after becoming aware of a personal data breach">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffff"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/>
         </extensionElements>
         <outgoing>sid-proc-e1</outgoing>
      </startEvent>
      <task completionQuantity="1" id="sid-proc-task1" isForCompensation="false" name="notify the controller of a personal data breach" startQuantity="1">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffcc"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <incoming>sid-proc-e1</incoming>
         <outgoing>sid-proc-e2</outgoing>
      </task>
      <endEvent id="sid-proc-end" name="breach notification sent end event">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffff"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioLabel bottom="true" left="false" ref="text_name" right="false" top="false" valign="top" x="15.0" y="38.0"/>
         </extensionElements>
         <incoming>sid-proc-e2</incoming>
      </endEvent>
      
      <sequenceFlow id="sid-proc-e1" isImmediate="true" name="" sourceRef="sid-proc-start" targetRef="sid-proc-task1"/>
      <sequenceFlow id="sid-proc-e2" isImmediate="true" name="" sourceRef="sid-proc-task1" targetRef="sid-proc-end"/>
   </process>

   <!-- CONTROLLER PROCESS -->
   <process id="sid-process-cont" isClosed="false" isExecutable="false" name="Controller" processType="None">
      <laneSet id="sid-laneset-cont">
         <lane id="sid-lane-cont">
            <extensionElements>
               <signavio:signavioMetaData metaKey="bgcolor" metaValue=""/>
               <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            </extensionElements>
            <flowNodeRef>sid-cont-start</flowNodeRef>
            <flowNodeRef>sid-cont-gw-risk-div</flowNodeRef>
            <flowNodeRef>sid-cont-task-notify</flowNodeRef>
            <flowNodeRef>sid-cont-gw-risk-conv</flowNodeRef>
            <flowNodeRef>sid-cont-task-assess72</flowNodeRef>
            <flowNodeRef>sid-cont-gw-72h-div</flowNodeRef>
            <flowNodeRef>sid-cont-task-reasons</flowNodeRef>
            <flowNodeRef>sid-cont-gw-72h-conv</flowNodeRef>
            <flowNodeRef>sid-cont-gw-info-div</flowNodeRef>
            <flowNodeRef>sid-cont-task-info</flowNodeRef>
            <flowNodeRef>sid-cont-gw-info-conv</flowNodeRef>
            <flowNodeRef>sid-cont-task-doc</flowNodeRef>
            <flowNodeRef>sid-cont-task-assessrisk</flowNodeRef>
            <flowNodeRef>sid-cont-gw-highrisk-div</flowNodeRef>
            <flowNodeRef>sid-cont-task-assess-effort</flowNodeRef>
            <flowNodeRef>sid-cont-gw-effort-div</flowNodeRef>
            <flowNodeRef>sid-cont-gw-perf-div</flowNodeRef>
            <flowNodeRef>sid-cont-task-public</flowNodeRef>
            <flowNodeRef>sid-cont-gw-perf-conv</flowNodeRef>
            <flowNodeRef>sid-cont-gw-prot-div</flowNodeRef>
            <flowNodeRef>sid-cont-task-comm</flowNodeRef>
            <flowNodeRef>sid-cont-gw-prot-conv</flowNodeRef>
            <flowNodeRef>sid-cont-gw-effort-conv</flowNodeRef>
            <flowNodeRef>sid-cont-gw-highrisk-conv</flowNodeRef>
            <flowNodeRef>sid-cont-end</flowNodeRef>
         </lane>
      </laneSet>
      
      <startEvent id="sid-cont-start" isInterrupting="true" name="Start in the case of any personal data breach">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffff"/>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/>
         </extensionElements>
         <outgoing>sid-cont-e1</outgoing>
         <messageEventDefinition id="sid-msgdef-cont"/>
      </startEvent>

      <exclusiveGateway gatewayDirection="Diverging" id="sid-cont-gw-risk-div" isMarkerVisible="true" name="unlikely to result in a risk?">
         <extensionElements><signavio:signavioLabel bottom="true" left="false" ref="text_name" right="false" top="false" valign="top" x="20.0" y="45.0"/></extensionElements>
         <incoming>sid-cont-e1</incoming>
         <outgoing>sid-cont-e2</outgoing>
         <outgoing>sid-cont-e3</outgoing>
      </exclusiveGateway>

      <task id="sid-cont-task-notify" name="notify the personal data breach to the supervisory authority not later than 72 hours after having become aware of it">
         <extensionElements><signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffcc"/></extensionElements>
         <incoming>sid-cont-e2</incoming>
         <outgoing>sid-cont-e4</outgoing>
      </task>

      <exclusiveGateway gatewayDirection="Converging" id="sid-cont-gw-risk-conv" isMarkerVisible="true" name="">
         <incoming>sid-cont-e3</incoming>
         <incoming>sid-cont-e4</incoming>
         <outgoing>sid-cont-e5</outgoing>
      </exclusiveGateway>

      <task id="sid-cont-task-assess72" name="assess whether the notification is not made within 72 hours after having become aware">
         <extensionElements><signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffcc"/></extensionElements>
         <incoming>sid-cont-e5</incoming>
         <outgoing>sid-cont-e6</outgoing>
      </task>

      <exclusiveGateway gatewayDirection="Diverging" id="sid-cont-gw-72h-div" isMarkerVisible="true" name="not made within 72h?">
         <extensionElements><signavio:signavioLabel bottom="true" left="false" ref="text_name" right="false" top="false" valign="top" x="20.0" y="45.0"/></extensionElements>
         <incoming>sid-cont-e6</incoming>
         <outgoing>sid-cont-e7</outgoing>
         <outgoing>sid-cont-e8</outgoing>
      </exclusiveGateway>

      <task id="sid-cont-task-reasons" name="accompany the notification with reasons for the delay">
         <extensionElements><signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffcc"/></extensionElements>
         <incoming>sid-cont-e7</incoming>
         <outgoing>sid-cont-e9</outgoing>
      </task>

      <exclusiveGateway gatewayDirection="Converging" id="sid-cont-gw-72h-conv" isMarkerVisible="true" name="">
         <incoming>sid-cont-e8</incoming>
         <incoming>sid-cont-e9</incoming>
         <outgoing>sid-cont-e10</outgoing>
      </exclusiveGateway>

      <exclusiveGateway gatewayDirection="Diverging" id="sid-cont-gw-info-div" isMarkerVisible="true" name="not possible to provide all info?">
         <extensionElements><signavio:signavioLabel bottom="true" left="false" ref="text_name" right="false" top="false" valign="top" x="20.0" y="45.0"/></extensionElements>
         <incoming>sid-cont-e10</incoming>
         <outgoing>sid-cont-e11</outgoing>
         <outgoing>sid-cont-e12</outgoing>
      </exclusiveGateway>

      <task id="sid-cont-task-info" name="provide the information">
         <extensionElements><signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffcc"/></extensionElements>
         <incoming>sid-cont-e11</incoming>
         <outgoing>sid-cont-e13</outgoing>
      </task>

      <exclusiveGateway gatewayDirection="Converging" id="sid-cont-gw-info-conv" isMarkerVisible="true" name="">
         <incoming>sid-cont-e12</incoming>
         <incoming>sid-cont-e13</incoming>
         <outgoing>sid-cont-e14</outgoing>
      </exclusiveGateway>

      <task id="sid-cont-task-doc" name="document any personal data breaches">
         <extensionElements><signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffcc"/></extensionElements>
         <incoming>sid-cont-e14</incoming>
         <outgoing>sid-cont-e15</outgoing>
      </task>

      <task id="sid-cont-task-assessrisk" name="assess whether the data breach is likely to result in a high risk to the rights and freedoms of natural persons">
         <extensionElements><signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffcc"/></extensionElements>
         <incoming>sid-cont-e15</incoming>
         <outgoing>sid-cont-e16</outgoing>
      </task>

      <exclusiveGateway gatewayDirection="Diverging" id="sid-cont-gw-highrisk-div" isMarkerVisible="true" name="likely high risk?">
         <extensionElements><signavio:signavioLabel bottom="true" left="false" ref="text_name" right="false" top="false" valign="top" x="20.0" y="45.0"/></extensionElements>
         <incoming>sid-cont-e16</incoming>
         <outgoing>sid-cont-e17</outgoing>
         <outgoing>sid-cont-e18</outgoing>
      </exclusiveGateway>

      <task id="sid-cont-task-assess-effort" name="assess whether communication would involve disproportionate effort">
         <extensionElements><signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffcc"/></extensionElements>
         <incoming>sid-cont-e17</incoming>
         <outgoing>sid-cont-e19</outgoing>
      </task>

      <exclusiveGateway gatewayDirection="Diverging" id="sid-cont-gw-effort-div" isMarkerVisible="true" name="disproportionate effort?">
         <extensionElements><signavio:signavioLabel bottom="true" left="false" ref="text_name" right="false" top="false" valign="top" x="20.0" y="45.0"/></extensionElements>
         <incoming>sid-cont-e19</incoming>
         <outgoing>sid-cont-e20</outgoing>
         <outgoing>sid-cont-e21</outgoing>
      </exclusiveGateway>

      <exclusiveGateway gatewayDirection="Diverging" id="sid-cont-gw-perf-div" isMarkerVisible="true" name="communicated instead?">
         <extensionElements><signavio:signavioLabel bottom="true" left="false" ref="text_name" right="false" top="false" valign="top" x="20.0" y="45.0"/></extensionElements>
         <incoming>sid-cont-e20</incoming>
         <outgoing>sid-cont-e22</outgoing>
         <outgoing>sid-cont-e23</outgoing>
      </exclusiveGateway>

      <task id="sid-cont-task-public" name="carry out a public communication or similar measure">
         <extensionElements><signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffcc"/></extensionElements>
         <incoming>sid-cont-e22</incoming>
         <outgoing>sid-cont-e24</outgoing>
      </task>

      <exclusiveGateway gatewayDirection="Converging" id="sid-cont-gw-perf-conv" isMarkerVisible="true" name="">
         <incoming>sid-cont-e23</incoming>
         <incoming>sid-cont-e24</incoming>
         <outgoing>sid-cont-e25</outgoing>
      </exclusiveGateway>

      <exclusiveGateway gatewayDirection="Diverging" id="sid-cont-gw-prot-div" isMarkerVisible="true" name="protection measures applied?">
         <extensionElements><signavio:signavioLabel bottom="true" left="false" ref="text_name" right="false" top="false" valign="top" x="20.0" y="45.0"/></extensionElements>
         <incoming>sid-cont-e21</incoming>
         <outgoing>sid-cont-e26</outgoing>
         <outgoing>sid-cont-e27</outgoing>
      </exclusiveGateway>

      <task id="sid-cont-task-comm" name="communicate the personal data breach to the data subject">
         <extensionElements><signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffcc"/></extensionElements>
         <incoming>sid-cont-e26</incoming>
         <outgoing>sid-cont-e28</outgoing>
      </task>

      <exclusiveGateway gatewayDirection="Converging" id="sid-cont-gw-prot-conv" isMarkerVisible="true" name="">
         <incoming>sid-cont-e27</incoming>
         <incoming>sid-cont-e28</incoming>
         <outgoing>sid-cont-e29</outgoing>
      </exclusiveGateway>

      <exclusiveGateway gatewayDirection="Converging" id="sid-cont-gw-effort-conv" isMarkerVisible="true" name="">
         <incoming>sid-cont-e25</incoming>
         <incoming>sid-cont-e29</incoming>
         <outgoing>sid-cont-e30</outgoing>
      </exclusiveGateway>

      <exclusiveGateway gatewayDirection="Converging" id="sid-cont-gw-highrisk-conv" isMarkerVisible="true" name="">
         <incoming>sid-cont-e18</incoming>
         <incoming>sid-cont-e30</incoming>
         <outgoing>sid-cont-e31</outgoing>
      </exclusiveGateway>

      <endEvent id="sid-cont-end" name="data breach handled end event">
         <extensionElements><signavio:signavioLabel bottom="true" left="false" ref="text_name" right="false" top="false" valign="top" x="15.0" y="38.0"/></extensionElements>
         <incoming>sid-cont-e31</incoming>
      </endEvent>

      <sequenceFlow id="sid-cont-e1" isImmediate="true" name="" sourceRef="sid-cont-start" targetRef="sid-cont-gw-risk-div"/>
      <sequenceFlow id="sid-cont-e2" isImmediate="true" name="no" sourceRef="sid-cont-gw-risk-div" targetRef="sid-cont-task-notify"/>
      <sequenceFlow id="sid-cont-e3" isImmediate="true" name="yes" sourceRef="sid-cont-gw-risk-div" targetRef="sid-cont-gw-risk-conv"/>
      <sequenceFlow id="sid-cont-e4" isImmediate="true" name="" sourceRef="sid-cont-task-notify" targetRef="sid-cont-gw-risk-conv"/>
      <sequenceFlow id="sid-cont-e5" isImmediate="true" name="" sourceRef="sid-cont-gw-risk-conv" targetRef="sid-cont-task-assess72"/>
      <sequenceFlow id="sid-cont-e6" isImmediate="true" name="" sourceRef="sid-cont-task-assess72" targetRef="sid-cont-gw-72h-div"/>
      <sequenceFlow id="sid-cont-e7" isImmediate="true" name="yes" sourceRef="sid-cont-gw-72h-div" targetRef="sid-cont-task-reasons"/>
      <sequenceFlow id="sid-cont-e8" isImmediate="true" name="no" sourceRef="sid-cont-gw-72h-div" targetRef="sid-cont-gw-72h-conv"/>
      <sequenceFlow id="sid-cont-e9" isImmediate="true" name="" sourceRef="sid-cont-task-reasons" targetRef="sid-cont-gw-72h-conv"/>
      <sequenceFlow id="sid-cont-e10" isImmediate="true" name="" sourceRef="sid-cont-gw-72h-conv" targetRef="sid-cont-gw-info-div"/>
      <sequenceFlow id="sid-cont-e11" isImmediate="true" name="yes" sourceRef="sid-cont-gw-info-div" targetRef="sid-cont-task-info"/>
      <sequenceFlow id="sid-cont-e12" isImmediate="true" name="no" sourceRef="sid-cont-gw-info-div" targetRef="sid-cont-gw-info-conv"/>
      <sequenceFlow id="sid-cont-e13" isImmediate="true" name="" sourceRef="sid-cont-task-info" targetRef="sid-cont-gw-info-conv"/>
      <sequenceFlow id="sid-cont-e14" isImmediate="true" name="" sourceRef="sid-cont-gw-info-conv" targetRef="sid-cont-task-doc"/>
      <sequenceFlow id="sid-cont-e15" isImmediate="true" name="" sourceRef="sid-cont-task-doc" targetRef="sid-cont-task-assessrisk"/>
      <sequenceFlow id="sid-cont-e16" isImmediate="true" name="" sourceRef="sid-cont-task-assessrisk" targetRef="sid-cont-gw-highrisk-div"/>
      <sequenceFlow id="sid-cont-e17" isImmediate="true" name="yes" sourceRef="sid-cont-gw-highrisk-div" targetRef="sid-cont-task-assess-effort"/>
      <sequenceFlow id="sid-cont-e18" isImmediate="true" name="no" sourceRef="sid-cont-gw-highrisk-div" targetRef="sid-cont-gw-highrisk-conv"/>
      <sequenceFlow id="sid-cont-e19" isImmediate="true" name="" sourceRef="sid-cont-task-assess-effort" targetRef="sid-cont-gw-effort-div"/>
      <sequenceFlow id="sid-cont-e20" isImmediate="true" name="yes" sourceRef="sid-cont-gw-effort-div" targetRef="sid-cont-gw-perf-div"/>
      <sequenceFlow id="sid-cont-e21" isImmediate="true" name="no" sourceRef="sid-cont-gw-effort-div" targetRef="sid-cont-gw-prot-div"/>
      <sequenceFlow id="sid-cont-e22" isImmediate="true" name="no" sourceRef="sid-cont-gw-perf-div" targetRef="sid-cont-task-public"/>
      <sequenceFlow id="sid-cont-e23" isImmediate="true" name="yes" sourceRef="sid-cont-gw-perf-div" targetRef="sid-cont-gw-perf-conv"/>
      <sequenceFlow id="sid-cont-e24" isImmediate="true" name="" sourceRef="sid-cont-task-public" targetRef="sid-cont-gw-perf-conv"/>
      <sequenceFlow id="sid-cont-e25" isImmediate="true" name="" sourceRef="sid-cont-gw-perf-conv" targetRef="sid-cont-gw-effort-conv"/>
      <sequenceFlow id="sid-cont-e26" isImmediate="true" name="no" sourceRef="sid-cont-gw-prot-div" targetRef="sid-cont-task-comm"/>
      <sequenceFlow id="sid-cont-e27" isImmediate="true" name="yes" sourceRef="sid-cont-gw-prot-div" targetRef="sid-cont-gw-prot-conv"/>
      <sequenceFlow id="sid-cont-e28" isImmediate="true" name="" sourceRef="sid-cont-task-comm" targetRef="sid-cont-gw-prot-conv"/>
      <sequenceFlow id="sid-cont-e29" isImmediate="true" name="" sourceRef="sid-cont-gw-prot-conv" targetRef="sid-cont-gw-effort-conv"/>
      <sequenceFlow id="sid-cont-e30" isImmediate="true" name="" sourceRef="sid-cont-gw-effort-conv" targetRef="sid-cont-gw-highrisk-conv"/>
      <sequenceFlow id="sid-cont-e31" isImmediate="true" name="" sourceRef="sid-cont-gw-highrisk-conv" targetRef="sid-cont-end"/>
   </process>

   <!-- SUPERVISORY AUTHORITY PROCESS -->
   <process id="sid-process-sa" isClosed="false" isExecutable="false" name="Supervisory Authority" processType="None">
      <laneSet id="sid-laneset-sa">
         <lane id="sid-lane-sa">
            <extensionElements>
               <signavio:signavioMetaData metaKey="bgcolor" metaValue=""/>
               <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            </extensionElements>
            <flowNodeRef>sid-sa-start</flowNodeRef>
            <flowNodeRef>sid-sa-task-verify</flowNodeRef>
            <flowNodeRef>sid-sa-task-assess</flowNodeRef>
            <flowNodeRef>sid-sa-gw-highrisk-div</flowNodeRef>
            <flowNodeRef>sid-sa-task-consider</flowNodeRef>
            <flowNodeRef>sid-sa-gw-decide-div</flowNodeRef>
            <flowNodeRef>sid-sa-task-decide</flowNodeRef>
            <flowNodeRef>sid-sa-gw-decide-conv</flowNodeRef>
            <flowNodeRef>sid-sa-gw-para3-div</flowNodeRef>
            <flowNodeRef>sid-sa-task-require</flowNodeRef>
            <flowNodeRef>sid-sa-gw-para3-conv</flowNodeRef>
            <flowNodeRef>sid-sa-gw-highrisk-conv</flowNodeRef>
            <flowNodeRef>sid-sa-end</flowNodeRef>
         </lane>
      </laneSet>
      
      <startEvent id="sid-sa-start" isInterrupting="true" name="Start upon receiving notification">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffff"/>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/>
         </extensionElements>
         <outgoing>sid-sa-e1</outgoing>
         <messageEventDefinition id="sid-msgdef-sa"/>
      </startEvent>

      <task id="sid-sa-task-verify" name="verify compliance">
         <extensionElements><signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffcc"/></extensionElements>
         <incoming>sid-sa-e1</incoming>
         <outgoing>sid-sa-e2</outgoing>
      </task>

      <task id="sid-sa-task-assess" name="assess whether the controller has not already communicated and if the personal data breach is likely a high risk to the rights and freedoms of natural persons">
         <extensionElements><signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffcc"/></extensionElements>
         <incoming>sid-sa-e2</incoming>
         <outgoing>sid-sa-e3</outgoing>
      </task>

      <exclusiveGateway gatewayDirection="Diverging" id="sid-sa-gw-highrisk-div" isMarkerVisible="true" name="not communicated &amp; high risk?">
         <extensionElements><signavio:signavioLabel bottom="true" left="false" ref="text_name" right="false" top="false" valign="top" x="20.0" y="45.0"/></extensionElements>
         <incoming>sid-sa-e3</incoming>
         <outgoing>sid-sa-e4</outgoing>
         <outgoing>sid-sa-e5</outgoing>
      </exclusiveGateway>

      <task id="sid-sa-task-consider" name="consider the likelihood of the data breach resulting in a high risk">
         <extensionElements><signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffcc"/></extensionElements>
         <incoming>sid-sa-e4</incoming>
         <outgoing>sid-sa-e6</outgoing>
      </task>

      <exclusiveGateway gatewayDirection="Diverging" id="sid-sa-gw-decide-div" isMarkerVisible="true" name="conditions met?">
         <extensionElements><signavio:signavioLabel bottom="true" left="false" ref="text_name" right="false" top="false" valign="top" x="20.0" y="45.0"/></extensionElements>
         <incoming>sid-sa-e6</incoming>
         <outgoing>sid-sa-e7</outgoing>
         <outgoing>sid-sa-e8</outgoing>
      </exclusiveGateway>

      <task id="sid-sa-task-decide" name="decide that any of the conditions are met">
         <extensionElements><signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffcc"/></extensionElements>
         <incoming>sid-sa-e7</incoming>
         <outgoing>sid-sa-e9</outgoing>
      </task>

      <exclusiveGateway gatewayDirection="Converging" id="sid-sa-gw-decide-conv" isMarkerVisible="true" name="">
         <incoming>sid-sa-e8</incoming>
         <incoming>sid-sa-e9</incoming>
         <outgoing>sid-sa-e10</outgoing>
      </exclusiveGateway>

      <exclusiveGateway gatewayDirection="Diverging" id="sid-sa-gw-para3-div" isMarkerVisible="true" name="conditions in para 3 met?">
         <extensionElements><signavio:signavioLabel bottom="true" left="false" ref="text_name" right="false" top="false" valign="top" x="20.0" y="45.0"/></extensionElements>
         <incoming>sid-sa-e10</incoming>
         <outgoing>sid-sa-e11</outgoing>
         <outgoing>sid-sa-e12</outgoing>
      </exclusiveGateway>

      <task id="sid-sa-task-require" name="require the controller to communicate the data breach to the data subject">
         <extensionElements><signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffcc"/></extensionElements>
         <incoming>sid-sa-e12</incoming>
         <outgoing>sid-sa-e13</outgoing>
      </task>

      <exclusiveGateway gatewayDirection="Converging" id="sid-sa-gw-para3-conv" isMarkerVisible="true" name="">
         <incoming>sid-sa-e11</incoming>
         <incoming>sid-sa-e13</incoming>
         <outgoing>sid-sa-e14</outgoing>
      </exclusiveGateway>

      <exclusiveGateway gatewayDirection="Converging" id="sid-sa-gw-highrisk-conv" isMarkerVisible="true" name="">
         <incoming>sid-sa-e5</incoming>
         <incoming>sid-sa-e14</incoming>
         <outgoing>sid-sa-e15</outgoing>
      </exclusiveGateway>

      <endEvent id="sid-sa-end" name="compliance verified end event">
         <extensionElements><signavio:signavioLabel bottom="true" left="false" ref="text_name" right="false" top="false" valign="top" x="15.0" y="38.0"/></extensionElements>
         <incoming>sid-sa-e15</incoming>
      </endEvent>

