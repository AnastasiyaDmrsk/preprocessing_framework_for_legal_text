   <process id="process_qtsp" isClosed="false" isExecutable="false" name="Qualified Trust Service Provider or Non-qualified Trust Service Provider" processType="None">
      <startEvent id="qtsp_start" name="Start" />
      <exclusiveGateway id="qtsp_gw1_div" gatewayDirection="Diverging" isMarkerVisible="true" name="assess whether required by supervisory body" />
      <task id="qtsp_task1" name="remedy failures to fulfil requirements" />
      <exclusiveGateway id="qtsp_gw2_conv" gatewayDirection="Converging" isMarkerVisible="true" />
      <task id="qtsp_task2" name="take appropriate technical and organisational measures to manage the risks" />
      <task id="qtsp_task3" name="take measures to prevent and minimise the impact of security incidents" />
      <task id="qtsp_task4" name="inform stakeholders of the adverse effects of any security incidents" />
      <exclusiveGateway id="qtsp_gw3_div" gatewayDirection="Diverging" isMarkerVisible="true" name="assess whether the breach of security or loss of integrity has a significant impact on the trust service provided or on the personal data" />
      <task id="qtsp_task5" name="notify the supervisory body and other relevant bodies" />
      <exclusiveGateway id="qtsp_gw4_conv" gatewayDirection="Converging" isMarkerVisible="true" />
      <exclusiveGateway id="qtsp_gw5_div" gatewayDirection="Diverging" isMarkerVisible="true" name="assess whether the breach of security or loss of integrity has a significant impact on the trust service provided or on the personal data" />
      <task id="qtsp_task6" name="notify the natural or legal person" />
      <exclusiveGateway id="qtsp_gw6_conv" gatewayDirection="Converging" isMarkerVisible="true" />
      <exclusiveGateway id="qtsp_gw7_div" gatewayDirection="Diverging" isMarkerVisible="true" name="assess whether in the public interest" />
      <task id="qtsp_task7" name="inform the public about the breach of security or loss of integrity" />
      <exclusiveGateway id="qtsp_gw8_conv" gatewayDirection="Converging" isMarkerVisible="true" />
      <endEvent id="qtsp_end" name="compliance and incident management completed" />

