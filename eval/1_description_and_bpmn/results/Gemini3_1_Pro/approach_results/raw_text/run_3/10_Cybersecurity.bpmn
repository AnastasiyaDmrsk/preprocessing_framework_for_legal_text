<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" 
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" 
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" 
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" 
             xmlns:signavio="http://www.signavio.com" 
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
             exporter="Signavio Process Editor" 
             exporterVersion="19.2.2" 
             id="sid-main" 
             targetNamespace="http://www.signavio.com" 
             xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd">
   <collaboration id="collab_1">
      <participant id="Participant_Commission" name="Commission" processRef="Process_Commission"/>
      <participant id="Participant_ECCG" name="ECCG" processRef="Process_ECCG"/>
      <participant id="Participant_ENISA" name="ENISA" processRef="Process_ENISA"/>
      <participant id="Participant_IP" name="Interested Party" processRef="Process_IP"/>
      
      <messageFlow id="m_c_to_enisa" sourceRef="c_transmit" targetRef="en_start"/>
      <messageFlow id="m_e_to_enisa" sourceRef="e_transmit" targetRef="en_start"/>
      <messageFlow id="m_enisa_to_c" sourceRef="en_transmit_cand" targetRef="c_catch_scheme"/>
      <messageFlow id="m_enisa_to_e" sourceRef="en_coop" targetRef="e_catch_notif"/>
      <messageFlow id="m_e_to_enisa_op" sourceRef="e_transmit_opinion" targetRef="en_catch_opinion"/>
      <messageFlow id="m_c_to_enisa_rev" sourceRef="c_transmit_revise" targetRef="en_catch_rev_req"/>
      <messageFlow id="m_e_to_enisa_rev" sourceRef="e_transmit_revise" targetRef="en_catch_rev_req"/>
      <!-- Target participant when no specific receiving element exists -->
      <messageFlow id="m_ip_to_enisa" sourceRef="ip_transmit" targetRef="Participant_ENISA"/>
   </collaboration>

   <process id="Process_Commission" isClosed="false" isExecutable="true" name="Commission" processType="None">
      <startEvent id="c_start" name="identification of a need for a new or reviewed European cybersecurity certification scheme">
         <outgoing>c_sf_1</outgoing>
      </startEvent>
      <task id="c_assess_1" name="assess whether the scheme is on the basis of the Union rolling work programme">
         <incoming>c_sf_1</incoming>
         <outgoing>c_sf_2</outgoing>
      </task>
      <exclusiveGateway id="c_gw_1_div" gatewayDirection="Diverging" isMarkerVisible="true" name="Is on the basis?">
         <incoming>c_sf_2</incoming>
         <outgoing>c_sf_gw1_y</outgoing>
         <outgoing>c_sf_gw1_n</outgoing>
      </exclusiveGateway>
      
      <task id="c_req_prep" name="request ENISA to prepare a candidate cybersecurity certification scheme">
         <incoming>c_sf_gw1_y</incoming>
         <outgoing>c_sf_3</outgoing>
      </task>
      <task id="c_req_rev" name="request ENISA to review an existing European cybersecurity certification scheme">
         <incoming>c_sf_3</incoming>
         <outgoing>c_sf_4</outgoing>
      </task>
      
      <task id="c_assess_2" name="assess whether the scheme is in duly justified cases and not included in programme">
         <incoming>c_sf_gw1_n</incoming>
         <outgoing>c_sf_5</outgoing>
      </task>
      <exclusiveGateway id="c_gw_2_div" gatewayDirection="Diverging" isMarkerVisible="true" name="In justified cases?">
         <incoming>c_sf_5</incoming>
         <outgoing>c_sf_gw2_y</outgoing>
         <outgoing>c_sf_gw2_n</outgoing>
      </exclusiveGateway>
      <task id="c_req_prep_2" name="request ENISA to prepare a candidate cybersecurity certification scheme">
         <incoming>c_sf_gw2_y</incoming>
         <outgoing>c_sf_6</outgoing>
      </task>
      <task id="c_req_rev_2" name="request ENISA to review an existing European cybersecurity certification scheme">
         <incoming>c_sf_6</incoming>
         <outgoing>c_sf_7</outgoing>
      </task>
      <task id="c_update_prog" name="update the Union rolling work programme">
         <incoming>c_sf_7</incoming>
         <outgoing>c_sf_8</outgoing>
      </task>
      
      <exclusiveGateway id="c_gw_1_conv" gatewayDirection="Converging" isMarkerVisible="true" name="Merge paths">
         <incoming>c_sf_4</incoming>
         <incoming>c_sf_8</incoming>
         <incoming>c_sf_gw2_n</incoming>
         <outgoing>c_sf_9</outgoing>
      </exclusiveGateway>
      
      <task id="c_transmit" name="transmit the request to ENISA">
         <incoming>c_sf_9</incoming>
         <outgoing>c_sf_10</outgoing>
      </task>
      <intermediateCatchEvent id="c_catch_scheme" name="Upon receiving the candidate scheme">
         <incoming>c_sf_10</incoming>
         <outgoing>c_sf_11</outgoing>
         <messageEventDefinition id="msg_def_c_1"/>
      </intermediateCatchEvent>
      <task id="c_adopt" name="adopt implementing acts">
         <incoming>c_sf_11</incoming>
         <outgoing>c_sf_12</outgoing>
      </task>
      
      <exclusiveGateway id="c_gw_3_div" gatewayDirection="Diverging" isMarkerVisible="true" name="If necessary?">
         <incoming>c_sf_12</incoming>
         <outgoing>c_sf_gw3_y</outgoing>
         <outgoing>c_sf_gw3_n</outgoing>
      </exclusiveGateway>
      <task id="c_req_revise" name="request ENISA to start the process of developing a revised candidate scheme">
         <incoming>c_sf_gw3_y</incoming>
         <outgoing>c_sf_13</outgoing>
      </task>
      <task id="c_transmit_revise" name="transmit the request for a revised candidate scheme to ENISA">
         <incoming>c_sf_13</incoming>
         <outgoing>c_sf_14</outgoing>
      </task>
      
      <exclusiveGateway id="c_gw_3_conv" gatewayDirection="Converging" isMarkerVisible="true" name="Merge Revise">
         <incoming>c_sf_14</incoming>
         <incoming>c_sf_gw3_n</incoming>
         <outgoing>c_sf_15</outgoing>
      </exclusiveGateway>
      <endEvent id="c_end" name="scheme adoption or revision request end event">
         <incoming>c_sf_15</incoming>
      </endEvent>

      <sequenceFlow id="c_sf_1" isImmediate="true" sourceRef="c_start" targetRef="c_assess_1"/>
      <sequenceFlow id="c_sf_2" isImmediate="true" sourceRef="c_assess_1" targetRef="c_gw_1_div"/>
      <sequenceFlow id="c_sf_gw1_y" isImmediate="true" name="yes" sourceRef="c_gw_1_div" targetRef="c_req_prep"/>
      <sequenceFlow id="c_sf_gw1_n" isImmediate="true" name="no" sourceRef="c_gw_1_div" targetRef="c_assess_2"/>
      <sequenceFlow id="c_sf_3" isImmediate="true" sourceRef="c_req_prep" targetRef="c_req_rev"/>
      <sequenceFlow id="c_sf_4" isImmediate="true" sourceRef="c_req_rev" targetRef="c_gw_1_conv"/>
      <sequenceFlow id="c_sf_5" isImmediate="true" sourceRef="c_assess_2" targetRef="c_gw_2_div"/>
      <sequenceFlow id="c_sf_gw2_y" isImmediate="true" name="yes" sourceRef="c_gw_2_div" targetRef="c_req_prep_2"/>
      <sequenceFlow id="c_sf_gw2_n" isImmediate="true" name="no" sourceRef="c_gw_2_div" targetRef="c_gw_1_conv"/>
      <sequenceFlow id="c_sf_6" isImmediate="true" sourceRef="c_req_prep_2" targetRef="c_req_rev_2"/>
      <sequenceFlow id="c_sf_7" isImmediate="true" sourceRef="c_req_rev_2" targetRef="c_update_prog"/>
      <sequenceFlow id="c_sf_8" isImmediate="true" sourceRef="c_update_prog" targetRef="c_gw_1_conv"/>
      <sequenceFlow id="c_sf_9" isImmediate="true" sourceRef="c_gw_1_conv" targetRef="c_transmit"/>
      <sequenceFlow id="c_sf_10" isImmediate="true" sourceRef="c_transmit" targetRef="c_catch_scheme"/>
      <sequenceFlow id="c_sf_11" isImmediate="true" sourceRef="c_catch_scheme" targetRef="c_adopt"/>
      <sequenceFlow id="c_sf_12" isImmediate="true" sourceRef="c_adopt" targetRef="c_gw_3_div"/>
      <sequenceFlow id="c_sf_gw3_y" isImmediate="true" name="yes" sourceRef="c_gw_3_div" targetRef="c_req_revise"/>
      <sequenceFlow id="c_sf_gw3_n" isImmediate="true" name="no" sourceRef="c_gw_3_div" targetRef="c_gw_3_conv"/>
      <sequenceFlow id="c_sf_13" isImmediate="true" sourceRef="c_req_revise" targetRef="c_transmit_revise"/>
      <sequenceFlow id="c_sf_14" isImmediate="true" sourceRef="c_transmit_revise" targetRef="c_gw_3_conv"/>
      <sequenceFlow id="c_sf_15" isImmediate="true" sourceRef="c_gw_3_conv" targetRef="c_end"/>
   </process>

   <process id="Process_ECCG" isClosed="false" isExecutable="true" name="ECCG" processType="None">
      <startEvent id="e_start" name="Start ECCG">
         <outgoing>e_sf_1</outgoing>
      </startEvent>
      <task id="e_assess_1" name="assess whether the scheme is in duly justified cases and not included in programme">
         <incoming>e_sf_1</incoming>
         <outgoing>e_sf_2</outgoing>
      </task>
      <exclusiveGateway id="e_gw_1_div" gatewayDirection="Diverging" isMarkerVisible="true" name="Justified cases?">
         <incoming>e_sf_2</incoming>
         <outgoing>e_sf_gw1_y</outgoing>
         <outgoing>e_sf_gw1_n</outgoing>
      </exclusiveGateway>
      <task id="e_req_prep" name="request ENISA to prepare a candidate cybersecurity certification scheme">
         <incoming>e_sf_gw1_y</incoming>
         <outgoing>e_sf_3</outgoing>
      </task>
      <task id="e_req_rev" name="request ENISA to review an existing European cybersecurity certification scheme">
         <incoming>e_sf_3</incoming>
         <outgoing>e_sf_4</outgoing>
      </task>
      <exclusiveGateway id="e_gw_1_conv" gatewayDirection="Converging" isMarkerVisible="true" name="Merge prep">
         <incoming>e_sf_4</incoming>
         <incoming>e_sf_gw1_n</incoming>
         <outgoing>e_sf_5</outgoing>
      </exclusiveGateway>
      <task id="e_transmit" name="transmit the request to ENISA">
         <incoming>e_sf_5</incoming>
         <outgoing>e_sf_6</outgoing>
      </task>
      <intermediateCatchEvent id="e_catch_notif" name="Upon receiving notification of preparation">
         <incoming>e_sf_6</incoming>
         <outgoing>e_sf_7</outgoing>
         <messageEventDefinition id="msg_def_e_1"/>
      </intermediateCatchEvent>
      <task id="e_provide_assist" name="provide ENISA with assistance and expert advice">
         <incoming>e_sf_7</incoming>
         <outgoing>e_sf_8</outgoing>
      </task>
      <task id="e_adopt_opinion" name="adopt an opinion on the candidate scheme">
         <incoming>e_sf_8</incoming>
         <outgoing>e_sf_9</outgoing>
      </task>
      <task id="e_transmit_opinion" name="transmit the opinion to ENISA">
         <incoming>e_sf_9</incoming>
         <outgoing>e_sf_10</outgoing>
      </task>
      <exclusiveGateway id="e_gw_2_div" gatewayDirection="Diverging" isMarkerVisible="true" name="Necessary?">
         <incoming>e_sf_10</incoming>
         <outgoing>e_sf_gw2_y</outgoing>
         <outgoing>e_sf_gw2_n</outgoing>
      </exclusiveGateway>
      <task id="e_req_revise" name="request ENISA to start process of revising">
         <incoming>e_sf_gw2_y</incoming>
         <outgoing>e_sf_11</outgoing>
      </task>
      <task id="e_transmit_revise" name="transmit the request for a revised candidate scheme to ENISA">
         <incoming>e_sf_11</incoming>
         <outgoing>e_sf_12</outgoing>
      </task>
      <exclusiveGateway id="e_gw_2_conv" gatewayDirection="Converging" isMarkerVisible="true" name="Merge revise">
         <incoming>e_sf_12</incoming>
         <incoming>e_sf_gw2_n</incoming>
         <outgoing>e_sf_13</outgoing>
      </exclusiveGateway>
      <endEvent id="e_end" name="scheme opinion or revision request end event">
         <incoming>e_sf_13</incoming>
      </endEvent>

      <sequenceFlow id="e_sf_1" isImmediate="true" sourceRef="e_start" targetRef="e_assess_1"/>
      <sequenceFlow id="e_sf_2" isImmediate="true" sourceRef="e_assess_1" targetRef="e_gw_1_div"/>
      <sequenceFlow id="e_sf_gw1_y" isImmediate="true" name="yes" sourceRef="e_gw_1_div" targetRef="e_req_prep"/>
      <sequenceFlow id="e_sf_gw1_n" isImmediate="true" name="no" sourceRef="e_gw_1_div" targetRef="e_gw_1_conv"/>
      <sequenceFlow id="e_sf_3" isImmediate="true" sourceRef="e_req_prep" targetRef="e_req_rev"/>
      <sequenceFlow id="e_sf_4" isImmediate="true" sourceRef="e_req_rev" targetRef="e_gw_1_conv"/>
      <sequenceFlow id="e_sf_5" isImmediate="true" sourceRef="e_gw_1_conv" targetRef="e_transmit"/>
      <sequenceFlow id="e_sf_6" isImmediate="true" sourceRef="e_transmit" targetRef="e_catch_notif"/>
      <sequenceFlow id="e_sf_7" isImmediate="true" sourceRef="e_catch_notif" targetRef="e_provide_assist"/>
      <sequenceFlow id="e_sf_8" isImmediate="true" sourceRef="e_provide_assist" targetRef="e_adopt_opinion"/>
      <sequenceFlow id="e_sf_9" isImmediate="true" sourceRef="e_adopt_opinion" targetRef="e_transmit_opinion"/>
      <sequenceFlow id="e_sf_10" isImmediate="true" sourceRef="e_transmit_opinion" targetRef="e_gw_2_div"/>
      <sequenceFlow id="e_sf_gw2_y" isImmediate="true" name="yes" sourceRef="e_gw_2_div" targetRef="e_req_revise"/>
      <sequenceFlow id="e_sf_gw2_n" isImmediate="true" name="no" sourceRef="e_gw_2_div" targetRef="e_gw_2_conv"/>
      <sequenceFlow id="e_sf_11" isImmediate="true" sourceRef="e_req_revise" targetRef="e_transmit_revise"/>
      <sequenceFlow id="e_sf_12" isImmediate="true" sourceRef="e_transmit_revise" targetRef="e_gw_2_conv"/>
      <sequenceFlow id="e_sf_13" isImmediate="true" sourceRef="e_gw_2_conv" targetRef="e_end"/>
   </process>

   <process id="Process_ENISA" isClosed="false" isExecutable="true" name="ENISA" processType="None">
      <laneSet id="ls_enisa">
         <lane id="Lane_ENISA" name="ENISA">
            <flowNodeRef>en_start</flowNodeRef>
            <flowNodeRef>en_assess_src</flowNodeRef>
            <flowNodeRef>en_gw_1_div</flowNodeRef>
            <flowNodeRef>en_prep_c</flowNodeRef>
            <flowNodeRef>en_gw_2_div</flowNodeRef>
            <flowNodeRef>en_prep_e</flowNodeRef>
            <flowNodeRef>en_give_reasons</flowNodeRef>
            <flowNodeRef>en_gw_3_conv</flowNodeRef>
            <flowNodeRef>en_gw_4_div_and</flowNodeRef>
            <flowNodeRef>en_consult</flowNodeRef>
            <flowNodeRef>en_establish</flowNodeRef>
            <flowNodeRef>en_coop</flowNodeRef>
            <flowNodeRef>en_gw_5_conv_and</flowNodeRef>
            <flowNodeRef>en_catch_opinion</flowNodeRef>
            <flowNodeRef>en_take_account</flowNodeRef>
            <flowNodeRef>en_transmit_cand</flowNodeRef>
            <flowNodeRef>en_evaluate</flowNodeRef>
            <flowNodeRef>en_catch_rev_req</flowNodeRef>
            <flowNodeRef>en_start_rev</flowNodeRef>
            <flowNodeRef>en_gw_skip_conv</flowNodeRef>
            <flowNodeRef>en_end</flowNodeRef>
         </lane>
         <lane id="Lane_MB" name="Management Board">
            <flowNodeRef>mb_take_decision</flowNodeRef>
         </lane>
      </laneSet>

      <startEvent id="en_start" name="Upon receiving the request">
         <outgoing>en_sf_1</outgoing>
         <messageEventDefinition id="msg_def_en_1"/>
      </startEvent>
      <task id="en_assess_src" name="assess whether the request is from the Commission or the ECCG">
         <incoming>en_sf_1</incoming>
         <outgoing>en_sf_2</outgoing>
      </task>
      <exclusiveGateway id="en_gw_1_div" gatewayDirection="Diverging" isMarkerVisible="true" name="Source?">
         <incoming>en_sf_2</incoming>
         <outgoing>en_sf_gw1_c</outgoing>
         <outgoing>en_sf_gw1_e</outgoing>
      </exclusiveGateway>
      
      <task id="en_prep_c" name="prepare a candidate cybersecurity certification scheme">
         <incoming>en_sf_gw1_c</incoming>
         <outgoing>en_sf_3</outgoing>
      </task>
      
      <exclusiveGateway id="en_gw_2_div" gatewayDirection="Diverging" isMarkerVisible="true" name="Refuse ECCG request?">
         <incoming>en_sf_gw1_e</incoming>
         <outgoing>en_sf_gw2_p</outgoing>
         <outgoing>en_sf_gw2_r</outgoing>
      </exclusiveGateway>
      <task id="en_prep_e" name="prepare a candidate cybersecurity certification scheme">
         <incoming>en_sf_gw2_p</incoming>
         <outgoing>en_sf_4</outgoing>
      </task>
      <task id="en_give_reasons" name="give reasons for refusal">
         <incoming>en_sf_gw2_r</incoming>
         <outgoing>en_sf_5</outgoing>
      </task>
      <task id="mb_take_decision" name="take decision to refuse a request">
         <incoming>en_sf_5</incoming>
         <outgoing>en_sf_skip</outgoing>
      </task>

      <exclusiveGateway id="en_gw_3_conv" gatewayDirection="Converging" isMarkerVisible="true" name="Merge preparation">
         <incoming>en_sf_3</incoming>
         <incoming>en_sf_4</incoming>
         <outgoing>en_sf_6</outgoing>
      </exclusiveGateway>
      
      <parallelGateway id="en_gw_4_div_and" gatewayDirection="Diverging" name="Parallel activities">
         <incoming>en_sf_6</incoming>
         <outgoing>en_sf_p1</outgoing>
         <outgoing>en_sf_p2</outgoing>
         <outgoing>en_sf_p3</outgoing>
      </parallelGateway>
      <task id="en_consult" name="consult all relevant stakeholders">
         <incoming>en_sf_p1</incoming>
         <outgoing>en_sf_p1_out</outgoing>
      </task>
      <task id="en_establish" name="establish an ad hoc working group">
         <incoming>en_sf_p2</incoming>
         <outgoing>en_sf_p2_out</outgoing>
      </task>
      <task id="en_coop" name="cooperate with the ECCG">
         <incoming>en_sf_p3</incoming>
         <outgoing>en_sf_p3_out</outgoing>
      </task>
      <parallelGateway id="en_gw_5_conv_and" gatewayDirection="Converging" name="Merge activities">
         <incoming>en_sf_p1_out</incoming>
         <incoming>en_sf_p2_out</incoming>
         <incoming>en_sf_p3_out</incoming>
         <outgoing>en_sf_7</outgoing>
      </parallelGateway>

      <intermediateCatchEvent id="en_catch_opinion" name="Upon receiving the opinion from the ECCG">
         <incoming>en_sf_7</incoming>
         <outgoing>en_sf_8</outgoing>
         <messageEventDefinition id="msg_def_en_2"/>
      </intermediateCatchEvent>
      <task id="en_take_account" name="take utmost account of the ECCG opinion">
         <incoming>en_sf_8</incoming>
         <outgoing>en_sf_9</outgoing>
      </task>
      <task id="en_transmit_cand" name="transmit the candidate scheme to the Commission">
         <incoming>en_sf_9</incoming>
         <outgoing>en_sf_10</outgoing>
      </task>
      <task id="en_evaluate" name="evaluate each adopted European cybersecurity certification scheme">
         <incoming>en_sf_10</incoming>
         <outgoing>en_sf_11</outgoing>
      </task>
      <intermediateCatchEvent id="en_catch_rev_req" name="Upon receiving a request from Commission or ECCG">
         <incoming>en_sf_11</incoming>
         <outgoing>en_sf_12</outgoing>
         <messageEventDefinition id="msg_def_en_3"/>
      </intermediateCatchEvent>
      <task id="en_start_rev" name="start developing a revised candidate scheme">
         <incoming>en_sf_12</incoming>
         <outgoing>en_sf_13</outgoing>
      </task>
      
      <exclusiveGateway id="en_gw_skip_conv" gatewayDirection="Converging" isMarkerVisible="true" name="Merge refusal path">
         <incoming>en_sf_13</incoming>
         <incoming>en_sf_skip</incoming>
         <outgoing>en_sf_14</outgoing>
      </exclusiveGateway>
      <endEvent id="en_end" name="candidate scheme evaluation or revision start end event">
         <incoming>en_sf_14</incoming>
      </endEvent>

      <sequenceFlow id="en_sf_1" isImmediate="true" sourceRef="en_start" targetRef="en_assess_src"/>
      <sequenceFlow id="en_sf_2" isImmediate="true" sourceRef="en_assess_src" targetRef="en_gw_1_div"/>
      <sequenceFlow id="en_sf_gw1_c" isImmediate="true" name="Commission" sourceRef="en_gw_1_div" targetRef="en_prep_c"/>
      <sequenceFlow id="en_sf_gw1_e" isImmediate="true" name="ECCG" sourceRef="en_gw_1_div" targetRef="en_gw_2_div"/>
      <sequenceFlow id="en_sf_3" isImmediate="true" sourceRef="en_prep_c" targetRef="en_gw_3_conv"/>
      <sequenceFlow id="en_sf_gw2_p" isImmediate="true" name="prepare" sourceRef="en_gw_2_div" targetRef="en_prep_e"/>
      <sequenceFlow id="en_sf_gw2_r" isImmediate="true" name="refuse" sourceRef="en_gw_2_div" targetRef="en_give_reasons"/>
      <sequenceFlow id="en_sf_4" isImmediate="true" sourceRef="en_prep_e" targetRef="en_gw_3_conv"/>
      <sequenceFlow id="en_sf_5" isImmediate="true" sourceRef="en_give_reasons" targetRef="mb_take_decision"/>
      <sequenceFlow id="en_sf_skip" isImmediate="true" sourceRef="mb_take_decision" targetRef="en_gw_skip_conv"/>
      <sequenceFlow id="en_sf_6" isImmediate="true" sourceRef="en_gw_3_conv" targetRef="en_gw_4_div_and"/>
      <sequenceFlow id="en_sf_p1" isImmediate="true" sourceRef="en_gw_4_div_and" targetRef="en_consult"/>
      <sequenceFlow id="en_sf_p2" isImmediate="true" sourceRef="en_gw_4_div_and" targetRef="en_establish"/>
      <sequenceFlow id="en_sf_p3" isImmediate="true" sourceRef="en_gw_4_div_and" targetRef="en_coop"/>
      <sequenceFlow id="en_sf_p1_out" isImmediate="true" sourceRef="en_consult" targetRef="en_gw_5_conv_and"/>
      <sequenceFlow id="en_sf_p2_out" isImmediate="true" sourceRef="en_establish" targetRef="en_gw_5_conv_and"/>
      <sequenceFlow id="en_sf_p3_out" isImmediate="true" sourceRef="en_coop" targetRef="en_gw_5_conv_and"/>
      <sequenceFlow id="en_sf_7" isImmediate="true" sourceRef="en_gw_5_conv_and" targetRef="en_catch_opinion"/>
      <sequenceFlow id="en_sf_8" isImmediate="true" sourceRef="en_catch_opinion" targetRef="en_take_account"/>
      <sequenceFlow id="en_sf_9" isImmediate="true" sourceRef="en_take_account" targetRef="en_transmit_cand"/>
      <sequenceFlow id="en_sf_10" isImmediate="true" sourceRef="en_transmit_cand" targetRef="en_evaluate"/>
      <sequenceFlow id="en_sf_11" isImmediate="true" sourceRef="en_evaluate" targetRef="en_catch_rev_req"/>
