         </extensionElements>
         <incoming>Seq_OPP_15</incoming>
      </endEvent>

      <sequenceFlow id="Seq_OPP_1" sourceRef="Start_OPP" targetRef="Task_OPP_1" isImmediate="true"/>
      <sequenceFlow id="Seq_OPP_2" sourceRef="Task_OPP_1" targetRef="GW_OPP_1" isImmediate="true"/>
      <sequenceFlow id="Seq_OPP_3" name="yes" sourceRef="GW_OPP_1" targetRef="Task_OPP_2" isImmediate="true"/>
      <sequenceFlow id="Seq_OPP_4" sourceRef="Task_OPP_2" targetRef="Task_OPP_3" isImmediate="true"/>
      <sequenceFlow id="Seq_OPP_5" sourceRef="Task_OPP_3" targetRef="GW_OPP_1_Conv" isImmediate="true"/>
      <sequenceFlow id="Seq_OPP_6" name="no" sourceRef="GW_OPP_1" targetRef="GW_OPP_1_Conv" isImmediate="true"/>
      <sequenceFlow id="Seq_OPP_7" sourceRef="GW_OPP_1_Conv" targetRef="GW_OPP_2" isImmediate="true"/>
      <sequenceFlow id="Seq_OPP_8" name="yes" sourceRef="GW_OPP_2" targetRef="Task_OPP_4" isImmediate="true"/>
