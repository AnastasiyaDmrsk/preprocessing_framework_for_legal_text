         </extensionElements>
         <incoming>Seq_OPP_7</incoming>
         <outgoing>Seq_OPP_8</outgoing>
         <outgoing>Seq_OPP_10</outgoing>
      </exclusiveGateway>
      <task id="Task_OPP_4" name="decide upon notices">
         <incoming>Seq_OPP_8</incoming>
         <outgoing>Seq_OPP_9</outgoing>
      </task>
      <exclusiveGateway id="GW_OPP_2_Conv" name="" isMarkerVisible="true" gatewayDirection="Converging">
         <incoming>Seq_OPP_9</incoming>
         <incoming>Seq_OPP_10</incoming>
         <outgoing>Seq_OPP_11</outgoing>
      </exclusiveGateway>
      <exclusiveGateway id="GW_OPP_3" name="assess whether a trusted flagger has submitted insufficiently precise..." isMarkerVisible="true" gatewayDirection="Diverging">
         <extensionElements>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/>
         </extensionElements>
         <incoming>Seq_OPP_11</incoming>
         <outgoing>Seq_OPP_12</outgoing>
         <outgoing>Seq_OPP_14</outgoing>
      </exclusiveGateway>
      <task id="Task_OPP_5" name="communicate information to the Digital Services Coordinator">
         <incoming>Seq_OPP_12</incoming>
         <outgoing>Seq_OPP_13</outgoing>
      </task>
      <exclusiveGateway id="GW_OPP_3_Conv" name="" isMarkerVisible="true" gatewayDirection="Converging">
         <incoming>Seq_OPP_13</incoming>
         <incoming>Seq_OPP_14</incoming>
         <outgoing>Seq_OPP_15</outgoing>
