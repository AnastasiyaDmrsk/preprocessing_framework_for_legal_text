      <sequenceFlow id="Seq_COM_2" sourceRef="Catch_COM_1" targetRef="Task_COM_1" isImmediate="true"/>
      <sequenceFlow id="Seq_COM_3" sourceRef="Task_COM_1" targetRef="Task_COM_2" isImmediate="true"/>
      <sequenceFlow id="Seq_COM_4" sourceRef="Task_COM_2" targetRef="Task_COM_3" isImmediate="true"/>
      <sequenceFlow id="Seq_COM_5" sourceRef="Task_COM_3" targetRef="GW_COM_1" isImmediate="true"/>
      <sequenceFlow id="Seq_COM_6" name="yes" sourceRef="GW_COM_1" targetRef="Task_COM_4" isImmediate="true"/>
      <sequenceFlow id="Seq_COM_7" sourceRef="Task_COM_4" targetRef="GW_COM_1_Conv" isImmediate="true"/>
      <sequenceFlow id="Seq_COM_8" name="no" sourceRef="GW_COM_1" targetRef="GW_COM_1_Conv" isImmediate="true"/>
