      <sequenceFlow id="Seq_OPP_12" name="yes" sourceRef="GW_OPP_3" targetRef="Task_OPP_5" isImmediate="true"/>
      <sequenceFlow id="Seq_OPP_13" sourceRef="Task_OPP_5" targetRef="GW_OPP_3_Conv" isImmediate="true"/>
      <sequenceFlow id="Seq_OPP_14" name="no" sourceRef="GW_OPP_3" targetRef="GW_OPP_3_Conv" isImmediate="true"/>
      <sequenceFlow id="Seq_OPP_15" sourceRef="GW_OPP_3_Conv" targetRef="End_OPP" isImmediate="true"/>
   </process>

   <process id="Proc_DSC" isClosed="false" isExecutable="false" name="Digital Services Coordinator" processType="None">
      <laneSet id="LaneSet_DSC">
         <lane id="Lane_DSC">
            <flowNodeRef>Start_DSC</flowNodeRef>
