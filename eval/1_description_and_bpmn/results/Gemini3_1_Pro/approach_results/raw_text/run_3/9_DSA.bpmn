         </extensionElements>
         <outgoing>Seq_DSC_1</outgoing>
      </startEvent>
      <exclusiveGateway id="GW_DSC_1" name="assess whether upon application by any entity, the applicant is established..." isMarkerVisible="true" gatewayDirection="Diverging">
         <extensionElements>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/>
         </extensionElements>
         <incoming>Seq_DSC_1</incoming>
         <outgoing>Seq_DSC_2</outgoing>
         <outgoing>Seq_DSC_4</outgoing>
      </exclusiveGateway>
      <task id="Task_DSC_1" name="award the status of trusted flagger">
         <incoming>Seq_DSC_2</incoming>
         <outgoing>Seq_DSC_3</outgoing>
      </task>
      <exclusiveGateway id="GW_DSC_1_Conv" name="" isMarkerVisible="true" gatewayDirection="Converging">
         <incoming>Seq_DSC_3</incoming>
         <incoming>Seq_DSC_4</incoming>
         <outgoing>Seq_DSC_5</outgoing>
      </exclusiveGateway>
      <exclusiveGateway id="GW_DSC_2" name="assess whether it is following award... or following suspension..." isMarkerVisible="true" gatewayDirection="Diverging">
         <extensionElements>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/>
         </extensionElements>
         <incoming>Seq_DSC_5</incoming>
         <outgoing>Seq_DSC_6</outgoing>
         <outgoing>Seq_DSC_8</outgoing>
      </exclusiveGateway>
      <task id="Task_DSC_2" name="communicate to the Commission and the Board the names...">
         <incoming>Seq_DSC_6</incoming>
         <outgoing>Seq_DSC_7</outgoing>
      </task>
      <exclusiveGateway id="GW_DSC_2_Conv" name="" isMarkerVisible="true" gatewayDirection="Converging">
         <incoming>Seq_DSC_7</incoming>
         <incoming>Seq_DSC_8</incoming>
         <outgoing>Seq_DSC_9</outgoing>
      </exclusiveGateway>
      <intermediateCatchEvent id="Catch_DSC_1" name="Receive reports from the Trusted Flagger">
         <extensionElements>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/>
         </extensionElements>
         <incoming>Seq_DSC_9</incoming>
         <outgoing>Seq_DSC_10</outgoing>
         <messageEventDefinition id="MsgDef_DSC_1"/>
      </intermediateCatchEvent>
      <intermediateCatchEvent id="Catch_DSC_2" name="Receive information from an Online Platform Provider">
         <extensionElements>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/>
         </extensionElements>
         <incoming>Seq_DSC_10</incoming>
         <outgoing>Seq_DSC_11</outgoing>
         <messageEventDefinition id="MsgDef_DSC_2"/>
      </intermediateCatchEvent>
      <exclusiveGateway id="GW_DSC_3" name="assess whether legitimate reasons to open an investigation" isMarkerVisible="true" gatewayDirection="Diverging">
         <extensionElements>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/>
         </extensionElements>
         <incoming>Seq_DSC_11</incoming>
         <outgoing>Seq_DSC_12</outgoing>
         <outgoing>Seq_DSC_16</outgoing>
      </exclusiveGateway>
      <task id="Task_DSC_3" name="suspend the status of trusted flagger">
         <incoming>Seq_DSC_12</incoming>
         <outgoing>Seq_DSC_13</outgoing>
      </task>
      <task id="Task_DSC_4" name="carry out the investigation without undue delay">
         <incoming>Seq_DSC_13</incoming>
         <outgoing>Seq_DSC_14</outgoing>
      </task>
      <task id="Task_DSC_5" name="afford the entity an opportunity to react to the investigation findings">
         <incoming>Seq_DSC_14</incoming>
         <outgoing>Seq_DSC_15</outgoing>
      </task>
      <exclusiveGateway id="GW_DSC_3_Conv" name="" isMarkerVisible="true" gatewayDirection="Converging">
         <incoming>Seq_DSC_15</incoming>
         <incoming>Seq_DSC_16</incoming>
         <outgoing>Seq_DSC_17</outgoing>
      </exclusiveGateway>
      <exclusiveGateway id="GW_DSC_4" name="assess whether the entity no longer meets the conditions" isMarkerVisible="true" gatewayDirection="Diverging">
         <extensionElements>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/>
         </extensionElements>
         <incoming>Seq_DSC_17</incoming>
         <outgoing>Seq_DSC_18</outgoing>
         <outgoing>Seq_DSC_20</outgoing>
      </exclusiveGateway>
      <task id="Task_DSC_6" name="revoke the trusted flagger status">
         <incoming>Seq_DSC_18</incoming>
         <outgoing>Seq_DSC_19</outgoing>
      </task>
      <exclusiveGateway id="GW_DSC_4_Conv" name="" isMarkerVisible="true" gatewayDirection="Converging">
         <incoming>Seq_DSC_19</incoming>
         <incoming>Seq_DSC_20</incoming>
         <outgoing>Seq_DSC_21</outgoing>
      </exclusiveGateway>
      <endEvent id="End_DSC" name="End">
         <extensionElements>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="14.0" y="-8.0"/>
         </extensionElements>
         <incoming>Seq_DSC_21</incoming>
      </endEvent>

      <sequenceFlow id="Seq_DSC_1" sourceRef="Start_DSC" targetRef="GW_DSC_1" isImmediate="true"/>
      <sequenceFlow id="Seq_DSC_2" name="yes" sourceRef="GW_DSC_1" targetRef="Task_DSC_1" isImmediate="true"/>
      <sequenceFlow id="Seq_DSC_3" sourceRef="Task_DSC_1" targetRef="GW_DSC_1_Conv" isImmediate="true"/>
      <sequenceFlow id="Seq_DSC_4" name="no" sourceRef="GW_DSC_1" targetRef="GW_DSC_1_Conv" isImmediate="true"/>
      <sequenceFlow id="Seq_DSC_5" sourceRef="GW_DSC_1_Conv" targetRef="GW_DSC_2" isImmediate="true"/>
      <sequenceFlow id="Seq_DSC_6" name="yes" sourceRef="GW_DSC_2" targetRef="Task_DSC_2" isImmediate="true"/>
      <sequenceFlow id="Seq_DSC_7" sourceRef="Task_DSC_2" targetRef="GW_DSC_2_Conv" isImmediate="true"/>
      <sequenceFlow id="Seq_DSC_8" name="no" sourceRef="GW_DSC_2" targetRef="GW_DSC_2_Conv" isImmediate="true"/>
      <sequenceFlow id="Seq_DSC_9" sourceRef="GW_DSC_2_Conv" targetRef="Catch_DSC_1" isImmediate="true"/>
      <sequenceFlow id="Seq_DSC_10" sourceRef="Catch_DSC_1" targetRef="Catch_DSC_2" isImmediate="true"/>
      <sequenceFlow id="Seq_DSC_11" sourceRef="Catch_DSC_2" targetRef="GW_DSC_3" isImmediate="true"/>
      <sequenceFlow id="Seq_DSC_12" name="yes" sourceRef="GW_DSC_3" targetRef="Task_DSC_3" isImmediate="true"/>
      <sequenceFlow id="Seq_DSC_13" sourceRef="Task_DSC_3" targetRef="Task_DSC_4" isImmediate="true"/>
      <sequenceFlow id="Seq_DSC_14" sourceRef="Task_DSC_4" targetRef="Task_DSC_5" isImmediate="true"/>
      <sequenceFlow id="Seq_DSC_15" sourceRef="Task_DSC_5" targetRef="GW_DSC_3_Conv" isImmediate="true"/>
      <sequenceFlow id="Seq_DSC_16" name="no" sourceRef="GW_DSC_3" targetRef="GW_DSC_3_Conv" isImmediate="true"/>
      <sequenceFlow id="Seq_DSC_17" sourceRef="GW_DSC_3_Conv" targetRef="GW_DSC_4" isImmediate="true"/>
      <sequenceFlow id="Seq_DSC_18" name="yes" sourceRef="GW_DSC_4" targetRef="Task_DSC_6" isImmediate="true"/>
      <sequenceFlow id="Seq_DSC_19" sourceRef="Task_DSC_6" targetRef="GW_DSC_4_Conv" isImmediate="true"/>
      <sequenceFlow id="Seq_DSC_20" name="no" sourceRef="GW_DSC_4" targetRef="GW_DSC_4_Conv" isImmediate="true"/>
      <sequenceFlow id="Seq_DSC_21" sourceRef="GW_DSC_4_Conv" targetRef="End_DSC" isImmediate="true"/>
   </process>

   <process id="Proc_TF" isClosed="false" isExecutable="false" name="Trusted Flagger" processType="None">
      <laneSet id="LaneSet_TF">
         <lane id="Lane_TF">
            <flowNodeRef>Start_TF</flowNodeRef>
            <flowNodeRef>Task_TF_1</flowNodeRef>
            <flowNodeRef>Task_TF_2</flowNodeRef>
            <flowNodeRef>Task_TF_3</flowNodeRef>
            <flowNodeRef>Catch_TF_1</flowNodeRef>
            <flowNodeRef>Task_TF_4</flowNodeRef>
            <flowNodeRef>End_TF</flowNodeRef>
         </lane>
      </laneSet>

      <startEvent id="Start_TF" name="Start">
         <extensionElements>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/>
         </extensionElements>
         <outgoing>Seq_TF_1</outgoing>
      </startEvent>
      <task id="Task_TF_1" name="publish reports on notices submitted">
         <incoming>Seq_TF_1</incoming>
         <outgoing>Seq_TF_2</outgoing>
      </task>
      <task id="Task_TF_2" name="send reports to the Digital Services Coordinator">
         <incoming>Seq_TF_2</incoming>
         <outgoing>Seq_TF_3</outgoing>
      </task>
      <task id="Task_TF_3" name="make reports publicly available">
         <incoming>Seq_TF_3</incoming>
         <outgoing>Seq_TF_4</outgoing>
      </task>
      <intermediateCatchEvent id="Catch_TF_1" name="Receive an opportunity to react">
         <extensionElements>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/>
         </extensionElements>
         <incoming>Seq_TF_4</incoming>
         <outgoing>Seq_TF_5</outgoing>
         <messageEventDefinition id="MsgDef_TF_1"/>
      </intermediateCatchEvent>
      <task id="Task_TF_4" name="react to the investigation findings">
         <incoming>Seq_TF_5</incoming>
         <outgoing>Seq_TF_6</outgoing>
      </task>
      <endEvent id="End_TF" name="End">
         <extensionElements>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="14.0" y="-8.0"/>
         </extensionElements>
         <incoming>Seq_TF_6</incoming>
      </endEvent>

      <sequenceFlow id="Seq_TF_1" sourceRef="Start_TF" targetRef="Task_TF_1" isImmediate="true"/>
      <sequenceFlow id="Seq_TF_2" sourceRef="Task_TF_1" targetRef="Task_TF_2" isImmediate="true"/>
      <sequenceFlow id="Seq_TF_3" sourceRef="Task_TF_2" targetRef="Task_TF_3" isImmediate="true"/>
      <sequenceFlow id="Seq_TF_4" sourceRef="Task_TF_3" targetRef="Catch_TF_1" isImmediate="true"/>
      <sequenceFlow id="Seq_TF_5" sourceRef="Catch_TF_1" targetRef="Task_TF_4" isImmediate="true"/>
      <sequenceFlow id="Seq_TF_6" sourceRef="Task_TF_4" targetRef="End_TF" isImmediate="true"/>
   </process>

   <process id="Proc_COM" isClosed="false" isExecutable="false" name="Commission" processType="None">
      <laneSet id="LaneSet_COM">
         <lane id="Lane_COM">
            <flowNodeRef>Start_COM</flowNodeRef>
            <flowNodeRef>Catch_COM_1</flowNodeRef>
            <flowNodeRef>Task_COM_1</flowNodeRef>
            <flowNodeRef>Task_COM_2</flowNodeRef>
            <flowNodeRef>Task_COM_3</flowNodeRef>
            <flowNodeRef>GW_COM_1</flowNodeRef>
            <flowNodeRef>Task_COM_4</flowNodeRef>
            <flowNodeRef>GW_COM_1_Conv</flowNodeRef>
            <flowNodeRef>End_COM</flowNodeRef>
         </lane>
      </laneSet>

      <startEvent id="Start_COM" name="Start">
         <extensionElements>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/>
         </extensionElements>
         <outgoing>Seq_COM_1</outgoing>
      </startEvent>
      <intermediateCatchEvent id="Catch_COM_1" name="Receive the names, addresses...">
         <extensionElements>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/>
         </extensionElements>
         <incoming>Seq_COM_1</incoming>
         <outgoing>Seq_COM_2</outgoing>
         <messageEventDefinition id="MsgDef_COM_1"/>
      </intermediateCatchEvent>
      <task id="Task_COM_1" name="publish information in a publicly available database">
         <incoming>Seq_COM_2</incoming>
         <outgoing>Seq_COM_3</outgoing>
      </task>
      <task id="Task_COM_2" name="keep database up to date">
         <incoming>Seq_COM_3</incoming>
         <outgoing>Seq_COM_4</outgoing>
      </task>
      <task id="Task_COM_3" name="consult">
         <incoming>Seq_COM_4</incoming>
         <outgoing>Seq_COM_5</outgoing>
      </task>
      <exclusiveGateway id="GW_COM_1" name="assess whether necessary" isMarkerVisible="true" gatewayDirection="Diverging">
         <extensionElements>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/>
         </extensionElements>
         <incoming>Seq_COM_5</incoming>
         <outgoing>Seq_COM_6</outgoing>
         <outgoing>Seq_COM_8</outgoing>
      </exclusiveGateway>
      <task id="Task_COM_4" name="issue guidelines after consulting the Board">
         <incoming>Seq_COM_6</incoming>
         <outgoing>Seq_COM_7</outgoing>
      </task>
      <exclusiveGateway id="GW_COM_1_Conv" name="" isMarkerVisible="true" gatewayDirection="Converging">
         <incoming>Seq_COM_7</incoming>
         <incoming>Seq_COM_8</incoming>
         <outgoing>Seq_COM_9</outgoing>
      </exclusiveGateway>
      <endEvent id="End_COM" name="End">
