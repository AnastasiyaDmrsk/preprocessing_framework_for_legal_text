   <process id="Proc_OPP" isClosed="false" isExecutable="false" name="Online Platform Provider" processType="None">
      <laneSet id="LaneSet_OPP">
         <lane id="Lane_OPP">
            <flowNodeRef>Start_OPP</flowNodeRef>
            <flowNodeRef>Task_OPP_1</flowNodeRef>
            <flowNodeRef>GW_OPP_1</flowNodeRef>
            <flowNodeRef>Task_OPP_2</flowNodeRef>
            <flowNodeRef>Task_OPP_3</flowNodeRef>
            <flowNodeRef>GW_OPP_1_Conv</flowNodeRef>
            <flowNodeRef>GW_OPP_2</flowNodeRef>
            <flowNodeRef>Task_OPP_4</flowNodeRef>
            <flowNodeRef>GW_OPP_2_Conv</flowNodeRef>
            <flowNodeRef>GW_OPP_3</flowNodeRef>
            <flowNodeRef>Task_OPP_5</flowNodeRef>
            <flowNodeRef>GW_OPP_3_Conv</flowNodeRef>
            <flowNodeRef>End_OPP</flowNodeRef>
         </lane>
      </laneSet>
      
      <startEvent id="Start_OPP" name="Start">
         <extensionElements>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/>
         </extensionElements>
         <outgoing>Seq_OPP_1</outgoing>
      </startEvent>
      <task id="Task_OPP_1" name="take the necessary technical and organisational measures for notices">
         <incoming>Seq_OPP_1</incoming>
         <outgoing>Seq_OPP_2</outgoing>
      </task>
      <exclusiveGateway id="GW_OPP_1" name="assess whether notices are submitted within their designated area of expertise..." isMarkerVisible="true" gatewayDirection="Diverging">
         <extensionElements>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/>
         </extensionElements>
