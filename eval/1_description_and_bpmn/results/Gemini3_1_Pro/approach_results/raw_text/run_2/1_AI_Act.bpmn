<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:i18n="http://www.omg.org/spec/BPMN/non-normative/extensions/i18n/1.0" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" xmlns:signavio="http://www.signavio.com" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" exporter="Signavio Process Editor, http://www.signavio.com" exporterVersion="19.2.2" expressionLanguage="http://www.w3.org/TR/XPath" id="sid-2a5d4e96-a02e-4cba-86c8-19fd40a18e9f" targetNamespace="http://www.signavio.com" typeLanguage="http://www.w3.org/2001/XMLSchema" xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd">
   <collaboration id="sid-4777cf43-884d-49c4-a325-9f435a12218a">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="revisionid" metaValue="b3dc1b4e1592411f82de7f913634ad06"/>
      </extensionElements>
      <participant id="Participant_SME" name="SME" processRef="Process_SME">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffff"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
      </participant>
      <participant id="Participant_MS" name="Member State" processRef="Process_MS">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffff"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
      </participant>
      <participant id="Participant_BD" name="Board" processRef="Process_BD">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffff"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
      </participant>
      <participant id="Participant_AIO" name="AI Office" processRef="Process_AIO">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffff"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
      </participant>
      <messageFlow id="MsgFlow_SME_MS" name="" sourceRef="SME_Task_Transmit" targetRef="MS_Catch_Needs">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
      </messageFlow>
      <messageFlow id="MsgFlow_BD_AIO" name="" sourceRef="BD_Task_Transmit" targetRef="AIO_Catch_Req">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
      </messageFlow>
   </collaboration>

   <!-- SME PROCESS -->
   <process id="Process_SME" isClosed="false" isExecutable="false" name="SME" processType="None">
      <laneSet id="LaneSet_SME">
         <lane id="Lane_SME">
            <flowNodeRef>SME_Start</flowNodeRef>
            <flowNodeRef>SME_XOR_Split</flowNodeRef>
            <flowNodeRef>SME_Task_Share</flowNodeRef>
            <flowNodeRef>SME_XOR_Merge</flowNodeRef>
            <flowNodeRef>SME_Task_Transmit</flowNodeRef>
            <flowNodeRef>SME_End</flowNodeRef>
         </lane>
      </laneSet>
      <startEvent id="SME_Start" name="need to implement measures for providers and deployers">
         <extensionElements>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/>
         </extensionElements>
         <outgoing>Flow_SME_1</outgoing>
      </startEvent>
      <exclusiveGateway id="SME_XOR_Split" name="if required?" gatewayDirection="Diverging" isMarkerVisible="true">
         <extensionElements>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/>
         </extensionElements>
         <incoming>Flow_SME_1</incoming>
         <outgoing>Flow_SME_2</outgoing>
         <outgoing>Flow_SME_3</outgoing>
      </exclusiveGateway>
      <task id="SME_Task_Share" name="Share interests and needs">
         <incoming>Flow_SME_2</incoming>
         <outgoing>Flow_SME_4</outgoing>
      </task>
      <exclusiveGateway id="SME_XOR_Merge" gatewayDirection="Converging" isMarkerVisible="true">
         <incoming>Flow_SME_3</incoming>
         <incoming>Flow_SME_4</incoming>
         <outgoing>Flow_SME_5</outgoing>
      </exclusiveGateway>
      <task id="SME_Task_Transmit" name="Transmit interests and needs to the Member State">
         <incoming>Flow_SME_5</incoming>
         <outgoing>Flow_SME_6</outgoing>
      </task>
      <endEvent id="SME_End" name="End">
         <extensionElements>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="14.0" y="-8.0"/>
         </extensionElements>
         <incoming>Flow_SME_6</incoming>
      </endEvent>
      <sequenceFlow id="Flow_SME_1" sourceRef="SME_Start" targetRef="SME_XOR_Split" isImmediate="true"/>
      <sequenceFlow id="Flow_SME_2" name="yes" sourceRef="SME_XOR_Split" targetRef="SME_Task_Share" isImmediate="true"/>
      <sequenceFlow id="Flow_SME_3" name="no" sourceRef="SME_XOR_Split" targetRef="SME_XOR_Merge" isImmediate="true"/>
      <sequenceFlow id="Flow_SME_4" sourceRef="SME_Task_Share" targetRef="SME_XOR_Merge" isImmediate="true"/>
      <sequenceFlow id="Flow_SME_5" sourceRef="SME_XOR_Merge" targetRef="SME_Task_Transmit" isImmediate="true"/>
      <sequenceFlow id="Flow_SME_6" sourceRef="SME_Task_Transmit" targetRef="SME_End" isImmediate="true"/>
   </process>

   <!-- MEMBER STATE PROCESS -->
   <process id="Process_MS" isClosed="false" isExecutable="false" name="Member State" processType="None">
      <laneSet id="LaneSet_MS">
         <lane id="Lane_MS">
            <flowNodeRef>MS_Start</flowNodeRef>
            <flowNodeRef>MS_AND_Split</flowNodeRef>
            <flowNodeRef>MS_Task_Assess1</flowNodeRef>
            <flowNodeRef>MS_XOR_Assess1</flowNodeRef>
            <flowNodeRef>MS_Task_ProvidePrio</flowNodeRef>
            <flowNodeRef>MS_XOR_Merge1</flowNodeRef>
            <flowNodeRef>MS_Task_Assess2</flowNodeRef>
            <flowNodeRef>MS_XOR_Assess2</flowNodeRef>
            <flowNodeRef>MS_Task_NotPreclude</flowNodeRef>
            <flowNodeRef>MS_XOR_Merge2</flowNodeRef>
            <flowNodeRef>MS_Task_Organise</flowNodeRef>
            <flowNodeRef>MS_Task_Utilise</flowNodeRef>
            <flowNodeRef>MS_Task_Assess3</flowNodeRef>
            <flowNodeRef>MS_XOR_Assess3</flowNodeRef>
            <flowNodeRef>MS_Task_Establish</flowNodeRef>
            <flowNodeRef>MS_XOR_Merge3</flowNodeRef>
            <flowNodeRef>MS_Task_ProvideAdv</flowNodeRef>
            <flowNodeRef>MS_Task_Respond</flowNodeRef>
            <flowNodeRef>MS_Task_Facilitate</flowNodeRef>
            <flowNodeRef>MS_AND_Merge</flowNodeRef>
            <flowNodeRef>MS_Catch_Needs</flowNodeRef>
            <flowNodeRef>MS_Task_TakeInto</flowNodeRef>
            <flowNodeRef>MS_Task_SetFees</flowNodeRef>
            <flowNodeRef>MS_End</flowNodeRef>
         </lane>
      </laneSet>
      <startEvent id="MS_Start" name="Start">
         <extensionElements>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/>
         </extensionElements>
         <outgoing>Flow_MS_1</outgoing>
      </startEvent>
      <parallelGateway id="MS_AND_Split" gatewayDirection="Diverging">
         <incoming>Flow_MS_1</incoming>
         <outgoing>Flow_MS_P1</outgoing>
         <outgoing>Flow_MS_P2</outgoing>
         <outgoing>Flow_MS_P3</outgoing>
         <outgoing>Flow_MS_P4</outgoing>
      </parallelGateway>
      
      <!-- MS Path 1 -->
      <task id="MS_Task_Assess1" name="Assess whether SMEs have a registered office or a branch in the Union and fulfil eligibility conditions">
         <incoming>Flow_MS_P1</incoming>
         <outgoing>Flow_MS_A1</outgoing>
      </task>
      <exclusiveGateway id="MS_XOR_Assess1" name="SMEs fulfil conditions?" gatewayDirection="Diverging" isMarkerVisible="true">
         <extensionElements>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/>
         </extensionElements>
         <incoming>Flow_MS_A1</incoming>
         <outgoing>Flow_MS_A2</outgoing>
         <outgoing>Flow_MS_A3</outgoing>
      </exclusiveGateway>
      <task id="MS_Task_ProvidePrio" name="Provide SMEs with priority access">
         <incoming>Flow_MS_A2</incoming>
         <outgoing>Flow_MS_A4</outgoing>
      </task>
      <exclusiveGateway id="MS_XOR_Merge1" gatewayDirection="Converging" isMarkerVisible="true">
         <incoming>Flow_MS_A3</incoming>
         <incoming>Flow_MS_A4</incoming>
         <outgoing>Flow_MS_A5</outgoing>
      </exclusiveGateway>
      <task id="MS_Task_Assess2" name="Assess whether other SMEs fulfil eligibility conditions">
         <incoming>Flow_MS_A5</incoming>
         <outgoing>Flow_MS_A6</outgoing>
      </task>
      <exclusiveGateway id="MS_XOR_Assess2" name="Other SMEs fulfil conditions?" gatewayDirection="Diverging" isMarkerVisible="true">
         <extensionElements>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/>
         </extensionElements>
         <incoming>Flow_MS_A6</incoming>
         <outgoing>Flow_MS_A7</outgoing>
         <outgoing>Flow_MS_A8</outgoing>
      </exclusiveGateway>
      <task id="MS_Task_NotPreclude" name="Not Preclude other SMEs from access to AI regulatory sandbox">
         <incoming>Flow_MS_A7</incoming>
         <outgoing>Flow_MS_A9</outgoing>
      </task>
      <exclusiveGateway id="MS_XOR_Merge2" gatewayDirection="Converging" isMarkerVisible="true">
         <incoming>Flow_MS_A8</incoming>
         <incoming>Flow_MS_A9</incoming>
         <outgoing>Flow_MS_EndP1</outgoing>
      </exclusiveGateway>

      <!-- MS Path 2 -->
      <task id="MS_Task_Organise" name="Organise specific activities">
         <incoming>Flow_MS_P2</incoming>
         <outgoing>Flow_MS_EndP2</outgoing>
      </task>

      <!-- MS Path 3 -->
      <task id="MS_Task_Utilise" name="Utilise existing dedicated channels">
         <incoming>Flow_MS_P3</incoming>
         <outgoing>Flow_MS_B1</outgoing>
      </task>
      <task id="MS_Task_Assess3" name="Assess whether it is appropriate">
         <incoming>Flow_MS_B1</incoming>
         <outgoing>Flow_MS_B2</outgoing>
      </task>
      <exclusiveGateway id="MS_XOR_Assess3" name="Is it appropriate?" gatewayDirection="Diverging" isMarkerVisible="true">
         <extensionElements>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/>
         </extensionElements>
         <incoming>Flow_MS_B2</incoming>
         <outgoing>Flow_MS_B3</outgoing>
         <outgoing>Flow_MS_B4</outgoing>
      </exclusiveGateway>
      <task id="MS_Task_Establish" name="Establish new channels">
         <incoming>Flow_MS_B3</incoming>
         <outgoing>Flow_MS_B5</outgoing>
      </task>
      <exclusiveGateway id="MS_XOR_Merge3" gatewayDirection="Converging" isMarkerVisible="true">
         <incoming>Flow_MS_B4</incoming>
         <incoming>Flow_MS_B5</incoming>
         <outgoing>Flow_MS_B6</outgoing>
      </exclusiveGateway>
      <task id="MS_Task_ProvideAdv" name="Provide advice">
         <incoming>Flow_MS_B6</incoming>
         <outgoing>Flow_MS_B7</outgoing>
      </task>
      <task id="MS_Task_Respond" name="Respond to queries">
         <incoming>Flow_MS_B7</incoming>
         <outgoing>Flow_MS_EndP3</outgoing>
      </task>

      <!-- MS Path 4 -->
      <task id="MS_Task_Facilitate" name="Facilitate the participation of SMEs in the development process">
         <incoming>Flow_MS_P4</incoming>
         <outgoing>Flow_MS_EndP4</outgoing>
      </task>

      <!-- MS Merge & Finish -->
      <parallelGateway id="MS_AND_Merge" gatewayDirection="Converging">
         <incoming>Flow_MS_EndP1</incoming>
         <incoming>Flow_MS_EndP2</incoming>
         <incoming>Flow_MS_EndP3</incoming>
         <incoming>Flow_MS_EndP4</incoming>
         <outgoing>Flow_MS_Merge1</outgoing>
      </parallelGateway>

      <intermediateCatchEvent id="MS_Catch_Needs" name="Upon receiving interests and needs">
         <extensionElements>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/>
         </extensionElements>
         <incoming>Flow_MS_Merge1</incoming>
         <outgoing>Flow_MS_2</outgoing>
         <messageEventDefinition id="MsgDef_MS_Needs"/>
      </intermediateCatchEvent>
      <task id="MS_Task_TakeInto" name="Take into account the specific interests and needs">
         <incoming>Flow_MS_2</incoming>
         <outgoing>Flow_MS_3</outgoing>
      </task>
      <task id="MS_Task_SetFees" name="Set the fees for conformity assessment">
         <incoming>Flow_MS_3</incoming>
         <outgoing>Flow_MS_4</outgoing>
      </task>
      <endEvent id="MS_End" name="End">
         <extensionElements>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="14.0" y="-8.0"/>
         </extensionElements>
         <incoming>Flow_MS_4</incoming>
      </endEvent>

      <sequenceFlow id="Flow_MS_1" sourceRef="MS_Start" targetRef="MS_AND_Split" isImmediate="true"/>
      <!-- Path 1 Flows -->
      <sequenceFlow id="Flow_MS_P1" sourceRef="MS_AND_Split" targetRef="MS_Task_Assess1" isImmediate="true"/>
      <sequenceFlow id="Flow_MS_A1" sourceRef="MS_Task_Assess1" targetRef="MS_XOR_Assess1" isImmediate="true"/>
      <sequenceFlow id="Flow_MS_A2" name="yes" sourceRef="MS_XOR_Assess1" targetRef="MS_Task_ProvidePrio" isImmediate="true"/>
      <sequenceFlow id="Flow_MS_A3" name="no" sourceRef="MS_XOR_Assess1" targetRef="MS_XOR_Merge1" isImmediate="true"/>
      <sequenceFlow id="Flow_MS_A4" sourceRef="MS_Task_ProvidePrio" targetRef="MS_XOR_Merge1" isImmediate="true"/>
      <sequenceFlow id="Flow_MS_A5" sourceRef="MS_XOR_Merge1" targetRef="MS_Task_Assess2" isImmediate="true"/>
      <sequenceFlow id="Flow_MS_A6" sourceRef="MS_Task_Assess2" targetRef="MS_XOR_Assess2" isImmediate="true"/>
      <sequenceFlow id="Flow_MS_A7" name="yes" sourceRef="MS_XOR_Assess2" targetRef="MS_Task_NotPreclude" isImmediate="true"/>
      <sequenceFlow id="Flow_MS_A8" name="no" sourceRef="MS_XOR_Assess2" targetRef="MS_XOR_Merge2" isImmediate="true"/>
      <sequenceFlow id="Flow_MS_A9" sourceRef="MS_Task_NotPreclude" targetRef="MS_XOR_Merge2" isImmediate="true"/>
      <sequenceFlow id="Flow_MS_EndP1" sourceRef="MS_XOR_Merge2" targetRef="MS_AND_Merge" isImmediate="true"/>
      <!-- Path 2 Flows -->
      <sequenceFlow id="Flow_MS_P2" sourceRef="MS_AND_Split" targetRef="MS_Task_Organise" isImmediate="true"/>
      <sequenceFlow id="Flow_MS_EndP2" sourceRef="MS_Task_Organise" targetRef="MS_AND_Merge" isImmediate="true"/>
      <!-- Path 3 Flows -->
      <sequenceFlow id="Flow_MS_P3" sourceRef="MS_AND_Split" targetRef="MS_Task_Utilise" isImmediate="true"/>
      <sequenceFlow id="Flow_MS_B1" sourceRef="MS_Task_Utilise" targetRef="MS_Task_Assess3" isImmediate="true"/>
      <sequenceFlow id="Flow_MS_B2" sourceRef="MS_Task_Assess3" targetRef="MS_XOR_Assess3" isImmediate="true"/>
      <sequenceFlow id="Flow_MS_B3" name="yes" sourceRef="MS_XOR_Assess3" targetRef="MS_Task_Establish" isImmediate="true"/>
      <sequenceFlow id="Flow_MS_B4" name="no" sourceRef="MS_XOR_Assess3" targetRef="MS_XOR_Merge3" isImmediate="true"/>
      <sequenceFlow id="Flow_MS_B5" sourceRef="MS_Task_Establish" targetRef="MS_XOR_Merge3" isImmediate="true"/>
      <sequenceFlow id="Flow_MS_B6" sourceRef="MS_XOR_Merge3" targetRef="MS_Task_ProvideAdv" isImmediate="true"/>
      <sequenceFlow id="Flow_MS_B7" sourceRef="MS_Task_ProvideAdv" targetRef="MS_Task_Respond" isImmediate="true"/>
      <sequenceFlow id="Flow_MS_EndP3" sourceRef="MS_Task_Respond" targetRef="MS_AND_Merge" isImmediate="true"/>
      <!-- Path 4 Flows -->
      <sequenceFlow id="Flow_MS_P4" sourceRef="MS_AND_Split" targetRef="MS_Task_Facilitate" isImmediate="true"/>
      <sequenceFlow id="Flow_MS_EndP4" sourceRef="MS_Task_Facilitate" targetRef="MS_AND_Merge" isImmediate="true"/>
      <!-- Post Merge Flows -->
      <sequenceFlow id="Flow_MS_Merge1" sourceRef="MS_AND_Merge" targetRef="MS_Catch_Needs" isImmediate="true"/>
      <sequenceFlow id="Flow_MS_2" sourceRef="MS_Catch_Needs" targetRef="MS_Task_TakeInto" isImmediate="true"/>
      <sequenceFlow id="Flow_MS_3" sourceRef="MS_Task_TakeInto" targetRef="MS_Task_SetFees" isImmediate="true"/>
      <sequenceFlow id="Flow_MS_4" sourceRef="MS_Task_SetFees" targetRef="MS_End" isImmediate="true"/>
   </process>

   <!-- BOARD PROCESS -->
   <process id="Process_BD" isClosed="false" isExecutable="false" name="Board" processType="None">
      <laneSet id="LaneSet_BD">
         <lane id="Lane_BD">
            <flowNodeRef>BD_Start</flowNodeRef>
            <flowNodeRef>BD_XOR_Split</flowNodeRef>
            <flowNodeRef>BD_Task_ReqTemp</flowNodeRef>
            <flowNodeRef>BD_XOR_Merge</flowNodeRef>
            <flowNodeRef>BD_Task_Transmit</flowNodeRef>
            <flowNodeRef>BD_End</flowNodeRef>
         </lane>
      </laneSet>
      <startEvent id="BD_Start" name="Start">
         <extensionElements>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/>
         </extensionElements>
         <outgoing>Flow_BD_1</outgoing>
      </startEvent>
      <exclusiveGateway id="BD_XOR_Split" name="if required?" gatewayDirection="Diverging" isMarkerVisible="true">
         <extensionElements>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/>
         </extensionElements>
         <incoming>Flow_BD_1</incoming>
         <outgoing>Flow_BD_2</outgoing>
         <outgoing>Flow_BD_3</outgoing>
      </exclusiveGateway>
      <task id="BD_Task_ReqTemp" name="Request standardised templates">
         <incoming>Flow_BD_2</incoming>
         <outgoing>Flow_BD_4</outgoing>
      </task>
      <exclusiveGateway id="BD_XOR_Merge" gatewayDirection="Converging" isMarkerVisible="true">
         <incoming>Flow_BD_3</incoming>
         <incoming>Flow_BD_4</incoming>
         <outgoing>Flow_BD_5</outgoing>
      </exclusiveGateway>
      <task id="BD_Task_Transmit" name="Transmit the request for standardised templates to the AI Office">
         <incoming>Flow_BD_5</incoming>
         <outgoing>Flow_BD_6</outgoing>
      </task>
      <endEvent id="BD_End" name="End">
         <extensionElements>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="14.0" y="-8.0"/>
         </extensionElements>
         <incoming>Flow_BD_6</incoming>
      </endEvent>
      <sequenceFlow id="Flow_BD_1" sourceRef="BD_Start" targetRef="BD_XOR_Split" isImmediate="true"/>
      <sequenceFlow id="Flow_BD_2" name="yes" sourceRef="BD_XOR_Split" targetRef="BD_Task_ReqTemp" isImmediate="true"/>
      <sequenceFlow id="Flow_BD_3" name="no" sourceRef="BD_XOR_Split" targetRef="BD_XOR_Merge" isImmediate="true"/>
      <sequenceFlow id="Flow_BD_4" sourceRef="BD_Task_ReqTemp" targetRef="BD_XOR_Merge" isImmediate="true"/>
      <sequenceFlow id="Flow_BD_5" sourceRef="BD_XOR_Merge" targetRef="BD_Task_Transmit" isImmediate="true"/>
      <sequenceFlow id="Flow_BD_6" sourceRef="BD_Task_Transmit" targetRef="BD_End" isImmediate="true"/>
   </process>

   <!-- AI OFFICE PROCESS -->
   <process id="Process_AIO" isClosed="false" isExecutable="false" name="AI Office" processType="None">
      <laneSet id="LaneSet_AIO">
         <lane id="Lane_AIO">
            <flowNodeRef>AIO_Start</flowNodeRef>
            <flowNodeRef>AIO_AND_Split</flowNodeRef>
            <flowNodeRef>AIO_Catch_Req</flowNodeRef>
            <flowNodeRef>AIO_Task_Assess</flowNodeRef>
            <flowNodeRef>AIO_XOR_Assess</flowNodeRef>
            <flowNodeRef>AIO_Task_Provide</flowNodeRef>
            <flowNodeRef>AIO_XOR_Merge</flowNodeRef>
            <flowNodeRef>AIO_Task_Develop</flowNodeRef>
            <flowNodeRef>AIO_Task_Maintain</flowNodeRef>
            <flowNodeRef>AIO_Task_Organise</flowNodeRef>
            <flowNodeRef>AIO_Task_Evaluate</flowNodeRef>
            <flowNodeRef>AIO_Task_Promote</flowNodeRef>
            <flowNodeRef>AIO_AND_Merge</flowNodeRef>
            <flowNodeRef>AIO_End</flowNodeRef>
         </lane>
      </laneSet>
      <startEvent id="AIO_Start" name="Start">
         <extensionElements>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/>
         </extensionElements>
         <outgoing>Flow_AIO_1</outgoing>
      </startEvent>
      <parallelGateway id="AIO_AND_Split" gatewayDirection="Diverging">
         <incoming>Flow_AIO_1</incoming>
         <outgoing>Flow_AIO_P1</outgoing>
         <outgoing>Flow_AIO_P2</outgoing>
         <outgoing>Flow_AIO_P3</outgoing>
         <outgoing>Flow_AIO_P4</outgoing>
      </parallelGateway>

      <!-- AIO Path 1 -->
      <intermediateCatchEvent id="AIO_Catch_Req" name="Upon receiving the request for standardised templates">
         <extensionElements>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/>
         </extensionElements>
         <incoming>Flow_AIO_P1</incoming>
         <outgoing>Flow_AIO_A1</outgoing>
         <messageEventDefinition id="MsgDef_AIO_Req"/>
      </intermediateCatchEvent>
      <task id="AIO_Task_Assess" name="Assess whether templates are specified by the Board in its request">
         <incoming>Flow_AIO_A1</incoming>
         <outgoing>Flow_AIO_A2</outgoing>
      </task>
      <exclusiveGateway id="AIO_XOR_Assess" name="templates specified?" gatewayDirection="Diverging" isMarkerVisible="true">
         <extensionElements>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/>
         </extensionElements>
         <incoming>Flow_AIO_A2</incoming>
         <outgoing>Flow_AIO_A3</outgoing>
         <outgoing>Flow_AIO_A4</outgoing>
      </exclusiveGateway>
      <task id="AIO_Task_Provide" name="Provide standardised templates">
