            <incoming>sf_cm5</incoming>
            <outgoing>sf_cm6</outgoing>
            <outgoing>sf_cm7</outgoing>
        </exclusiveGateway>
        <task id="t3_comm" name="adopt implementing acts...">
            <incoming>sf_cm6</incoming>
            <outgoing>sf_cm8</outgoing>
        </task>
        <task id="t4_comm" name="exchange advice and cooperate with the Cooperation Group on the draft">
            <incoming>sf_cm7</incoming>
            <incoming>sf_cm8</incoming>
            <outgoing>sf_cm9</outgoing>
        </task>
        <task id="t5_comm" name="assess whether when adopting implementing acts under paragraph 11">
            <incoming>sf_cm9</incoming>
            <outgoing>sf_cm10</outgoing>
        </task>
        <exclusiveGateway id="gw3_comm" gatewayDirection="Diverging" isMarkerVisible="true" name="If true?">
