            <incoming>sf_cm10</incoming>
            <outgoing>sf_cm11</outgoing>
            <outgoing>sf_cm12</outgoing>
        </exclusiveGateway>
        <task id="t6_comm" name="adopt implementing acts">
            <incoming>sf_cm11</incoming>
            <outgoing>sf_cm13</outgoing>
        </task>
        <endEvent id="end_comm" name="implementing acts adoption">
            <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
            <incoming>sf_cm12</incoming>
            <incoming>sf_cm13</incoming>
        </endEvent>

