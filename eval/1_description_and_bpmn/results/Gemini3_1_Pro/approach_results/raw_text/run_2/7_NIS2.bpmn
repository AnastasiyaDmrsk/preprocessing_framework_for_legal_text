    <collaboration id="collab_1">
        <participant id="p_eie" name="Essential and Important Entity" processRef="pr_eie" />
        <participant id="p_tsp" name="Trust Service Provider" processRef="pr_tsp" />
        <participant id="p_ca" name="Competent Authority" processRef="pr_ca" />
        <participant id="p_csirt" name="CSIRT" processRef="pr_csirt" />
        <participant id="p_spoc" name="Single Point of Contact" processRef="pr_spoc" />
        <participant id="p_enisa" name="ENISA" processRef="pr_enisa" />
        <participant id="p_comm" name="Commission" processRef="pr_comm" />
        <participant id="p_cg" name="Cooperation Group" processRef="pr_cg" />

        <messageFlow id="mf1" sourceRef="t2_eie" targetRef="catch_notif_csirt" />
        <messageFlow id="mf2" sourceRef="t2_eie" targetRef="catch_notif_ca" />
        <messageFlow id="mf3" sourceRef="t9_eie" targetRef="p_csirt" />
        <messageFlow id="mf4" sourceRef="t9_eie" targetRef="p_ca" />
        <messageFlow id="mf5" sourceRef="t10_eie" targetRef="p_csirt" />
        <messageFlow id="mf6" sourceRef="t10_eie" targetRef="p_ca" />
        <messageFlow id="mf7" sourceRef="t15_eie" targetRef="catch_tech_csirt" />
        
        <messageFlow id="mf8" sourceRef="t1_tsp" targetRef="p_csirt" />
        <messageFlow id="mf9" sourceRef="t1_tsp" targetRef="p_ca" />
        
        <messageFlow id="mf10" sourceRef="t6_ca" targetRef="p_csirt" />
        
        <messageFlow id="mf11" sourceRef="t3_csirt" targetRef="catch_req_spoc" />
        <messageFlow id="mf12" sourceRef="t4_csirt" targetRef="catch_req_eie" />
        <messageFlow id="mf13" sourceRef="t13_csirt" targetRef="p_enisa" />
        <messageFlow id="mf14" sourceRef="t19_csirt" targetRef="p_spoc" />
        
        <messageFlow id="mf15" sourceRef="t3_spoc" targetRef="catch_rep_enisa" />
        <messageFlow id="mf16" sourceRef="t2_enisa" targetRef="p_cg" />
        <messageFlow id="mf17" sourceRef="t4_comm" targetRef="catch_draft_cg" />
    </collaboration>

    <process id="pr_eie" isClosed="false" isExecutable="false" name="Essential and Important Entity">
        <startEvent id="start_eie" name="significant incident that has a significant impact on the provision of services">
            <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
            <outgoing>sf_e1</outgoing>
        </startEvent>
        <task id="t1_eie" name="assess whether an incident has caused or is capable of causing severe operational disruption or financial loss...">
            <incoming>sf_e1</incoming>
            <outgoing>sf_e2</outgoing>
        </task>
        <exclusiveGateway id="gw1_eie" gatewayDirection="Diverging" isMarkerVisible="true" name="If true?">
            <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
            <incoming>sf_e2</incoming>
            <outgoing>sf_e3</outgoing>
            <outgoing>sf_e4</outgoing>
        </exclusiveGateway>
        <task id="t2_eie" name="notify the CSIRT or the competent authority">
            <incoming>sf_e3</incoming>
            <outgoing>sf_e5</outgoing>
        </task>
        <task id="t3_eie" name="assess whether an incident has caused... or if the significant incident is likely to adversely affect...">
            <incoming>sf_e4</incoming>
            <incoming>sf_e5</incoming>
            <outgoing>sf_e6</outgoing>
        </task>
        <exclusiveGateway id="gw2_eie" gatewayDirection="Diverging" isMarkerVisible="true" name="If true?">
            <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
            <incoming>sf_e6</incoming>
            <outgoing>sf_e7</outgoing>
            <outgoing>sf_e8</outgoing>
        </exclusiveGateway>
        <task id="t4_eie" name="notify the recipients of their services">
            <incoming>sf_e7</incoming>
            <outgoing>sf_e9</outgoing>
        </task>
        <task id="t5_eie" name="assess whether to determine any cross-border impact of the incident">
            <incoming>sf_e8</incoming>
            <incoming>sf_e9</incoming>
            <outgoing>sf_e10</outgoing>
        </task>
        <exclusiveGateway id="gw3_eie" gatewayDirection="Diverging" isMarkerVisible="true" name="If true?">
            <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
            <incoming>sf_e10</incoming>
            <outgoing>sf_e11</outgoing>
            <outgoing>sf_e12</outgoing>
        </exclusiveGateway>
        <task id="t6_eie" name="report any information">
            <incoming>sf_e11</incoming>
            <outgoing>sf_e13</outgoing>
        </task>
        <task id="t7_eie" name="assess whether applicable">
            <incoming>sf_e12</incoming>
            <incoming>sf_e13</incoming>
            <outgoing>sf_e14</outgoing>
        </task>
        <exclusiveGateway id="gw4_eie" gatewayDirection="Diverging" isMarkerVisible="true" name="If true?">
            <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
            <incoming>sf_e14</incoming>
            <outgoing>sf_e15</outgoing>
            <outgoing>sf_e16</outgoing>
        </exclusiveGateway>
        <task id="t8_eie" name="communicate to the recipients any measures or remedies to take">
            <incoming>sf_e15</incoming>
            <outgoing>sf_e17</outgoing>
        </task>
        <task id="t9_eie" name="submit to the CSIRT or the competent authority an early warning">
            <incoming>sf_e16</incoming>
            <incoming>sf_e17</incoming>
            <outgoing>sf_e18</outgoing>
        </task>
        <task id="t10_eie" name="submit to the CSIRT or the competent authority an incident notification">
            <incoming>sf_e18</incoming>
            <outgoing>sf_e19</outgoing>
        </task>
        <intermediateCatchEvent id="catch_req_eie" name="Receive request from CSIRT/CA">
            <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
            <incoming>sf_e19</incoming>
            <outgoing>sf_e20</outgoing>
            <messageEventDefinition id="med_1"/>
        </intermediateCatchEvent>
        <task id="t11_eie" name="submit an intermediate report on relevant status updates">
            <incoming>sf_e20</incoming>
            <outgoing>sf_e21</outgoing>
        </task>
        <task id="t12_eie" name="submit to the CSIRT or the competent authority a final report">
            <incoming>sf_e21</incoming>
            <outgoing>sf_e22</outgoing>
        </task>
        <task id="t13_eie" name="assess whether in the event of an ongoing incident at the time of the submission...">
            <incoming>sf_e22</incoming>
            <outgoing>sf_e23</outgoing>
        </task>
        <exclusiveGateway id="gw5_eie" gatewayDirection="Diverging" isMarkerVisible="true" name="If true?">
            <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
            <incoming>sf_e23</incoming>
            <outgoing>sf_e24</outgoing>
            <outgoing>sf_e25</outgoing>
        </exclusiveGateway>
        <task id="t14_eie" name="provide a progress report at the time of submission...">
            <incoming>sf_e24</incoming>
            <outgoing>sf_e26</outgoing>
        </task>
        <exclusiveGateway id="gw6_eie" gatewayDirection="Diverging" isMarkerVisible="true" name="May request tech support?">
            <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
            <incoming>sf_e25</incoming>
            <incoming>sf_e26</incoming>
            <outgoing>sf_e27</outgoing>
            <outgoing>sf_e28</outgoing>
        </exclusiveGateway>
        <task id="t15_eie" name="request additional technical support">
            <incoming>sf_e27</incoming>
            <outgoing>sf_e29</outgoing>
        </task>
        <exclusiveGateway id="gw7_eie" gatewayDirection="Diverging" isMarkerVisible="true" name="May inform public?">
            <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
            <incoming>sf_e28</incoming>
            <incoming>sf_e29</incoming>
            <outgoing>sf_e30</outgoing>
            <outgoing>sf_e31</outgoing>
        </exclusiveGateway>
        <task id="t16_eie" name="inform the public about the significant incident">
            <incoming>sf_e30</incoming>
            <outgoing>sf_e32</outgoing>
        </task>
        <endEvent id="end_eie" name="reporting completion">
            <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
            <incoming>sf_e31</incoming>
            <incoming>sf_e32</incoming>
        </endEvent>

        <!-- EIE Flows -->
        <sequenceFlow id="sf_e1" isImmediate="true" sourceRef="start_eie" targetRef="t1_eie" />
        <sequenceFlow id="sf_e2" isImmediate="true" sourceRef="t1_eie" targetRef="gw1_eie" />
        <sequenceFlow id="sf_e3" name="yes" isImmediate="true" sourceRef="gw1_eie" targetRef="t2_eie" />
        <sequenceFlow id="sf_e4" name="no" isImmediate="true" sourceRef="gw1_eie" targetRef="t3_eie" />
        <sequenceFlow id="sf_e5" isImmediate="true" sourceRef="t2_eie" targetRef="t3_eie" />
        <sequenceFlow id="sf_e6" isImmediate="true" sourceRef="t3_eie" targetRef="gw2_eie" />
        <sequenceFlow id="sf_e7" name="yes" isImmediate="true" sourceRef="gw2_eie" targetRef="t4_eie" />
        <sequenceFlow id="sf_e8" name="no" isImmediate="true" sourceRef="gw2_eie" targetRef="t5_eie" />
        <sequenceFlow id="sf_e9" isImmediate="true" sourceRef="t4_eie" targetRef="t5_eie" />
        <sequenceFlow id="sf_e10" isImmediate="true" sourceRef="t5_eie" targetRef="gw3_eie" />
        <sequenceFlow id="sf_e11" name="yes" isImmediate="true" sourceRef="gw3_eie" targetRef="t6_eie" />
        <sequenceFlow id="sf_e12" name="no" isImmediate="true" sourceRef="gw3_eie" targetRef="t7_eie" />
        <sequenceFlow id="sf_e13" isImmediate="true" sourceRef="t6_eie" targetRef="t7_eie" />
        <sequenceFlow id="sf_e14" isImmediate="true" sourceRef="t7_eie" targetRef="gw4_eie" />
        <sequenceFlow id="sf_e15" name="yes" isImmediate="true" sourceRef="gw4_eie" targetRef="t8_eie" />
        <sequenceFlow id="sf_e16" name="no" isImmediate="true" sourceRef="gw4_eie" targetRef="t9_eie" />
        <sequenceFlow id="sf_e17" isImmediate="true" sourceRef="t8_eie" targetRef="t9_eie" />
        <sequenceFlow id="sf_e18" isImmediate="true" sourceRef="t9_eie" targetRef="t10_eie" />
        <sequenceFlow id="sf_e19" isImmediate="true" sourceRef="t10_eie" targetRef="catch_req_eie" />
        <sequenceFlow id="sf_e20" isImmediate="true" sourceRef="catch_req_eie" targetRef="t11_eie" />
        <sequenceFlow id="sf_e21" isImmediate="true" sourceRef="t11_eie" targetRef="t12_eie" />
        <sequenceFlow id="sf_e22" isImmediate="true" sourceRef="t12_eie" targetRef="t13_eie" />
        <sequenceFlow id="sf_e23" isImmediate="true" sourceRef="t13_eie" targetRef="gw5_eie" />
        <sequenceFlow id="sf_e24" name="yes" isImmediate="true" sourceRef="gw5_eie" targetRef="t14_eie" />
        <sequenceFlow id="sf_e25" name="no" isImmediate="true" sourceRef="gw5_eie" targetRef="gw6_eie" />
        <sequenceFlow id="sf_e26" isImmediate="true" sourceRef="t14_eie" targetRef="gw6_eie" />
        <sequenceFlow id="sf_e27" name="yes" isImmediate="true" sourceRef="gw6_eie" targetRef="t15_eie" />
        <sequenceFlow id="sf_e28" name="no" isImmediate="true" sourceRef="gw6_eie" targetRef="gw7_eie" />
        <sequenceFlow id="sf_e29" isImmediate="true" sourceRef="t15_eie" targetRef="gw7_eie" />
        <sequenceFlow id="sf_e30" name="yes" isImmediate="true" sourceRef="gw7_eie" targetRef="t16_eie" />
        <sequenceFlow id="sf_e31" name="no" isImmediate="true" sourceRef="gw7_eie" targetRef="end_eie" />
        <sequenceFlow id="sf_e32" isImmediate="true" sourceRef="t16_eie" targetRef="end_eie" />
    </process>

    <process id="pr_tsp" isClosed="false" isExecutable="false" name="Trust Service Provider">
        <startEvent id="start_tsp" name="Start">
            <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
            <outgoing>sf_t1</outgoing>
        </startEvent>
        <task id="t1_tsp" name="notify the CSIRT or the competent authority...">
            <incoming>sf_t1</incoming>
            <outgoing>sf_t2</outgoing>
        </task>
        <exclusiveGateway id="gw1_tsp" gatewayDirection="Diverging" isMarkerVisible="true" name="May request guidance?">
            <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
            <incoming>sf_t2</incoming>
            <outgoing>sf_t3</outgoing>
            <outgoing>sf_t4</outgoing>
        </exclusiveGateway>
        <task id="t2_tsp" name="request guidance or operational advice...">
            <incoming>sf_t3</incoming>
            <outgoing>sf_t5</outgoing>
        </task>
        <endEvent id="end_tsp" name="notification completion">
            <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
            <incoming>sf_t4</incoming>
            <incoming>sf_t5</incoming>
        </endEvent>

        <!-- TSP Flows -->
        <sequenceFlow id="sf_t1" isImmediate="true" sourceRef="start_tsp" targetRef="t1_tsp" />
        <sequenceFlow id="sf_t2" isImmediate="true" sourceRef="t1_tsp" targetRef="gw1_tsp" />
        <sequenceFlow id="sf_t3" name="yes" isImmediate="true" sourceRef="gw1_tsp" targetRef="t2_tsp" />
        <sequenceFlow id="sf_t4" name="no" isImmediate="true" sourceRef="gw1_tsp" targetRef="end_tsp" />
        <sequenceFlow id="sf_t5" isImmediate="true" sourceRef="t2_tsp" targetRef="end_tsp" />
    </process>

    <process id="pr_ca" isClosed="false" isExecutable="false" name="Competent Authority">
        <startEvent id="start_ca" name="Start">
            <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
            <outgoing>sf_ca1</outgoing>
        </startEvent>
        <task id="t1_ca" name="ensure that entities notify CSIRT">
            <incoming>sf_ca1</incoming>
            <outgoing>sf_ca2</outgoing>
        </task>
        <task id="t2_ca" name="ensure entities report information enabling determination of cross-border impact">
            <incoming>sf_ca2</incoming>
            <outgoing>sf_ca3</outgoing>
        </task>
        <task id="t3_ca" name="assess whether entities notify competent authority">
            <incoming>sf_ca3</incoming>
            <outgoing>sf_ca4</outgoing>
        </task>
        <exclusiveGateway id="gw1_ca" gatewayDirection="Diverging" isMarkerVisible="true" name="If true?">
            <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
            <incoming>sf_ca4</incoming>
            <outgoing>sf_ca5</outgoing>
            <outgoing>sf_ca6</outgoing>
        </exclusiveGateway>
        <task id="t4_ca" name="ensure that competent authority forwards notification to CSIRT upon receipt">
            <incoming>sf_ca5</incoming>
            <outgoing>sf_ca7</outgoing>
        </task>
        <intermediateCatchEvent id="catch_notif_ca" name="Receive notification">
            <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
            <incoming>sf_ca6</incoming>
            <incoming>sf_ca7</incoming>
            <outgoing>sf_ca8</outgoing>
            <messageEventDefinition id="med_2"/>
        </intermediateCatchEvent>
        <task id="t5_ca" name="assess whether the entities concerned notify the competent authority">
            <incoming>sf_ca8</incoming>
            <outgoing>sf_ca9</outgoing>
        </task>
        <exclusiveGateway id="gw2_ca" gatewayDirection="Diverging" isMarkerVisible="true" name="If true?">
            <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
            <incoming>sf_ca9</incoming>
            <outgoing>sf_ca10</outgoing>
            <outgoing>sf_ca11</outgoing>
        </exclusiveGateway>
        <task id="t6_ca" name="forward the notification to the CSIRT">
            <incoming>sf_ca10</incoming>
            <outgoing>sf_ca12</outgoing>
        </task>
        <task id="t7_ca" name="assess whether in the case of a cross-border or cross-sectoral significant incident">
            <incoming>sf_ca11</incoming>
            <incoming>sf_ca12</incoming>
            <outgoing>sf_ca13</outgoing>
        </task>
        <exclusiveGateway id="gw3_ca" gatewayDirection="Diverging" isMarkerVisible="true" name="If true?">
            <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
            <incoming>sf_ca13</incoming>
            <outgoing>sf_ca14</outgoing>
            <outgoing>sf_ca15</outgoing>
        </exclusiveGateway>
        <task id="t8_ca" name="ensure that single points of contact are provided with information">
            <incoming>sf_ca14</incoming>
            <outgoing>sf_ca16</outgoing>
        </task>
        <task id="t9_ca" name="assess whether applicable">
            <incoming>sf_ca15</incoming>
            <incoming>sf_ca16</incoming>
            <outgoing>sf_ca17</outgoing>
        </task>
        <exclusiveGateway id="gw4_ca" gatewayDirection="Diverging" isMarkerVisible="true" name="If true?">
            <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
            <incoming>sf_ca17</incoming>
            <outgoing>sf_ca18</outgoing>
            <outgoing>sf_ca19</outgoing>
        </exclusiveGateway>
        <task id="t10_ca" name="ensure that entities communicate measures to recipients affected">
            <incoming>sf_ca18</incoming>
            <outgoing>sf_ca20</outgoing>
        </task>
        <task id="t11_ca" name="ensure that entities submit early warning to CSIRT">
            <incoming>sf_ca19</incoming>
            <incoming>sf_ca20</incoming>
            <outgoing>sf_ca21</outgoing>
        </task>
        <task id="t12_ca" name="ensure that entities submit incident notification to CSIRT">
            <incoming>sf_ca21</incoming>
            <outgoing>sf_ca22</outgoing>
        </task>
        <task id="t13_ca" name="ensure that entities submit intermediate report to CSIRT">
            <incoming>sf_ca22</incoming>
            <outgoing>sf_ca23</outgoing>
        </task>
        <task id="t14_ca" name="ensure that entities submit final report to CSIRT">
            <incoming>sf_ca23</incoming>
            <outgoing>sf_ca24</outgoing>
        </task>
        <task id="t15_ca" name="assess whether incident is ongoing at time of submission of final report">
            <incoming>sf_ca24</incoming>
            <outgoing>sf_ca25</outgoing>
        </task>
        <exclusiveGateway id="gw5_ca" gatewayDirection="Diverging" isMarkerVisible="true" name="If true?">
            <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
            <incoming>sf_ca25</incoming>
            <outgoing>sf_ca26</outgoing>
            <outgoing>sf_ca27</outgoing>
        </exclusiveGateway>
        <task id="t16_ca" name="ensure that entities provide progress report and final report for ongoing incidents">
            <incoming>sf_ca26</incoming>
            <outgoing>sf_ca28</outgoing>
        </task>
        <task id="t17_ca" name="assess whether the CSIRT is not the initial recipient of the notification and upon request">
            <incoming>sf_ca27</incoming>
            <incoming>sf_ca28</incoming>
            <outgoing>sf_ca29</outgoing>
        </task>
        <exclusiveGateway id="gw6_ca" gatewayDirection="Diverging" isMarkerVisible="true" name="If true?">
            <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
            <incoming>sf_ca29</incoming>
            <outgoing>sf_ca30</outgoing>
            <outgoing>sf_ca31</outgoing>
        </exclusiveGateway>
        <task id="t18_ca" name="cooperate with the CSIRT on guidance">
            <incoming>sf_ca30</incoming>
            <outgoing>sf_ca32</outgoing>
        </task>
        <endEvent id="end_ca" name="oversight completion">
            <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
            <incoming>sf_ca31</incoming>
            <incoming>sf_ca32</incoming>
        </endEvent>

        <!-- CA Flows -->
        <sequenceFlow id="sf_ca1" isImmediate="true" sourceRef="start_ca" targetRef="t1_ca" />
        <sequenceFlow id="sf_ca2" isImmediate="true" sourceRef="t1_ca" targetRef="t2_ca" />
