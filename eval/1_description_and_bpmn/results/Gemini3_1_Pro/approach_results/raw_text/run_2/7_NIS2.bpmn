        </startEvent>
        <exclusiveGateway id="gw1_comm" gatewayDirection="Diverging" isMarkerVisible="true" name="May adopt acts?">
            <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
            <incoming>sf_cm1</incoming>
            <outgoing>sf_cm2</outgoing>
            <outgoing>sf_cm3</outgoing>
        </exclusiveGateway>
        <task id="t1_comm" name="adopt implementing acts, specifying the type of information, format...">
            <incoming>sf_cm2</incoming>
            <outgoing>sf_cm4</outgoing>
        </task>
        <task id="t2_comm" name="adopt implementing acts, specifying the cases in which an incident shall be considered significant">
            <incoming>sf_cm3</incoming>
            <incoming>sf_cm4</incoming>
            <outgoing>sf_cm5</outgoing>
        </task>
        <exclusiveGateway id="gw2_comm" gatewayDirection="Diverging" isMarkerVisible="true" name="May adopt acts for EIE?">
