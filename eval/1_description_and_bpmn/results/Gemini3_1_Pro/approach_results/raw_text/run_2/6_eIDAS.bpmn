<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" 
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" 
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" 
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" 
             xmlns:signavio="http://www.signavio.com" 
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
             exporter="Signavio Process Editor, http://www.signavio.com" 
             exporterVersion="19.2.2" 
             expressionLanguage="http://www.w3.org/TR/XPath" 
             id="sid-main" 
             targetNamespace="http://www.signavio.com" 
             typeLanguage="http://www.w3.org/2001/XMLSchema" 
             xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd">
   
   <collaboration id="collab_1">
      <participant id="pool_ms" name="Member State" processRef="proc_ms"/>
      <participant id="pool_sb" name="Supervisory Body" processRef="proc_sb"/>
      <participant id="pool_comm" name="Commission" processRef="proc_comm"/>
      <participant id="pool_asb" name="Another Supervisory Body" processRef="proc_asb"/>
      <participant id="pool_cab" name="Conformity Assessment Body" processRef="proc_cab"/>
      <participant id="pool_qtsp" name="Qualified Trust Service Provider or Non-qualified Trust Service Provider" processRef="proc_qtsp"/>
      
      <messageFlow id="mf_ms_comm" name="" sourceRef="task_ms_3" targetRef="pool_comm"/>
      <messageFlow id="mf_ms_sb" name="" sourceRef="task_ms_4" targetRef="catch_sb_1"/>
      <messageFlow id="mf_sb_cab" name="" sourceRef="task_sb_p6" targetRef="catch_cab_1"/>
      <messageFlow id="mf_sb_qtsp" name="" sourceRef="task_sb_p11" targetRef="catch_qtsp_1"/>
      <messageFlow id="mf_sb_comm" name="" sourceRef="task_sb_19" targetRef="catch_comm_1"/>
      <messageFlow id="mf_asb_sb" name="" sourceRef="task_asb_1" targetRef="catch_sb_2"/>
      <messageFlow id="mf_qtsp_sb" name="" sourceRef="task_qtsp_5" targetRef="catch_sb_3"/>
      <messageFlow id="mf_sb_qtsp_inform" name="" sourceRef="task_sb_25" targetRef="pool_qtsp"/>
   </collaboration>

   <!-- Member State Process -->
   <process id="proc_ms" isClosed="false" isExecutable="false" name="Member State" processType="None">
      <laneSet id="ls_ms">
         <lane id="lane_ms">
            <flowNodeRef>start_ms</flowNodeRef>
            <flowNodeRef>pg_ms_div</flowNodeRef>
            <flowNodeRef>task_ms_1</flowNodeRef>
            <flowNodeRef>task_ms_2</flowNodeRef>
            <flowNodeRef>pg_ms_conv</flowNodeRef>
            <flowNodeRef>task_ms_3</flowNodeRef>
            <flowNodeRef>task_ms_4</flowNodeRef>
            <flowNodeRef>task_ms_5</flowNodeRef>
            <flowNodeRef>xor_ms_div</flowNodeRef>
            <flowNodeRef>pg_ms_div2</flowNodeRef>
            <flowNodeRef>task_ms_6</flowNodeRef>
            <flowNodeRef>task_ms_7</flowNodeRef>
            <flowNodeRef>pg_ms_conv2</flowNodeRef>
            <flowNodeRef>xor_ms_conv</flowNodeRef>
            <flowNodeRef>end_ms</flowNodeRef>
         </lane>
      </laneSet>
      <startEvent id="start_ms" name="need to establish supervision for trust services">
         <outgoing>seq_ms_1</outgoing>
      </startEvent>
      <parallelGateway gatewayDirection="Diverging" id="pg_ms_div" name="">
         <incoming>seq_ms_1</incoming>
         <outgoing>seq_ms_2</outgoing>
         <outgoing>seq_ms_3</outgoing>
      </parallelGateway>
      <task completionQuantity="1" id="task_ms_1" isForCompensation="false" name="designate a supervisory body" startQuantity="1">
         <incoming>seq_ms_2</incoming>
         <outgoing>seq_ms_4</outgoing>
      </task>
      <task completionQuantity="1" id="task_ms_2" isForCompensation="false" name="give the necessary powers and adequate resources to a supervisory body" startQuantity="1">
         <incoming>seq_ms_3</incoming>
         <outgoing>seq_ms_5</outgoing>
      </task>
      <parallelGateway gatewayDirection="Converging" id="pg_ms_conv" name="">
         <incoming>seq_ms_4</incoming>
         <incoming>seq_ms_5</incoming>
         <outgoing>seq_ms_6</outgoing>
      </parallelGateway>
      <task completionQuantity="1" id="task_ms_3" isForCompensation="false" name="notify to the Commission the names and the addresses of the supervisory bodies" startQuantity="1">
         <incoming>seq_ms_6</incoming>
         <outgoing>seq_ms_7</outgoing>
      </task>
      <task completionQuantity="1" id="task_ms_4" isForCompensation="false" name="require the supervisory body to establish, maintain and update a trust infrastructure if trust infrastructure is required" startQuantity="1">
         <incoming>seq_ms_7</incoming>
         <outgoing>seq_ms_8</outgoing>
      </task>
      <task completionQuantity="1" id="task_ms_5" isForCompensation="false" name="authorise their supervisory bodies to carry out joint investigations if needed" startQuantity="1">
         <incoming>seq_ms_8</incoming>
         <outgoing>seq_ms_9</outgoing>
      </task>
      <exclusiveGateway gatewayDirection="Diverging" id="xor_ms_div" isMarkerVisible="true" name="assess whether Member States authorise their supervisory bodies to carry out joint investigations">
         <incoming>seq_ms_9</incoming>
         <outgoing>seq_ms_10</outgoing>
         <outgoing>seq_ms_11</outgoing>
      </exclusiveGateway>
      <parallelGateway gatewayDirection="Diverging" id="pg_ms_div2" name="">
         <incoming>seq_ms_10</incoming>
         <outgoing>seq_ms_12</outgoing>
         <outgoing>seq_ms_13</outgoing>
      </parallelGateway>
      <task completionQuantity="1" id="task_ms_6" isForCompensation="false" name="agree upon the arrangements and procedures for such joint actions" startQuantity="1">
         <incoming>seq_ms_12</incoming>
         <outgoing>seq_ms_14</outgoing>
      </task>
      <task completionQuantity="1" id="task_ms_7" isForCompensation="false" name="establish the arrangements and procedures for such joint actions" startQuantity="1">
         <incoming>seq_ms_13</incoming>
         <outgoing>seq_ms_15</outgoing>
      </task>
      <parallelGateway gatewayDirection="Converging" id="pg_ms_conv2" name="">
         <incoming>seq_ms_14</incoming>
         <incoming>seq_ms_15</incoming>
         <outgoing>seq_ms_16</outgoing>
      </parallelGateway>
      <exclusiveGateway gatewayDirection="Converging" id="xor_ms_conv" isMarkerVisible="true" name="">
         <incoming>seq_ms_16</incoming>
         <incoming>seq_ms_11</incoming>
         <outgoing>seq_ms_17</outgoing>
      </exclusiveGateway>
      <endEvent id="end_ms" name="Member State supervision established end event">
         <incoming>seq_ms_17</incoming>
      </endEvent>
      <sequenceFlow id="seq_ms_1" isImmediate="true" sourceRef="start_ms" targetRef="pg_ms_div"/>
      <sequenceFlow id="seq_ms_2" isImmediate="true" sourceRef="pg_ms_div" targetRef="task_ms_1"/>
      <sequenceFlow id="seq_ms_3" isImmediate="true" sourceRef="pg_ms_div" targetRef="task_ms_2"/>
      <sequenceFlow id="seq_ms_4" isImmediate="true" sourceRef="task_ms_1" targetRef="pg_ms_conv"/>
      <sequenceFlow id="seq_ms_5" isImmediate="true" sourceRef="task_ms_2" targetRef="pg_ms_conv"/>
      <sequenceFlow id="seq_ms_6" isImmediate="true" sourceRef="pg_ms_conv" targetRef="task_ms_3"/>
      <sequenceFlow id="seq_ms_7" isImmediate="true" sourceRef="task_ms_3" targetRef="task_ms_4"/>
      <sequenceFlow id="seq_ms_8" isImmediate="true" sourceRef="task_ms_4" targetRef="task_ms_5"/>
      <sequenceFlow id="seq_ms_9" isImmediate="true" sourceRef="task_ms_5" targetRef="xor_ms_div"/>
      <sequenceFlow id="seq_ms_10" isImmediate="true" name="If Member States authorise their supervisory bodies to carry out joint investigations" sourceRef="xor_ms_div" targetRef="pg_ms_div2"/>
      <sequenceFlow id="seq_ms_11" isImmediate="true" name="" sourceRef="xor_ms_div" targetRef="xor_ms_conv"/>
      <sequenceFlow id="seq_ms_12" isImmediate="true" sourceRef="pg_ms_div2" targetRef="task_ms_6"/>
      <sequenceFlow id="seq_ms_13" isImmediate="true" sourceRef="pg_ms_div2" targetRef="task_ms_7"/>
      <sequenceFlow id="seq_ms_14" isImmediate="true" sourceRef="task_ms_6" targetRef="pg_ms_conv2"/>
      <sequenceFlow id="seq_ms_15" isImmediate="true" sourceRef="task_ms_7" targetRef="pg_ms_conv2"/>
      <sequenceFlow id="seq_ms_16" isImmediate="true" sourceRef="pg_ms_conv2" targetRef="xor_ms_conv"/>
      <sequenceFlow id="seq_ms_17" isImmediate="true" sourceRef="xor_ms_conv" targetRef="end_ms"/>
   </process>

   <!-- Supervisory Body Process -->
   <process id="proc_sb" isClosed="false" isExecutable="false" name="Supervisory Body" processType="None">
      <laneSet id="ls_sb">
         <lane id="lane_sb">
            <flowNodeRef>start_sb</flowNodeRef>
            <flowNodeRef>task_sb_1</flowNodeRef>
            <flowNodeRef>xor_sb_div1</flowNodeRef>
            <flowNodeRef>task_sb_2</flowNodeRef>
            <flowNodeRef>xor_sb_conv1</flowNodeRef>
            <flowNodeRef>pg_sb_div</flowNodeRef>
            <flowNodeRef>task_sb_p1</flowNodeRef>
            <flowNodeRef>task_sb_p2</flowNodeRef>
            <flowNodeRef>task_sb_p3</flowNodeRef>
            <flowNodeRef>task_sb_p4</flowNodeRef>
            <flowNodeRef>task_sb_p5</flowNodeRef>
            <flowNodeRef>task_sb_p6</flowNodeRef>
            <flowNodeRef>task_sb_p7</flowNodeRef>
            <flowNodeRef>task_sb_p8</flowNodeRef>
            <flowNodeRef>task_sb_p9</flowNodeRef>
            <flowNodeRef>task_sb_p10</flowNodeRef>
            <flowNodeRef>task_sb_p11</flowNodeRef>
            <flowNodeRef>pg_sb_conv</flowNodeRef>
            <flowNodeRef>xor_sb_div2</flowNodeRef>
            <flowNodeRef>task_sb_14</flowNodeRef>
            <flowNodeRef>xor_sb_conv2</flowNodeRef>
            <flowNodeRef>xor_sb_div3</flowNodeRef>
            <flowNodeRef>task_sb_15</flowNodeRef>
            <flowNodeRef>xor_sb_conv3</flowNodeRef>
            <flowNodeRef>catch_sb_1</flowNodeRef>
            <flowNodeRef>task_sb_16</flowNodeRef>
            <flowNodeRef>task_sb_17</flowNodeRef>
            <flowNodeRef>task_sb_18</flowNodeRef>
            <flowNodeRef>task_sb_19</flowNodeRef>
            <flowNodeRef>catch_sb_2</flowNodeRef>
            <flowNodeRef>xor_sb_div4</flowNodeRef>
            <flowNodeRef>task_sb_20</flowNodeRef>
            <flowNodeRef>task_sb_21</flowNodeRef>
            <flowNodeRef>xor_sb_conv4</flowNodeRef>
            <flowNodeRef>task_sb_22</flowNodeRef>
            <flowNodeRef>catch_sb_3</flowNodeRef>
            <flowNodeRef>xor_sb_div5</flowNodeRef>
            <flowNodeRef>task_sb_23</flowNodeRef>
            <flowNodeRef>xor_sb_conv5</flowNodeRef>
            <flowNodeRef>xor_sb_div6</flowNodeRef>
            <flowNodeRef>pg_sb_div3</flowNodeRef>
            <flowNodeRef>task_sb_24</flowNodeRef>
            <flowNodeRef>task_sb_25</flowNodeRef>
            <flowNodeRef>pg_sb_conv3</flowNodeRef>
            <flowNodeRef>xor_sb_conv6</flowNodeRef>
            <flowNodeRef>task_sb_26</flowNodeRef>
            <flowNodeRef>end_sb</flowNodeRef>
         </lane>
      </laneSet>
      <startEvent id="start_sb" name="Start">
         <outgoing>seq_sb_1</outgoing>
      </startEvent>
      <task completionQuantity="1" id="task_sb_1" isForCompensation="false" name="supervise qualified trust service providers" startQuantity="1">
         <incoming>seq_sb_1</incoming>
         <outgoing>seq_sb_2</outgoing>
      </task>
      <exclusiveGateway gatewayDirection="Diverging" id="xor_sb_div1" isMarkerVisible="true" name="assess whether when informed that those do not meet the requirements">
         <incoming>seq_sb_2</incoming>
         <outgoing>seq_sb_3</outgoing>
         <outgoing>seq_sb_4</outgoing>
      </exclusiveGateway>
      <task completionQuantity="1" id="task_sb_2" isForCompensation="false" name="take action in relation to non-qualified trust service providers" startQuantity="1">
         <incoming>seq_sb_3</incoming>
         <outgoing>seq_sb_5</outgoing>
      </task>
      <exclusiveGateway gatewayDirection="Converging" id="xor_sb_conv1" isMarkerVisible="true" name="">
         <incoming>seq_sb_5</incoming>
         <incoming>seq_sb_4</incoming>
         <outgoing>seq_sb_6</outgoing>
      </exclusiveGateway>
      <parallelGateway gatewayDirection="Diverging" id="pg_sb_div" name="">
         <incoming>seq_sb_6</incoming>
         <outgoing>seq_sb_p1_in</outgoing>
         <outgoing>seq_sb_p2_in</outgoing>
         <outgoing>seq_sb_p3_in</outgoing>
         <outgoing>seq_sb_p4_in</outgoing>
         <outgoing>seq_sb_p5_in</outgoing>
         <outgoing>seq_sb_p6_in</outgoing>
         <outgoing>seq_sb_p7_in</outgoing>
         <outgoing>seq_sb_p8_in</outgoing>
         <outgoing>seq_sb_p9_in</outgoing>
         <outgoing>seq_sb_p10_in</outgoing>
         <outgoing>seq_sb_p11_in</outgoing>
      </parallelGateway>
      <task id="task_sb_p1" name="cooperate with other supervisory bodies">
         <incoming>seq_sb_p1_in</incoming>
         <outgoing>seq_sb_p1_out</outgoing>
      </task>
      <task id="task_sb_p2" name="provide other supervisory bodies with assistance">
         <incoming>seq_sb_p2_in</incoming>
         <outgoing>seq_sb_p2_out</outgoing>
      </task>
      <task id="task_sb_p3" name="analyse the conformity assessment reports">
         <incoming>seq_sb_p3_in</incoming>
         <outgoing>seq_sb_p3_out</outgoing>
      </task>
      <task id="task_sb_p4" name="inform other supervisory bodies and the public about breaches of security or loss of integrity">
         <incoming>seq_sb_p4_in</incoming>
         <outgoing>seq_sb_p4_out</outgoing>
      </task>
      <task id="task_sb_p5" name="carry out audits">
         <incoming>seq_sb_p5_in</incoming>
         <outgoing>seq_sb_p5_out</outgoing>
      </task>
      <task id="task_sb_p6" name="request a conformity assessment body to perform a conformity assessment">
         <incoming>seq_sb_p6_in</incoming>
         <outgoing>seq_sb_p6_out</outgoing>
      </task>
      <task id="task_sb_p7" name="cooperate with the data protection authorities">
         <incoming>seq_sb_p7_in</incoming>
         <outgoing>seq_sb_p7_out</outgoing>
      </task>
      <task id="task_sb_p8" name="grant qualified status to trust service providers">
         <incoming>seq_sb_p8_in</incoming>
         <outgoing>seq_sb_p8_out</outgoing>
      </task>
      <task id="task_sb_p9" name="withdraw qualified status from trust service providers">
         <incoming>seq_sb_p9_in</incoming>
         <outgoing>seq_sb_p9_out</outgoing>
      </task>
      <task id="task_sb_p10" name="inform the body responsible for the national trusted list about the status change, except where that body is also the supervisory body">
         <incoming>seq_sb_p10_in</incoming>
         <outgoing>seq_sb_p10_out</outgoing>
      </task>
      <task id="task_sb_p11" name="require that trust service providers remedy any failure to fulfil the requirements">
         <incoming>seq_sb_p11_in</incoming>
         <outgoing>seq_sb_p11_out</outgoing>
      </task>
      <parallelGateway gatewayDirection="Converging" id="pg_sb_conv" name="">
         <incoming>seq_sb_p1_out</incoming>
         <incoming>seq_sb_p2_out</incoming>
         <incoming>seq_sb_p3_out</incoming>
         <incoming>seq_sb_p4_out</incoming>
         <incoming>seq_sb_p5_out</incoming>
         <incoming>seq_sb_p6_out</incoming>
         <incoming>seq_sb_p7_out</incoming>
         <incoming>seq_sb_p8_out</incoming>
         <incoming>seq_sb_p9_out</incoming>
         <incoming>seq_sb_p10_out</incoming>
         <incoming>seq_sb_p11_out</incoming>
         <outgoing>seq_sb_7</outgoing>
      </parallelGateway>
      <exclusiveGateway gatewayDirection="Diverging" id="xor_sb_div2" isMarkerVisible="true" name="assess whether where personal data protection rules have been breached">
         <incoming>seq_sb_7</incoming>
         <outgoing>seq_sb_8</outgoing>
         <outgoing>seq_sb_9</outgoing>
      </exclusiveGateway>
      <task id="task_sb_14" name="inform the data protection authorities about the results">
         <incoming>seq_sb_8</incoming>
         <outgoing>seq_sb_10</outgoing>
      </task>
      <exclusiveGateway gatewayDirection="Converging" id="xor_sb_conv2" isMarkerVisible="true" name="">
         <incoming>seq_sb_10</incoming>
         <incoming>seq_sb_9</incoming>
         <outgoing>seq_sb_11</outgoing>
      </exclusiveGateway>
      <exclusiveGateway gatewayDirection="Diverging" id="xor_sb_div3" isMarkerVisible="true" name="assess whether in cases where the qualified trust service provider ceases its activities">
         <incoming>seq_sb_11</incoming>
         <outgoing>seq_sb_12</outgoing>
         <outgoing>seq_sb_13</outgoing>
      </exclusiveGateway>
      <task id="task_sb_15" name="verify the existence and correct application of provisions on termination plans">
         <incoming>seq_sb_12</incoming>
         <outgoing>seq_sb_14</outgoing>
      </task>
      <exclusiveGateway gatewayDirection="Converging" id="xor_sb_conv3" isMarkerVisible="true" name="">
         <incoming>seq_sb_14</incoming>
         <incoming>seq_sb_13</incoming>
         <outgoing>seq_sb_15</outgoing>
      </exclusiveGateway>
      <intermediateCatchEvent id="catch_sb_1" name="Upon receiving a requirement from the Member State">
         <incoming>seq_sb_15</incoming>
         <outgoing>seq_sb_16</outgoing>
         <messageEventDefinition id="msg_sb_1"/>
      </intermediateCatchEvent>
      <task id="task_sb_16" name="establish a trust infrastructure if required by Member State">
         <incoming>seq_sb_16</incoming>
         <outgoing>seq_sb_17</outgoing>
      </task>
      <task id="task_sb_17" name="maintain a trust infrastructure if required by Member State">
         <incoming>seq_sb_17</incoming>
         <outgoing>seq_sb_18</outgoing>
      </task>
      <task id="task_sb_18" name="update a trust infrastructure if required by Member State">
         <incoming>seq_sb_18</incoming>
         <outgoing>seq_sb_19</outgoing>
      </task>
      <task id="task_sb_19" name="By 31 March each year, submit to the Commission a report on its previous year's main activities and a summary of breach notifications">
         <incoming>seq_sb_19</incoming>
         <outgoing>seq_sb_20</outgoing>
      </task>
      <intermediateCatchEvent id="catch_sb_2" name="Upon receipt of a justified request from another supervisory body">
         <incoming>seq_sb_20</incoming>
         <outgoing>seq_sb_21</outgoing>
         <messageEventDefinition id="msg_sb_2"/>
      </intermediateCatchEvent>
      <exclusiveGateway gatewayDirection="Diverging" id="xor_sb_div4" isMarkerVisible="true" name="assess whether the supervisory body is not competent...">
         <incoming>seq_sb_21</incoming>
         <outgoing>seq_sb_22</outgoing>
         <outgoing>seq_sb_23</outgoing>
      </exclusiveGateway>
      <task id="task_sb_20" name="refuse assistance">
         <incoming>seq_sb_22</incoming>
         <outgoing>seq_sb_24</outgoing>
      </task>
      <task id="task_sb_21" name="provide assistance">
         <incoming>seq_sb_23</incoming>
         <outgoing>seq_sb_25</outgoing>
      </task>
      <exclusiveGateway gatewayDirection="Converging" id="xor_sb_conv4" isMarkerVisible="true" name="">
         <incoming>seq_sb_24</incoming>
         <incoming>seq_sb_25</incoming>
         <outgoing>seq_sb_26</outgoing>
      </exclusiveGateway>
      <task id="task_sb_22" name="carry out joint investigations if authorised">
         <incoming>seq_sb_26</incoming>
         <outgoing>seq_sb_27</outgoing>
      </task>
      <intermediateCatchEvent id="catch_sb_3" name="Upon receiving a notification of a breach of security or loss of integrity">
         <incoming>seq_sb_27</incoming>
         <outgoing>seq_sb_28</outgoing>
         <messageEventDefinition id="msg_sb_3"/>
      </intermediateCatchEvent>
      <exclusiveGateway gatewayDirection="Diverging" id="xor_sb_div5" isMarkerVisible="true" name="assess whether if a breach of security or loss of integrity concerns two or more Member States">
         <incoming>seq_sb_28</incoming>
         <outgoing>seq_sb_29</outgoing>
         <outgoing>seq_sb_30</outgoing>
      </exclusiveGateway>
      <task id="task_sb_23" name="inform the supervisory bodies in other Member States concerned and ENISA of the significant incident">
         <incoming>seq_sb_29</incoming>
         <outgoing>seq_sb_31</outgoing>
      </task>
      <exclusiveGateway gatewayDirection="Converging" id="xor_sb_conv5" isMarkerVisible="true" name="">
         <incoming>seq_sb_31</incoming>
         <incoming>seq_sb_30</incoming>
         <outgoing>seq_sb_32</outgoing>
      </exclusiveGateway>
      <exclusiveGateway gatewayDirection="Diverging" id="xor_sb_div6" isMarkerVisible="true" name="assess whether if in the public interest">
         <incoming>seq_sb_32</incoming>
         <outgoing>seq_sb_33</outgoing>
         <outgoing>seq_sb_34</outgoing>
      </exclusiveGateway>
      <parallelGateway gatewayDirection="Diverging" id="pg_sb_div3" name="">
         <incoming>seq_sb_33</incoming>
         <outgoing>seq_sb_35</outgoing>
         <outgoing>seq_sb_36</outgoing>
      </parallelGateway>
      <task id="task_sb_24" name="inform the public about the breach of security or loss of integrity">
         <incoming>seq_sb_35</incoming>
         <outgoing>seq_sb_37</outgoing>
      </task>
      <task id="task_sb_25" name="require the trust service provider to inform the public about the breach">
         <incoming>seq_sb_36</incoming>
         <outgoing>seq_sb_38</outgoing>
      </task>
      <parallelGateway gatewayDirection="Converging" id="pg_sb_conv3" name="">
         <incoming>seq_sb_37</incoming>
         <incoming>seq_sb_38</incoming>
         <outgoing>seq_sb_39</outgoing>
      </parallelGateway>
      <exclusiveGateway gatewayDirection="Converging" id="xor_sb_conv6" isMarkerVisible="true" name="">
         <incoming>seq_sb_39</incoming>
         <incoming>seq_sb_34</incoming>
         <outgoing>seq_sb_40</outgoing>
      </exclusiveGateway>
      <task id="task_sb_26" name="Once a year, provide ENISA with a summary of notifications of breach">
         <incoming>seq_sb_40</incoming>
         <outgoing>seq_sb_41</outgoing>
      </task>
      <endEvent id="end_sb" name="supervision completed end event">
         <incoming>seq_sb_41</incoming>
      </endEvent>

      <sequenceFlow id="seq_sb_1" isImmediate="true" sourceRef="start_sb" targetRef="task_sb_1"/>
      <sequenceFlow id="seq_sb_2" isImmediate="true" sourceRef="task_sb_1" targetRef="xor_sb_div1"/>
      <sequenceFlow id="seq_sb_3" isImmediate="true" name="If when informed that those do not meet the requirements" sourceRef="xor_sb_div1" targetRef="task_sb_2"/>
      <sequenceFlow id="seq_sb_4" isImmediate="true" name="" sourceRef="xor_sb_div1" targetRef="xor_sb_conv1"/>
      <sequenceFlow id="seq_sb_5" isImmediate="true" sourceRef="task_sb_2" targetRef="xor_sb_conv1"/>
