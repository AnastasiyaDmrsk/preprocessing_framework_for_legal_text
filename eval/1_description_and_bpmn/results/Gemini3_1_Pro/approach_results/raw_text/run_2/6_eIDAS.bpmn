   <!-- Commission Process -->
   <process id="proc_comm" isClosed="false" isExecutable="false" name="Commission" processType="None">
      <laneSet id="ls_comm">
         <lane id="lane_comm">
            <flowNodeRef>start_comm</flowNodeRef>
            <flowNodeRef>catch_comm_1</flowNodeRef>
            <flowNodeRef>task_comm_1</flowNodeRef>
            <flowNodeRef>task_comm_2</flowNodeRef>
            <flowNodeRef>task_comm_3</flowNodeRef>
            <flowNodeRef>pg_comm_div</flowNodeRef>
            <flowNodeRef>task_comm_4</flowNodeRef>
            <flowNodeRef>task_comm_5</flowNodeRef>
            <flowNodeRef>pg_comm_conv</flowNodeRef>
            <flowNodeRef>end_comm</flowNodeRef>
         </lane>
      </laneSet>
      <startEvent id="start_comm" name="Start">
         <outgoing>seq_comm_1</outgoing>
      </startEvent>
      <intermediateCatchEvent id="catch_comm_1" name="Upon receiving the annual report">
         <incoming>seq_comm_1</incoming>
         <outgoing>seq_comm_2</outgoing>
         <messageEventDefinition id="msg_comm_1"/>
      </intermediateCatchEvent>
      <task id="task_comm_1" name="make the annual report available to Member States">
         <incoming>seq_comm_2</incoming>
         <outgoing>seq_comm_3</outgoing>
      </task>
      <task id="task_comm_2" name="define the formats and procedures for the report if adjustments needed">
         <incoming>seq_comm_3</incoming>
         <outgoing>seq_comm_4</outgoing>
      </task>
      <task id="task_comm_3" name="adopt those implementing acts">
         <incoming>seq_comm_4</incoming>
         <outgoing>seq_comm_5</outgoing>
      </task>
      <parallelGateway gatewayDirection="Diverging" id="pg_comm_div" name="">
         <incoming>seq_comm_5</incoming>
         <outgoing>seq_comm_6</outgoing>
         <outgoing>seq_comm_7</outgoing>
      </parallelGateway>
      <task id="task_comm_4" name="further specify the measures if specification is required">
         <incoming>seq_comm_6</incoming>
         <outgoing>seq_comm_8</outgoing>
      </task>
      <task id="task_comm_5" name="define the formats and procedures if specification is required">
         <incoming>seq_comm_7</incoming>
         <outgoing>seq_comm_9</outgoing>
      </task>
      <parallelGateway gatewayDirection="Converging" id="pg_comm_conv" name="">
         <incoming>seq_comm_8</incoming>
         <incoming>seq_comm_9</incoming>
         <outgoing>seq_comm_10</outgoing>
      </parallelGateway>
      <endEvent id="end_comm" name="Commission oversight completed end event">
         <incoming>seq_comm_10</incoming>
      </endEvent>

      <sequenceFlow id="seq_comm_1" isImmediate="true" sourceRef="start_comm" targetRef="catch_comm_1"/>
      <sequenceFlow id="seq_comm_2" isImmediate="true" sourceRef="catch_comm_1" targetRef="task_comm_1"/>
      <sequenceFlow id="seq_comm_3" isImmediate="true" sourceRef="task_comm_1" targetRef="task_comm_2"/>
      <sequenceFlow id="seq_comm_4" isImmediate="true" sourceRef="task_comm_2" targetRef="task_comm_3"/>
      <sequenceFlow id="seq_comm_5" isImmediate="true" sourceRef="task_comm_3" targetRef="pg_comm_div"/>
      <sequenceFlow id="seq_comm_6" isImmediate="true" sourceRef="pg_comm_div" targetRef="task_comm_4"/>
      <sequenceFlow id="seq_comm_7" isImmediate="true" sourceRef="pg_comm_div" targetRef="task_comm_5"/>
      <sequenceFlow id="seq_comm_8" isImmediate="true" sourceRef="task_comm_4" targetRef="pg_comm_conv"/>
      <sequenceFlow id="seq_comm_9" isImmediate="true" sourceRef="task_comm_5" targetRef="pg_comm_conv"/>
      <sequenceFlow id="seq_comm_10" isImmediate="true" sourceRef="pg_comm_conv" targetRef="end_comm"/>
   </process>

   <!-- Another Supervisory Body Process -->
   <process id="proc_asb" isClosed="false" isExecutable="false" name="Another Supervisory Body" processType="None">
      <laneSet id="ls_asb">
         <lane id="lane_asb">
            <flowNodeRef>start_asb</flowNodeRef>
