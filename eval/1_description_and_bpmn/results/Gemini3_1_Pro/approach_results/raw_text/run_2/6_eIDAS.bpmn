      <sequenceFlow id="seq_asb_3" isImmediate="true" sourceRef="task_asb_2" targetRef="end_asb"/>
   </process>

   <!-- Conformity Assessment Body Process -->
   <process id="proc_cab" isClosed="false" isExecutable="false" name="Conformity Assessment Body" processType="None">
      <laneSet id="ls_cab">
         <lane id="lane_cab">
            <flowNodeRef>start_cab</flowNodeRef>
