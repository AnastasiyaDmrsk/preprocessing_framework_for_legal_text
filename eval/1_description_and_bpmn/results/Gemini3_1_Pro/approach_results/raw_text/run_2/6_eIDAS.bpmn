            <flowNodeRef>task_qtsp_4</flowNodeRef>
            <flowNodeRef>xor_qtsp_div</flowNodeRef>
            <flowNodeRef>pg_qtsp_div2</flowNodeRef>
            <flowNodeRef>task_qtsp_5</flowNodeRef>
            <flowNodeRef>task_qtsp_6</flowNodeRef>
            <flowNodeRef>pg_qtsp_conv2</flowNodeRef>
            <flowNodeRef>xor_qtsp_conv</flowNodeRef>
            <flowNodeRef>task_qtsp_7</flowNodeRef>
            <flowNodeRef>end_qtsp</flowNodeRef>
         </lane>
      </laneSet>
      <startEvent id="start_qtsp" name="Start">
         <outgoing>seq_qtsp_1</outgoing>
      </startEvent>
      <parallelGateway gatewayDirection="Diverging" id="pg_qtsp_div1" name="">
         <incoming>seq_qtsp_1</incoming>
         <outgoing>seq_qtsp_2</outgoing>
         <outgoing>seq_qtsp_3</outgoing>
         <outgoing>seq_qtsp_4</outgoing>
      </parallelGateway>
      <task id="task_qtsp_1" name="take appropriate technical and organisational measures to manage the risks">
         <incoming>seq_qtsp_2</incoming>
         <outgoing>seq_qtsp_5</outgoing>
      </task>
      <task id="task_qtsp_2" name="take measures to prevent and minimise the impact of security incidents">
         <incoming>seq_qtsp_3</incoming>
         <outgoing>seq_qtsp_6</outgoing>
      </task>
      <task id="task_qtsp_3" name="inform stakeholders of the adverse effects of any security incidents">
         <incoming>seq_qtsp_4</incoming>
         <outgoing>seq_qtsp_7</outgoing>
      </task>
      <parallelGateway gatewayDirection="Converging" id="pg_qtsp_conv1" name="">
         <incoming>seq_qtsp_5</incoming>
         <incoming>seq_qtsp_6</incoming>
         <incoming>seq_qtsp_7</incoming>
         <outgoing>seq_qtsp_8</outgoing>
      </parallelGateway>
      <intermediateCatchEvent id="catch_qtsp_1" name="Upon receiving a requirement from the supervisory body">
         <incoming>seq_qtsp_8</incoming>
         <outgoing>seq_qtsp_9</outgoing>
         <messageEventDefinition id="msg_qtsp_1"/>
      </intermediateCatchEvent>
      <task id="task_qtsp_4" name="remedy failures to fulfil requirements if required by supervisory body">
         <incoming>seq_qtsp_9</incoming>
         <outgoing>seq_qtsp_10</outgoing>
      </task>
      <exclusiveGateway gatewayDirection="Diverging" id="xor_qtsp_div" isMarkerVisible="true" name="assess whether if the breach of security or loss of integrity has a significant impact...">
         <incoming>seq_qtsp_10</incoming>
         <outgoing>seq_qtsp_11</outgoing>
         <outgoing>seq_qtsp_12</outgoing>
      </exclusiveGateway>
      <parallelGateway gatewayDirection="Diverging" id="pg_qtsp_div2" name="">
         <incoming>seq_qtsp_11</incoming>
         <outgoing>seq_qtsp_13</outgoing>
         <outgoing>seq_qtsp_14</outgoing>
      </parallelGateway>
      <task id="task_qtsp_5" name="notify the supervisory body and other relevant bodies">
         <incoming>seq_qtsp_13</incoming>
         <outgoing>seq_qtsp_15</outgoing>
      </task>
      <task id="task_qtsp_6" name="notify the natural or legal person">
         <incoming>seq_qtsp_14</incoming>
         <outgoing>seq_qtsp_16</outgoing>
      </task>
      <parallelGateway gatewayDirection="Converging" id="pg_qtsp_conv2" name="">
         <incoming>seq_qtsp_15</incoming>
         <incoming>seq_qtsp_16</incoming>
         <outgoing>seq_qtsp_17</outgoing>
      </parallelGateway>
      <exclusiveGateway gatewayDirection="Converging" id="xor_qtsp_conv" isMarkerVisible="true" name="">
         <incoming>seq_qtsp_17</incoming>
         <incoming>seq_qtsp_12</incoming>
         <outgoing>seq_qtsp_18</outgoing>
      </exclusiveGateway>
      <task id="task_qtsp_7" name="inform the public about the breach of security or loss of integrity if in the public interest, except where trust service provider should inform public only if required by supervisory body">
         <incoming>seq_qtsp_18</incoming>
         <outgoing>seq_qtsp_19</outgoing>
      </task>
      <endEvent id="end_qtsp" name="trust service provision secured end event">
         <incoming>seq_qtsp_19</incoming>
      </endEvent>

      <sequenceFlow id="seq_qtsp_1" isImmediate="true" sourceRef="start_qtsp" targetRef="pg_qtsp_div1"/>
      <sequenceFlow id="seq_qtsp_2" isImmediate="true" sourceRef="pg_qtsp_div1" targetRef="task_qtsp_1"/>
      <sequenceFlow id="seq_qtsp_3" isImmediate="true" sourceRef="pg_qtsp_div1" targetRef="task_qtsp_2"/>
      <sequenceFlow id="seq_qtsp_4" isImmediate="true" sourceRef="pg_qtsp_div1" targetRef="task_qtsp_3"/>
      <sequenceFlow id="seq_qtsp_5" isImmediate="true" sourceRef="task_qtsp_1" targetRef="pg_qtsp_conv1"/>
      <sequenceFlow id="seq_qtsp_6" isImmediate="true" sourceRef="task_qtsp_2" targetRef="pg_qtsp_conv1"/>
      <sequenceFlow id="seq_qtsp_7" isImmediate="true" sourceRef="task_qtsp_3" targetRef="pg_qtsp_conv1"/>
      <sequenceFlow id="seq_qtsp_8" isImmediate="true" sourceRef="pg_qtsp_conv1" targetRef="catch_qtsp_1"/>
      <sequenceFlow id="seq_qtsp_9" isImmediate="true" sourceRef="catch_qtsp_1" targetRef="task_qtsp_4"/>
      <sequenceFlow id="seq_qtsp_10" isImmediate="true" sourceRef="task_qtsp_4" targetRef="xor_qtsp_div"/>
      <sequenceFlow id="seq_qtsp_11" isImmediate="true" name="If if the breach of security or loss of integrity has a significant impact on the trust service provided or on the personal data" sourceRef="xor_qtsp_div" targetRef="pg_qtsp_div2"/>
      <sequenceFlow id="seq_qtsp_12" isImmediate="true" name="" sourceRef="xor_qtsp_div" targetRef="xor_qtsp_conv"/>
      <sequenceFlow id="seq_qtsp_13" isImmediate="true" sourceRef="pg_qtsp_div2" targetRef="task_qtsp_5"/>
      <sequenceFlow id="seq_qtsp_14" isImmediate="true" sourceRef="pg_qtsp_div2" targetRef="task_qtsp_6"/>
      <sequenceFlow id="seq_qtsp_15" isImmediate="true" sourceRef="task_qtsp_5" targetRef="pg_qtsp_conv2"/>
      <sequenceFlow id="seq_qtsp_16" isImmediate="true" sourceRef="task_qtsp_6" targetRef="pg_qtsp_conv2"/>
      <sequenceFlow id="seq_qtsp_17" isImmediate="true" sourceRef="pg_qtsp_conv2" targetRef="xor_qtsp_conv"/>
      <sequenceFlow id="seq_qtsp_18" isImmediate="true" sourceRef="xor_qtsp_conv" targetRef="task_qtsp_7"/>
      <sequenceFlow id="seq_qtsp_19" isImmediate="true" sourceRef="task_qtsp_7" targetRef="end_qtsp"/>
   </process>

