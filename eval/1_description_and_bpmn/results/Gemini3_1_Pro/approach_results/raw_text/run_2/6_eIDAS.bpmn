      <startEvent id="start_cab" name="Start">
         <outgoing>seq_cab_1</outgoing>
      </startEvent>
      <intermediateCatchEvent id="catch_cab_1" name="Upon receiving a request from the Supervisory Body">
         <incoming>seq_cab_1</incoming>
         <outgoing>seq_cab_2</outgoing>
         <messageEventDefinition id="msg_cab_1"/>
      </intermediateCatchEvent>
      <task id="task_cab_1" name="perform a conformity assessment of the qualified trust service providers upon request">
         <incoming>seq_cab_2</incoming>
         <outgoing>seq_cab_3</outgoing>
      </task>
      <endEvent id="end_cab" name="conformity assessment completed end event">
         <incoming>seq_cab_3</incoming>
      </endEvent>

      <sequenceFlow id="seq_cab_1" isImmediate="true" sourceRef="start_cab" targetRef="catch_cab_1"/>
      <sequenceFlow id="seq_cab_2" isImmediate="true" sourceRef="catch_cab_1" targetRef="task_cab_1"/>
      <sequenceFlow id="seq_cab_3" isImmediate="true" sourceRef="task_cab_1" targetRef="end_cab"/>
   </process>

   <!-- QTSP Process -->
   <process id="proc_qtsp" isClosed="false" isExecutable="false" name="Qualified Trust Service Provider or Non-qualified Trust Service Provider" processType="None">
      <laneSet id="ls_qtsp">
         <lane id="lane_qtsp">
            <flowNodeRef>start_qtsp</flowNodeRef>
            <flowNodeRef>pg_qtsp_div1</flowNodeRef>
            <flowNodeRef>task_qtsp_1</flowNodeRef>
            <flowNodeRef>task_qtsp_2</flowNodeRef>
            <flowNodeRef>task_qtsp_3</flowNodeRef>
