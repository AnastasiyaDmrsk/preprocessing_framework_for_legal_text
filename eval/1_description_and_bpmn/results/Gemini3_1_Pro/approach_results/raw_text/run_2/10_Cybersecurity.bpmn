      <sequenceFlow id="ENISA_SF_25" isImmediate="true" sourceRef="ENISA_EBG_End" targetRef="ENISA_Catch_Rev"/>
      <sequenceFlow id="ENISA_SF_26" isImmediate="true" sourceRef="ENISA_Catch_Timer" targetRef="ENISA_T11_eval"/>
