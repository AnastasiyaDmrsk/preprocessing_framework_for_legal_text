      <sequenceFlow id="ENISA_SF_7" isImmediate="true" sourceRef="ENISA_T2_assess" targetRef="ENISA_GW_Refuse"/>
      <sequenceFlow id="ENISA_SF_8" isImmediate="true" name="refuse" sourceRef="ENISA_GW_Refuse" targetRef="ENISA_T3_take_dec"/>
      <sequenceFlow id="ENISA_SF_9" isImmediate="true" name="not refuse" sourceRef="ENISA_GW_Refuse" targetRef="ENISA_T5_prep_eccg"/>
      <sequenceFlow id="ENISA_SF_10" isImmediate="true" sourceRef="ENISA_T3_take_dec" targetRef="ENISA_T4_give_reas"/>
