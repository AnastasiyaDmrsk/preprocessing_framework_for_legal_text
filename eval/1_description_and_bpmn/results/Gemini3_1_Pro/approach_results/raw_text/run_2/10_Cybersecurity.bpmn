      <sequenceFlow id="ENISA_SF_12" isImmediate="true" sourceRef="ENISA_T5_prep_eccg" targetRef="ENISA_GW_Prep_Merge"/>
      <sequenceFlow id="ENISA_SF_13" isImmediate="true" sourceRef="ENISA_GW_Prep_Merge" targetRef="ENISA_AND_Split"/>
      <sequenceFlow id="ENISA_SF_14" isImmediate="true" sourceRef="ENISA_AND_Split" targetRef="ENISA_T6_consult"/>
      <sequenceFlow id="ENISA_SF_15" isImmediate="true" sourceRef="ENISA_AND_Split" targetRef="ENISA_T7_adhoc"/>
      <sequenceFlow id="ENISA_SF_16" isImmediate="true" sourceRef="ENISA_AND_Split" targetRef="ENISA_T8_coop"/>
