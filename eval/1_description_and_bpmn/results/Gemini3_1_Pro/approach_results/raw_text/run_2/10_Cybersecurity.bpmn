      <sequenceFlow id="ENISA_SF_29" isImmediate="true" sourceRef="ENISA_T12_rev" targetRef="ENISA_End_Rev"/>
   </process>

   <!-- PROCESS: Interested Party -->
   <process id="Proc_IP" isClosed="false" isExecutable="false" name="Interested Party" processType="None">
      <startEvent id="IP_Start" name="Start">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
         <outgoing>IP_SF_1</outgoing>
      </startEvent>

      <exclusiveGateway id="IP_GW_Split" name="Required?" gatewayDirection="Diverging" isMarkerVisible="true">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements>
         <incoming>IP_SF_1</incoming>
         <outgoing>IP_SF_2</outgoing>
         <outgoing>IP_SF_3</outgoing>
      </exclusiveGateway>

      <task id="IP_T1" name="Provide feedback">
         <incoming>IP_SF_2</incoming>
         <outgoing>IP_SF_4</outgoing>
      </task>

      <exclusiveGateway id="IP_GW_Merge" gatewayDirection="Converging" isMarkerVisible="true">
         <incoming>IP_SF_3</incoming>
         <incoming>IP_SF_4</incoming>
         <outgoing>IP_SF_5</outgoing>
      </exclusiveGateway>

      <task id="IP_T2" name="Transmit feedback to ENISA">
         <incoming>IP_SF_5</incoming>
         <outgoing>IP_SF_6</outgoing>
      </task>

      <endEvent id="IP_End" name="Feedback transmission end event">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
         <incoming>IP_SF_6</incoming>
      </endEvent>

      <sequenceFlow id="IP_SF_1" isImmediate="true" sourceRef="IP_Start" targetRef="IP_GW_Split"/>
      <sequenceFlow id="IP_SF_2" isImmediate="true" name="yes" sourceRef="IP_GW_Split" targetRef="IP_T1"/>
      <sequenceFlow id="IP_SF_3" isImmediate="true" name="no" sourceRef="IP_GW_Split" targetRef="IP_GW_Merge"/>
      <sequenceFlow id="IP_SF_4" isImmediate="true" sourceRef="IP_T1" targetRef="IP_GW_Merge"/>
      <sequenceFlow id="IP_SF_5" isImmediate="true" sourceRef="IP_GW_Merge" targetRef="IP_T2"/>
      <sequenceFlow id="IP_SF_6" isImmediate="true" sourceRef="IP_T2" targetRef="IP_End"/>
   </process>

