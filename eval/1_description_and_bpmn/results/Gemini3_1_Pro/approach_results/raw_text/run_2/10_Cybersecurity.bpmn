<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" 
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" 
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" 
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" 
             xmlns:signavio="http://www.signavio.com" 
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
             exporter="Signavio Process Editor" exporterVersion="19.2.2" 
             expressionLanguage="http://www.w3.org/TR/XPath" 
             id="sid-def-001" targetNamespace="http://www.signavio.com" 
             typeLanguage="http://www.w3.org/2001/XMLSchema" 
             xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd">
   
   <collaboration id="collab_1">
      <participant id="Part_Com" name="Commission" processRef="Proc_Com"/>
      <participant id="Part_ECCG" name="ECCG" processRef="Proc_ECCG"/>
      <participant id="Part_ENISA" name="ENISA" processRef="Proc_ENISA"/>
      <participant id="Part_IP" name="Interested Party" processRef="Proc_IP"/>
      
      <!-- Message Flows -->
      <messageFlow id="Msg_Com_Req" sourceRef="Com_T6" targetRef="ENISA_Catch_Com"/>
      <messageFlow id="Msg_ECCG_Req" sourceRef="ECCG_T3" targetRef="ENISA_Catch_ECCG"/>
      <messageFlow id="Msg_ECCG_Op" sourceRef="ECCG_T6" targetRef="ENISA_Catch_Op"/>
      <messageFlow id="Msg_ENISA_Scheme" sourceRef="ENISA_T10" targetRef="Com_Catch_Scheme"/>
      <messageFlow id="Msg_Com_Rev" sourceRef="Com_T9" targetRef="ENISA_Catch_Rev"/>
      <messageFlow id="Msg_ECCG_Rev" sourceRef="ECCG_T8" targetRef="ENISA_Catch_Rev"/>
      <messageFlow id="Msg_IP_Feedback" sourceRef="IP_T2" targetRef="Part_ENISA"/>
   </collaboration>

   <!-- PROCESS: Commission -->
   <process id="Proc_Com" isClosed="false" isExecutable="false" name="Commission" processType="None">
      <startEvent id="Com_Start" name="Need to prepare or review scheme">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
         <outgoing>Com_SF_1</outgoing>
      </startEvent>
      
      <exclusiveGateway id="Com_GW_Req_Split" name="Determine request type" gatewayDirection="Diverging" isMarkerVisible="true">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements>
         <incoming>Com_SF_1</incoming>
         <outgoing>Com_SF_2</outgoing>
         <outgoing>Com_SF_3</outgoing>
         <outgoing>Com_SF_4</outgoing>
         <outgoing>Com_SF_5</outgoing>
      </exclusiveGateway>
      
      <task id="Com_T1" name="Request ENISA to prepare candidate scheme">
         <incoming>Com_SF_2</incoming>
         <outgoing>Com_SF_6</outgoing>
      </task>
      <task id="Com_T2" name="Request ENISA to review existing scheme">
         <incoming>Com_SF_3</incoming>
         <outgoing>Com_SF_7</outgoing>
      </task>
      <task id="Com_T3" name="Request ENISA to prepare candidate scheme">
         <incoming>Com_SF_4</incoming>
         <outgoing>Com_SF_8</outgoing>
      </task>
      <task id="Com_T4" name="Request ENISA to review existing scheme">
         <incoming>Com_SF_5</incoming>
         <outgoing>Com_SF_9</outgoing>
      </task>
      
      <exclusiveGateway id="Com_GW_Req_Merge" gatewayDirection="Converging" isMarkerVisible="true">
         <incoming>Com_SF_6</incoming>
         <incoming>Com_SF_7</incoming>
         <incoming>Com_SF_8</incoming>
         <incoming>Com_SF_9</incoming>
         <outgoing>Com_SF_10</outgoing>
      </exclusiveGateway>

      <exclusiveGateway id="Com_GW_Upd_Split" name="Following request under paragraph 2?" gatewayDirection="Diverging" isMarkerVisible="true">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements>
         <incoming>Com_SF_10</incoming>
         <outgoing>Com_SF_11</outgoing>
         <outgoing>Com_SF_12</outgoing>
      </exclusiveGateway>

      <task id="Com_T5" name="Update Union rolling work programme">
         <incoming>Com_SF_11</incoming>
         <outgoing>Com_SF_13</outgoing>
      </task>

      <exclusiveGateway id="Com_GW_Upd_Merge" gatewayDirection="Converging" isMarkerVisible="true">
         <incoming>Com_SF_12</incoming>
         <incoming>Com_SF_13</incoming>
         <outgoing>Com_SF_14</outgoing>
      </exclusiveGateway>

      <task id="Com_T6" name="Transmit request to prepare/review to ENISA">
         <incoming>Com_SF_14</incoming>
         <outgoing>Com_SF_15</outgoing>
      </task>

      <intermediateCatchEvent id="Com_Catch_Scheme" name="Receive candidate scheme">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
         <incoming>Com_SF_15</incoming>
         <outgoing>Com_SF_16</outgoing>
         <messageEventDefinition id="MsgDef_Com_Scheme"/>
      </intermediateCatchEvent>

      <exclusiveGateway id="Com_GW_Action_Split" name="Action on scheme" gatewayDirection="Diverging" isMarkerVisible="true">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements>
         <incoming>Com_SF_16</incoming>
         <outgoing>Com_SF_17</outgoing>
         <outgoing>Com_SF_18</outgoing>
      </exclusiveGateway>

      <task id="Com_T7" name="Adopt implementing acts">
         <incoming>Com_SF_17</incoming>
         <outgoing>Com_SF_19</outgoing>
      </task>

      <task id="Com_T8" name="Request ENISA to start process of developing revised scheme">
         <incoming>Com_SF_18</incoming>
         <outgoing>Com_SF_20</outgoing>
      </task>
      
      <task id="Com_T9" name="Transmit request to start developing revised scheme to ENISA">
         <incoming>Com_SF_20</incoming>
         <outgoing>Com_SF_21</outgoing>
      </task>

      <exclusiveGateway id="Com_GW_Action_Merge" gatewayDirection="Converging" isMarkerVisible="true">
         <incoming>Com_SF_19</incoming>
         <incoming>Com_SF_21</incoming>
         <outgoing>Com_SF_22</outgoing>
      </exclusiveGateway>

      <endEvent id="Com_End" name="Implementing acts adoption or revision request end event">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
         <incoming>Com_SF_22</incoming>
      </endEvent>

      <sequenceFlow id="Com_SF_1" isImmediate="true" sourceRef="Com_Start" targetRef="Com_GW_Req_Split"/>
      <sequenceFlow id="Com_SF_2" isImmediate="true" name="prepare (rolling WP)" sourceRef="Com_GW_Req_Split" targetRef="Com_T1"/>
      <sequenceFlow id="Com_SF_3" isImmediate="true" name="review (rolling WP)" sourceRef="Com_GW_Req_Split" targetRef="Com_T2"/>
      <sequenceFlow id="Com_SF_4" isImmediate="true" name="prepare (justified)" sourceRef="Com_GW_Req_Split" targetRef="Com_T3"/>
      <sequenceFlow id="Com_SF_5" isImmediate="true" name="review (justified)" sourceRef="Com_GW_Req_Split" targetRef="Com_T4"/>
      <sequenceFlow id="Com_SF_6" isImmediate="true" sourceRef="Com_T1" targetRef="Com_GW_Req_Merge"/>
      <sequenceFlow id="Com_SF_7" isImmediate="true" sourceRef="Com_T2" targetRef="Com_GW_Req_Merge"/>
      <sequenceFlow id="Com_SF_8" isImmediate="true" sourceRef="Com_T3" targetRef="Com_GW_Req_Merge"/>
      <sequenceFlow id="Com_SF_9" isImmediate="true" sourceRef="Com_T4" targetRef="Com_GW_Req_Merge"/>
      <sequenceFlow id="Com_SF_10" isImmediate="true" sourceRef="Com_GW_Req_Merge" targetRef="Com_GW_Upd_Split"/>
      <sequenceFlow id="Com_SF_11" isImmediate="true" name="yes" sourceRef="Com_GW_Upd_Split" targetRef="Com_T5"/>
      <sequenceFlow id="Com_SF_12" isImmediate="true" name="no" sourceRef="Com_GW_Upd_Split" targetRef="Com_GW_Upd_Merge"/>
      <sequenceFlow id="Com_SF_13" isImmediate="true" sourceRef="Com_T5" targetRef="Com_GW_Upd_Merge"/>
      <sequenceFlow id="Com_SF_14" isImmediate="true" sourceRef="Com_GW_Upd_Merge" targetRef="Com_T6"/>
      <sequenceFlow id="Com_SF_15" isImmediate="true" sourceRef="Com_T6" targetRef="Com_Catch_Scheme"/>
      <sequenceFlow id="Com_SF_16" isImmediate="true" sourceRef="Com_Catch_Scheme" targetRef="Com_GW_Action_Split"/>
      <sequenceFlow id="Com_SF_17" isImmediate="true" name="adopt" sourceRef="Com_GW_Action_Split" targetRef="Com_T7"/>
      <sequenceFlow id="Com_SF_18" isImmediate="true" name="revise" sourceRef="Com_GW_Action_Split" targetRef="Com_T8"/>
      <sequenceFlow id="Com_SF_19" isImmediate="true" sourceRef="Com_T7" targetRef="Com_GW_Action_Merge"/>
      <sequenceFlow id="Com_SF_20" isImmediate="true" sourceRef="Com_T8" targetRef="Com_T9"/>
      <sequenceFlow id="Com_SF_21" isImmediate="true" sourceRef="Com_T9" targetRef="Com_GW_Action_Merge"/>
      <sequenceFlow id="Com_SF_22" isImmediate="true" sourceRef="Com_GW_Action_Merge" targetRef="Com_End"/>
   </process>

   <!-- PROCESS: ECCG -->
   <process id="Proc_ECCG" isClosed="false" isExecutable="false" name="ECCG" processType="None">
      <startEvent id="ECCG_Start" name="Start">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
         <outgoing>ECCG_SF_1</outgoing>
      </startEvent>

      <exclusiveGateway id="ECCG_GW_Req_Split" name="Type of request" gatewayDirection="Diverging" isMarkerVisible="true">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements>
         <incoming>ECCG_SF_1</incoming>
         <outgoing>ECCG_SF_2</outgoing>
         <outgoing>ECCG_SF_3</outgoing>
      </exclusiveGateway>

      <task id="ECCG_T1" name="Request ENISA to prepare candidate scheme">
         <incoming>ECCG_SF_2</incoming>
         <outgoing>ECCG_SF_4</outgoing>
      </task>
      
      <task id="ECCG_T2" name="Request ENISA to review existing scheme">
         <incoming>ECCG_SF_3</incoming>
         <outgoing>ECCG_SF_5</outgoing>
      </task>

      <exclusiveGateway id="ECCG_GW_Req_Merge" gatewayDirection="Converging" isMarkerVisible="true">
         <incoming>ECCG_SF_4</incoming>
         <incoming>ECCG_SF_5</incoming>
         <outgoing>ECCG_SF_6</outgoing>
      </exclusiveGateway>

      <task id="ECCG_T3" name="Transmit request to prepare/review to ENISA">
         <incoming>ECCG_SF_6</incoming>
         <outgoing>ECCG_SF_7</outgoing>
      </task>

      <task id="ECCG_T4" name="Provide ENISA with assistance and expert advice">
         <incoming>ECCG_SF_7</incoming>
         <outgoing>ECCG_SF_8</outgoing>
      </task>

      <task id="ECCG_T5" name="Adopt opinion on candidate scheme">
         <incoming>ECCG_SF_8</incoming>
         <outgoing>ECCG_SF_9</outgoing>
      </task>

      <task id="ECCG_T6" name="Transmit opinion on candidate scheme to ENISA">
         <incoming>ECCG_SF_9</incoming>
         <outgoing>ECCG_SF_10</outgoing>
      </task>

      <exclusiveGateway id="ECCG_GW_Rev_Split" name="Revision necessary?" gatewayDirection="Diverging" isMarkerVisible="true">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements>
         <incoming>ECCG_SF_10</incoming>
         <outgoing>ECCG_SF_11</outgoing>
         <outgoing>ECCG_SF_12</outgoing>
      </exclusiveGateway>

      <task id="ECCG_T7" name="Request ENISA to start process of developing revised scheme">
         <incoming>ECCG_SF_11</incoming>
         <outgoing>ECCG_SF_13</outgoing>
      </task>

      <task id="ECCG_T8" name="Transmit request to start developing to ENISA">
         <incoming>ECCG_SF_13</incoming>
         <outgoing>ECCG_SF_14</outgoing>
      </task>

      <exclusiveGateway id="ECCG_GW_Rev_Merge" gatewayDirection="Converging" isMarkerVisible="true">
         <incoming>ECCG_SF_12</incoming>
         <incoming>ECCG_SF_14</incoming>
         <outgoing>ECCG_SF_15</outgoing>
      </exclusiveGateway>

      <endEvent id="ECCG_End" name="Opinion transmission or revision request end event">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
         <incoming>ECCG_SF_15</incoming>
      </endEvent>

      <sequenceFlow id="ECCG_SF_1" isImmediate="true" sourceRef="ECCG_Start" targetRef="ECCG_GW_Req_Split"/>
      <sequenceFlow id="ECCG_SF_2" isImmediate="true" name="prepare" sourceRef="ECCG_GW_Req_Split" targetRef="ECCG_T1"/>
      <sequenceFlow id="ECCG_SF_3" isImmediate="true" name="review" sourceRef="ECCG_GW_Req_Split" targetRef="ECCG_T2"/>
      <sequenceFlow id="ECCG_SF_4" isImmediate="true" sourceRef="ECCG_T1" targetRef="ECCG_GW_Req_Merge"/>
      <sequenceFlow id="ECCG_SF_5" isImmediate="true" sourceRef="ECCG_T2" targetRef="ECCG_GW_Req_Merge"/>
      <sequenceFlow id="ECCG_SF_6" isImmediate="true" sourceRef="ECCG_GW_Req_Merge" targetRef="ECCG_T3"/>
      <sequenceFlow id="ECCG_SF_7" isImmediate="true" sourceRef="ECCG_T3" targetRef="ECCG_T4"/>
      <sequenceFlow id="ECCG_SF_8" isImmediate="true" sourceRef="ECCG_T4" targetRef="ECCG_T5"/>
      <sequenceFlow id="ECCG_SF_9" isImmediate="true" sourceRef="ECCG_T5" targetRef="ECCG_T6"/>
      <sequenceFlow id="ECCG_SF_10" isImmediate="true" sourceRef="ECCG_T6" targetRef="ECCG_GW_Rev_Split"/>
      <sequenceFlow id="ECCG_SF_11" isImmediate="true" name="yes" sourceRef="ECCG_GW_Rev_Split" targetRef="ECCG_T7"/>
      <sequenceFlow id="ECCG_SF_12" isImmediate="true" name="no" sourceRef="ECCG_GW_Rev_Split" targetRef="ECCG_GW_Rev_Merge"/>
      <sequenceFlow id="ECCG_SF_13" isImmediate="true" sourceRef="ECCG_T7" targetRef="ECCG_T8"/>
      <sequenceFlow id="ECCG_SF_14" isImmediate="true" sourceRef="ECCG_T8" targetRef="ECCG_GW_Rev_Merge"/>
      <sequenceFlow id="ECCG_SF_15" isImmediate="true" sourceRef="ECCG_GW_Rev_Merge" targetRef="ECCG_End"/>
   </process>

   <!-- PROCESS: ENISA -->
   <process id="Proc_ENISA" isClosed="false" isExecutable="false" name="ENISA" processType="None">
      <laneSet id="LaneSet_ENISA">
         <lane id="Lane_Main" name="Main">
            <flowNodeRef>ENISA_Start</flowNodeRef>
            <flowNodeRef>ENISA_EBG</flowNodeRef>
            <flowNodeRef>ENISA_Catch_Com</flowNodeRef>
            <flowNodeRef>ENISA_Catch_ECCG</flowNodeRef>
            <flowNodeRef>ENISA_T1_prep_com</flowNodeRef>
            <flowNodeRef>ENISA_T2_assess</flowNodeRef>
            <flowNodeRef>ENISA_GW_Refuse</flowNodeRef>
            <flowNodeRef>ENISA_T4_give_reas</flowNodeRef>
            <flowNodeRef>ENISA_End_Refuse</flowNodeRef>
            <flowNodeRef>ENISA_T5_prep_eccg</flowNodeRef>
            <flowNodeRef>ENISA_GW_Prep_Merge</flowNodeRef>
            <flowNodeRef>ENISA_AND_Split</flowNodeRef>
            <flowNodeRef>ENISA_T6_consult</flowNodeRef>
            <flowNodeRef>ENISA_T7_adhoc</flowNodeRef>
            <flowNodeRef>ENISA_T8_coop</flowNodeRef>
            <flowNodeRef>ENISA_AND_Merge</flowNodeRef>
            <flowNodeRef>ENISA_Catch_Op</flowNodeRef>
            <flowNodeRef>ENISA_T9_acct</flowNodeRef>
            <flowNodeRef>ENISA_T10_trans</flowNodeRef>
            <flowNodeRef>ENISA_EBG_End</flowNodeRef>
            <flowNodeRef>ENISA_Catch_Timer</flowNodeRef>
            <flowNodeRef>ENISA_T11_eval</flowNodeRef>
            <flowNodeRef>ENISA_End_Eval</flowNodeRef>
            <flowNodeRef>ENISA_Catch_Rev</flowNodeRef>
            <flowNodeRef>ENISA_T12_rev</flowNodeRef>
            <flowNodeRef>ENISA_End_Rev</flowNodeRef>
         </lane>
         <lane id="Lane_MB" name="Management Board">
            <flowNodeRef>ENISA_T3_take_dec</flowNodeRef>
         </lane>
      </laneSet>

      <startEvent id="ENISA_Start" name="Start">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
         <outgoing>ENISA_SF_1</outgoing>
      </startEvent>

      <eventBasedGateway id="ENISA_EBG" gatewayDirection="Diverging">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements>
         <incoming>ENISA_SF_1</incoming>
         <outgoing>ENISA_SF_2</outgoing>
         <outgoing>ENISA_SF_3</outgoing>
      </eventBasedGateway>

      <intermediateCatchEvent id="ENISA_Catch_Com" name="Receive Commission request">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
         <incoming>ENISA_SF_2</incoming>
         <outgoing>ENISA_SF_4</outgoing>
         <messageEventDefinition id="MsgDef_ENISA_Com"/>
      </intermediateCatchEvent>

      <intermediateCatchEvent id="ENISA_Catch_ECCG" name="Receive ECCG request">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
         <incoming>ENISA_SF_3</incoming>
         <outgoing>ENISA_SF_5</outgoing>
         <messageEventDefinition id="MsgDef_ENISA_ECCG"/>
      </intermediateCatchEvent>

      <task id="ENISA_T1_prep_com" name="Prepare candidate scheme">
         <incoming>ENISA_SF_4</incoming>
         <outgoing>ENISA_SF_6</outgoing>
      </task>

      <task id="ENISA_T2_assess" name="Assess whether to refuse request">
         <incoming>ENISA_SF_5</incoming>
         <outgoing>ENISA_SF_7</outgoing>
      </task>

      <exclusiveGateway id="ENISA_GW_Refuse" name="Refuse?" gatewayDirection="Diverging" isMarkerVisible="true">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements>
         <incoming>ENISA_SF_7</incoming>
         <outgoing>ENISA_SF_8</outgoing>
         <outgoing>ENISA_SF_9</outgoing>
      </exclusiveGateway>

      <task id="ENISA_T3_take_dec" name="Take decision to refuse request">
         <incoming>ENISA_SF_8</incoming>
         <outgoing>ENISA_SF_10</outgoing>
      </task>

      <task id="ENISA_T4_give_reas" name="Give reasons for refusal">
         <incoming>ENISA_SF_10</incoming>
         <outgoing>ENISA_SF_11</outgoing>
      </task>

      <endEvent id="ENISA_End_Refuse" name="Refusal end">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
         <incoming>ENISA_SF_11</incoming>
      </endEvent>

      <task id="ENISA_T5_prep_eccg" name="Prepare candidate scheme (ECCG)">
         <incoming>ENISA_SF_9</incoming>
         <outgoing>ENISA_SF_12</outgoing>
      </task>

      <exclusiveGateway id="ENISA_GW_Prep_Merge" gatewayDirection="Converging" isMarkerVisible="true">
         <incoming>ENISA_SF_6</incoming>
         <incoming>ENISA_SF_12</incoming>
         <outgoing>ENISA_SF_13</outgoing>
      </exclusiveGateway>

      <parallelGateway id="ENISA_AND_Split" gatewayDirection="Diverging">
         <incoming>ENISA_SF_13</incoming>
         <outgoing>ENISA_SF_14</outgoing>
         <outgoing>ENISA_SF_15</outgoing>
         <outgoing>ENISA_SF_16</outgoing>
      </parallelGateway>

      <task id="ENISA_T6_consult" name="Consult relevant stakeholders">
         <incoming>ENISA_SF_14</incoming>
         <outgoing>ENISA_SF_17</outgoing>
      </task>

      <task id="ENISA_T7_adhoc" name="Establish ad hoc working group">
         <incoming>ENISA_SF_15</incoming>
         <outgoing>ENISA_SF_18</outgoing>
      </task>

      <task id="ENISA_T8_coop" name="Cooperate with ECCG">
         <incoming>ENISA_SF_16</incoming>
         <outgoing>ENISA_SF_19</outgoing>
      </task>

      <parallelGateway id="ENISA_AND_Merge" gatewayDirection="Converging">
         <incoming>ENISA_SF_17</incoming>
         <incoming>ENISA_SF_18</incoming>
         <incoming>ENISA_SF_19</incoming>
         <outgoing>ENISA_SF_20</outgoing>
      </parallelGateway>

      <intermediateCatchEvent id="ENISA_Catch_Op" name="Receive opinion">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
         <incoming>ENISA_SF_20</incoming>
         <outgoing>ENISA_SF_21</outgoing>
         <messageEventDefinition id="MsgDef_ENISA_Op"/>
      </intermediateCatchEvent>

      <task id="ENISA_T9_acct" name="Take utmost account of opinion">
         <incoming>ENISA_SF_21</incoming>
         <outgoing>ENISA_SF_22</outgoing>
      </task>

      <task id="ENISA_T10_trans" name="Transmit candidate scheme to Commission">
         <incoming>ENISA_SF_22</incoming>
         <outgoing>ENISA_SF_23</outgoing>
      </task>

      <eventBasedGateway id="ENISA_EBG_End" gatewayDirection="Diverging">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements>
         <incoming>ENISA_SF_23</incoming>
         <outgoing>ENISA_SF_24</outgoing>
         <outgoing>ENISA_SF_25</outgoing>
      </eventBasedGateway>

      <intermediateCatchEvent id="ENISA_Catch_Timer" name="5 years passed">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
         <incoming>ENISA_SF_24</incoming>
         <outgoing>ENISA_SF_26</outgoing>
         <timerEventDefinition id="TimerDef_ENISA"/>
      </intermediateCatchEvent>

      <task id="ENISA_T11_eval" name="Evaluate adopted scheme">
         <incoming>ENISA_SF_26</incoming>
         <outgoing>ENISA_SF_27</outgoing>
      </task>

      <endEvent id="ENISA_End_Eval" name="Evaluation end event">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
         <incoming>ENISA_SF_27</incoming>
      </endEvent>

      <intermediateCatchEvent id="ENISA_Catch_Rev" name="Receive request to develop revised scheme">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
         <incoming>ENISA_SF_25</incoming>
         <outgoing>ENISA_SF_28</outgoing>
         <messageEventDefinition id="MsgDef_ENISA_Rev"/>
      </intermediateCatchEvent>

      <task id="ENISA_T12_rev" name="Start developing revised candidate scheme">
         <incoming>ENISA_SF_28</incoming>
         <outgoing>ENISA_SF_29</outgoing>
      </task>

      <endEvent id="ENISA_End_Rev" name="Scheme transmission end event">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
         <incoming>ENISA_SF_29</incoming>
      </endEvent>

      <sequenceFlow id="ENISA_SF_1" isImmediate="true" sourceRef="ENISA_Start" targetRef="ENISA_EBG"/>
      <sequenceFlow id="ENISA_SF_2" isImmediate="true" sourceRef="ENISA_EBG" targetRef="ENISA_Catch_Com"/>
