         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="Task_Cust_3" id="Task_Cust_3_gui">
            <omgdc:Bounds height="80.0" width="100.0" x="500.0" y="510.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="GW_Cust_Conv" id="GW_Cust_Conv_gui">
            <omgdc:Bounds height="40.0" width="40.0" x="650.0" y="430.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="End_Cust" id="End_Cust_gui">
            <omgdc:Bounds height="30.0" width="30.0" x="750.0" y="435.0"/>
         </bpmndi:BPMNShape>

         <!-- OBLIGED ENTITY NODES -->
         <bpmndi:BPMNShape bpmnElement="Start_OE" id="Start_OE_gui">
            <omgdc:Bounds height="30.0" width="30.0" x="185.0" y="835.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="Task_OE_1" id="Task_OE_1_gui">
            <omgdc:Bounds height="80.0" width="100.0" x="250.0" y="810.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="Task_OE_2" id="Task_OE_2_gui">
            <omgdc:Bounds height="80.0" width="100.0" x="400.0" y="810.0"/>
         </bpmndi:BPMNShape>
