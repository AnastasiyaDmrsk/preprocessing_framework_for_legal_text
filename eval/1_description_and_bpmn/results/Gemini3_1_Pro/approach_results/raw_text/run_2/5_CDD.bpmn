            <omgdc:Bounds height="40.0" width="40.0" x="650.0" y="830.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="Task_OE_P1" id="Task_OE_P1_gui">
            <omgdc:Bounds height="80.0" width="100.0" x="750.0" y="610.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="Task_OE_P2" id="Task_OE_P2_gui">
            <omgdc:Bounds height="80.0" width="100.0" x="750.0" y="710.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="Task_OE_P3" id="Task_OE_P3_gui">
            <omgdc:Bounds height="80.0" width="100.0" x="750.0" y="810.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="Task_OE_P4" id="Task_OE_P4_gui">
            <omgdc:Bounds height="80.0" width="100.0" x="750.0" y="910.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="Task_OE_P5" id="Task_OE_P5_gui">
            <omgdc:Bounds height="80.0" width="100.0" x="750.0" y="1010.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="GW_OE_Para_Conv" id="GW_OE_Para_Conv_gui">
            <omgdc:Bounds height="40.0" width="40.0" x="900.0" y="830.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="Task_OE_3" id="Task_OE_3_gui">
            <omgdc:Bounds height="80.0" width="100.0" x="1000.0" y="810.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="GW_OE_Conv" id="GW_OE_Conv_gui">
            <omgdc:Bounds height="40.0" width="40.0" x="1150.0" y="830.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="End_OE" id="End_OE_gui">
            <omgdc:Bounds height="30.0" width="30.0" x="1250.0" y="835.0"/>
         </bpmndi:BPMNShape>

         <!-- FIU NODES -->
         <bpmndi:BPMNShape bpmnElement="Start_FIU" id="Start_FIU_gui">
            <omgdc:Bounds height="30.0" width="30.0" x="1035.0" y="1310.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="End_FIU" id="End_FIU_gui">
            <omgdc:Bounds height="30.0" width="30.0" x="1150.0" y="1310.0"/>
         </bpmndi:BPMNShape>

         <!-- MEMBER STATE EDGES -->
         <bpmndi:BPMNEdge bpmnElement="Flow_MS_1" id="Flow_MS_1_gui">
            <omgdi:waypoint x="215.0" y="150.0"/>
            <omgdi:waypoint x="250.0" y="150.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="Flow_MS_2" id="Flow_MS_2_gui">
            <omgdi:waypoint x="350.0" y="150.0"/>
            <omgdi:waypoint x="400.0" y="150.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="Flow_MS_3" id="Flow_MS_3_gui">
            <omgdi:waypoint x="500.0" y="150.0"/>
            <omgdi:waypoint x="530.0" y="150.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="Flow_MS_4" id="Flow_MS_4_gui">
            <omgdi:waypoint x="570.0" y="150.0"/>
            <omgdi:waypoint x="630.0" y="150.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="Flow_MS_5" id="Flow_MS_5_gui">
            <omgdi:waypoint x="730.0" y="150.0"/>
            <omgdi:waypoint x="780.0" y="150.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="Flow_MS_6" id="Flow_MS_6_gui">
            <omgdi:waypoint x="550.0" y="170.0"/>
            <omgdi:waypoint x="550.0" y="220.0"/>
            <omgdi:waypoint x="800.0" y="220.0"/>
            <omgdi:waypoint x="800.0" y="170.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="Flow_MS_7" id="Flow_MS_7_gui">
            <omgdi:waypoint x="820.0" y="150.0"/>
            <omgdi:waypoint x="880.0" y="150.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="Flow_MS_8" id="Flow_MS_8_gui">
