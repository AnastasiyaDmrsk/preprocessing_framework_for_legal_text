   <process id="proc_implant" isClosed="false" isExecutable="false" name="Manufacturer of implantable devices" processType="None">
      <startEvent id="imp_start" name="Start"/>
      <task id="imp_t1" name="keep tech doc for 15 years"/>
      <endEvent id="imp_end" name="End"/>
      <sequenceFlow id="f_imp_1" sourceRef="imp_start" targetRef="imp_t1" isImmediate="true"/>
      <sequenceFlow id="f_imp_2" sourceRef="imp_t1" targetRef="imp_end" isImmediate="true"/>
   </process>

   <process id="proc_qms" isClosed="false" isExecutable="false" name="Quality Management System" processType="None">
      <startEvent id="qms_start" name="Start"/>
      <parallelGateway id="qms_g1_s" gatewayDirection="Diverging" name="Split"/>
      <task id="qms_t1" name="cover all parts and elements"/>
      <task id="qms_t2" name="govern the structure"/>
      <task id="qms_t3" name="address at least the aspects"/>
      <parallelGateway id="qms_g1_m" gatewayDirection="Converging" name="Merge"/>
      <endEvent id="qms_end" name="End"/>
      
      <sequenceFlow id="f_qms_1" sourceRef="qms_start" targetRef="qms_g1_s" isImmediate="true"/>
