      <task id="man_t32" name="provide competent authority with info"/>

      <intermediateCatchEvent id="man_e3" name="receiving requirement to provide samples">
         <extensionElements><signavio:signavioLabel bottom="true" left="false" ref="text_name" right="false" top="false" valign="bottom" x="15.0" y="35.0"/></extensionElements>
         <messageEventDefinition id="med_3"/>
      </intermediateCatchEvent>
      <task id="man_t33" name="provide samples of the device"/>

      <intermediateCatchEvent id="man_e4" name="receiving requirement to grant access">
         <extensionElements><signavio:signavioLabel bottom="true" left="false" ref="text_name" right="false" top="false" valign="bottom" x="15.0" y="35.0"/></extensionElements>
         <messageEventDefinition id="med_4"/>
      </intermediateCatchEvent>
      <task id="man_t34" name="grant access to the device"/>

      <intermediateCatchEvent id="man_e5" name="receiving request collaboration">
         <extensionElements><signavio:signavioLabel bottom="true" left="false" ref="text_name" right="false" top="false" valign="bottom" x="15.0" y="35.0"/></extensionElements>
         <messageEventDefinition id="med_5"/>
      </intermediateCatchEvent>
      <task id="man_t35" name="cooperate with competent authority"/>

      <exclusiveGateway id="man_g9_s" gatewayDirection="Diverging" isMarkerVisible="true" name="designed by another?">
          <extensionElements><signavio:signavioLabel bottom="true" left="false" ref="text_name" right="false" top="false" valign="bottom" x="20.0" y="45.0"/></extensionElements>
      </exclusiveGateway>
      <task id="man_t36" name="ensure info on person identity is submitted"/>
      <exclusiveGateway id="man_g9_m" gatewayDirection="Converging" isMarkerVisible="true" name="Merge">
          <extensionElements><signavio:signavioLabel bottom="true" left="false" ref="text_name" right="false" top="false" valign="bottom" x="20.0" y="45.0"/></extensionElements>
      </exclusiveGateway>

      <task id="man_t37" name="have measures for financial coverage"/>
      <endEvent id="man_end" name="compliance obligations fulfilled">
          <extensionElements><signavio:signavioLabel bottom="true" left="false" ref="text_name" right="false" top="false" valign="bottom" x="15.0" y="35.0"/></extensionElements>
      </endEvent>

