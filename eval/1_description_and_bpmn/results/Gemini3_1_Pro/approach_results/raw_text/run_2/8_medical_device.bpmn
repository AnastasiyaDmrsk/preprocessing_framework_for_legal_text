   <process id="proc_custom" isClosed="false" isExecutable="false" name="Manufacturer of custom-made devices" processType="None">
      <startEvent id="cus_start" name="Start"/>
      <parallelGateway id="cus_g1_s" gatewayDirection="Diverging" name="Split"/>
      <task id="cus_t1" name="draw up documentation"/>
      <task id="cus_t2" name="keep up to date documentation"/>
      <task id="cus_t3" name="keep available for competent authorities documentation"/>
      <parallelGateway id="cus_g1_m" gatewayDirection="Converging" name="Merge"/>
      <endEvent id="cus_end" name="End"/>
      
      <sequenceFlow id="f_cus_1" sourceRef="cus_start" targetRef="cus_g1_s" isImmediate="true"/>
      <sequenceFlow id="f_cus_2" sourceRef="cus_g1_s" targetRef="cus_t1" isImmediate="true"/>
