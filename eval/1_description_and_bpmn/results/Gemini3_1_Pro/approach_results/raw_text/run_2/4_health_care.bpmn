         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="sid-hp-task4" id="sid-hp-task4_gui">
            <omgdc:Bounds height="80.0" width="100.0" x="800.0" y="685.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="sid-hp-task5" id="sid-hp-task5_gui">
            <omgdc:Bounds height="80.0" width="100.0" x="940.0" y="685.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="sid-hp-task6" id="sid-hp-task6_gui">
            <omgdc:Bounds height="80.0" width="100.0" x="1080.0" y="685.0"/>
         </bpmndi:BPMNShape>
