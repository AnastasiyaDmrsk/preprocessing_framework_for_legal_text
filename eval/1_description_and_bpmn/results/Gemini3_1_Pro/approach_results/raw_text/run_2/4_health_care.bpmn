         <bpmndi:BPMNShape bpmnElement="sid-comm-task3" id="sid-comm-task3_gui">
            <omgdc:Bounds height="80.0" width="100.0" x="550.0" y="100.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="sid-comm-task4" id="sid-comm-task4_gui">
            <omgdc:Bounds height="80.0" width="100.0" x="700.0" y="100.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="sid-comm-end" id="sid-comm-end_gui">
            <omgdc:Bounds height="30.0" width="30.0" x="850.0" y="125.0"/>
         </bpmndi:BPMNShape>

         <!-- Participant: Applicant / Representative -->
         <bpmndi:BPMNShape bpmnElement="sid-part-app" id="sid-part-app_gui" isHorizontal="true">
            <omgdc:Bounds height="250.0" width="1000.0" x="100.0" y="300.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="sid-lane-app" id="sid-lane-app_gui" isHorizontal="true">
