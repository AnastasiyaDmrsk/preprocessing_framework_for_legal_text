         </bpmndi:BPMNShape>

         <!-- Participant: Competent Authority -->
         <bpmndi:BPMNShape bpmnElement="sid-part-ca" id="sid-part-ca_gui" isHorizontal="true">
            <omgdc:Bounds height="200.0" width="1000.0" x="100.0" y="950.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="sid-lane-ca" id="sid-lane-ca_gui" isHorizontal="true">
            <omgdc:Bounds height="200.0" width="970.0" x="130.0" y="950.0"/>
