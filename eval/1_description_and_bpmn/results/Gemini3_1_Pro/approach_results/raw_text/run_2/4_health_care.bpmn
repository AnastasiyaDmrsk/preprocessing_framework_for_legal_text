         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="sid-app-gw1" id="sid-app-gw1_gui">
            <omgdc:Bounds height="40.0" width="40.0" x="250.0" y="405.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="sid-app-task1" id="sid-app-task1_gui">
            <omgdc:Bounds height="80.0" width="100.0" x="350.0" y="320.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="sid-app-task2" id="sid-app-task2_gui">
            <omgdc:Bounds height="80.0" width="100.0" x="350.0" y="460.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="sid-app-gw2" id="sid-app-gw2_gui">
            <omgdc:Bounds height="40.0" width="40.0" x="500.0" y="405.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="sid-app-end" id="sid-app-end_gui">
            <omgdc:Bounds height="30.0" width="30.0" x="580.0" y="410.0"/>
         </bpmndi:BPMNShape>

         <!-- Participant: Health Professional -->
         <bpmndi:BPMNShape bpmnElement="sid-part-hp" id="sid-part-hp_gui" isHorizontal="true">
            <omgdc:Bounds height="250.0" width="1400.0" x="100.0" y="600.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="sid-lane-hp" id="sid-lane-hp_gui" isHorizontal="true">
            <omgdc:Bounds height="250.0" width="1370.0" x="130.0" y="600.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="sid-hp-start" id="sid-hp-start_gui">
            <omgdc:Bounds height="30.0" width="30.0" x="180.0" y="710.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="sid-hp-task1" id="sid-hp-task1_gui">
            <omgdc:Bounds height="80.0" width="100.0" x="250.0" y="685.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="sid-hp-gw1" id="sid-hp-gw1_gui">
            <omgdc:Bounds height="40.0" width="40.0" x="380.0" y="705.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="sid-hp-task2" id="sid-hp-task2_gui">
            <omgdc:Bounds height="80.0" width="100.0" x="460.0" y="620.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="sid-hp-gw2" id="sid-hp-gw2_gui">
            <omgdc:Bounds height="40.0" width="40.0" x="580.0" y="705.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="sid-hp-task3" id="sid-hp-task3_gui">
