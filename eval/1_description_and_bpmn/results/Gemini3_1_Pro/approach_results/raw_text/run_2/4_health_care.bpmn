<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:i18n="http://www.omg.org/spec/BPMN/non-normative/extensions/i18n/1.0" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" xmlns:signavio="http://www.signavio.com" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" exporter="Signavio Process Editor, http://www.signavio.com" exporterVersion="19.2.2" expressionLanguage="http://www.w3.org/TR/XPath" id="sid-definitions" targetNamespace="http://www.signavio.com" typeLanguage="http://www.w3.org/2001/XMLSchema" xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd">
   <collaboration id="sid-collaboration">
      <participant id="sid-part-comm" name="Commission" processRef="sid-proc-comm">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffff"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
      </participant>
      <participant id="sid-part-app" name="Applicant / Representative" processRef="sid-proc-app">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffff"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
      </participant>
      <participant id="sid-part-hp" name="Health Professional" processRef="sid-proc-hp">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffff"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
      </participant>
      <participant id="sid-part-ca" name="Competent Authority" processRef="sid-proc-ca">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffff"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
      </participant>
      <messageFlow id="sid-msg-1" name="" sourceRef="sid-hp-task1" targetRef="sid-ca-start">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
      </messageFlow>
   </collaboration>
   
   <process id="sid-proc-comm" isClosed="false" isExecutable="false" name="Commission" processType="None">
      <laneSet id="sid-laneSet-comm">
         <lane id="sid-lane-comm">
            <extensionElements>
               <signavio:signavioMetaData metaKey="bgcolor" metaValue=""/>
               <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            </extensionElements>
            <flowNodeRef>sid-comm-start</flowNodeRef>
            <flowNodeRef>sid-comm-task1</flowNodeRef>
            <flowNodeRef>sid-comm-task2</flowNodeRef>
            <flowNodeRef>sid-comm-task3</flowNodeRef>
            <flowNodeRef>sid-comm-task4</flowNodeRef>
            <flowNodeRef>sid-comm-end</flowNodeRef>
         </lane>
      </laneSet>
      <startEvent id="sid-comm-start" name="Start">
         <extensionElements>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/>
         </extensionElements>
         <outgoing>sid-comm-f1</outgoing>
      </startEvent>
      <task id="sid-comm-task1" name="Draw up the common health certificate">
         <incoming>sid-comm-f1</incoming>
         <outgoing>sid-comm-f2</outgoing>
      </task>
      <task id="sid-comm-task2" name="Adopt implementing acts">
         <incoming>sid-comm-f2</incoming>
         <outgoing>sid-comm-f3</outgoing>
      </task>
      <task id="sid-comm-task3" name="Adopt uniform conditions and practical arrangements for exchanging the information">
         <incoming>sid-comm-f3</incoming>
         <outgoing>sid-comm-f4</outgoing>
      </task>
      <task id="sid-comm-task4" name="Adopt those implementing acts">
         <incoming>sid-comm-f4</incoming>
         <outgoing>sid-comm-f5</outgoing>
      </task>
      <endEvent id="sid-comm-end" name="End">
         <extensionElements>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/>
         </extensionElements>
         <incoming>sid-comm-f5</incoming>
      </endEvent>
      <sequenceFlow id="sid-comm-f1" isImmediate="true" sourceRef="sid-comm-start" targetRef="sid-comm-task1"/>
      <sequenceFlow id="sid-comm-f2" isImmediate="true" sourceRef="sid-comm-task1" targetRef="sid-comm-task2"/>
      <sequenceFlow id="sid-comm-f3" isImmediate="true" sourceRef="sid-comm-task2" targetRef="sid-comm-task3"/>
      <sequenceFlow id="sid-comm-f4" isImmediate="true" sourceRef="sid-comm-task3" targetRef="sid-comm-task4"/>
      <sequenceFlow id="sid-comm-f5" isImmediate="true" sourceRef="sid-comm-task4" targetRef="sid-comm-end"/>
   </process>

   <process id="sid-proc-app" isClosed="false" isExecutable="false" name="Applicant / Representative" processType="None">
      <laneSet id="sid-laneSet-app">
         <lane id="sid-lane-app">
            <extensionElements>
               <signavio:signavioMetaData metaKey="bgcolor" metaValue=""/>
               <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            </extensionElements>
            <flowNodeRef>sid-app-start</flowNodeRef>
            <flowNodeRef>sid-app-gw1</flowNodeRef>
            <flowNodeRef>sid-app-task1</flowNodeRef>
            <flowNodeRef>sid-app-task2</flowNodeRef>
            <flowNodeRef>sid-app-gw2</flowNodeRef>
            <flowNodeRef>sid-app-end</flowNodeRef>
         </lane>
      </laneSet>
      <startEvent id="sid-app-start" name="Start">
         <extensionElements>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/>
         </extensionElements>
         <outgoing>sid-app-f1</outgoing>
      </startEvent>
      <exclusiveGateway gatewayDirection="Diverging" id="sid-app-gw1" isMarkerVisible="true" name="Consent action?">
         <extensionElements>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/>
         </extensionElements>
         <incoming>sid-app-f1</incoming>
         <outgoing>sid-app-f2</outgoing>
         <outgoing>sid-app-f3</outgoing>
         <outgoing>sid-app-f4</outgoing>
      </exclusiveGateway>
      <task id="sid-app-task1" name="Provide consent">
         <incoming>sid-app-f2</incoming>
         <outgoing>sid-app-f5</outgoing>
      </task>
      <task id="sid-app-task2" name="Refuse consent">
         <incoming>sid-app-f3</incoming>
         <outgoing>sid-app-f6</outgoing>
      </task>
      <exclusiveGateway gatewayDirection="Converging" id="sid-app-gw2" isMarkerVisible="true" name="Merge">
         <extensionElements>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/>
         </extensionElements>
         <incoming>sid-app-f4</incoming>
         <incoming>sid-app-f5</incoming>
         <incoming>sid-app-f6</incoming>
         <outgoing>sid-app-f7</outgoing>
      </exclusiveGateway>
      <endEvent id="sid-app-end" name="End">
         <extensionElements>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/>
         </extensionElements>
         <incoming>sid-app-f7</incoming>
      </endEvent>
      <sequenceFlow id="sid-app-f1" isImmediate="true" sourceRef="sid-app-start" targetRef="sid-app-gw1"/>
      <sequenceFlow id="sid-app-f2" isImmediate="true" name="provide if required" sourceRef="sid-app-gw1" targetRef="sid-app-task1"/>
      <sequenceFlow id="sid-app-f3" isImmediate="true" name="refuse if required" sourceRef="sid-app-gw1" targetRef="sid-app-task2"/>
      <sequenceFlow id="sid-app-f4" isImmediate="true" name="not required" sourceRef="sid-app-gw1" targetRef="sid-app-gw2"/>
      <sequenceFlow id="sid-app-f5" isImmediate="true" sourceRef="sid-app-task1" targetRef="sid-app-gw2"/>
      <sequenceFlow id="sid-app-f6" isImmediate="true" sourceRef="sid-app-task2" targetRef="sid-app-gw2"/>
      <sequenceFlow id="sid-app-f7" isImmediate="true" sourceRef="sid-app-gw2" targetRef="sid-app-end"/>
   </process>

   <process id="sid-proc-hp" isClosed="false" isExecutable="false" name="Health Professional" processType="None">
      <laneSet id="sid-laneSet-hp">
         <lane id="sid-lane-hp">
            <extensionElements>
               <signavio:signavioMetaData metaKey="bgcolor" metaValue=""/>
               <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            </extensionElements>
            <flowNodeRef>sid-hp-start</flowNodeRef>
            <flowNodeRef>sid-hp-task1</flowNodeRef>
            <flowNodeRef>sid-hp-gw1</flowNodeRef>
            <flowNodeRef>sid-hp-task2</flowNodeRef>
            <flowNodeRef>sid-hp-gw2</flowNodeRef>
            <flowNodeRef>sid-hp-task3</flowNodeRef>
            <flowNodeRef>sid-hp-task4</flowNodeRef>
            <flowNodeRef>sid-hp-task5</flowNodeRef>
            <flowNodeRef>sid-hp-task6</flowNodeRef>
            <flowNodeRef>sid-hp-task7</flowNodeRef>
            <flowNodeRef>sid-hp-end</flowNodeRef>
         </lane>
      </laneSet>
      <startEvent id="sid-hp-start" name="Start">
         <extensionElements>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/>
         </extensionElements>
         <outgoing>sid-hp-f1</outgoing>
      </startEvent>
      <task id="sid-hp-task1" name="Transmit to the Member State responsible information to the Competent Authority for the sole purpose of the provision of medical care or treatment, in so far as the information is available to the competent authority, and after having obtained the explicit consent of the applicant / representative or, if the applicant is physically or legally incapable of giving his or her consent, when such transmission is necessary to protect the vital interests of the applicant or of another person">
         <incoming>sid-hp-f1</incoming>
         <outgoing>sid-hp-f2</outgoing>
      </task>
      <exclusiveGateway gatewayDirection="Diverging" id="sid-hp-gw1" isMarkerVisible="true" name="Specific cases?">
         <extensionElements>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/>
         </extensionElements>
         <incoming>sid-hp-f2</incoming>
         <outgoing>sid-hp-f3</outgoing>
         <outgoing>sid-hp-f4</outgoing>
      </exclusiveGateway>
      <task id="sid-hp-task2" name="Include information on physical or mental health">
         <incoming>sid-hp-f3</incoming>
         <outgoing>sid-hp-f5</outgoing>
      </task>
      <exclusiveGateway gatewayDirection="Converging" id="sid-hp-gw2" isMarkerVisible="true" name="Merge">
         <extensionElements>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/>
         </extensionElements>
         <incoming>sid-hp-f4</incoming>
         <incoming>sid-hp-f5</incoming>
         <outgoing>sid-hp-f6</outgoing>
      </exclusiveGateway>
      <task id="sid-hp-task3" name="Obtain explicit consent prior to transmitting the information referred to in paragraph 1, except where the applicant is physically or legally incapable of giving his or her consent, when such transmission is necessary to protect the vital interests of the applicant or of another person">
         <incoming>sid-hp-f6</incoming>
         <outgoing>sid-hp-f7</outgoing>
      </task>
      <task id="sid-hp-task4" name="Carry out the processing of personal health data">
         <incoming>sid-hp-f7</incoming>
         <outgoing>sid-hp-f8</outgoing>
      </task>
      <task id="sid-hp-task5" name="Exchange information">
         <incoming>sid-hp-f8</incoming>
         <outgoing>sid-hp-f9</outgoing>
      </task>
      <task id="sid-hp-task6" name="Use exchanged information only for the purposes set out in paragraph 1">
         <incoming>sid-hp-f9</incoming>
         <outgoing>sid-hp-f10</outgoing>
      </task>
      <task id="sid-hp-task7" name="not Further process the information">
         <incoming>sid-hp-f10</incoming>
         <outgoing>sid-hp-f11</outgoing>
      </task>
      <endEvent id="sid-hp-end" name="End">
         <extensionElements>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/>
         </extensionElements>
         <incoming>sid-hp-f11</incoming>
      </endEvent>
      <sequenceFlow id="sid-hp-f1" isImmediate="true" sourceRef="sid-hp-start" targetRef="sid-hp-task1"/>
      <sequenceFlow id="sid-hp-f2" isImmediate="true" sourceRef="sid-hp-task1" targetRef="sid-hp-gw1"/>
      <sequenceFlow id="sid-hp-f3" isImmediate="true" name="in specific cases" sourceRef="sid-hp-gw1" targetRef="sid-hp-task2"/>
      <sequenceFlow id="sid-hp-f4" isImmediate="true" name="otherwise" sourceRef="sid-hp-gw1" targetRef="sid-hp-gw2"/>
      <sequenceFlow id="sid-hp-f5" isImmediate="true" sourceRef="sid-hp-task2" targetRef="sid-hp-gw2"/>
      <sequenceFlow id="sid-hp-f6" isImmediate="true" sourceRef="sid-hp-gw2" targetRef="sid-hp-task3"/>
      <sequenceFlow id="sid-hp-f7" isImmediate="true" sourceRef="sid-hp-task3" targetRef="sid-hp-task4"/>
      <sequenceFlow id="sid-hp-f8" isImmediate="true" sourceRef="sid-hp-task4" targetRef="sid-hp-task5"/>
      <sequenceFlow id="sid-hp-f9" isImmediate="true" sourceRef="sid-hp-task5" targetRef="sid-hp-task6"/>
      <sequenceFlow id="sid-hp-f10" isImmediate="true" sourceRef="sid-hp-task6" targetRef="sid-hp-task7"/>
      <sequenceFlow id="sid-hp-f11" isImmediate="true" sourceRef="sid-hp-task7" targetRef="sid-hp-end"/>
   </process>

   <process id="sid-proc-ca" isClosed="false" isExecutable="false" name="Competent Authority" processType="None">
      <laneSet id="sid-laneSet-ca">
         <lane id="sid-lane-ca">
            <extensionElements>
               <signavio:signavioMetaData metaKey="bgcolor" metaValue=""/>
               <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            </extensionElements>
            <flowNodeRef>sid-ca-start</flowNodeRef>
            <flowNodeRef>sid-ca-task1</flowNodeRef>
            <flowNodeRef>sid-ca-end</flowNodeRef>
         </lane>
      </laneSet>
      <startEvent id="sid-ca-start" isInterrupting="true" name="Upon receiving the information">
         <extensionElements>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/>
         </extensionElements>
         <outgoing>sid-ca-f1</outgoing>
         <messageEventDefinition id="sid-msg-def-1"/>
      </startEvent>
      <task id="sid-ca-task1" name="Ensure that special needs are adequately addressed">
         <incoming>sid-ca-f1</incoming>
         <outgoing>sid-ca-f2</outgoing>
      </task>
      <endEvent id="sid-ca-end" name="End">
         <extensionElements>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/>
         </extensionElements>
         <incoming>sid-ca-f2</incoming>
      </endEvent>
      <sequenceFlow id="sid-ca-f1" isImmediate="true" sourceRef="sid-ca-start" targetRef="sid-ca-task1"/>
      <sequenceFlow id="sid-ca-f2" isImmediate="true" sourceRef="sid-ca-task1" targetRef="sid-ca-end"/>
   </process>

   <bpmndi:BPMNDiagram id="sid-diagram">
      <bpmndi:BPMNPlane bpmnElement="sid-collaboration" id="sid-plane">
         <!-- Participant: Commission -->
         <bpmndi:BPMNShape bpmnElement="sid-part-comm" id="sid-part-comm_gui" isHorizontal="true">
            <omgdc:Bounds height="200.0" width="1000.0" x="100.0" y="50.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="sid-lane-comm" id="sid-lane-comm_gui" isHorizontal="true">
            <omgdc:Bounds height="200.0" width="970.0" x="130.0" y="50.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="sid-comm-start" id="sid-comm-start_gui">
