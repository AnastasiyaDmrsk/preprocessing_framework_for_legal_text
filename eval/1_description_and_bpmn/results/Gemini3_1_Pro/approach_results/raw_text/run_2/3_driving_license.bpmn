      <sequenceFlow id="Flow_MS_11" isImmediate="true" sourceRef="Gateway_MS_Merge9" targetRef="Gateway_MS_Split10"/>

      <sequenceFlow id="Flow_MS_S10_Yes" isImmediate="true" name="yes" sourceRef="Gateway_MS_Split10" targetRef="Task_MS_InfComm1"/>
      <sequenceFlow id="Flow_MS_S10_No" isImmediate="true" name="no" sourceRef="Gateway_MS_Split10" targetRef="Gateway_MS_Merge10"/>
