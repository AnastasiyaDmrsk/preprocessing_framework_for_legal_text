<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" 
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" 
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" 
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" 
             xmlns:signavio="http://www.signavio.com" 
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
             exporter="Signavio Process Editor, http://www.signavio.com" 
             exporterVersion="19.2.2" 
             expressionLanguage="http://www.w3.org/TR/XPath" 
             id="sid-main-definitions" 
             targetNamespace="http://www.signavio.com" 
             typeLanguage="http://www.w3.org/2001/XMLSchema" 
             xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd">
   
   <collaboration id="collaboration_1">
      <participant id="Participant_Applicant" name="Applicant" processRef="Process_Applicant">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffff"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
      </participant>
      <participant id="Participant_MemberState" name="Member State" processRef="Process_MemberState">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffff"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
      </participant>
      <participant id="Participant_Commission" name="Commission" processRef="Process_Commission">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffff"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
      </participant>
      <messageFlow id="MessageFlow_1" name="guidelines adopted" sourceRef="Task_MS_InfComm1" targetRef="CatchEvent_Comm_1">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
      </messageFlow>
      <messageFlow id="MessageFlow_2" name="public awareness campaigns developed" sourceRef="Task_MS_InfComm2" targetRef="CatchEvent_Comm_2">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
      </messageFlow>
   </collaboration>

   <process id="Process_Applicant" isClosed="false" isExecutable="false" name="Applicant" processType="None">
      <startEvent id="StartEvent_App" name="application for the issuance or renewal of a driving licence">
         <extensionElements>
            <signavio:signavioLabel align="center" ref="text_name" valign="bottom" x="15.0" y="-8.0"/>
         </extensionElements>
         <outgoing>Flow_App_1</outgoing>
      </startEvent>
      
      <exclusiveGateway gatewayDirection="Diverging" id="Gateway_App_Split1" isMarkerVisible="true" name="assess whether a driving licence is issued for the first time or renewed...">
         <incoming>Flow_App_1</incoming>
         <outgoing>Flow_App_Split1_Yes</outgoing>
         <outgoing>Flow_App_Split1_Exc1</outgoing>
         <outgoing>Flow_App_Split1_Exc2</outgoing>
         <outgoing>Flow_App_Split1_No</outgoing>
      </exclusiveGateway>

      <task completionQuantity="1" id="Task_App_Med" isForCompensation="false" name="undergo a medical examination" startQuantity="1">
         <incoming>Flow_App_Split1_Yes</incoming>
         <outgoing>Flow_App_Task1_Out</outgoing>
      </task>

      <exclusiveGateway gatewayDirection="Converging" id="Gateway_App_Merge1" isMarkerVisible="true" name="">
         <incoming>Flow_App_Task1_Out</incoming>
         <incoming>Flow_App_Split1_Exc1</incoming>
         <incoming>Flow_App_Split1_Exc2</incoming>
         <incoming>Flow_App_Split1_No</incoming>
         <outgoing>Flow_App_2</outgoing>
      </exclusiveGateway>

      <exclusiveGateway gatewayDirection="Diverging" id="Gateway_App_Split2" isMarkerVisible="true" name="assess whether a self-assessment form is required...">
         <incoming>Flow_App_2</incoming>
         <outgoing>Flow_App_Split2_Yes</outgoing>
         <outgoing>Flow_App_Split2_No</outgoing>
      </exclusiveGateway>

      <task completionQuantity="1" id="Task_App_Self" isForCompensation="false" name="fill in a self-assessment form" startQuantity="1">
         <incoming>Flow_App_Split2_Yes</incoming>
         <outgoing>Flow_App_Task2_Out</outgoing>
      </task>

      <exclusiveGateway gatewayDirection="Converging" id="Gateway_App_Merge2" isMarkerVisible="true" name="">
         <incoming>Flow_App_Task2_Out</incoming>
         <incoming>Flow_App_Split2_No</incoming>
         <outgoing>Flow_App_3</outgoing>
      </exclusiveGateway>

      <endEvent id="EndEvent_App" name="End">
         <incoming>Flow_App_3</incoming>
      </endEvent>

      <sequenceFlow id="Flow_App_1" isImmediate="true" sourceRef="StartEvent_App" targetRef="Gateway_App_Split1"/>
      <sequenceFlow id="Flow_App_Split1_Yes" isImmediate="true" name="yes" sourceRef="Gateway_App_Split1" targetRef="Task_App_Med"/>
      <sequenceFlow id="Flow_App_Split1_Exc1" isImmediate="true" name="except where for category AM" sourceRef="Gateway_App_Split1" targetRef="Gateway_App_Merge1"/>
      <sequenceFlow id="Flow_App_Split1_Exc2" isImmediate="true" name="except where alternative measures are used" sourceRef="Gateway_App_Split1" targetRef="Gateway_App_Merge1"/>
      <sequenceFlow id="Flow_App_Split1_No" isImmediate="true" name="no" sourceRef="Gateway_App_Split1" targetRef="Gateway_App_Merge1"/>
      <sequenceFlow id="Flow_App_Task1_Out" isImmediate="true" sourceRef="Task_App_Med" targetRef="Gateway_App_Merge1"/>
      <sequenceFlow id="Flow_App_2" isImmediate="true" sourceRef="Gateway_App_Merge1" targetRef="Gateway_App_Split2"/>
      <sequenceFlow id="Flow_App_Split2_Yes" isImmediate="true" name="yes" sourceRef="Gateway_App_Split2" targetRef="Task_App_Self"/>
      <sequenceFlow id="Flow_App_Split2_No" isImmediate="true" name="no" sourceRef="Gateway_App_Split2" targetRef="Gateway_App_Merge2"/>
      <sequenceFlow id="Flow_App_Task2_Out" isImmediate="true" sourceRef="Task_App_Self" targetRef="Gateway_App_Merge2"/>
      <sequenceFlow id="Flow_App_3" isImmediate="true" sourceRef="Gateway_App_Merge2" targetRef="EndEvent_App"/>
   </process>

   <process id="Process_MemberState" isClosed="false" isExecutable="false" name="Member State" processType="None">
      <startEvent id="StartEvent_MS" name="Start">
         <outgoing>Flow_MS_1</outgoing>
      </startEvent>

      <exclusiveGateway gatewayDirection="Diverging" id="Gateway_MS_Split1" isMarkerVisible="true" name="except where applies to AM...">
         <incoming>Flow_MS_1</incoming>
         <outgoing>Flow_MS_S1_Yes</outgoing>
         <outgoing>Flow_MS_S1_No</outgoing>
      </exclusiveGateway>

      <task id="Task_MS_EnsureMed" name="ensure that applicants undergo a medical examination before a driving licence is issued for the first time">
         <incoming>Flow_MS_S1_No</incoming>
         <outgoing>Flow_MS_T1_Out</outgoing>
      </task>

      <exclusiveGateway gatewayDirection="Converging" id="Gateway_MS_Merge1" isMarkerVisible="true" name="">
         <incoming>Flow_MS_T1_Out</incoming>
         <incoming>Flow_MS_S1_Yes</incoming>
         <outgoing>Flow_MS_2</outgoing>
      </exclusiveGateway>

      <exclusiveGateway gatewayDirection="Diverging" id="Gateway_MS_Split2" isMarkerVisible="true" name="except where for category AM...">
         <incoming>Flow_MS_2</incoming>
         <outgoing>Flow_MS_S2_Yes</outgoing>
         <outgoing>Flow_MS_S2_No</outgoing>
      </exclusiveGateway>

      <task id="Task_MS_ReqMed" name="require a medical examination for driving licences of categories C...">
         <incoming>Flow_MS_S2_No</incoming>
         <outgoing>Flow_MS_T2_Out</outgoing>
      </task>

      <exclusiveGateway gatewayDirection="Converging" id="Gateway_MS_Merge2" isMarkerVisible="true" name="">
         <incoming>Flow_MS_T2_Out</incoming>
         <incoming>Flow_MS_S2_Yes</incoming>
         <outgoing>Flow_MS_3</outgoing>
      </exclusiveGateway>

      <task id="Task_MS_ReqSelf" name="require the applicant to fill in a self-assessment form for driving licence categories AM...">
         <incoming>Flow_MS_3</incoming>
         <outgoing>Flow_MS_4</outgoing>
      </task>

      <exclusiveGateway gatewayDirection="Diverging" id="Gateway_MS_Split3" isMarkerVisible="true" name="if required instead of a medical examination...">
         <incoming>Flow_MS_4</incoming>
         <outgoing>Flow_MS_S3_Yes</outgoing>
         <outgoing>Flow_MS_S3_No</outgoing>
      </exclusiveGateway>

      <task id="Task_MS_EstSys" name="establish a national system of assessment of fitness to drive...">
         <incoming>Flow_MS_S3_Yes</incoming>
         <outgoing>Flow_MS_T3_Out</outgoing>
      </task>

      <exclusiveGateway gatewayDirection="Converging" id="Gateway_MS_Merge3" isMarkerVisible="true" name="">
         <incoming>Flow_MS_T3_Out</incoming>
         <incoming>Flow_MS_S3_No</incoming>
         <outgoing>Flow_MS_5</outgoing>
      </exclusiveGateway>

      <exclusiveGateway gatewayDirection="Diverging" id="Gateway_MS_Split4" isMarkerVisible="true" name="for non-compliance...">
         <incoming>Flow_MS_5</incoming>
         <outgoing>Flow_MS_S4_Yes</outgoing>
         <outgoing>Flow_MS_S4_No</outgoing>
      </exclusiveGateway>

      <task id="Task_MS_ProvMeas" name="provide for appropriate measures to address non-compliance...">
         <incoming>Flow_MS_S4_Yes</incoming>
         <outgoing>Flow_MS_T4_Out</outgoing>
      </task>

      <exclusiveGateway gatewayDirection="Converging" id="Gateway_MS_Merge4" isMarkerVisible="true" name="">
         <incoming>Flow_MS_T4_Out</incoming>
         <incoming>Flow_MS_S4_No</incoming>
         <outgoing>Flow_MS_6</outgoing>
      </exclusiveGateway>

      <exclusiveGateway gatewayDirection="Diverging" id="Gateway_MS_Split5" isMarkerVisible="true" name="if the Member State has established a national system...">
         <incoming>Flow_MS_6</incoming>
         <outgoing>Flow_MS_S5_Yes</outgoing>
         <outgoing>Flow_MS_S5_No</outgoing>
      </exclusiveGateway>

      <task id="Task_MS_AppSys" name="apply the national system to monitor">
         <incoming>Flow_MS_S5_Yes</incoming>
         <outgoing>Flow_MS_T5_Out</outgoing>
      </task>

      <exclusiveGateway gatewayDirection="Converging" id="Gateway_MS_Merge5" isMarkerVisible="true" name="">
         <incoming>Flow_MS_T5_Out</incoming>
         <incoming>Flow_MS_S5_No</incoming>
         <outgoing>Flow_MS_7</outgoing>
      </exclusiveGateway>

      <exclusiveGateway gatewayDirection="Diverging" id="Gateway_MS_Split6" isMarkerVisible="true" name="assess whether the applicant is likely to have the medical conditions">
         <incoming>Flow_MS_7</incoming>
         <outgoing>Flow_MS_S6_Yes</outgoing>
         <outgoing>Flow_MS_S6_No</outgoing>
      </exclusiveGateway>

      <task id="Task_MS_EnsMed" name="ensure that the applicant undergoes a medical examination">
         <incoming>Flow_MS_S6_Yes</incoming>
         <outgoing>Flow_MS_T6_Out</outgoing>
      </task>

      <exclusiveGateway gatewayDirection="Converging" id="Gateway_MS_Merge6" isMarkerVisible="true" name="">
         <incoming>Flow_MS_T6_Out</incoming>
         <incoming>Flow_MS_S6_No</incoming>
         <outgoing>Flow_MS_8</outgoing>
      </exclusiveGateway>

      <exclusiveGateway gatewayDirection="Diverging" id="Gateway_MS_Split7" isMarkerVisible="true" name="if awareness is required">
         <incoming>Flow_MS_8</incoming>
         <outgoing>Flow_MS_S7_Yes</outgoing>
         <outgoing>Flow_MS_S7_No</outgoing>
      </exclusiveGateway>

      <task id="Task_MS_Aware" name="take measures to raise awareness">
         <incoming>Flow_MS_S7_Yes</incoming>
         <outgoing>Flow_MS_T7_Out</outgoing>
      </task>

      <exclusiveGateway gatewayDirection="Converging" id="Gateway_MS_Merge7" isMarkerVisible="true" name="">
         <incoming>Flow_MS_T7_Out</incoming>
         <incoming>Flow_MS_S7_No</incoming>
         <outgoing>Flow_MS_9</outgoing>
      </exclusiveGateway>

      <exclusiveGateway gatewayDirection="Diverging" id="Gateway_MS_Split8" isMarkerVisible="true" name="if knowledge improvement is required">
         <incoming>Flow_MS_9</incoming>
         <outgoing>Flow_MS_S8_Yes</outgoing>
         <outgoing>Flow_MS_S8_No</outgoing>
      </exclusiveGateway>

      <task id="Task_MS_Know" name="take measures to improve the knowledge of the health sector">
         <incoming>Flow_MS_S8_Yes</incoming>
         <outgoing>Flow_MS_T8_Out</outgoing>
      </task>

      <exclusiveGateway gatewayDirection="Converging" id="Gateway_MS_Merge8" isMarkerVisible="true" name="">
         <incoming>Flow_MS_T8_Out</incoming>
         <incoming>Flow_MS_S8_No</incoming>
         <outgoing>Flow_MS_10</outgoing>
      </exclusiveGateway>

      <exclusiveGateway gatewayDirection="Diverging" id="Gateway_MS_Split9" isMarkerVisible="true" name="if adopting of guidelines is required">
         <incoming>Flow_MS_10</incoming>
         <outgoing>Flow_MS_S9_Yes</outgoing>
         <outgoing>Flow_MS_S9_No</outgoing>
      </exclusiveGateway>

      <task id="Task_MS_Adopt" name="adopt guidelines for medical practitioners">
         <incoming>Flow_MS_S9_Yes</incoming>
         <outgoing>Flow_MS_T9_Out</outgoing>
      </task>

      <exclusiveGateway gatewayDirection="Converging" id="Gateway_MS_Merge9" isMarkerVisible="true" name="">
         <incoming>Flow_MS_T9_Out</incoming>
         <incoming>Flow_MS_S9_No</incoming>
         <outgoing>Flow_MS_11</outgoing>
      </exclusiveGateway>

      <exclusiveGateway gatewayDirection="Diverging" id="Gateway_MS_Split10" isMarkerVisible="true" name="If the Member State adopts guidelines...">
         <incoming>Flow_MS_11</incoming>
         <outgoing>Flow_MS_S10_Yes</outgoing>
         <outgoing>Flow_MS_S10_No</outgoing>
      </exclusiveGateway>

      <task id="Task_MS_InfComm1" name="inform the Commission of guidelines adopted">
         <incoming>Flow_MS_S10_Yes</incoming>
         <outgoing>Flow_MS_T10_Out</outgoing>
      </task>

      <exclusiveGateway gatewayDirection="Converging" id="Gateway_MS_Merge10" isMarkerVisible="true" name="">
         <incoming>Flow_MS_T10_Out</incoming>
         <incoming>Flow_MS_S10_No</incoming>
         <outgoing>Flow_MS_12</outgoing>
      </exclusiveGateway>

      <exclusiveGateway gatewayDirection="Diverging" id="Gateway_MS_Split11" isMarkerVisible="true" name="if awareness campaigns are required">
         <incoming>Flow_MS_12</incoming>
         <outgoing>Flow_MS_S11_Yes</outgoing>
         <outgoing>Flow_MS_S11_No</outgoing>
      </exclusiveGateway>

      <task id="Task_MS_DevCamp" name="develop public awareness campaigns">
         <incoming>Flow_MS_S11_Yes</incoming>
         <outgoing>Flow_MS_T11_Out</outgoing>
      </task>

      <exclusiveGateway gatewayDirection="Converging" id="Gateway_MS_Merge11" isMarkerVisible="true" name="">
         <incoming>Flow_MS_T11_Out</incoming>
         <incoming>Flow_MS_S11_No</incoming>
         <outgoing>Flow_MS_13</outgoing>
      </exclusiveGateway>

      <exclusiveGateway gatewayDirection="Diverging" id="Gateway_MS_Split12" isMarkerVisible="true" name="If the Member State develops public awareness campaigns">
         <incoming>Flow_MS_13</incoming>
         <outgoing>Flow_MS_S12_Yes</outgoing>
         <outgoing>Flow_MS_S12_No</outgoing>
      </exclusiveGateway>

      <task id="Task_MS_InfComm2" name="inform the Commission of any public awareness campaigns developed">
         <incoming>Flow_MS_S12_Yes</incoming>
         <outgoing>Flow_MS_T12_Out</outgoing>
      </task>

      <exclusiveGateway gatewayDirection="Converging" id="Gateway_MS_Merge12" isMarkerVisible="true" name="">
         <incoming>Flow_MS_T12_Out</incoming>
         <incoming>Flow_MS_S12_No</incoming>
         <outgoing>Flow_MS_14</outgoing>
      </exclusiveGateway>

      <exclusiveGateway gatewayDirection="Diverging" id="Gateway_MS_Split13" isMarkerVisible="true" name="if stricter standards are required">
         <incoming>Flow_MS_14</incoming>
         <outgoing>Flow_MS_S13_Yes</outgoing>
         <outgoing>Flow_MS_S13_No</outgoing>
      </exclusiveGateway>

      <task id="Task_MS_SetStand" name="set standards stricter than those set out in Annex III">
         <incoming>Flow_MS_S13_Yes</incoming>
         <outgoing>Flow_MS_T13_Out</outgoing>
      </task>

      <exclusiveGateway gatewayDirection="Converging" id="Gateway_MS_Merge13" isMarkerVisible="true" name="">
         <incoming>Flow_MS_T13_Out</incoming>
         <incoming>Flow_MS_S13_No</incoming>
         <outgoing>Flow_MS_15</outgoing>
      </exclusiveGateway>

      <endEvent id="EndEvent_MS" name="End">
         <incoming>Flow_MS_15</incoming>
      </endEvent>

      <!-- Flows for Member State Process -->
      <sequenceFlow id="Flow_MS_1" isImmediate="true" sourceRef="StartEvent_MS" targetRef="Gateway_MS_Split1"/>
      <sequenceFlow id="Flow_MS_S1_Yes" isImmediate="true" name="yes" sourceRef="Gateway_MS_Split1" targetRef="Gateway_MS_Merge1"/>
      <sequenceFlow id="Flow_MS_S1_No" isImmediate="true" name="no" sourceRef="Gateway_MS_Split1" targetRef="Task_MS_EnsureMed"/>
      <sequenceFlow id="Flow_MS_T1_Out" isImmediate="true" sourceRef="Task_MS_EnsureMed" targetRef="Gateway_MS_Merge1"/>
      <sequenceFlow id="Flow_MS_2" isImmediate="true" sourceRef="Gateway_MS_Merge1" targetRef="Gateway_MS_Split2"/>
      
      <sequenceFlow id="Flow_MS_S2_Yes" isImmediate="true" name="yes" sourceRef="Gateway_MS_Split2" targetRef="Gateway_MS_Merge2"/>
      <sequenceFlow id="Flow_MS_S2_No" isImmediate="true" name="no" sourceRef="Gateway_MS_Split2" targetRef="Task_MS_ReqMed"/>
      <sequenceFlow id="Flow_MS_T2_Out" isImmediate="true" sourceRef="Task_MS_ReqMed" targetRef="Gateway_MS_Merge2"/>
      <sequenceFlow id="Flow_MS_3" isImmediate="true" sourceRef="Gateway_MS_Merge2" targetRef="Task_MS_ReqSelf"/>
      <sequenceFlow id="Flow_MS_4" isImmediate="true" sourceRef="Task_MS_ReqSelf" targetRef="Gateway_MS_Split3"/>
      
      <sequenceFlow id="Flow_MS_S3_Yes" isImmediate="true" name="yes" sourceRef="Gateway_MS_Split3" targetRef="Task_MS_EstSys"/>
      <sequenceFlow id="Flow_MS_S3_No" isImmediate="true" name="no" sourceRef="Gateway_MS_Split3" targetRef="Gateway_MS_Merge3"/>
      <sequenceFlow id="Flow_MS_T3_Out" isImmediate="true" sourceRef="Task_MS_EstSys" targetRef="Gateway_MS_Merge3"/>
      <sequenceFlow id="Flow_MS_5" isImmediate="true" sourceRef="Gateway_MS_Merge3" targetRef="Gateway_MS_Split4"/>

      <sequenceFlow id="Flow_MS_S4_Yes" isImmediate="true" name="yes" sourceRef="Gateway_MS_Split4" targetRef="Task_MS_ProvMeas"/>
      <sequenceFlow id="Flow_MS_S4_No" isImmediate="true" name="no" sourceRef="Gateway_MS_Split4" targetRef="Gateway_MS_Merge4"/>
      <sequenceFlow id="Flow_MS_T4_Out" isImmediate="true" sourceRef="Task_MS_ProvMeas" targetRef="Gateway_MS_Merge4"/>
      <sequenceFlow id="Flow_MS_6" isImmediate="true" sourceRef="Gateway_MS_Merge4" targetRef="Gateway_MS_Split5"/>

      <sequenceFlow id="Flow_MS_S5_Yes" isImmediate="true" name="yes" sourceRef="Gateway_MS_Split5" targetRef="Task_MS_AppSys"/>
      <sequenceFlow id="Flow_MS_S5_No" isImmediate="true" name="no" sourceRef="Gateway_MS_Split5" targetRef="Gateway_MS_Merge5"/>
