      <sequenceFlow id="Flow_MS_7" isImmediate="true" sourceRef="Gateway_MS_Merge5" targetRef="Gateway_MS_Split6"/>

      <sequenceFlow id="Flow_MS_S6_Yes" isImmediate="true" name="yes" sourceRef="Gateway_MS_Split6" targetRef="Task_MS_EnsMed"/>
      <sequenceFlow id="Flow_MS_S6_No" isImmediate="true" name="no" sourceRef="Gateway_MS_Split6" targetRef="Gateway_MS_Merge6"/>
      <sequenceFlow id="Flow_MS_T6_Out" isImmediate="true" sourceRef="Task_MS_EnsMed" targetRef="Gateway_MS_Merge6"/>
      <sequenceFlow id="Flow_MS_8" isImmediate="true" sourceRef="Gateway_MS_Merge6" targetRef="Gateway_MS_Split7"/>

      <sequenceFlow id="Flow_MS_S7_Yes" isImmediate="true" name="yes" sourceRef="Gateway_MS_Split7" targetRef="Task_MS_Aware"/>
      <sequenceFlow id="Flow_MS_S7_No" isImmediate="true" name="no" sourceRef="Gateway_MS_Split7" targetRef="Gateway_MS_Merge7"/>
      <sequenceFlow id="Flow_MS_T7_Out" isImmediate="true" sourceRef="Task_MS_Aware" targetRef="Gateway_MS_Merge7"/>
      <sequenceFlow id="Flow_MS_9" isImmediate="true" sourceRef="Gateway_MS_Merge7" targetRef="Gateway_MS_Split8"/>

      <sequenceFlow id="Flow_MS_S8_Yes" isImmediate="true" name="yes" sourceRef="Gateway_MS_Split8" targetRef="Task_MS_Know"/>
      <sequenceFlow id="Flow_MS_S8_No" isImmediate="true" name="no" sourceRef="Gateway_MS_Split8" targetRef="Gateway_MS_Merge8"/>
      <sequenceFlow id="Flow_MS_T8_Out" isImmediate="true" sourceRef="Task_MS_Know" targetRef="Gateway_MS_Merge8"/>
      <sequenceFlow id="Flow_MS_10" isImmediate="true" sourceRef="Gateway_MS_Merge8" targetRef="Gateway_MS_Split9"/>

      <sequenceFlow id="Flow_MS_S9_Yes" isImmediate="true" name="yes" sourceRef="Gateway_MS_Split9" targetRef="Task_MS_Adopt"/>
      <sequenceFlow id="Flow_MS_S9_No" isImmediate="true" name="no" sourceRef="Gateway_MS_Split9" targetRef="Gateway_MS_Merge9"/>
