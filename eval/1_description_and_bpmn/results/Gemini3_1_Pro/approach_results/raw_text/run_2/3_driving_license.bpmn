      <sequenceFlow id="Flow_MS_13" isImmediate="true" sourceRef="Gateway_MS_Merge11" targetRef="Gateway_MS_Split12"/>

      <sequenceFlow id="Flow_MS_S12_Yes" isImmediate="true" name="yes" sourceRef="Gateway_MS_Split12" targetRef="Task_MS_InfComm2"/>
      <sequenceFlow id="Flow_MS_S12_No" isImmediate="true" name="no" sourceRef="Gateway_MS_Split12" targetRef="Gateway_MS_Merge12"/>
      <sequenceFlow id="Flow_MS_T12_Out" isImmediate="true" sourceRef="Task_MS_InfComm2" targetRef="Gateway_MS_Merge12"/>
      <sequenceFlow id="Flow_MS_14" isImmediate="true" sourceRef="Gateway_MS_Merge12" targetRef="Gateway_MS_Split13"/>

      <sequenceFlow id="Flow_MS_S13_Yes" isImmediate="true" name="yes" sourceRef="Gateway_MS_Split13" targetRef="Task_MS_SetStand"/>
      <sequenceFlow id="Flow_MS_S13_No" isImmediate="true" name="no" sourceRef="Gateway_MS_Split13" targetRef="Gateway_MS_Merge13"/>
      <sequenceFlow id="Flow_MS_T13_Out" isImmediate="true" sourceRef="Task_MS_SetStand" targetRef="Gateway_MS_Merge13"/>
      <sequenceFlow id="Flow_MS_15" isImmediate="true" sourceRef="Gateway_MS_Merge13" targetRef="EndEvent_MS"/>
   </process>

   <process id="Process_Commission" isClosed="false" isExecutable="false" name="Commission" processType="None">
      <startEvent id="StartEvent_Comm" name="Start">
         <outgoing>Flow_Comm_1</outgoing>
      </startEvent>

      <parallelGateway gatewayDirection="Diverging" id="Gateway_Comm_Split" name="">
         <incoming>Flow_Comm_1</incoming>
         <outgoing>Flow_Comm_S_B1</outgoing>
         <outgoing>Flow_Comm_S_B2</outgoing>
      </parallelGateway>

      <intermediateCatchEvent id="CatchEvent_Comm_1" name="Upon being informed of guidelines adopted">
         <incoming>Flow_Comm_S_B1</incoming>
         <outgoing>Flow_Comm_C1_Out</outgoing>
         <messageEventDefinition id="MsgDef_1"/>
      </intermediateCatchEvent>

      <task id="Task_Comm_1" name="make available to the other Member States the guidelines adopted">
         <incoming>Flow_Comm_C1_Out</incoming>
         <outgoing>Flow_Comm_T1_Out</outgoing>
      </task>

      <intermediateCatchEvent id="CatchEvent_Comm_2" name="Upon being informed of any public awareness campaigns developed">
         <incoming>Flow_Comm_S_B2</incoming>
         <outgoing>Flow_Comm_C2_Out</outgoing>
         <messageEventDefinition id="MsgDef_2"/>
      </intermediateCatchEvent>

      <task id="Task_Comm_2" name="make available to the other Member States the information">
         <incoming>Flow_Comm_C2_Out</incoming>
         <outgoing>Flow_Comm_T2_Out</outgoing>
      </task>

      <parallelGateway gatewayDirection="Converging" id="Gateway_Comm_Merge" name="">
         <incoming>Flow_Comm_T1_Out</incoming>
         <incoming>Flow_Comm_T2_Out</incoming>
         <outgoing>Flow_Comm_2</outgoing>
      </parallelGateway>

      <endEvent id="EndEvent_Comm" name="End">
         <incoming>Flow_Comm_2</incoming>
      </endEvent>

      <sequenceFlow id="Flow_Comm_1" isImmediate="true" sourceRef="StartEvent_Comm" targetRef="Gateway_Comm_Split"/>
      <sequenceFlow id="Flow_Comm_S_B1" isImmediate="true" sourceRef="Gateway_Comm_Split" targetRef="CatchEvent_Comm_1"/>
      <sequenceFlow id="Flow_Comm_C1_Out" isImmediate="true" sourceRef="CatchEvent_Comm_1" targetRef="Task_Comm_1"/>
      <sequenceFlow id="Flow_Comm_T1_Out" isImmediate="true" sourceRef="Task_Comm_1" targetRef="Gateway_Comm_Merge"/>
      <sequenceFlow id="Flow_Comm_S_B2" isImmediate="true" sourceRef="Gateway_Comm_Split" targetRef="CatchEvent_Comm_2"/>
      <sequenceFlow id="Flow_Comm_C2_Out" isImmediate="true" sourceRef="CatchEvent_Comm_2" targetRef="Task_Comm_2"/>
      <sequenceFlow id="Flow_Comm_T2_Out" isImmediate="true" sourceRef="Task_Comm_2" targetRef="Gateway_Comm_Merge"/>
      <sequenceFlow id="Flow_Comm_2" isImmediate="true" sourceRef="Gateway_Comm_Merge" targetRef="EndEvent_Comm"/>
   </process>

