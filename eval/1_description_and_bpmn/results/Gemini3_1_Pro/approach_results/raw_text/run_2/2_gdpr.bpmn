         <incoming>Flow_C20</incoming>
         <outgoing>Flow_C21</outgoing>
      </exclusiveGateway>
      <task completionQuantity="1" id="Task_C9" isForCompensation="false" name="assess whether communication would involve disproportionate effort" startQuantity="1">
         <extensionElements>
