      <sequenceFlow id="Flow_C3" isImmediate="true" name="likely to result in a risk, except where unlikely" sourceRef="GW_C1_split" targetRef="Task_C2"/>
      <sequenceFlow id="Flow_C4" isImmediate="true" sourceRef="Task_C2" targetRef="GW_C1_merge"/>
      <sequenceFlow id="Flow_C5" isImmediate="true" name="unlikely to result in a risk" sourceRef="GW_C1_split" targetRef="GW_C1_merge"/>
