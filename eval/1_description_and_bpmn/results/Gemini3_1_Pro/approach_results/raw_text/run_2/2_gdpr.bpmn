      <sequenceFlow id="Flow_C17" isImmediate="true" sourceRef="Task_C7" targetRef="GW_C4_split"/>
      <sequenceFlow id="Flow_C18" isImmediate="true" name="likely high risk, except where technical measures, subsequent measures, or disproportionate effort apply" sourceRef="GW_C4_split" targetRef="Task_C8"/>
      <sequenceFlow id="Flow_C19" isImmediate="true" sourceRef="Task_C8" targetRef="GW_C4_merge"/>
