      <sequenceFlow id="Flow_C9" isImmediate="true" sourceRef="Task_C4" targetRef="GW_C2_merge"/>
      <sequenceFlow id="Flow_C10" isImmediate="true" name="notification is made within 72 hours" sourceRef="GW_C2_split" targetRef="GW_C2_merge"/>
      <sequenceFlow id="Flow_C11" isImmediate="true" sourceRef="GW_C2_merge" targetRef="GW_C3_split"/>
      <sequenceFlow id="Flow_C12" isImmediate="true" name="not possible to provide all info at the same time" sourceRef="GW_C3_split" targetRef="Task_C5"/>
