         <outgoing>Flow_C3</outgoing>
         <outgoing>Flow_C5</outgoing>
      </exclusiveGateway>
      <task completionQuantity="1" id="Task_C2" isForCompensation="false" name="notify the personal data breach to the supervisory authority" startQuantity="1">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffcc"/>
         </extensionElements>
         <incoming>Flow_C3</incoming>
         <outgoing>Flow_C4</outgoing>
