            <omgdc:Bounds height="80.0" width="100.0" x="200.0" y="45.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="End_Processor" id="End_Processor_gui">
            <omgdc:Bounds height="30.0" width="30.0" x="360.0" y="70.0"/>
