      <sequenceFlow id="Flow_C24" isImmediate="true" sourceRef="Task_C10" targetRef="GW_C5_merge"/>
      <sequenceFlow id="Flow_C25" isImmediate="true" name="would not involve disproportionate effort" sourceRef="GW_C5_split" targetRef="GW_C5_merge"/>
      <sequenceFlow id="Flow_C26" isImmediate="true" sourceRef="GW_C5_merge" targetRef="End_Controller"/>
   </process>

   <process id="Process_SA" isClosed="false" isExecutable="true" name="Supervisory Authority" processType="None">
      <laneSet id="LaneSet_SA">
         <lane id="Lane_SA">
            <extensionElements>
               <signavio:signavioMetaData metaKey="bgcolor" metaValue=""/>
               <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            </extensionElements>
            <flowNodeRef>Start_SA</flowNodeRef>
            <flowNodeRef>Catch_SA_1</flowNodeRef>
            <flowNodeRef>Task_SA1</flowNodeRef>
            <flowNodeRef>Task_SA2</flowNodeRef>
            <flowNodeRef>Task_SA3</flowNodeRef>
            <flowNodeRef>GW_SA1_split</flowNodeRef>
            <flowNodeRef>Task_SA4</flowNodeRef>
            <flowNodeRef>Task_SA5</flowNodeRef>
            <flowNodeRef>GW_SA1_merge</flowNodeRef>
            <flowNodeRef>End_SA</flowNodeRef>
         </lane>
      </laneSet>
      <startEvent id="Start_SA" name="Start">
         <extensionElements>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/>
         </extensionElements>
         <outgoing>Flow_SA1</outgoing>
      </startEvent>
      <intermediateCatchEvent id="Catch_SA_1" name="Receive the notification from the Controller">
         <extensionElements>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/>
         </extensionElements>
         <incoming>Flow_SA1</incoming>
         <outgoing>Flow_SA2</outgoing>
         <messageEventDefinition id="MsgDef_1"/>
      </intermediateCatchEvent>
      <task completionQuantity="1" id="Task_SA1" isForCompensation="false" name="verify compliance" startQuantity="1">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffcc"/>
         </extensionElements>
         <incoming>Flow_SA2</incoming>
         <outgoing>Flow_SA3</outgoing>
      </task>
      <task completionQuantity="1" id="Task_SA2" isForCompensation="false" name="consider the likelihood of the data breach resulting in a high risk" startQuantity="1">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffcc"/>
         </extensionElements>
         <incoming>Flow_SA3</incoming>
         <outgoing>Flow_SA4</outgoing>
      </task>
      <task completionQuantity="1" id="Task_SA3" isForCompensation="false" name="assess whether the controller has not already communicated and whether likely high risk" startQuantity="1">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffcc"/>
         </extensionElements>
         <incoming>Flow_SA4</incoming>
         <outgoing>Flow_SA5</outgoing>
      </task>
      <exclusiveGateway gatewayDirection="Diverging" id="GW_SA1_split" isMarkerVisible="true" name="Conditions met?">
         <extensionElements>
            <signavio:signavioLabel bottom="true" left="false" ref="text_name" right="false" top="false" valign="top" x="20.0" y="45.0"/>
         </extensionElements>
         <incoming>Flow_SA5</incoming>
         <outgoing>Flow_SA6</outgoing>
         <outgoing>Flow_SA7</outgoing>
         <outgoing>Flow_SA10</outgoing>
      </exclusiveGateway>
      <task completionQuantity="1" id="Task_SA4" isForCompensation="false" name="require the controller to communicate the data breach to the data subject" startQuantity="1">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffcc"/>
         </extensionElements>
         <incoming>Flow_SA6</incoming>
         <outgoing>Flow_SA8</outgoing>
      </task>
      <task completionQuantity="1" id="Task_SA5" isForCompensation="false" name="decide that any of the conditions are met" startQuantity="1">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffcc"/>
         </extensionElements>
         <incoming>Flow_SA7</incoming>
         <outgoing>Flow_SA9</outgoing>
      </task>
      <exclusiveGateway gatewayDirection="Converging" id="GW_SA1_merge" isMarkerVisible="true">
         <incoming>Flow_SA8</incoming>
         <incoming>Flow_SA9</incoming>
         <incoming>Flow_SA10</incoming>
         <outgoing>Flow_SA11</outgoing>
      </exclusiveGateway>
      <endEvent id="End_SA" name="End">
         <extensionElements>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/>
         </extensionElements>
         <incoming>Flow_SA11</incoming>
      </endEvent>
      <sequenceFlow id="Flow_SA1" isImmediate="true" sourceRef="Start_SA" targetRef="Catch_SA_1"/>
      <sequenceFlow id="Flow_SA2" isImmediate="true" sourceRef="Catch_SA_1" targetRef="Task_SA1"/>
      <sequenceFlow id="Flow_SA3" isImmediate="true" sourceRef="Task_SA1" targetRef="Task_SA2"/>
      <sequenceFlow id="Flow_SA4" isImmediate="true" sourceRef="Task_SA2" targetRef="Task_SA3"/>
      <sequenceFlow id="Flow_SA5" isImmediate="true" sourceRef="Task_SA3" targetRef="GW_SA1_split"/>
      <sequenceFlow id="Flow_SA6" isImmediate="true" name="not already communicated and likely high risk, except where conditions referred to in paragraph 3 are met" sourceRef="GW_SA1_split" targetRef="Task_SA4"/>
      <sequenceFlow id="Flow_SA7" isImmediate="true" name="not already communicated and likely high risk" sourceRef="GW_SA1_split" targetRef="Task_SA5"/>
      <sequenceFlow id="Flow_SA8" isImmediate="true" sourceRef="Task_SA4" targetRef="GW_SA1_merge"/>
      <sequenceFlow id="Flow_SA9" isImmediate="true" sourceRef="Task_SA5" targetRef="GW_SA1_merge"/>
      <sequenceFlow id="Flow_SA10" isImmediate="true" name="already communicated or not high risk" sourceRef="GW_SA1_split" targetRef="GW_SA1_merge"/>
      <sequenceFlow id="Flow_SA11" isImmediate="true" sourceRef="GW_SA1_merge" targetRef="End_SA"/>
   </process>

   <bpmndi:BPMNDiagram id="BPMNDiagram_1">
      <bpmndi:BPMNPlane bpmnElement="Collaboration_1" id="BPMNPlane_1">
         <bpmndi:BPMNShape bpmnElement="Participant_Processor" id="Participant_Processor_gui" isHorizontal="true">
