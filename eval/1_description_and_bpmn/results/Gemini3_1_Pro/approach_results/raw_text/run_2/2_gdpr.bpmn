      <exclusiveGateway gatewayDirection="Converging" id="GW_C1_merge" isMarkerVisible="true">
         <incoming>Flow_C4</incoming>
         <incoming>Flow_C5</incoming>
         <outgoing>Flow_C6</outgoing>
      </exclusiveGateway>
      <task completionQuantity="1" id="Task_C3" isForCompensation="false" name="assess whether the notification is not made within 72 hours" startQuantity="1">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffcc"/>
         </extensionElements>
         <incoming>Flow_C6</incoming>
         <outgoing>Flow_C7</outgoing>
      </task>
      <exclusiveGateway gatewayDirection="Diverging" id="GW_C2_split" isMarkerVisible="true" name="Not made within 72h?">
         <extensionElements>
            <signavio:signavioLabel bottom="true" left="false" ref="text_name" right="false" top="false" valign="top" x="20.0" y="45.0"/>
