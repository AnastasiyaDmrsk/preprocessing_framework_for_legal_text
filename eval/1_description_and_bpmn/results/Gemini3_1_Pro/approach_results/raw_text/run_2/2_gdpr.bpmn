         <outgoing>Flow_C23</outgoing>
         <outgoing>Flow_C25</outgoing>
      </exclusiveGateway>
      <task completionQuantity="1" id="Task_C10" isForCompensation="false" name="carry out a public communication or similar measure" startQuantity="1">
