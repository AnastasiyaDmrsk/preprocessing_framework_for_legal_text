<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             xmlns:signavio="http://www.signavio.com"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             exporter="Signavio Process Editor" exporterVersion="19.2.2"
             id="sid-main-definition" targetNamespace="http://www.signavio.com"
             xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd">

    <collaboration id="collab_1">
        <participant id="pool_app" name="Applicant" processRef="proc_app" />
        <participant id="pool_ms" name="Member State" processRef="proc_ms" />
        <participant id="pool_com" name="Commission" processRef="proc_com" />
        <messageFlow id="msg_1" name="" sourceRef="task_ms_11" targetRef="catch_com_1" />
        <messageFlow id="msg_2" name="" sourceRef="task_ms_13" targetRef="catch_com_2" />
    </collaboration>

    <!-- Applicant Process -->
    <process id="proc_app" isClosed="false" isExecutable="false" name="Applicant" processType="None">
        <laneSet id="laneset_app">
            <lane id="lane_app">
                <flowNodeRef>start_app</flowNodeRef>
                <flowNodeRef>gw_app_s_1</flowNodeRef>
                <flowNodeRef>task_app_1</flowNodeRef>
                <flowNodeRef>gw_app_m_1</flowNodeRef>
                <flowNodeRef>gw_app_s_2</flowNodeRef>
                <flowNodeRef>task_app_2</flowNodeRef>
                <flowNodeRef>gw_app_m_2</flowNodeRef>
                <flowNodeRef>end_app</flowNodeRef>
            </lane>
        </laneSet>

        <startEvent id="start_app" name="application for the issuance or renewal of a driving licence">
            <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
            <outgoing>seq_app_start</outgoing>
        </startEvent>

        <exclusiveGateway id="gw_app_s_1" name="" gatewayDirection="Diverging" isMarkerVisible="true">
            <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements>
            <incoming>seq_app_start</incoming>
            <outgoing>seq_app_s1_yes</outgoing>
            <outgoing>seq_app_s1_no</outgoing>
        </exclusiveGateway>

        <task id="task_app_1" name="undergo a medical examination">
            <incoming>seq_app_s1_yes</incoming>
            <outgoing>seq_app_t1_out</outgoing>
        </task>

        <exclusiveGateway id="gw_app_m_1" name="" gatewayDirection="Converging" isMarkerVisible="true">
            <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements>
            <incoming>seq_app_t1_out</incoming>
            <incoming>seq_app_s1_no</incoming>
            <outgoing>seq_app_m1_out</outgoing>
        </exclusiveGateway>

        <exclusiveGateway id="gw_app_s_2" name="" gatewayDirection="Diverging" isMarkerVisible="true">
            <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements>
            <incoming>seq_app_m1_out</incoming>
            <outgoing>seq_app_s2_yes</outgoing>
            <outgoing>seq_app_s2_no</outgoing>
        </exclusiveGateway>

        <task id="task_app_2" name="fill in a self-assessment form">
            <incoming>seq_app_s2_yes</incoming>
            <outgoing>seq_app_t2_out</outgoing>
        </task>

        <exclusiveGateway id="gw_app_m_2" name="" gatewayDirection="Converging" isMarkerVisible="true">
            <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements>
            <incoming>seq_app_t2_out</incoming>
            <incoming>seq_app_s2_no</incoming>
            <outgoing>seq_app_end</outgoing>
        </exclusiveGateway>

        <endEvent id="end_app" name="End">
            <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
            <incoming>seq_app_end</incoming>
        </endEvent>

        <sequenceFlow id="seq_app_start" name="" sourceRef="start_app" targetRef="gw_app_s_1" isImmediate="true" />
        <sequenceFlow id="seq_app_s1_yes" name="yes" sourceRef="gw_app_s_1" targetRef="task_app_1" isImmediate="true" />
        <sequenceFlow id="seq_app_s1_no" name="no" sourceRef="gw_app_s_1" targetRef="gw_app_m_1" isImmediate="true" />
        <sequenceFlow id="seq_app_t1_out" name="" sourceRef="task_app_1" targetRef="gw_app_m_1" isImmediate="true" />
        <sequenceFlow id="seq_app_m1_out" name="" sourceRef="gw_app_m_1" targetRef="gw_app_s_2" isImmediate="true" />
        <sequenceFlow id="seq_app_s2_yes" name="yes" sourceRef="gw_app_s_2" targetRef="task_app_2" isImmediate="true" />
        <sequenceFlow id="seq_app_s2_no" name="no" sourceRef="gw_app_s_2" targetRef="gw_app_m_2" isImmediate="true" />
        <sequenceFlow id="seq_app_t2_out" name="" sourceRef="task_app_2" targetRef="gw_app_m_2" isImmediate="true" />
        <sequenceFlow id="seq_app_end" name="" sourceRef="gw_app_m_2" targetRef="end_app" isImmediate="true" />
    </process>

    <!-- Member State Process -->
    <process id="proc_ms" isClosed="false" isExecutable="false" name="Member State" processType="None">
        <laneSet id="laneset_ms">
            <lane id="lane_ms">
                <flowNodeRef>start_ms</flowNodeRef>
                
                <flowNodeRef>gw_ms_s_1</flowNodeRef>
                <flowNodeRef>task_ms_1</flowNodeRef>
                <flowNodeRef>gw_ms_m_1</flowNodeRef>
                
                <flowNodeRef>gw_ms_s_2</flowNodeRef>
                <flowNodeRef>task_ms_2</flowNodeRef>
                <flowNodeRef>gw_ms_m_2</flowNodeRef>
                
                <flowNodeRef>gw_ms_s_3</flowNodeRef>
                <flowNodeRef>task_ms_3</flowNodeRef>
                <flowNodeRef>gw_ms_m_3</flowNodeRef>
                
                <flowNodeRef>gw_ms_s_4</flowNodeRef>
                <flowNodeRef>task_ms_4</flowNodeRef>
                <flowNodeRef>gw_ms_m_4</flowNodeRef>

                <flowNodeRef>gw_ms_s_5</flowNodeRef>
                <flowNodeRef>task_ms_5</flowNodeRef>
                <flowNodeRef>gw_ms_m_5</flowNodeRef>

                <flowNodeRef>gw_ms_s_6</flowNodeRef>
                <flowNodeRef>task_ms_6</flowNodeRef>
                <flowNodeRef>gw_ms_m_6</flowNodeRef>

                <flowNodeRef>gw_ms_s_7</flowNodeRef>
                <flowNodeRef>task_ms_7</flowNodeRef>
                <flowNodeRef>gw_ms_m_7</flowNodeRef>

                <flowNodeRef>gw_ms_s_8</flowNodeRef>
                <flowNodeRef>task_ms_8</flowNodeRef>
                <flowNodeRef>gw_ms_m_8</flowNodeRef>

                <flowNodeRef>gw_ms_s_9</flowNodeRef>
                <flowNodeRef>task_ms_9</flowNodeRef>
                <flowNodeRef>gw_ms_m_9</flowNodeRef>

                <flowNodeRef>gw_ms_s_10</flowNodeRef>
                <flowNodeRef>task_ms_10</flowNodeRef>
                <flowNodeRef>gw_ms_m_10</flowNodeRef>

                <flowNodeRef>gw_ms_s_11</flowNodeRef>
                <flowNodeRef>task_ms_11</flowNodeRef>
                <flowNodeRef>gw_ms_m_11</flowNodeRef>

                <flowNodeRef>gw_ms_s_12</flowNodeRef>
                <flowNodeRef>task_ms_12</flowNodeRef>
                <flowNodeRef>gw_ms_m_12</flowNodeRef>

                <flowNodeRef>gw_ms_s_13</flowNodeRef>
                <flowNodeRef>task_ms_13</flowNodeRef>
                <flowNodeRef>gw_ms_m_13</flowNodeRef>

                <flowNodeRef>gw_ms_s_14</flowNodeRef>
                <flowNodeRef>task_ms_14</flowNodeRef>
                <flowNodeRef>gw_ms_m_14</flowNodeRef>

                <flowNodeRef>end_ms</flowNodeRef>
            </lane>
        </laneSet>

        <startEvent id="start_ms" name="Start">
            <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
            <outgoing>seq_ms_start</outgoing>
        </startEvent>

        <!-- Block 1 -->
        <exclusiveGateway id="gw_ms_s_1" gatewayDirection="Diverging" isMarkerVisible="true"><extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements><incoming>seq_ms_start</incoming><outgoing>seq_ms_s1_yes</outgoing><outgoing>seq_ms_s1_no</outgoing></exclusiveGateway>
        <task id="task_ms_1" name="ensure that applicants undergo a medical examination"><incoming>seq_ms_s1_yes</incoming><outgoing>seq_ms_t1_out</outgoing></task>
        <exclusiveGateway id="gw_ms_m_1" gatewayDirection="Converging" isMarkerVisible="true"><extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements><incoming>seq_ms_t1_out</incoming><incoming>seq_ms_s1_no</incoming><outgoing>seq_ms_m1_out</outgoing></exclusiveGateway>
        <sequenceFlow id="seq_ms_s1_yes" name="yes" sourceRef="gw_ms_s_1" targetRef="task_ms_1" isImmediate="true" /><sequenceFlow id="seq_ms_s1_no" name="no" sourceRef="gw_ms_s_1" targetRef="gw_ms_m_1" isImmediate="true" /><sequenceFlow id="seq_ms_t1_out" sourceRef="task_ms_1" targetRef="gw_ms_m_1" isImmediate="true" /><sequenceFlow id="seq_ms_m1_out" sourceRef="gw_ms_m_1" targetRef="gw_ms_s_2" isImmediate="true" />

        <!-- Block 2 -->
        <exclusiveGateway id="gw_ms_s_2" gatewayDirection="Diverging" isMarkerVisible="true"><extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements><incoming>seq_ms_m1_out</incoming><outgoing>seq_ms_s2_yes</outgoing><outgoing>seq_ms_s2_no</outgoing></exclusiveGateway>
        <task id="task_ms_2" name="require a medical examination"><incoming>seq_ms_s2_yes</incoming><outgoing>seq_ms_t2_out</outgoing></task>
        <exclusiveGateway id="gw_ms_m_2" gatewayDirection="Converging" isMarkerVisible="true"><extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements><incoming>seq_ms_t2_out</incoming><incoming>seq_ms_s2_no</incoming><outgoing>seq_ms_m2_out</outgoing></exclusiveGateway>
        <sequenceFlow id="seq_ms_s2_yes" name="yes" sourceRef="gw_ms_s_2" targetRef="task_ms_2" isImmediate="true" /><sequenceFlow id="seq_ms_s2_no" name="no" sourceRef="gw_ms_s_2" targetRef="gw_ms_m_2" isImmediate="true" /><sequenceFlow id="seq_ms_t2_out" sourceRef="task_ms_2" targetRef="gw_ms_m_2" isImmediate="true" /><sequenceFlow id="seq_ms_m2_out" sourceRef="gw_ms_m_2" targetRef="gw_ms_s_3" isImmediate="true" />

        <!-- Block 3 -->
        <exclusiveGateway id="gw_ms_s_3" gatewayDirection="Diverging" isMarkerVisible="true"><extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements><incoming>seq_ms_m2_out</incoming><outgoing>seq_ms_s3_yes</outgoing><outgoing>seq_ms_s3_no</outgoing></exclusiveGateway>
        <task id="task_ms_3" name="require the applicant to fill in a self-assessment form"><incoming>seq_ms_s3_yes</incoming><outgoing>seq_ms_t3_out</outgoing></task>
        <exclusiveGateway id="gw_ms_m_3" gatewayDirection="Converging" isMarkerVisible="true"><extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements><incoming>seq_ms_t3_out</incoming><incoming>seq_ms_s3_no</incoming><outgoing>seq_ms_m3_out</outgoing></exclusiveGateway>
        <sequenceFlow id="seq_ms_s3_yes" name="yes" sourceRef="gw_ms_s_3" targetRef="task_ms_3" isImmediate="true" /><sequenceFlow id="seq_ms_s3_no" name="no" sourceRef="gw_ms_s_3" targetRef="gw_ms_m_3" isImmediate="true" /><sequenceFlow id="seq_ms_t3_out" sourceRef="task_ms_3" targetRef="gw_ms_m_3" isImmediate="true" /><sequenceFlow id="seq_ms_m3_out" sourceRef="gw_ms_m_3" targetRef="gw_ms_s_4" isImmediate="true" />

        <!-- Block 4 -->
        <exclusiveGateway id="gw_ms_s_4" gatewayDirection="Diverging" isMarkerVisible="true"><extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements><incoming>seq_ms_m3_out</incoming><outgoing>seq_ms_s4_yes</outgoing><outgoing>seq_ms_s4_no</outgoing></exclusiveGateway>
        <task id="task_ms_4" name="establish a national system of assessment of fitness to drive"><incoming>seq_ms_s4_yes</incoming><outgoing>seq_ms_t4_out</outgoing></task>
        <exclusiveGateway id="gw_ms_m_4" gatewayDirection="Converging" isMarkerVisible="true"><extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements><incoming>seq_ms_t4_out</incoming><incoming>seq_ms_s4_no</incoming><outgoing>seq_ms_m4_out</outgoing></exclusiveGateway>
        <sequenceFlow id="seq_ms_s4_yes" name="yes" sourceRef="gw_ms_s_4" targetRef="task_ms_4" isImmediate="true" /><sequenceFlow id="seq_ms_s4_no" name="no" sourceRef="gw_ms_s_4" targetRef="gw_ms_m_4" isImmediate="true" /><sequenceFlow id="seq_ms_t4_out" sourceRef="task_ms_4" targetRef="gw_ms_m_4" isImmediate="true" /><sequenceFlow id="seq_ms_m4_out" sourceRef="gw_ms_m_4" targetRef="gw_ms_s_5" isImmediate="true" />

        <!-- Block 5 -->
        <exclusiveGateway id="gw_ms_s_5" gatewayDirection="Diverging" isMarkerVisible="true"><extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements><incoming>seq_ms_m4_out</incoming><outgoing>seq_ms_s5_yes</outgoing><outgoing>seq_ms_s5_no</outgoing></exclusiveGateway>
        <task id="task_ms_5" name="provide for appropriate measures to address non-compliance"><incoming>seq_ms_s5_yes</incoming><outgoing>seq_ms_t5_out</outgoing></task>
        <exclusiveGateway id="gw_ms_m_5" gatewayDirection="Converging" isMarkerVisible="true"><extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements><incoming>seq_ms_t5_out</incoming><incoming>seq_ms_s5_no</incoming><outgoing>seq_ms_m5_out</outgoing></exclusiveGateway>
        <sequenceFlow id="seq_ms_s5_yes" name="yes" sourceRef="gw_ms_s_5" targetRef="task_ms_5" isImmediate="true" /><sequenceFlow id="seq_ms_s5_no" name="no" sourceRef="gw_ms_s_5" targetRef="gw_ms_m_5" isImmediate="true" /><sequenceFlow id="seq_ms_t5_out" sourceRef="task_ms_5" targetRef="gw_ms_m_5" isImmediate="true" /><sequenceFlow id="seq_ms_m5_out" sourceRef="gw_ms_m_5" targetRef="gw_ms_s_6" isImmediate="true" />

        <!-- Block 6 -->
        <exclusiveGateway id="gw_ms_s_6" gatewayDirection="Diverging" isMarkerVisible="true"><extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements><incoming>seq_ms_m5_out</incoming><outgoing>seq_ms_s6_yes</outgoing><outgoing>seq_ms_s6_no</outgoing></exclusiveGateway>
        <task id="task_ms_6" name="apply the national system to monitor"><incoming>seq_ms_s6_yes</incoming><outgoing>seq_ms_t6_out</outgoing></task>
        <exclusiveGateway id="gw_ms_m_6" gatewayDirection="Converging" isMarkerVisible="true"><extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements><incoming>seq_ms_t6_out</incoming><incoming>seq_ms_s6_no</incoming><outgoing>seq_ms_m6_out</outgoing></exclusiveGateway>
        <sequenceFlow id="seq_ms_s6_yes" name="yes" sourceRef="gw_ms_s_6" targetRef="task_ms_6" isImmediate="true" /><sequenceFlow id="seq_ms_s6_no" name="no" sourceRef="gw_ms_s_6" targetRef="gw_ms_m_6" isImmediate="true" /><sequenceFlow id="seq_ms_t6_out" sourceRef="task_ms_6" targetRef="gw_ms_m_6" isImmediate="true" /><sequenceFlow id="seq_ms_m6_out" sourceRef="gw_ms_m_6" targetRef="gw_ms_s_7" isImmediate="true" />

        <!-- Block 7 -->
        <exclusiveGateway id="gw_ms_s_7" gatewayDirection="Diverging" isMarkerVisible="true"><extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements><incoming>seq_ms_m6_out</incoming><outgoing>seq_ms_s7_yes</outgoing><outgoing>seq_ms_s7_no</outgoing></exclusiveGateway>
        <task id="task_ms_7" name="ensure that the applicant undergoes a medical examination"><incoming>seq_ms_s7_yes</incoming><outgoing>seq_ms_t7_out</outgoing></task>
        <exclusiveGateway id="gw_ms_m_7" gatewayDirection="Converging" isMarkerVisible="true"><extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements><incoming>seq_ms_t7_out</incoming><incoming>seq_ms_s7_no</incoming><outgoing>seq_ms_m7_out</outgoing></exclusiveGateway>
        <sequenceFlow id="seq_ms_s7_yes" name="yes" sourceRef="gw_ms_s_7" targetRef="task_ms_7" isImmediate="true" /><sequenceFlow id="seq_ms_s7_no" name="no" sourceRef="gw_ms_s_7" targetRef="gw_ms_m_7" isImmediate="true" /><sequenceFlow id="seq_ms_t7_out" sourceRef="task_ms_7" targetRef="gw_ms_m_7" isImmediate="true" /><sequenceFlow id="seq_ms_m7_out" sourceRef="gw_ms_m_7" targetRef="gw_ms_s_8" isImmediate="true" />

        <!-- Block 8 -->
        <exclusiveGateway id="gw_ms_s_8" gatewayDirection="Diverging" isMarkerVisible="true"><extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements><incoming>seq_ms_m7_out</incoming><outgoing>seq_ms_s8_yes</outgoing><outgoing>seq_ms_s8_no</outgoing></exclusiveGateway>
        <task id="task_ms_8" name="take measures to raise awareness"><incoming>seq_ms_s8_yes</incoming><outgoing>seq_ms_t8_out</outgoing></task>
        <exclusiveGateway id="gw_ms_m_8" gatewayDirection="Converging" isMarkerVisible="true"><extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements><incoming>seq_ms_t8_out</incoming><incoming>seq_ms_s8_no</incoming><outgoing>seq_ms_m8_out</outgoing></exclusiveGateway>
