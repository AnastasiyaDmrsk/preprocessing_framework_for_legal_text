        <!-- Block 9 -->
        <exclusiveGateway id="gw_ms_s_9" gatewayDirection="Diverging" isMarkerVisible="true"><extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements><incoming>seq_ms_m8_out</incoming><outgoing>seq_ms_s9_yes</outgoing><outgoing>seq_ms_s9_no</outgoing></exclusiveGateway>
        <task id="task_ms_9" name="take measures to improve the knowledge of the health sector"><incoming>seq_ms_s9_yes</incoming><outgoing>seq_ms_t9_out</outgoing></task>
        <exclusiveGateway id="gw_ms_m_9" gatewayDirection="Converging" isMarkerVisible="true"><extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements><incoming>seq_ms_t9_out</incoming><incoming>seq_ms_s9_no</incoming><outgoing>seq_ms_m9_out</outgoing></exclusiveGateway>
