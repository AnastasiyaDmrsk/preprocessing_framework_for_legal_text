        <!-- Block 10 -->
        <exclusiveGateway id="gw_ms_s_10" gatewayDirection="Diverging" isMarkerVisible="true"><extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements><incoming>seq_ms_m9_out</incoming><outgoing>seq_ms_s10_yes</outgoing><outgoing>seq_ms_s10_no</outgoing></exclusiveGateway>
