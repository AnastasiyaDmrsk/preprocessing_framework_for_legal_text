<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" 
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" 
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" 
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" 
             xmlns:signavio="http://www.signavio.com" 
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
             exporter="Signavio Process Editor, http://www.signavio.com" 
             exporterVersion="19.2.2" 
             expressionLanguage="http://www.w3.org/TR/XPath" 
             id="sid-def-trusted-flagger" 
             targetNamespace="http://www.signavio.com" 
             typeLanguage="http://www.w3.org/2001/XMLSchema" 
             xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd">
   
   <collaboration id="sid-collab">
      <participant id="part_OPP" name="Online Platform Provider" processRef="proc_OPP"/>
      <participant id="part_DSC" name="Digital Services Coordinator" processRef="proc_DSC"/>
      <participant id="part_TF" name="Trusted Flagger" processRef="proc_TF"/>
      <participant id="part_Comm" name="Commission" processRef="proc_Comm"/>
      <participant id="part_CoB" name="Commission or Board" processRef="proc_CoB"/>
      <participant id="part_Board" name="Board" processRef="proc_Board"/>
      
      <messageFlow id="mf_OPP_to_DSC" sourceRef="opp_t5" targetRef="dsc_catch1"/>
      <messageFlow id="mf_DSC_to_Comm" sourceRef="dsc_t2" targetRef="comm_catch1"/>
      <messageFlow id="mf_DSC_to_Board" sourceRef="dsc_t2" targetRef="board_catch1"/>
      <messageFlow id="mf_DSC_to_TF" sourceRef="dsc_t6" targetRef="tf_catch1"/>
      <messageFlow id="mf_TF_to_DSC" sourceRef="tf_t2" targetRef="dsc_catch2"/>
   </collaboration>

   <process id="proc_OPP" isClosed="false" isExecutable="false" name="Online Platform Provider" processType="None">
      <laneSet id="laneSet_OPP">
         <lane id="lane_OPP">
            <flowNodeRef>opp_start</flowNodeRef>
            <flowNodeRef>opp_t1</flowNodeRef>
            <flowNodeRef>opp_gw1_div</flowNodeRef>
            <flowNodeRef>opp_gw2_div</flowNodeRef>
            <flowNodeRef>opp_t2</flowNodeRef>
            <flowNodeRef>opp_t3</flowNodeRef>
            <flowNodeRef>opp_t4</flowNodeRef>
            <flowNodeRef>opp_gw3_conv</flowNodeRef>
            <flowNodeRef>opp_gw1_conv</flowNodeRef>
            <flowNodeRef>opp_gw4_div</flowNodeRef>
            <flowNodeRef>opp_t5</flowNodeRef>
            <flowNodeRef>opp_gw4_conv</flowNodeRef>
            <flowNodeRef>opp_end</flowNodeRef>
         </lane>
      </laneSet>

      <startEvent id="opp_start" name="Start">
         <extensionElements><signavio:signavioLabel align="center" bottom="true" left="false" ref="text_name" right="false" top="false" valign="top" x="15.0" y="32.0"/></extensionElements>
         <outgoing>opp_sf1</outgoing>
      </startEvent>
      <task id="opp_t1" name="take necessary technical and organisational measures">
         <incoming>opp_sf1</incoming>
         <outgoing>opp_sf2</outgoing>
      </task>
      <exclusiveGateway id="opp_gw1_div" name="assess mechanism" gatewayDirection="Diverging" isMarkerVisible="true">
         <extensionElements><signavio:signavioLabel align="center" bottom="true" left="false" ref="text_name" right="false" top="false" valign="top" x="20.0" y="42.0"/></extensionElements>
         <incoming>opp_sf2</incoming>
         <outgoing>opp_sf3_y</outgoing>
         <outgoing>opp_sf3_n</outgoing>
      </exclusiveGateway>
      <parallelGateway id="opp_gw2_div" gatewayDirection="Diverging">
         <incoming>opp_sf3_y</incoming>
         <outgoing>opp_sf4_1</outgoing>
         <outgoing>opp_sf4_2</outgoing>
         <outgoing>opp_sf4_3</outgoing>
      </parallelGateway>
      <task id="opp_t2" name="give priority">
         <incoming>opp_sf4_1</incoming>
         <outgoing>opp_sf5_1</outgoing>
      </task>
      <task id="opp_t3" name="process notices">
         <incoming>opp_sf4_2</incoming>
         <outgoing>opp_sf5_2</outgoing>
      </task>
      <task id="opp_t4" name="decide upon notices">
         <incoming>opp_sf4_3</incoming>
         <outgoing>opp_sf5_3</outgoing>
      </task>
      <parallelGateway id="opp_gw3_conv" gatewayDirection="Converging">
         <incoming>opp_sf5_1</incoming>
         <incoming>opp_sf5_2</incoming>
         <incoming>opp_sf5_3</incoming>
         <outgoing>opp_sf6</outgoing>
      </parallelGateway>
      <exclusiveGateway id="opp_gw1_conv" gatewayDirection="Converging" isMarkerVisible="true">
         <incoming>opp_sf6</incoming>
         <incoming>opp_sf3_n</incoming>
         <outgoing>opp_sf7</outgoing>
      </exclusiveGateway>
      <exclusiveGateway id="opp_gw4_div" name="assess precision" gatewayDirection="Diverging" isMarkerVisible="true">
         <extensionElements><signavio:signavioLabel align="center" bottom="true" left="false" ref="text_name" right="false" top="false" valign="top" x="20.0" y="42.0"/></extensionElements>
         <incoming>opp_sf7</incoming>
         <outgoing>opp_sf8_y</outgoing>
         <outgoing>opp_sf8_n</outgoing>
      </exclusiveGateway>
      <task id="opp_t5" name="communicate information">
         <incoming>opp_sf8_y</incoming>
         <outgoing>opp_sf9</outgoing>
      </task>
      <exclusiveGateway id="opp_gw4_conv" gatewayDirection="Converging" isMarkerVisible="true">
         <incoming>opp_sf9</incoming>
         <incoming>opp_sf8_n</incoming>
         <outgoing>opp_sf10</outgoing>
      </exclusiveGateway>
      <endEvent id="opp_end" name="End">
         <extensionElements><signavio:signavioLabel align="center" bottom="true" left="false" ref="text_name" right="false" top="false" valign="top" x="14.0" y="30.0"/></extensionElements>
         <incoming>opp_sf10</incoming>
      </endEvent>

      <sequenceFlow id="opp_sf1" isImmediate="true" sourceRef="opp_start" targetRef="opp_t1"/>
      <sequenceFlow id="opp_sf2" isImmediate="true" sourceRef="opp_t1" targetRef="opp_gw1_div"/>
      <sequenceFlow id="opp_sf3_y" name="yes" isImmediate="true" sourceRef="opp_gw1_div" targetRef="opp_gw2_div"/>
      <sequenceFlow id="opp_sf3_n" name="no" isImmediate="true" sourceRef="opp_gw1_div" targetRef="opp_gw1_conv"/>
      <sequenceFlow id="opp_sf4_1" isImmediate="true" sourceRef="opp_gw2_div" targetRef="opp_t2"/>
      <sequenceFlow id="opp_sf4_2" isImmediate="true" sourceRef="opp_gw2_div" targetRef="opp_t3"/>
      <sequenceFlow id="opp_sf4_3" isImmediate="true" sourceRef="opp_gw2_div" targetRef="opp_t4"/>
      <sequenceFlow id="opp_sf5_1" isImmediate="true" sourceRef="opp_t2" targetRef="opp_gw3_conv"/>
      <sequenceFlow id="opp_sf5_2" isImmediate="true" sourceRef="opp_t3" targetRef="opp_gw3_conv"/>
      <sequenceFlow id="opp_sf5_3" isImmediate="true" sourceRef="opp_t4" targetRef="opp_gw3_conv"/>
      <sequenceFlow id="opp_sf6" isImmediate="true" sourceRef="opp_gw3_conv" targetRef="opp_gw1_conv"/>
      <sequenceFlow id="opp_sf7" isImmediate="true" sourceRef="opp_gw1_conv" targetRef="opp_gw4_div"/>
      <sequenceFlow id="opp_sf8_y" name="yes" isImmediate="true" sourceRef="opp_gw4_div" targetRef="opp_t5"/>
      <sequenceFlow id="opp_sf8_n" name="no" isImmediate="true" sourceRef="opp_gw4_div" targetRef="opp_gw4_conv"/>
      <sequenceFlow id="opp_sf9" isImmediate="true" sourceRef="opp_t5" targetRef="opp_gw4_conv"/>
      <sequenceFlow id="opp_sf10" isImmediate="true" sourceRef="opp_gw4_conv" targetRef="opp_end"/>
   </process>

   <process id="proc_DSC" isClosed="false" isExecutable="false" name="Digital Services Coordinator" processType="None">
      <laneSet id="laneSet_DSC">
         <lane id="lane_DSC">
            <flowNodeRef>dsc_start</flowNodeRef>
            <flowNodeRef>dsc_gw1_div</flowNodeRef>
            <flowNodeRef>dsc_t1</flowNodeRef>
            <flowNodeRef>dsc_gw1_conv</flowNodeRef>
            <flowNodeRef>dsc_gw2_div</flowNodeRef>
            <flowNodeRef>dsc_t2</flowNodeRef>
            <flowNodeRef>dsc_gw2_conv</flowNodeRef>
            <flowNodeRef>dsc_catch1</flowNodeRef>
            <flowNodeRef>dsc_gw3_div</flowNodeRef>
            <flowNodeRef>dsc_t3</flowNodeRef>
            <flowNodeRef>dsc_t4</flowNodeRef>
            <flowNodeRef>dsc_gw3_conv</flowNodeRef>
            <flowNodeRef>dsc_gw4_div</flowNodeRef>
            <flowNodeRef>dsc_t5</flowNodeRef>
            <flowNodeRef>dsc_t6</flowNodeRef>
            <flowNodeRef>dsc_t7</flowNodeRef>
            <flowNodeRef>dsc_gw4_conv</flowNodeRef>
            <flowNodeRef>dsc_catch2</flowNodeRef>
            <flowNodeRef>dsc_end</flowNodeRef>
         </lane>
      </laneSet>

      <startEvent id="dsc_start" name="Start">
         <extensionElements><signavio:signavioLabel align="center" bottom="true" left="false" ref="text_name" right="false" top="false" valign="top" x="15.0" y="32.0"/></extensionElements>
         <outgoing>dsc_sf1</outgoing>
      </startEvent>
      <exclusiveGateway id="dsc_gw1_div" name="assess application" gatewayDirection="Diverging" isMarkerVisible="true">
         <extensionElements><signavio:signavioLabel align="center" bottom="true" left="false" ref="text_name" right="false" top="false" valign="top" x="20.0" y="42.0"/></extensionElements>
         <incoming>dsc_sf1</incoming>
         <outgoing>dsc_sf2_y</outgoing>
         <outgoing>dsc_sf2_n</outgoing>
      </exclusiveGateway>
      <task id="dsc_t1" name="award status">
         <incoming>dsc_sf2_y</incoming>
         <outgoing>dsc_sf3</outgoing>
      </task>
      <exclusiveGateway id="dsc_gw1_conv" gatewayDirection="Converging" isMarkerVisible="true">
         <incoming>dsc_sf3</incoming>
         <incoming>dsc_sf2_n</incoming>
         <outgoing>dsc_sf4</outgoing>
      </exclusiveGateway>
      <exclusiveGateway id="dsc_gw2_div" name="assess following award" gatewayDirection="Diverging" isMarkerVisible="true">
         <extensionElements><signavio:signavioLabel align="center" bottom="true" left="false" ref="text_name" right="false" top="false" valign="top" x="20.0" y="42.0"/></extensionElements>
         <incoming>dsc_sf4</incoming>
         <outgoing>dsc_sf5_y</outgoing>
         <outgoing>dsc_sf5_n</outgoing>
      </exclusiveGateway>
      <task id="dsc_t2" name="communicate to Commission and Board">
         <incoming>dsc_sf5_y</incoming>
         <outgoing>dsc_sf6</outgoing>
      </task>
      <exclusiveGateway id="dsc_gw2_conv" gatewayDirection="Converging" isMarkerVisible="true">
         <incoming>dsc_sf6</incoming>
         <incoming>dsc_sf5_n</incoming>
         <outgoing>dsc_sf7</outgoing>
      </exclusiveGateway>
      <intermediateCatchEvent id="dsc_catch1" name="Receive info">
         <extensionElements><signavio:signavioLabel align="center" bottom="true" left="false" ref="text_name" right="false" top="false" valign="top" x="15.0" y="32.0"/></extensionElements>
         <incoming>dsc_sf7</incoming>
         <outgoing>dsc_sf8</outgoing>
         <messageEventDefinition id="med_dsc1"/>
      </intermediateCatchEvent>
      <exclusiveGateway id="dsc_gw3_div" name="assess reasons" gatewayDirection="Diverging" isMarkerVisible="true">
         <extensionElements><signavio:signavioLabel align="center" bottom="true" left="false" ref="text_name" right="false" top="false" valign="top" x="20.0" y="42.0"/></extensionElements>
         <incoming>dsc_sf8</incoming>
         <outgoing>dsc_sf9_y</outgoing>
         <outgoing>dsc_sf9_n</outgoing>
      </exclusiveGateway>
      <task id="dsc_t3" name="suspend status">
         <incoming>dsc_sf9_y</incoming>
         <outgoing>dsc_sf10</outgoing>
      </task>
      <task id="dsc_t4" name="carry out investigation">
         <incoming>dsc_sf10</incoming>
         <outgoing>dsc_sf11</outgoing>
      </task>
      <exclusiveGateway id="dsc_gw3_conv" gatewayDirection="Converging" isMarkerVisible="true">
         <incoming>dsc_sf11</incoming>
         <incoming>dsc_sf9_n</incoming>
         <outgoing>dsc_sf12</outgoing>
      </exclusiveGateway>
      <exclusiveGateway id="dsc_gw4_div" name="assess conditions" gatewayDirection="Diverging" isMarkerVisible="true">
         <extensionElements><signavio:signavioLabel align="center" bottom="true" left="false" ref="text_name" right="false" top="false" valign="top" x="20.0" y="42.0"/></extensionElements>
         <incoming>dsc_sf12</incoming>
         <outgoing>dsc_sf13_y</outgoing>
         <outgoing>dsc_sf13_n</outgoing>
      </exclusiveGateway>
      <task id="dsc_t5" name="afford opportunity">
         <incoming>dsc_sf13_y</incoming>
         <outgoing>dsc_sf14</outgoing>
      </task>
      <task id="dsc_t6" name="transmit opportunity">
         <incoming>dsc_sf14</incoming>
         <outgoing>dsc_sf15</outgoing>
      </task>
      <task id="dsc_t7" name="revoke status">
         <incoming>dsc_sf15</incoming>
         <outgoing>dsc_sf16</outgoing>
      </task>
      <exclusiveGateway id="dsc_gw4_conv" gatewayDirection="Converging" isMarkerVisible="true">
         <incoming>dsc_sf16</incoming>
         <incoming>dsc_sf13_n</incoming>
         <outgoing>dsc_sf17</outgoing>
      </exclusiveGateway>
      <intermediateCatchEvent id="dsc_catch2" name="Receive reports">
         <extensionElements><signavio:signavioLabel align="center" bottom="true" left="false" ref="text_name" right="false" top="false" valign="top" x="15.0" y="32.0"/></extensionElements>
         <incoming>dsc_sf17</incoming>
         <outgoing>dsc_sf18</outgoing>
         <messageEventDefinition id="med_dsc2"/>
      </intermediateCatchEvent>
      <endEvent id="dsc_end" name="End">
         <extensionElements><signavio:signavioLabel align="center" bottom="true" left="false" ref="text_name" right="false" top="false" valign="top" x="14.0" y="30.0"/></extensionElements>
         <incoming>dsc_sf18</incoming>
      </endEvent>

      <sequenceFlow id="dsc_sf1" isImmediate="true" sourceRef="dsc_start" targetRef="dsc_gw1_div"/>
      <sequenceFlow id="dsc_sf2_y" name="yes" isImmediate="true" sourceRef="dsc_gw1_div" targetRef="dsc_t1"/>
      <sequenceFlow id="dsc_sf2_n" name="no" isImmediate="true" sourceRef="dsc_gw1_div" targetRef="dsc_gw1_conv"/>
      <sequenceFlow id="dsc_sf3" isImmediate="true" sourceRef="dsc_t1" targetRef="dsc_gw1_conv"/>
      <sequenceFlow id="dsc_sf4" isImmediate="true" sourceRef="dsc_gw1_conv" targetRef="dsc_gw2_div"/>
      <sequenceFlow id="dsc_sf5_y" name="yes" isImmediate="true" sourceRef="dsc_gw2_div" targetRef="dsc_t2"/>
      <sequenceFlow id="dsc_sf5_n" name="no" isImmediate="true" sourceRef="dsc_gw2_div" targetRef="dsc_gw2_conv"/>
      <sequenceFlow id="dsc_sf6" isImmediate="true" sourceRef="dsc_t2" targetRef="dsc_gw2_conv"/>
      <sequenceFlow id="dsc_sf7" isImmediate="true" sourceRef="dsc_gw2_conv" targetRef="dsc_catch1"/>
      <sequenceFlow id="dsc_sf8" isImmediate="true" sourceRef="dsc_catch1" targetRef="dsc_gw3_div"/>
      <sequenceFlow id="dsc_sf9_y" name="yes" isImmediate="true" sourceRef="dsc_gw3_div" targetRef="dsc_t3"/>
      <sequenceFlow id="dsc_sf9_n" name="no" isImmediate="true" sourceRef="dsc_gw3_div" targetRef="dsc_gw3_conv"/>
      <sequenceFlow id="dsc_sf10" isImmediate="true" sourceRef="dsc_t3" targetRef="dsc_t4"/>
      <sequenceFlow id="dsc_sf11" isImmediate="true" sourceRef="dsc_t4" targetRef="dsc_gw3_conv"/>
      <sequenceFlow id="dsc_sf12" isImmediate="true" sourceRef="dsc_gw3_conv" targetRef="dsc_gw4_div"/>
      <sequenceFlow id="dsc_sf13_y" name="yes" isImmediate="true" sourceRef="dsc_gw4_div" targetRef="dsc_t5"/>
      <sequenceFlow id="dsc_sf13_n" name="no" isImmediate="true" sourceRef="dsc_gw4_div" targetRef="dsc_gw4_conv"/>
      <sequenceFlow id="dsc_sf14" isImmediate="true" sourceRef="dsc_t5" targetRef="dsc_t6"/>
      <sequenceFlow id="dsc_sf15" isImmediate="true" sourceRef="dsc_t6" targetRef="dsc_t7"/>
      <sequenceFlow id="dsc_sf16" isImmediate="true" sourceRef="dsc_t7" targetRef="dsc_gw4_conv"/>
      <sequenceFlow id="dsc_sf17" isImmediate="true" sourceRef="dsc_gw4_conv" targetRef="dsc_catch2"/>
      <sequenceFlow id="dsc_sf18" isImmediate="true" sourceRef="dsc_catch2" targetRef="dsc_end"/>
   </process>

   <process id="proc_TF" isClosed="false" isExecutable="false" name="Trusted Flagger" processType="None">
      <laneSet id="laneSet_TF">
         <lane id="lane_TF">
            <flowNodeRef>tf_start</flowNodeRef>
            <flowNodeRef>tf_gw1_div</flowNodeRef>
            <flowNodeRef>tf_t1</flowNodeRef>
            <flowNodeRef>tf_gw1_conv</flowNodeRef>
            <flowNodeRef>tf_t2</flowNodeRef>
            <flowNodeRef>tf_t3</flowNodeRef>
            <flowNodeRef>tf_catch1</flowNodeRef>
            <flowNodeRef>tf_t4</flowNodeRef>
            <flowNodeRef>tf_end</flowNodeRef>
         </lane>
      </laneSet>

      <startEvent id="tf_start" name="Start">
         <extensionElements><signavio:signavioLabel align="center" bottom="true" left="false" ref="text_name" right="false" top="false" valign="top" x="15.0" y="32.0"/></extensionElements>
         <outgoing>tf_sf1</outgoing>
      </startEvent>
      <exclusiveGateway id="tf_gw1_div" name="assess reports" gatewayDirection="Diverging" isMarkerVisible="true">
         <extensionElements><signavio:signavioLabel align="center" bottom="true" left="false" ref="text_name" right="false" top="false" valign="top" x="20.0" y="42.0"/></extensionElements>
         <incoming>tf_sf1</incoming>
         <outgoing>tf_sf2_y</outgoing>
         <outgoing>tf_sf2_n</outgoing>
      </exclusiveGateway>
      <task id="tf_t1" name="publish reports">
         <incoming>tf_sf2_y</incoming>
         <outgoing>tf_sf3</outgoing>
      </task>
      <exclusiveGateway id="tf_gw1_conv" gatewayDirection="Converging" isMarkerVisible="true">
         <incoming>tf_sf3</incoming>
         <incoming>tf_sf2_n</incoming>
         <outgoing>tf_sf4</outgoing>
      </exclusiveGateway>
      <task id="tf_t2" name="send reports">
         <incoming>tf_sf4</incoming>
         <outgoing>tf_sf5</outgoing>
      </task>
      <task id="tf_t3" name="make publicly available">
         <incoming>tf_sf5</incoming>
         <outgoing>tf_sf6</outgoing>
      </task>
      <intermediateCatchEvent id="tf_catch1" name="Receive opportunity">
         <extensionElements><signavio:signavioLabel align="center" bottom="true" left="false" ref="text_name" right="false" top="false" valign="top" x="15.0" y="32.0"/></extensionElements>
         <incoming>tf_sf6</incoming>
         <outgoing>tf_sf7</outgoing>
         <messageEventDefinition id="med_tf1"/>
      </intermediateCatchEvent>
      <task id="tf_t4" name="react">
         <incoming>tf_sf7</incoming>
         <outgoing>tf_sf8</outgoing>
      </task>
      <endEvent id="tf_end" name="End">
         <extensionElements><signavio:signavioLabel align="center" bottom="true" left="false" ref="text_name" right="false" top="false" valign="top" x="14.0" y="30.0"/></extensionElements>
         <incoming>tf_sf8</incoming>
      </endEvent>

      <sequenceFlow id="tf_sf1" isImmediate="true" sourceRef="tf_start" targetRef="tf_gw1_div"/>
      <sequenceFlow id="tf_sf2_y" name="yes" isImmediate="true" sourceRef="tf_gw1_div" targetRef="tf_t1"/>
      <sequenceFlow id="tf_sf2_n" name="no" isImmediate="true" sourceRef="tf_gw1_div" targetRef="tf_gw1_conv"/>
      <sequenceFlow id="tf_sf3" isImmediate="true" sourceRef="tf_t1" targetRef="tf_gw1_conv"/>
      <sequenceFlow id="tf_sf4" isImmediate="true" sourceRef="tf_gw1_conv" targetRef="tf_t2"/>
      <sequenceFlow id="tf_sf5" isImmediate="true" sourceRef="tf_t2" targetRef="tf_t3"/>
      <sequenceFlow id="tf_sf6" isImmediate="true" sourceRef="tf_t3" targetRef="tf_catch1"/>
      <sequenceFlow id="tf_sf7" isImmediate="true" sourceRef="tf_catch1" targetRef="tf_t4"/>
      <sequenceFlow id="tf_sf8" isImmediate="true" sourceRef="tf_t4" targetRef="tf_end"/>
   </process>

   <process id="proc_Comm" isClosed="false" isExecutable="false" name="Commission" processType="None">
      <laneSet id="laneSet_Comm">
         <lane id="lane_Comm">
            <flowNodeRef>comm_start</flowNodeRef>
            <flowNodeRef>comm_catch1</flowNodeRef>
            <flowNodeRef>comm_t1</flowNodeRef>
            <flowNodeRef>comm_t2</flowNodeRef>
            <flowNodeRef>comm_gw1_div</flowNodeRef>
            <flowNodeRef>comm_t3</flowNodeRef>
            <flowNodeRef>comm_gw1_conv</flowNodeRef>
            <flowNodeRef>comm_end</flowNodeRef>
         </lane>
      </laneSet>

      <startEvent id="comm_start" name="Start">
         <extensionElements><signavio:signavioLabel align="center" bottom="true" left="false" ref="text_name" right="false" top="false" valign="top" x="15.0" y="32.0"/></extensionElements>
         <outgoing>comm_sf1</outgoing>
      </startEvent>
      <intermediateCatchEvent id="comm_catch1" name="Receive info">
         <extensionElements><signavio:signavioLabel align="center" bottom="true" left="false" ref="text_name" right="false" top="false" valign="top" x="15.0" y="32.0"/></extensionElements>
         <incoming>comm_sf1</incoming>
         <outgoing>comm_sf2</outgoing>
         <messageEventDefinition id="med_comm1"/>
      </intermediateCatchEvent>
      <task id="comm_t1" name="publish information">
         <incoming>comm_sf2</incoming>
         <outgoing>comm_sf3</outgoing>
      </task>
      <task id="comm_t2" name="keep database up to date">
         <incoming>comm_sf3</incoming>
         <outgoing>comm_sf4</outgoing>
      </task>
      <exclusiveGateway id="comm_gw1_div" name="assess necessary" gatewayDirection="Diverging" isMarkerVisible="true">
         <extensionElements><signavio:signavioLabel align="center" bottom="true" left="false" ref="text_name" right="false" top="false" valign="top" x="20.0" y="42.0"/></extensionElements>
         <incoming>comm_sf4</incoming>
         <outgoing>comm_sf5_y</outgoing>
         <outgoing>comm_sf5_n</outgoing>
      </exclusiveGateway>
      <task id="comm_t3" name="issue guidelines">
         <incoming>comm_sf5_y</incoming>
         <outgoing>comm_sf6</outgoing>
      </task>
      <exclusiveGateway id="comm_gw1_conv" gatewayDirection="Converging" isMarkerVisible="true">
         <incoming>comm_sf6</incoming>
         <incoming>comm_sf5_n</incoming>
         <outgoing>comm_sf7</outgoing>
      </exclusiveGateway>
