            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffff"/>
         </extensionElements>
      </participant>
      <participant id="participant_IP" name="Interested Party" processRef="process_IP">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffff"/>
         </extensionElements>
      </participant>

      <messageFlow id="mf1" name="" sourceRef="c_t6" targetRef="en_catch_req"/>
      <messageFlow id="mf2" name="" sourceRef="e_t3" targetRef="en_catch_req"/>
      <messageFlow id="mf3" name="" sourceRef="en_pt3" targetRef="e_catch1"/>
      <messageFlow id="mf4" name="" sourceRef="e_t6" targetRef="en_catch_op"/>
      <messageFlow id="mf5" name="" sourceRef="en_t6" targetRef="c_catch1"/>
      <messageFlow id="mf6" name="" sourceRef="ip_t2" targetRef="en_catch_fb"/>
      <messageFlow id="mf7" name="" sourceRef="c_t9" targetRef="en_catch_rev"/>
      <messageFlow id="mf8" name="" sourceRef="e_t8" targetRef="en_catch_rev"/>
   </collaboration>

   <process id="process_C" isClosed="false" isExecutable="true" name="Commission" processType="None">
      <startEvent id="c_start" name="Need to prepare or review scheme">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
         <outgoing>c_sf1</outgoing>
      </startEvent>
      <task id="c_t1" name="Assess whether the scheme is on the basis of the Union rolling work programme">
         <incoming>c_sf1</incoming>
         <outgoing>c_sf2</outgoing>
      </task>
      <exclusiveGateway id="c_gw1" name="On basis?" gatewayDirection="Diverging" isMarkerVisible="true">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements>
         <incoming>c_sf2</incoming>
         <outgoing>c_sf3</outgoing>
         <outgoing>c_sf4</outgoing>
         <outgoing>c_sf5</outgoing>
      </exclusiveGateway>
      <task id="c_t2a" name="Request ENISA to prepare a candidate cybersecurity certification scheme">
         <incoming>c_sf3</incoming>
         <outgoing>c_sf10</outgoing>
      </task>
      <task id="c_t2b" name="Request ENISA to review an existing European cybersecurity certification scheme">
         <incoming>c_sf4</incoming>
         <outgoing>c_sf11</outgoing>
      </task>
      <task id="c_t3" name="Assess whether the candidate scheme or existing scheme is not included in programme and whether in duly justified cases">
         <incoming>c_sf5</incoming>
         <outgoing>c_sf6</outgoing>
      </task>
      <exclusiveGateway id="c_gw2" name="Duly justified?" gatewayDirection="Diverging" isMarkerVisible="true">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements>
         <incoming>c_sf6</incoming>
         <outgoing>c_sf7</outgoing>
         <outgoing>c_sf8</outgoing>
         <outgoing>c_sf9</outgoing>
      </exclusiveGateway>
      <task id="c_t4a" name="Request ENISA to prepare a candidate cybersecurity certification scheme">
         <incoming>c_sf7</incoming>
         <outgoing>c_sf12</outgoing>
      </task>
      <task id="c_t4b" name="Request ENISA to review an existing European cybersecurity certification scheme">
         <incoming>c_sf8</incoming>
         <outgoing>c_sf13</outgoing>
      </task>
      <exclusiveGateway id="c_gw_merge1" name="Merge" gatewayDirection="Converging" isMarkerVisible="true">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements>
         <incoming>c_sf10</incoming>
         <incoming>c_sf11</incoming>
         <incoming>c_sf9</incoming>
         <incoming>c_sf12</incoming>
         <incoming>c_sf13</incoming>
         <outgoing>c_sf14</outgoing>
      </exclusiveGateway>
      <task id="c_t5" name="Update the Union rolling work programme">
         <incoming>c_sf14</incoming>
         <outgoing>c_sf15</outgoing>
      </task>
      <task id="c_t6" name="Transmit the request to ENISA">
         <incoming>c_sf15</incoming>
         <outgoing>c_sf16</outgoing>
      </task>
      <intermediateCatchEvent id="c_catch1" name="Receive candidate scheme">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
         <incoming>c_sf16</incoming>
         <outgoing>c_sf17</outgoing>
         <messageEventDefinition id="med_c_catch1"/>
      </intermediateCatchEvent>
      <task id="c_t7" name="Adopt implementing acts">
         <incoming>c_sf17</incoming>
         <outgoing>c_sf18</outgoing>
      </task>
      <task id="c_t8" name="Request ENISA to start the process of developing a revised candidate scheme">
         <incoming>c_sf18</incoming>
         <outgoing>c_sf19</outgoing>
      </task>
      <exclusiveGateway id="c_gw3" name="Request made?" gatewayDirection="Diverging" isMarkerVisible="true">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements>
         <incoming>c_sf19</incoming>
         <outgoing>c_sf20</outgoing>
         <outgoing>c_sf21</outgoing>
      </exclusiveGateway>
      <task id="c_t9" name="Transmit the request to ENISA">
         <incoming>c_sf20</incoming>
         <outgoing>c_sf22</outgoing>
      </task>
      <exclusiveGateway id="c_gw_merge2" name="Merge" gatewayDirection="Converging" isMarkerVisible="true">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements>
         <incoming>c_sf21</incoming>
         <incoming>c_sf22</incoming>
         <outgoing>c_sf23</outgoing>
      </exclusiveGateway>
      <endEvent id="c_end" name="Scheme adoption or revised candidate scheme end event">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
         <incoming>c_sf23</incoming>
      </endEvent>

      <sequenceFlow id="c_sf1" isImmediate="true" sourceRef="c_start" targetRef="c_t1"/>
      <sequenceFlow id="c_sf2" isImmediate="true" sourceRef="c_t1" targetRef="c_gw1"/>
      <sequenceFlow id="c_sf3" isImmediate="true" name="yes, prepare" sourceRef="c_gw1" targetRef="c_t2a"/>
      <sequenceFlow id="c_sf4" isImmediate="true" name="yes, review" sourceRef="c_gw1" targetRef="c_t2b"/>
      <sequenceFlow id="c_sf5" isImmediate="true" name="no" sourceRef="c_gw1" targetRef="c_t3"/>
      <sequenceFlow id="c_sf6" isImmediate="true" sourceRef="c_t3" targetRef="c_gw2"/>
      <sequenceFlow id="c_sf7" isImmediate="true" name="yes, prepare" sourceRef="c_gw2" targetRef="c_t4a"/>
      <sequenceFlow id="c_sf8" isImmediate="true" name="yes, review" sourceRef="c_gw2" targetRef="c_t4b"/>
      <sequenceFlow id="c_sf9" isImmediate="true" name="no" sourceRef="c_gw2" targetRef="c_gw_merge1"/>
      <sequenceFlow id="c_sf10" isImmediate="true" sourceRef="c_t2a" targetRef="c_gw_merge1"/>
      <sequenceFlow id="c_sf11" isImmediate="true" sourceRef="c_t2b" targetRef="c_gw_merge1"/>
      <sequenceFlow id="c_sf12" isImmediate="true" sourceRef="c_t4a" targetRef="c_gw_merge1"/>
      <sequenceFlow id="c_sf13" isImmediate="true" sourceRef="c_t4b" targetRef="c_gw_merge1"/>
      <sequenceFlow id="c_sf14" isImmediate="true" sourceRef="c_gw_merge1" targetRef="c_t5"/>
      <sequenceFlow id="c_sf15" isImmediate="true" sourceRef="c_t5" targetRef="c_t6"/>
      <sequenceFlow id="c_sf16" isImmediate="true" sourceRef="c_t6" targetRef="c_catch1"/>
      <sequenceFlow id="c_sf17" isImmediate="true" sourceRef="c_catch1" targetRef="c_t7"/>
      <sequenceFlow id="c_sf18" isImmediate="true" sourceRef="c_t7" targetRef="c_t8"/>
      <sequenceFlow id="c_sf19" isImmediate="true" sourceRef="c_t8" targetRef="c_gw3"/>
      <sequenceFlow id="c_sf20" isImmediate="true" name="yes" sourceRef="c_gw3" targetRef="c_t9"/>
      <sequenceFlow id="c_sf21" isImmediate="true" name="no" sourceRef="c_gw3" targetRef="c_gw_merge2"/>
      <sequenceFlow id="c_sf22" isImmediate="true" sourceRef="c_t9" targetRef="c_gw_merge2"/>
      <sequenceFlow id="c_sf23" isImmediate="true" sourceRef="c_gw_merge2" targetRef="c_end"/>
   </process>

   <process id="process_E" isClosed="false" isExecutable="true" name="ECCG" processType="None">
      <startEvent id="e_start" name="Start">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
         <outgoing>e_sf1</outgoing>
      </startEvent>
      <task id="e_t1" name="Assess whether the candidate scheme or existing scheme is not included in programme and whether in duly justified cases">
         <incoming>e_sf1</incoming>
         <outgoing>e_sf2</outgoing>
      </task>
      <exclusiveGateway id="e_gw1" name="Duly justified?" gatewayDirection="Diverging" isMarkerVisible="true">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements>
         <incoming>e_sf2</incoming>
         <outgoing>e_sf3</outgoing>
         <outgoing>e_sf4</outgoing>
         <outgoing>e_sf5</outgoing>
      </exclusiveGateway>
      <task id="e_t2a" name="Request ENISA to prepare a candidate cybersecurity certification scheme">
         <incoming>e_sf3</incoming>
         <outgoing>e_sf6</outgoing>
      </task>
      <task id="e_t2b" name="Request ENISA to review an existing European cybersecurity certification scheme">
         <incoming>e_sf4</incoming>
         <outgoing>e_sf7</outgoing>
      </task>
      <exclusiveGateway id="e_gw_merge1" name="Merge" gatewayDirection="Converging" isMarkerVisible="true">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements>
         <incoming>e_sf6</incoming>
         <incoming>e_sf7</incoming>
         <incoming>e_sf5</incoming>
         <outgoing>e_sf8</outgoing>
      </exclusiveGateway>
      <task id="e_t3" name="Transmit the request to ENISA">
         <incoming>e_sf8</incoming>
         <outgoing>e_sf9</outgoing>
      </task>
      <intermediateCatchEvent id="e_catch1" name="Receive communication from ENISA">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
         <incoming>e_sf9</incoming>
         <outgoing>e_sf10</outgoing>
         <messageEventDefinition id="med_e_catch1"/>
      </intermediateCatchEvent>
      <task id="e_t4" name="Provide ENISA with assistance and expert advice">
         <incoming>e_sf10</incoming>
         <outgoing>e_sf11</outgoing>
      </task>
      <task id="e_t5" name="Adopt an opinion on the candidate scheme">
         <incoming>e_sf11</incoming>
         <outgoing>e_sf12</outgoing>
      </task>
      <task id="e_t6" name="Transmit the opinion on the candidate scheme to ENISA">
         <incoming>e_sf12</incoming>
         <outgoing>e_sf13</outgoing>
      </task>
      <task id="e_t7" name="Request ENISA to start the process of developing a revised candidate scheme">
         <incoming>e_sf13</incoming>
         <outgoing>e_sf14</outgoing>
      </task>
      <exclusiveGateway id="e_gw2" name="Request made?" gatewayDirection="Diverging" isMarkerVisible="true">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements>
         <incoming>e_sf14</incoming>
         <outgoing>e_sf15</outgoing>
         <outgoing>e_sf16</outgoing>
      </exclusiveGateway>
      <task id="e_t8" name="Transmit the request to ENISA">
         <incoming>e_sf15</incoming>
         <outgoing>e_sf17</outgoing>
      </task>
      <exclusiveGateway id="e_gw_merge2" name="Merge" gatewayDirection="Converging" isMarkerVisible="true">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements>
         <incoming>e_sf16</incoming>
         <incoming>e_sf17</incoming>
         <outgoing>e_sf18</outgoing>
      </exclusiveGateway>
      <endEvent id="e_end" name="Revision request end event">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
         <incoming>e_sf18</incoming>
      </endEvent>

      <sequenceFlow id="e_sf1" isImmediate="true" sourceRef="e_start" targetRef="e_t1"/>
      <sequenceFlow id="e_sf2" isImmediate="true" sourceRef="e_t1" targetRef="e_gw1"/>
      <sequenceFlow id="e_sf3" isImmediate="true" name="yes, prepare" sourceRef="e_gw1" targetRef="e_t2a"/>
      <sequenceFlow id="e_sf4" isImmediate="true" name="yes, review" sourceRef="e_gw1" targetRef="e_t2b"/>
      <sequenceFlow id="e_sf5" isImmediate="true" name="no" sourceRef="e_gw1" targetRef="e_gw_merge1"/>
      <sequenceFlow id="e_sf6" isImmediate="true" sourceRef="e_t2a" targetRef="e_gw_merge1"/>
      <sequenceFlow id="e_sf7" isImmediate="true" sourceRef="e_t2b" targetRef="e_gw_merge1"/>
      <sequenceFlow id="e_sf8" isImmediate="true" sourceRef="e_gw_merge1" targetRef="e_t3"/>
      <sequenceFlow id="e_sf9" isImmediate="true" sourceRef="e_t3" targetRef="e_catch1"/>
      <sequenceFlow id="e_sf10" isImmediate="true" sourceRef="e_catch1" targetRef="e_t4"/>
      <sequenceFlow id="e_sf11" isImmediate="true" sourceRef="e_t4" targetRef="e_t5"/>
      <sequenceFlow id="e_sf12" isImmediate="true" sourceRef="e_t5" targetRef="e_t6"/>
      <sequenceFlow id="e_sf13" isImmediate="true" sourceRef="e_t6" targetRef="e_t7"/>
      <sequenceFlow id="e_sf14" isImmediate="true" sourceRef="e_t7" targetRef="e_gw2"/>
      <sequenceFlow id="e_sf15" isImmediate="true" name="yes" sourceRef="e_gw2" targetRef="e_t8"/>
      <sequenceFlow id="e_sf16" isImmediate="true" name="no" sourceRef="e_gw2" targetRef="e_gw_merge2"/>
      <sequenceFlow id="e_sf17" isImmediate="true" sourceRef="e_t8" targetRef="e_gw_merge2"/>
      <sequenceFlow id="e_sf18" isImmediate="true" sourceRef="e_gw_merge2" targetRef="e_end"/>
   </process>

   <process id="process_EN" isClosed="false" isExecutable="true" name="ENISA" processType="None">
      <laneSet id="ls_enisa">
         <lane id="lane_enisa_main" name="ENISA">
            <flowNodeRef>en_start</flowNodeRef>
            <flowNodeRef>en_catch_req</flowNodeRef>
            <flowNodeRef>en_gw1</flowNodeRef>
            <flowNodeRef>en_t1</flowNodeRef>
            <flowNodeRef>en_t3</flowNodeRef>
            <flowNodeRef>en_end_refuse</flowNodeRef>
            <flowNodeRef>en_t4</flowNodeRef>
            <flowNodeRef>en_gw_par1</flowNodeRef>
            <flowNodeRef>en_pt1</flowNodeRef>
            <flowNodeRef>en_pt2</flowNodeRef>
            <flowNodeRef>en_pt3</flowNodeRef>
            <flowNodeRef>en_gw_par2</flowNodeRef>
            <flowNodeRef>en_gw2</flowNodeRef>
            <flowNodeRef>en_gw_merge_op</flowNodeRef>
            <flowNodeRef>en_catch_op</flowNodeRef>
            <flowNodeRef>en_t5</flowNodeRef>
            <flowNodeRef>en_t6</flowNodeRef>
            <flowNodeRef>en_catch_fb</flowNodeRef>
            <flowNodeRef>en_t7</flowNodeRef>
            <flowNodeRef>en_catch_rev</flowNodeRef>
            <flowNodeRef>en_t8</flowNodeRef>
            <flowNodeRef>en_end</flowNodeRef>
         </lane>
         <lane id="lane_mb" name="Management Board">
            <flowNodeRef>en_t2_mb</flowNodeRef>
         </lane>
      </laneSet>

      <startEvent id="en_start" name="Start">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
         <outgoing>en_sf1</outgoing>
      </startEvent>
      <intermediateCatchEvent id="en_catch_req" name="Receive request from Commission or ECCG">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
         <incoming>en_sf1</incoming>
         <outgoing>en_sf2</outgoing>
         <messageEventDefinition id="med_en_catch_req"/>
      </intermediateCatchEvent>
      <exclusiveGateway id="en_gw1" name="Refuse ECCG request?" gatewayDirection="Diverging" isMarkerVisible="true">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements>
         <incoming>en_sf2</incoming>
         <outgoing>en_sf3</outgoing>
         <outgoing>en_sf7</outgoing>
      </exclusiveGateway>
      <task id="en_t1" name="Assess whether it decides to refuse a request from the ECCG">
         <incoming>en_sf3</incoming>
         <outgoing>en_sf4</outgoing>
      </task>
      <task id="en_t2_mb" name="Take decision to refuse a request">
         <incoming>en_sf4</incoming>
         <outgoing>en_sf5</outgoing>
      </task>
      <task id="en_t3" name="Give reasons for refusal of preparing a candidate scheme">
         <incoming>en_sf5</incoming>
         <outgoing>en_sf6</outgoing>
      </task>
      <endEvent id="en_end_refuse" name="Refusal end event">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
         <incoming>en_sf6</incoming>
      </endEvent>
      <task id="en_t4" name="Prepare a candidate cybersecurity certification scheme">
         <incoming>en_sf7</incoming>
         <outgoing>en_sf8</outgoing>
      </task>
      <parallelGateway id="en_gw_par1" name="Split" gatewayDirection="Diverging">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements>
         <incoming>en_sf8</incoming>
         <outgoing>en_sf9</outgoing>
         <outgoing>en_sf10</outgoing>
         <outgoing>en_sf11</outgoing>
      </parallelGateway>
      <task id="en_pt1" name="Consult all relevant stakeholders">
         <incoming>en_sf9</incoming>
         <outgoing>en_sf12</outgoing>
      </task>
      <task id="en_pt2" name="Establish an ad hoc working group">
         <incoming>en_sf10</incoming>
         <outgoing>en_sf13</outgoing>
      </task>
      <task id="en_pt3" name="Cooperate with the ECCG">
         <incoming>en_sf11</incoming>
         <outgoing>en_sf14</outgoing>
      </task>
      <parallelGateway id="en_gw_par2" name="Merge" gatewayDirection="Converging">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements>
         <incoming>en_sf12</incoming>
         <incoming>en_sf13</incoming>
         <incoming>en_sf14</incoming>
         <outgoing>en_sf_par_out</outgoing>
      </parallelGateway>

      <exclusiveGateway id="en_gw2" name="Opinion absent?" gatewayDirection="Diverging" isMarkerVisible="true">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements>
         <incoming>en_sf_par_out</incoming>
         <outgoing>en_sf15</outgoing>
         <outgoing>en_sf_except</outgoing>
      </exclusiveGateway>

      <intermediateCatchEvent id="en_catch_op" name="Receive opinion from ECCG">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/></extensionElements>
         <incoming>en_sf15</incoming>
         <outgoing>en_sf16</outgoing>
         <messageEventDefinition id="med_en_catch_op"/>
      </intermediateCatchEvent>
      <task id="en_t5" name="Take utmost account of the ECCG opinion">
         <incoming>en_sf16</incoming>
         <outgoing>en_sf_to_merge_op</outgoing>
      </task>

      <exclusiveGateway id="en_gw_merge_op" name="Merge" gatewayDirection="Converging" isMarkerVisible="true">
         <extensionElements><signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="20.0" y="-8.0"/></extensionElements>
         <incoming>en_sf_to_merge_op</incoming>
         <incoming>en_sf_except</incoming>
         <outgoing>en_sf17</outgoing>
      </exclusiveGateway>

      <task id="en_t6" name="Transmit the candidate scheme to the Commission">
         <incoming>en_sf17</incoming>
         <outgoing>en_sf18</outgoing>
      </task>
