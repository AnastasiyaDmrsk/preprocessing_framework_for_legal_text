   <collaboration id="collab_1">
      <participant id="participant_C" name="Commission" processRef="process_C">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffff"/>
         </extensionElements>
      </participant>
      <participant id="participant_E" name="ECCG" processRef="process_E">
