<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" 
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" 
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" 
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" 
             xmlns:signavio="http://www.signavio.com" 
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
             exporter="Signavio Process Editor, http://www.signavio.com" 
             exporterVersion="19.2.2" 
             expressionLanguage="http://www.w3.org/TR/XPath" 
             id="sid-process-def" 
             targetNamespace="http://www.signavio.com" 
             typeLanguage="http://www.w3.org/2001/XMLSchema" 
             xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd">
   <collaboration id="sid-collaboration-main">
      <participant id="Participant_Processor" name="Processor" processRef="Process_Processor"/>
      <participant id="Participant_Controller" name="Controller" processRef="Process_Controller"/>
      <participant id="Participant_SA" name="Supervisory Authority" processRef="Process_SA"/>
      <messageFlow id="Msg_P_to_C" sourceRef="Task_Notify_Cont" targetRef="Start_Cont"/>
      <messageFlow id="Msg_C_to_SA" sourceRef="Task_Doc" targetRef="Start_SA"/>
   </collaboration>
   
   <process id="Process_Processor" isClosed="false" isExecutable="false" name="Processor">
      <startEvent id="Start_Proc" name="Personal data breach">
         <outgoing>Flow_P1</outgoing>
      </startEvent>
      <task id="Task_Notify_Cont" name="Notify the controller of a personal data breach">
         <incoming>Flow_P1</incoming>
         <outgoing>Flow_P2</outgoing>
      </task>
      <endEvent id="End_Proc" name="End">
         <incoming>Flow_P2</incoming>
      </endEvent>
      <sequenceFlow id="Flow_P1" sourceRef="Start_Proc" targetRef="Task_Notify_Cont"/>
      <sequenceFlow id="Flow_P2" sourceRef="Task_Notify_Cont" targetRef="End_Proc"/>
   </process>
   
   <process id="Process_Controller" isClosed="false" isExecutable="false" name="Controller">
      <startEvent id="Start_Cont" name="Receive notification">
         <outgoing>Flow_C1</outgoing>
         <messageEventDefinition id="MsgDef_C1"/>
      </startEvent>
      <exclusiveGateway id="GW_Risk" name="Unlikely to result in risk?">
         <incoming>Flow_C1</incoming>
         <outgoing>Flow_C_Risk_False</outgoing>
         <outgoing>Flow_C_Risk_True</outgoing>
      </exclusiveGateway>
      <task id="Task_Notify_SA" name="Notify personal data breach to SA">
         <incoming>Flow_C_Risk_False</incoming>
         <outgoing>Flow_C2</outgoing>
      </task>
      <exclusiveGateway id="GW_72h" name="Not made within 72 hours?">
         <incoming>Flow_C2</incoming>
         <incoming>Flow_C_Risk_True</incoming>
         <outgoing>Flow_C_72h_True</outgoing>
         <outgoing>Flow_C_72h_False</outgoing>
      </exclusiveGateway>
      <task id="Task_Delay" name="Accompany notification with reasons for delay">
         <incoming>Flow_C_72h_True</incoming>
         <outgoing>Flow_C3</outgoing>
      </task>
      <exclusiveGateway id="GW_Info" name="Not possible to provide info at same time?">
         <incoming>Flow_C3</incoming>
         <incoming>Flow_C_72h_False</incoming>
         <outgoing>Flow_C_Info_True</outgoing>
         <outgoing>Flow_C_Info_False</outgoing>
      </exclusiveGateway>
      <task id="Task_Provide" name="Provide the information">
         <incoming>Flow_C_Info_True</incoming>
         <outgoing>Flow_C4</outgoing>
      </task>
      <task id="Task_Doc" name="Document any personal data breaches">
         <incoming>Flow_C4</incoming>
         <incoming>Flow_C_Info_False</incoming>
         <outgoing>Flow_C5</outgoing>
      </task>
      <exclusiveGateway id="GW_High_Risk" name="Likely high risk to rights/freedoms?">
         <incoming>Flow_C5</incoming>
         <outgoing>Flow_C_HR_True</outgoing>
         <outgoing>Flow_C_HR_False</outgoing>
      </exclusiveGateway>
      <task id="Task_Comm_DS" name="Communicate data breach to data subject">
         <incoming>Flow_C_HR_True</incoming>
         <outgoing>Flow_C6</outgoing>
      </task>
      <exclusiveGateway id="GW_Disprop" name="Disproportionate effort?">
         <incoming>Flow_C6</incoming>
         <outgoing>Flow_C_Disp_True</outgoing>
         <outgoing>Flow_C_Disp_False</outgoing>
      </exclusiveGateway>
      <task id="Task_Pub_Comm" name="Carry out a public communication">
         <incoming>Flow_C_Disp_True</incoming>
         <outgoing>Flow_C7</outgoing>
      </task>
      <endEvent id="End_Cont_1" name="End (No high risk)">
         <incoming>Flow_C_HR_False</incoming>
      </endEvent>
      <endEvent id="End_Cont_2" name="End (No disprop effort)">
         <incoming>Flow_C_Disp_False</incoming>
      </endEvent>
      <endEvent id="End_Cont_Main" name="End">
         <incoming>Flow_C7</incoming>
      </endEvent>
      
      <sequenceFlow id="Flow_C1" sourceRef="Start_Cont" targetRef="GW_Risk"/>
      <sequenceFlow id="Flow_C_Risk_False" sourceRef="GW_Risk" targetRef="Task_Notify_SA"/>
      <sequenceFlow id="Flow_C_Risk_True" sourceRef="GW_Risk" targetRef="GW_72h"/>
      <sequenceFlow id="Flow_C2" sourceRef="Task_Notify_SA" targetRef="GW_72h"/>
      <sequenceFlow id="Flow_C_72h_True" sourceRef="GW_72h" targetRef="Task_Delay"/>
      <sequenceFlow id="Flow_C_72h_False" sourceRef="GW_72h" targetRef="GW_Info"/>
      <sequenceFlow id="Flow_C3" sourceRef="Task_Delay" targetRef="GW_Info"/>
      <sequenceFlow id="Flow_C_Info_True" sourceRef="GW_Info" targetRef="Task_Provide"/>
      <sequenceFlow id="Flow_C_Info_False" sourceRef="GW_Info" targetRef="Task_Doc"/>
      <sequenceFlow id="Flow_C4" sourceRef="Task_Provide" targetRef="Task_Doc"/>
      <sequenceFlow id="Flow_C5" sourceRef="Task_Doc" targetRef="GW_High_Risk"/>
      <sequenceFlow id="Flow_C_HR_True" sourceRef="GW_High_Risk" targetRef="Task_Comm_DS"/>
      <sequenceFlow id="Flow_C_HR_False" sourceRef="GW_High_Risk" targetRef="End_Cont_1"/>
      <sequenceFlow id="Flow_C6" sourceRef="Task_Comm_DS" targetRef="GW_Disprop"/>
      <sequenceFlow id="Flow_C_Disp_True" sourceRef="GW_Disprop" targetRef="Task_Pub_Comm"/>
      <sequenceFlow id="Flow_C_Disp_False" sourceRef="GW_Disprop" targetRef="End_Cont_2"/>
      <sequenceFlow id="Flow_C7" sourceRef="Task_Pub_Comm" targetRef="End_Cont_Main"/>
   </process>
   
   <process id="Process_SA" isClosed="false" isExecutable="false" name="Supervisory Authority">
      <startEvent id="Start_SA" name="Receive notification and doc">
         <outgoing>Flow_S1</outgoing>
         <messageEventDefinition id="MsgDef_S1"/>
      </startEvent>
      <task id="Task_Verify" name="Verify compliance">
         <incoming>Flow_S1</incoming>
         <outgoing>Flow_S2</outgoing>
      </task>
      <task id="Task_Consider" name="Consider likelihood of high risk">
         <incoming>Flow_S2</incoming>
         <outgoing>Flow_S3</outgoing>
      </task>
      <exclusiveGateway id="GW_SA_Assess" name="Assess conditions">
         <incoming>Flow_S3</incoming>
         <outgoing>Flow_S_Req</outgoing>
         <outgoing>Flow_S_Dec</outgoing>
         <outgoing>Flow_S_Skip</outgoing>
      </exclusiveGateway>
      <task id="Task_SA_Req" name="Require controller to communicate data breach">
         <incoming>Flow_S_Req</incoming>
         <outgoing>Flow_S4</outgoing>
      </task>
      <task id="Task_SA_Dec" name="Decide any conditions are met">
         <incoming>Flow_S_Dec</incoming>
         <outgoing>Flow_S5</outgoing>
      </task>
      <endEvent id="End_SA_1" name="End">
         <incoming>Flow_S4</incoming>
      </endEvent>
      <endEvent id="End_SA_2" name="End">
         <incoming>Flow_S5</incoming>
      </endEvent>
      <endEvent id="End_SA_3" name="End (No action)">
         <incoming>Flow_S_Skip</incoming>
      </endEvent>
      
      <sequenceFlow id="Flow_S1" sourceRef="Start_SA" targetRef="Task_Verify"/>
      <sequenceFlow id="Flow_S2" sourceRef="Task_Verify" targetRef="Task_Consider"/>
      <sequenceFlow id="Flow_S3" sourceRef="Task_Consider" targetRef="GW_SA_Assess"/>
      <sequenceFlow id="Flow_S_Req" sourceRef="GW_SA_Assess" targetRef="Task_SA_Req"/>
      <sequenceFlow id="Flow_S_Dec" sourceRef="GW_SA_Assess" targetRef="Task_SA_Dec"/>
      <sequenceFlow id="Flow_S_Skip" sourceRef="GW_SA_Assess" targetRef="End_SA_3"/>
      <sequenceFlow id="Flow_S4" sourceRef="Task_SA_Req" targetRef="End_SA_1"/>
      <sequenceFlow id="Flow_S5" sourceRef="Task_SA_Dec" targetRef="End_SA_2"/>
   </process>

   <bpmndi:BPMNDiagram id="BPMNDiagram_main">
      <bpmndi:BPMNPlane bpmnElement="sid-collaboration-main" id="BPMNPlane_main">
         <bpmndi:BPMNShape bpmnElement="Participant_Processor" id="Shape_Participant_Processor" isHorizontal="true">
            <omgdc:Bounds height="150.0" width="1800.0" x="50.0" y="50.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="Participant_Controller" id="Shape_Participant_Controller" isHorizontal="true">
            <omgdc:Bounds height="300.0" width="1800.0" x="50.0" y="250.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="Participant_SA" id="Shape_Participant_SA" isHorizontal="true">
            <omgdc:Bounds height="250.0" width="1800.0" x="50.0" y="600.0"/>
         </bpmndi:BPMNShape>

         <bpmndi:BPMNShape bpmnElement="Start_Proc" id="Shape_Start_Proc">
            <omgdc:Bounds height="30.0" width="30.0" x="100.0" y="100.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="Task_Notify_Cont" id="Shape_Task_Notify_Cont">
            <omgdc:Bounds height="80.0" width="100.0" x="200.0" y="75.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="End_Proc" id="Shape_End_Proc">
            <omgdc:Bounds height="30.0" width="30.0" x="350.0" y="100.0"/>
         </bpmndi:BPMNShape>

         <bpmndi:BPMNShape bpmnElement="Start_Cont" id="Shape_Start_Cont">
            <omgdc:Bounds height="30.0" width="30.0" x="200.0" y="300.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="GW_Risk" id="Shape_GW_Risk">
            <omgdc:Bounds height="40.0" width="40.0" x="300.0" y="295.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="Task_Notify_SA" id="Shape_Task_Notify_SA">
            <omgdc:Bounds height="80.0" width="100.0" x="400.0" y="275.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="GW_72h" id="Shape_GW_72h">
            <omgdc:Bounds height="40.0" width="40.0" x="550.0" y="295.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="Task_Delay" id="Shape_Task_Delay">
            <omgdc:Bounds height="80.0" width="100.0" x="650.0" y="275.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="GW_Info" id="Shape_GW_Info">
            <omgdc:Bounds height="40.0" width="40.0" x="800.0" y="295.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="Task_Provide" id="Shape_Task_Provide">
            <omgdc:Bounds height="80.0" width="100.0" x="900.0" y="275.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="Task_Doc" id="Shape_Task_Doc">
            <omgdc:Bounds height="80.0" width="100.0" x="1050.0" y="275.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="GW_High_Risk" id="Shape_GW_High_Risk">
            <omgdc:Bounds height="40.0" width="40.0" x="1200.0" y="295.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="Task_Comm_DS" id="Shape_Task_Comm_DS">
            <omgdc:Bounds height="80.0" width="100.0" x="1300.0" y="275.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="GW_Disprop" id="Shape_GW_Disprop">
            <omgdc:Bounds height="40.0" width="40.0" x="1450.0" y="295.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="Task_Pub_Comm" id="Shape_Task_Pub_Comm">
            <omgdc:Bounds height="80.0" width="100.0" x="1550.0" y="275.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="End_Cont_1" id="Shape_End_Cont_1">
            <omgdc:Bounds height="30.0" width="30.0" x="1300.0" y="400.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="End_Cont_2" id="Shape_End_Cont_2">
            <omgdc:Bounds height="30.0" width="30.0" x="1550.0" y="400.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="End_Cont_Main" id="Shape_End_Cont_Main">
            <omgdc:Bounds height="30.0" width="30.0" x="1700.0" y="300.0"/>
         </bpmndi:BPMNShape>

         <bpmndi:BPMNShape bpmnElement="Start_SA" id="Shape_Start_SA">
            <omgdc:Bounds height="30.0" width="30.0" x="1050.0" y="650.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="Task_Verify" id="Shape_Task_Verify">
            <omgdc:Bounds height="80.0" width="100.0" x="1150.0" y="625.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="Task_Consider" id="Shape_Task_Consider">
            <omgdc:Bounds height="80.0" width="100.0" x="1300.0" y="625.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="GW_SA_Assess" id="Shape_GW_SA_Assess">
            <omgdc:Bounds height="40.0" width="40.0" x="1450.0" y="645.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="Task_SA_Req" id="Shape_Task_SA_Req">
            <omgdc:Bounds height="80.0" width="100.0" x="1550.0" y="565.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="Task_SA_Dec" id="Shape_Task_SA_Dec">
            <omgdc:Bounds height="80.0" width="100.0" x="1550.0" y="685.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="End_SA_1" id="Shape_End_SA_1">
            <omgdc:Bounds height="30.0" width="30.0" x="1700.0" y="590.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="End_SA_2" id="Shape_End_SA_2">
            <omgdc:Bounds height="30.0" width="30.0" x="1700.0" y="710.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="End_SA_3" id="Shape_End_SA_3">
            <omgdc:Bounds height="30.0" width="30.0" x="1450.0" y="780.0"/>
         </bpmndi:BPMNShape>

         <bpmndi:BPMNEdge bpmnElement="Flow_P1" id="Edge_Flow_P1">
            <omgdi:waypoint x="130.0" y="115.0"/>
            <omgdi:waypoint x="200.0" y="115.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="Flow_P2" id="Edge_Flow_P2">
            <omgdi:waypoint x="300.0" y="115.0"/>
            <omgdi:waypoint x="350.0" y="115.0"/>
         </bpmndi:BPMNEdge>
         
         <bpmndi:BPMNEdge bpmnElement="Flow_C1" id="Edge_Flow_C1">
            <omgdi:waypoint x="230.0" y="315.0"/>
            <omgdi:waypoint x="300.0" y="315.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="Flow_C_Risk_False" id="Edge_Flow_C_Risk_False">
            <omgdi:waypoint x="340.0" y="315.0"/>
            <omgdi:waypoint x="400.0" y="315.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="Flow_C_Risk_True" id="Edge_Flow_C_Risk_True">
            <omgdi:waypoint x="320.0" y="335.0"/>
            <omgdi:waypoint x="320.0" y="380.0"/>
            <omgdi:waypoint x="570.0" y="380.0"/>
            <omgdi:waypoint x="570.0" y="335.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="Flow_C2" id="Edge_Flow_C2">
            <omgdi:waypoint x="500.0" y="315.0"/>
            <omgdi:waypoint x="550.0" y="315.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="Flow_C_72h_True" id="Edge_Flow_C_72h_True">
            <omgdi:waypoint x="590.0" y="315.0"/>
            <omgdi:waypoint x="650.0" y="315.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="Flow_C_72h_False" id="Edge_Flow_C_72h_False">
            <omgdi:waypoint x="570.0" y="335.0"/>
            <omgdi:waypoint x="570.0" y="380.0"/>
            <omgdi:waypoint x="820.0" y="380.0"/>
            <omgdi:waypoint x="820.0" y="335.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="Flow_C3" id="Edge_Flow_C3">
            <omgdi:waypoint x="750.0" y="315.0"/>
            <omgdi:waypoint x="800.0" y="315.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="Flow_C_Info_True" id="Edge_Flow_C_Info_True">
            <omgdi:waypoint x="840.0" y="315.0"/>
            <omgdi:waypoint x="900.0" y="315.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="Flow_C_Info_False" id="Edge_Flow_C_Info_False">
            <omgdi:waypoint x="820.0" y="335.0"/>
            <omgdi:waypoint x="820.0" y="380.0"/>
            <omgdi:waypoint x="1070.0" y="380.0"/>
            <omgdi:waypoint x="1070.0" y="355.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="Flow_C4" id="Edge_Flow_C4">
            <omgdi:waypoint x="1000.0" y="315.0"/>
            <omgdi:waypoint x="1050.0" y="315.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="Flow_C5" id="Edge_Flow_C5">
            <omgdi:waypoint x="1150.0" y="315.0"/>
            <omgdi:waypoint x="1200.0" y="315.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="Flow_C_HR_True" id="Edge_Flow_C_HR_True">
            <omgdi:waypoint x="1240.0" y="315.0"/>
            <omgdi:waypoint x="1300.0" y="315.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="Flow_C_HR_False" id="Edge_Flow_C_HR_False">
            <omgdi:waypoint x="1220.0" y="335.0"/>
            <omgdi:waypoint x="1220.0" y="415.0"/>
            <omgdi:waypoint x="1300.0" y="415.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="Flow_C6" id="Edge_Flow_C6">
            <omgdi:waypoint x="1400.0" y="315.0"/>
            <omgdi:waypoint x="1450.0" y="315.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="Flow_C_Disp_True" id="Edge_Flow_C_Disp_True">
            <omgdi:waypoint x="1490.0" y="315.0"/>
            <omgdi:waypoint x="1550.0" y="315.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="Flow_C_Disp_False" id="Edge_Flow_C_Disp_False">
            <omgdi:waypoint x="1470.0" y="335.0"/>
            <omgdi:waypoint x="1470.0" y="415.0"/>
            <omgdi:waypoint x="1550.0" y="415.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="Flow_C7" id="Edge_Flow_C7">
            <omgdi:waypoint x="1650.0" y="315.0"/>
            <omgdi:waypoint x="1700.0" y="315.0"/>
         </bpmndi:BPMNEdge>

         <bpmndi:BPMNEdge bpmnElement="Flow_S1" id="Edge_Flow_S1">
            <omgdi:waypoint x="1080.0" y="665.0"/>
            <omgdi:waypoint x="1150.0" y="665.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="Flow_S2" id="Edge_Flow_S2">
            <omgdi:waypoint x="1250.0" y="665.0"/>
            <omgdi:waypoint x="1300.0" y="665.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="Flow_S3" id="Edge_Flow_S3">
            <omgdi:waypoint x="1400.0" y="665.0"/>
            <omgdi:waypoint x="1450.0" y="665.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="Flow_S_Req" id="Edge_Flow_S_Req">
            <omgdi:waypoint x="1470.0" y="645.0"/>
            <omgdi:waypoint x="1470.0" y="605.0"/>
            <omgdi:waypoint x="1550.0" y="605.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="Flow_S_Dec" id="Edge_Flow_S_Dec">
            <omgdi:waypoint x="1470.0" y="685.0"/>
            <omgdi:waypoint x="1470.0" y="725.0"/>
            <omgdi:waypoint x="1550.0" y="725.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="Flow_S_Skip" id="Edge_Flow_S_Skip">
            <omgdi:waypoint x="1470.0" y="685.0"/>
            <omgdi:waypoint x="1470.0" y="795.0"/>
            <omgdi:waypoint x="1480.0" y="795.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="Flow_S4" id="Edge_Flow_S4">
            <omgdi:waypoint x="1650.0" y="605.0"/>
