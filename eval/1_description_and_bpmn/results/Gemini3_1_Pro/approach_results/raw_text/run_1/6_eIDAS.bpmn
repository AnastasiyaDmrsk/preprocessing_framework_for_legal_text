  <!-- PROCESS 4: Conformity Assessment Body -->
  <process id="proc_cab" isExecutable="false">
    <startEvent id="cab_start" name="Start">
      <extensionElements><signavio:signavioLabel align="center" ref="text_name" valign="middle" x="15.0" y="35.0"/></extensionElements>
      <outgoing>cab_f1</outgoing>
    </startEvent>
    <intermediateCatchEvent id="cab_catch_req" name="receiving a request">
      <extensionElements><signavio:signavioLabel align="center" ref="text_name" valign="middle" x="15.0" y="35.0"/></extensionElements>
      <incoming>cab_f1</incoming>
      <outgoing>cab_f2</outgoing>
      <messageEventDefinition id="med_cab_1" />
    </intermediateCatchEvent>
    <task id="cab_t1" name="perform a conformity assessment">
      <incoming>cab_f2</incoming>
      <outgoing>cab_f3</outgoing>
    </task>
    <endEvent id="cab_end" name="assessment performed">
      <extensionElements><signavio:signavioLabel align="center" ref="text_name" valign="middle" x="15.0" y="35.0"/></extensionElements>
      <incoming>cab_f3</incoming>
    </endEvent>
    
    <sequenceFlow id="cab_f1" sourceRef="cab_start" targetRef="cab_catch_req" isImmediate="true" />
    <sequenceFlow id="cab_f2" sourceRef="cab_catch_req" targetRef="cab_t1" isImmediate="true" />
    <sequenceFlow id="cab_f3" sourceRef="cab_t1" targetRef="cab_end" isImmediate="true" />
  </process>

  <!-- PROCESS 5: Another Supervisory Body -->
  <process id="proc_asb" isExecutable="false">
    <startEvent id="asb_start" name="Start">
      <extensionElements><signavio:signavioLabel align="center" ref="text_name" valign="middle" x="15.0" y="35.0"/></extensionElements>
      <outgoing>asb_f1</outgoing>
    </startEvent>
    <task id="asb_t1" name="request assistance">
      <incoming>asb_f1</incoming>
      <outgoing>asb_f2</outgoing>
    </task>
    <endEvent id="asb_end" name="assistance requested">
      <extensionElements><signavio:signavioLabel align="center" ref="text_name" valign="middle" x="15.0" y="35.0"/></extensionElements>
      <incoming>asb_f2</incoming>
    </endEvent>

    <sequenceFlow id="asb_f1" sourceRef="asb_start" targetRef="asb_t1" isImmediate="true" />
    <sequenceFlow id="asb_f2" sourceRef="asb_t1" targetRef="asb_end" isImmediate="true" />
  </process>

  <!-- PROCESS 6: Qualified Trust Service Provider or Non-qualified Trust Service Provider -->
  <process id="proc_tsp" isExecutable="false">
    <startEvent id="tsp_start" name="Start">
      <extensionElements><signavio:signavioLabel align="center" ref="text_name" valign="middle" x="15.0" y="35.0"/></extensionElements>
      <outgoing>tsp_f1</outgoing>
    </startEvent>
    <exclusiveGateway id="tsp_gw1_s" gatewayDirection="Diverging" name="required by supervisory body?" isMarkerVisible="true">
      <extensionElements><signavio:signavioLabel align="center" ref="text_name" valign="middle" x="20.0" y="45.0"/></extensionElements>
      <incoming>tsp_f1</incoming>
      <outgoing>tsp_gw1_y</outgoing>
      <outgoing>tsp_gw1_n</outgoing>
    </exclusiveGateway>
    <task id="tsp_t1" name="remedy failures to fulfil requirements">
      <incoming>tsp_gw1_y</incoming>
      <outgoing>tsp_f2</outgoing>
    </task>
    <exclusiveGateway id="tsp_gw1_j" gatewayDirection="Converging" isMarkerVisible="true">
      <incoming>tsp_f2</incoming>
      <incoming>tsp_gw1_n</incoming>
      <outgoing>tsp_f3</outgoing>
    </exclusiveGateway>
    <task id="tsp_t2" name="take appropriate technical and organisational measures">
      <incoming>tsp_f3</incoming>
      <outgoing>tsp_f4</outgoing>
    </task>
    <task id="tsp_t3" name="take measures to prevent and minimise the impact">
      <incoming>tsp_f4</incoming>
      <outgoing>tsp_f5</outgoing>
    </task>
    <task id="tsp_t4" name="inform stakeholders of the adverse effects">
      <incoming>tsp_f5</incoming>
      <outgoing>tsp_f6</outgoing>
    </task>
    <exclusiveGateway id="tsp_gw2_s" gatewayDirection="Diverging" name="significant impact?" isMarkerVisible="true">
      <extensionElements><signavio:signavioLabel align="center" ref="text_name" valign="middle" x="20.0" y="45.0"/></extensionElements>
      <incoming>tsp_f6</incoming>
      <outgoing>tsp_gw2_y</outgoing>
      <outgoing>tsp_gw2_n</outgoing>
    </exclusiveGateway>
    <parallelGateway id="tsp_gw3_s" gatewayDirection="Diverging">
      <incoming>tsp_gw2_y</incoming>
      <outgoing>tsp_p_f1</outgoing>
      <outgoing>tsp_p_f2</outgoing>
    </parallelGateway>
    <task id="tsp_p1" name="notify the supervisory body and other relevant bodies">
      <incoming>tsp_p_f1</incoming>
      <outgoing>tsp_p_o1</outgoing>
    </task>
    <task id="tsp_p2" name="notify the natural or legal person">
      <incoming>tsp_p_f2</incoming>
      <outgoing>tsp_p_o2</outgoing>
    </task>
    <parallelGateway id="tsp_gw3_j" gatewayDirection="Converging">
      <incoming>tsp_p_o1</incoming>
      <incoming>tsp_p_o2</incoming>
      <outgoing>tsp_f7</outgoing>
    </parallelGateway>
    <exclusiveGateway id="tsp_gw2_j" gatewayDirection="Converging" isMarkerVisible="true">
      <incoming>tsp_f7</incoming>
      <incoming>tsp_gw2_n</incoming>
      <outgoing>tsp_f8</outgoing>
    </exclusiveGateway>
    <endEvent id="tsp_end" name="requirements fulfilled">
      <extensionElements><signavio:signavioLabel align="center" ref="text_name" valign="middle" x="15.0" y="35.0"/></extensionElements>
      <incoming>tsp_f8</incoming>
    </endEvent>

    <sequenceFlow id="tsp_f1" sourceRef="tsp_start" targetRef="tsp_gw1_s" isImmediate="true" />
    <sequenceFlow id="tsp_gw1_y" name="yes" sourceRef="tsp_gw1_s" targetRef="tsp_t1" isImmediate="true" />
    <sequenceFlow id="tsp_gw1_n" name="no" sourceRef="tsp_gw1_s" targetRef="tsp_gw1_j" isImmediate="true" />
    <sequenceFlow id="tsp_f2" sourceRef="tsp_t1" targetRef="tsp_gw1_j" isImmediate="true" />
    <sequenceFlow id="tsp_f3" sourceRef="tsp_gw1_j" targetRef="tsp_t2" isImmediate="true" />
    <sequenceFlow id="tsp_f4" sourceRef="tsp_t2" targetRef="tsp_t3" isImmediate="true" />
    <sequenceFlow id="tsp_f5" sourceRef="tsp_t3" targetRef="tsp_t4" isImmediate="true" />
    <sequenceFlow id="tsp_f6" sourceRef="tsp_t4" targetRef="tsp_gw2_s" isImmediate="true" />
    <sequenceFlow id="tsp_gw2_y" name="yes" sourceRef="tsp_gw2_s" targetRef="tsp_gw3_s" isImmediate="true" />
    <sequenceFlow id="tsp_gw2_n" name="no" sourceRef="tsp_gw2_s" targetRef="tsp_gw2_j" isImmediate="true" />
    <sequenceFlow id="tsp_p_f1" sourceRef="tsp_gw3_s" targetRef="tsp_p1" isImmediate="true" />
    <sequenceFlow id="tsp_p_f2" sourceRef="tsp_gw3_s" targetRef="tsp_p2" isImmediate="true" />
    <sequenceFlow id="tsp_p_o1" sourceRef="tsp_p1" targetRef="tsp_gw3_j" isImmediate="true" />
    <sequenceFlow id="tsp_p_o2" sourceRef="tsp_p2" targetRef="tsp_gw3_j" isImmediate="true" />
    <sequenceFlow id="tsp_f7" sourceRef="tsp_gw3_j" targetRef="tsp_gw2_j" isImmediate="true" />
    <sequenceFlow id="tsp_f8" sourceRef="tsp_gw2_j" targetRef="tsp_end" isImmediate="true" />
  </process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="collab_1">
