<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" 
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" 
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" 
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" 
             xmlns:signavio="http://www.signavio.com" 
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
             exporter="Signavio Process Editor" exporterVersion="19.2.2" 
             id="sid-process-model" targetNamespace="http://www.signavio.com">
  <collaboration id="collab_1">
    <participant id="pool_ms" name="Member State" processRef="proc_ms" />
    <participant id="pool_com" name="Commission" processRef="proc_com" />
    <participant id="pool_sb" name="Supervisory Body" processRef="proc_sb" />
    <participant id="pool_cab" name="Conformity Assessment Body" processRef="proc_cab" />
    <participant id="pool_asb" name="Another Supervisory Body" processRef="proc_asb" />
    <participant id="pool_tsp" name="Qualified Trust Service Provider or Non-qualified Trust Service Provider" processRef="proc_tsp" />
    
    <messageFlow id="msg_1" sourceRef="ms_t3" targetRef="pool_com" />
    <messageFlow id="msg_2" sourceRef="sb_t7" targetRef="com_catch_report" />
    <messageFlow id="msg_3" sourceRef="sb_p6" targetRef="cab_catch_req" />
    <messageFlow id="msg_4" sourceRef="asb_t1" targetRef="sb_catch_req" />
    <messageFlow id="msg_5" sourceRef="tsp_p1" targetRef="sb_catch_breach" />
  </collaboration>

  <!-- PROCESS 1: Member State -->
  <process id="proc_ms" isExecutable="false">
    <startEvent id="ms_start" name="implementation of the trust services regulation">
      <extensionElements><signavio:signavioLabel align="center" ref="text_name" valign="middle" x="15.0" y="35.0"/></extensionElements>
      <outgoing>ms_f1</outgoing>
    </startEvent>
    <task id="ms_t1" name="designate a supervisory body">
      <incoming>ms_f1</incoming>
      <outgoing>ms_f2</outgoing>
    </task>
    <task id="ms_t2" name="give the necessary powers and adequate resources to a supervisory body">
      <incoming>ms_f2</incoming>
      <outgoing>ms_f3</outgoing>
    </task>
    <task id="ms_t3" name="notify to the Commission the names and the addresses of the supervisory bodies">
      <incoming>ms_f3</incoming>
      <outgoing>ms_f4</outgoing>
    </task>
    
    <exclusiveGateway id="ms_gw1_s" gatewayDirection="Diverging" name="trust infrastructure required?" isMarkerVisible="true">
      <extensionElements><signavio:signavioLabel align="center" ref="text_name" valign="middle" x="20.0" y="45.0"/></extensionElements>
      <incoming>ms_f4</incoming>
      <outgoing>ms_gw1_y</outgoing>
      <outgoing>ms_gw1_n</outgoing>
    </exclusiveGateway>
    <task id="ms_t4" name="require the supervisory body to establish, maintain and update a trust infrastructure">
      <incoming>ms_gw1_y</incoming>
      <outgoing>ms_f5</outgoing>
    </task>
    <exclusiveGateway id="ms_gw1_j" gatewayDirection="Converging" isMarkerVisible="true">
      <incoming>ms_f5</incoming>
      <incoming>ms_gw1_n</incoming>
      <outgoing>ms_f6</outgoing>
    </exclusiveGateway>

    <exclusiveGateway id="ms_gw2_s" gatewayDirection="Diverging" name="authorise joint investigations if needed?" isMarkerVisible="true">
      <extensionElements><signavio:signavioLabel align="center" ref="text_name" valign="middle" x="20.0" y="45.0"/></extensionElements>
      <incoming>ms_f6</incoming>
      <outgoing>ms_gw2_y</outgoing>
      <outgoing>ms_gw2_n</outgoing>
    </exclusiveGateway>
    <task id="ms_t5" name="authorise their supervisory bodies to carry out joint investigations">
      <incoming>ms_gw2_y</incoming>
      <outgoing>ms_f7</outgoing>
    </task>
    <exclusiveGateway id="ms_gw2_j" gatewayDirection="Converging" isMarkerVisible="true">
      <incoming>ms_f7</incoming>
      <incoming>ms_gw2_n</incoming>
      <outgoing>ms_f8</outgoing>
    </exclusiveGateway>

    <exclusiveGateway id="ms_gw3_s" gatewayDirection="Diverging" name="Member States authorise joint investigations?" isMarkerVisible="true">
      <extensionElements><signavio:signavioLabel align="center" ref="text_name" valign="middle" x="20.0" y="45.0"/></extensionElements>
      <incoming>ms_f8</incoming>
      <outgoing>ms_gw3_y</outgoing>
      <outgoing>ms_gw3_n</outgoing>
    </exclusiveGateway>
    <parallelGateway id="ms_gw4_s" gatewayDirection="Diverging">
      <incoming>ms_gw3_y</incoming>
      <outgoing>ms_p1_f</outgoing>
      <outgoing>ms_p2_f</outgoing>
    </parallelGateway>
    <task id="ms_p1" name="agree upon the arrangements and procedures for such joint actions">
      <incoming>ms_p1_f</incoming>
      <outgoing>ms_p1_o</outgoing>
    </task>
    <task id="ms_p2" name="establish the arrangements and procedures for such joint actions">
      <incoming>ms_p2_f</incoming>
      <outgoing>ms_p2_o</outgoing>
    </task>
    <parallelGateway id="ms_gw4_j" gatewayDirection="Converging">
      <incoming>ms_p1_o</incoming>
      <incoming>ms_p2_o</incoming>
      <outgoing>ms_f9</outgoing>
    </parallelGateway>
    <exclusiveGateway id="ms_gw3_j" gatewayDirection="Converging" isMarkerVisible="true">
      <incoming>ms_f9</incoming>
      <incoming>ms_gw3_n</incoming>
      <outgoing>ms_f10</outgoing>
    </exclusiveGateway>
    
    <endEvent id="ms_end" name="Member State supervision setup completed">
      <extensionElements><signavio:signavioLabel align="center" ref="text_name" valign="middle" x="15.0" y="35.0"/></extensionElements>
      <incoming>ms_f10</incoming>
    </endEvent>

    <sequenceFlow id="ms_f1" sourceRef="ms_start" targetRef="ms_t1" isImmediate="true" />
    <sequenceFlow id="ms_f2" sourceRef="ms_t1" targetRef="ms_t2" isImmediate="true" />
    <sequenceFlow id="ms_f3" sourceRef="ms_t2" targetRef="ms_t3" isImmediate="true" />
    <sequenceFlow id="ms_f4" sourceRef="ms_t3" targetRef="ms_gw1_s" isImmediate="true" />
    <sequenceFlow id="ms_gw1_y" name="yes" sourceRef="ms_gw1_s" targetRef="ms_t4" isImmediate="true" />
    <sequenceFlow id="ms_gw1_n" name="no" sourceRef="ms_gw1_s" targetRef="ms_gw1_j" isImmediate="true" />
    <sequenceFlow id="ms_f5" sourceRef="ms_t4" targetRef="ms_gw1_j" isImmediate="true" />
    <sequenceFlow id="ms_f6" sourceRef="ms_gw1_j" targetRef="ms_gw2_s" isImmediate="true" />
    <sequenceFlow id="ms_gw2_y" name="yes" sourceRef="ms_gw2_s" targetRef="ms_t5" isImmediate="true" />
    <sequenceFlow id="ms_gw2_n" name="no" sourceRef="ms_gw2_s" targetRef="ms_gw2_j" isImmediate="true" />
    <sequenceFlow id="ms_f7" sourceRef="ms_t5" targetRef="ms_gw2_j" isImmediate="true" />
    <sequenceFlow id="ms_f8" sourceRef="ms_gw2_j" targetRef="ms_gw3_s" isImmediate="true" />
    <sequenceFlow id="ms_gw3_y" name="yes" sourceRef="ms_gw3_s" targetRef="ms_gw4_s" isImmediate="true" />
    <sequenceFlow id="ms_gw3_n" name="no" sourceRef="ms_gw3_s" targetRef="ms_gw3_j" isImmediate="true" />
    <sequenceFlow id="ms_p1_f" sourceRef="ms_gw4_s" targetRef="ms_p1" isImmediate="true" />
    <sequenceFlow id="ms_p2_f" sourceRef="ms_gw4_s" targetRef="ms_p2" isImmediate="true" />
    <sequenceFlow id="ms_p1_o" sourceRef="ms_p1" targetRef="ms_gw4_j" isImmediate="true" />
    <sequenceFlow id="ms_p2_o" sourceRef="ms_p2" targetRef="ms_gw4_j" isImmediate="true" />
    <sequenceFlow id="ms_f9" sourceRef="ms_gw4_j" targetRef="ms_gw3_j" isImmediate="true" />
    <sequenceFlow id="ms_f10" sourceRef="ms_gw3_j" targetRef="ms_end" isImmediate="true" />
  </process>

  <!-- PROCESS 2: Commission -->
  <process id="proc_com" isExecutable="false">
    <startEvent id="com_start" name="Start">
      <extensionElements><signavio:signavioLabel align="center" ref="text_name" valign="middle" x="15.0" y="35.0"/></extensionElements>
      <outgoing>com_f1</outgoing>
    </startEvent>
    <intermediateCatchEvent id="com_catch_report" name="receiving a report">
      <extensionElements><signavio:signavioLabel align="center" ref="text_name" valign="middle" x="15.0" y="35.0"/></extensionElements>
      <incoming>com_f1</incoming>
      <outgoing>com_f2</outgoing>
      <messageEventDefinition id="med_com_1" />
    </intermediateCatchEvent>
    <task id="com_t1" name="make the annual report available to Member States">
      <incoming>com_f2</incoming>
      <outgoing>com_f3</outgoing>
    </task>
    <exclusiveGateway id="com_gw1_s" gatewayDirection="Diverging" name="adjustments needed?" isMarkerVisible="true">
      <extensionElements><signavio:signavioLabel align="center" ref="text_name" valign="middle" x="20.0" y="45.0"/></extensionElements>
      <incoming>com_f3</incoming>
      <outgoing>com_gw1_y</outgoing>
      <outgoing>com_gw1_n</outgoing>
    </exclusiveGateway>
    <task id="com_t2" name="define the formats and procedures for the report">
      <incoming>com_gw1_y</incoming>
      <outgoing>com_f4</outgoing>
    </task>
    <exclusiveGateway id="com_gw1_j" gatewayDirection="Converging" isMarkerVisible="true">
      <incoming>com_f4</incoming>
      <incoming>com_gw1_n</incoming>
      <outgoing>com_f5</outgoing>
    </exclusiveGateway>
    <task id="com_t3" name="adopt those implementing acts">
      <incoming>com_f5</incoming>
      <outgoing>com_f6</outgoing>
    </task>
    <exclusiveGateway id="com_gw2_s" gatewayDirection="Diverging" name="specification is required (measures)?" isMarkerVisible="true">
      <extensionElements><signavio:signavioLabel align="center" ref="text_name" valign="middle" x="20.0" y="45.0"/></extensionElements>
      <incoming>com_f6</incoming>
      <outgoing>com_gw2_y</outgoing>
      <outgoing>com_gw2_n</outgoing>
    </exclusiveGateway>
    <task id="com_t4" name="further specify the measures">
      <incoming>com_gw2_y</incoming>
      <outgoing>com_f7</outgoing>
    </task>
    <exclusiveGateway id="com_gw2_j" gatewayDirection="Converging" isMarkerVisible="true">
      <incoming>com_f7</incoming>
      <incoming>com_gw2_n</incoming>
      <outgoing>com_f8</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="com_gw3_s" gatewayDirection="Diverging" name="specification is required (formats)?" isMarkerVisible="true">
      <extensionElements><signavio:signavioLabel align="center" ref="text_name" valign="middle" x="20.0" y="45.0"/></extensionElements>
      <incoming>com_f8</incoming>
      <outgoing>com_gw3_y</outgoing>
      <outgoing>com_gw3_n</outgoing>
    </exclusiveGateway>
    <task id="com_t5" name="define the formats and procedures">
      <incoming>com_gw3_y</incoming>
      <outgoing>com_f9</outgoing>
    </task>
    <exclusiveGateway id="com_gw3_j" gatewayDirection="Converging" isMarkerVisible="true">
      <incoming>com_f9</incoming>
      <incoming>com_gw3_n</incoming>
      <outgoing>com_f10</outgoing>
    </exclusiveGateway>
    <endEvent id="com_end" name="reporting frameworks implemented">
      <extensionElements><signavio:signavioLabel align="center" ref="text_name" valign="middle" x="15.0" y="35.0"/></extensionElements>
      <incoming>com_f10</incoming>
    </endEvent>

    <sequenceFlow id="com_f1" sourceRef="com_start" targetRef="com_catch_report" isImmediate="true" />
    <sequenceFlow id="com_f2" sourceRef="com_catch_report" targetRef="com_t1" isImmediate="true" />
    <sequenceFlow id="com_f3" sourceRef="com_t1" targetRef="com_gw1_s" isImmediate="true" />
    <sequenceFlow id="com_gw1_y" name="yes" sourceRef="com_gw1_s" targetRef="com_t2" isImmediate="true" />
    <sequenceFlow id="com_gw1_n" name="no" sourceRef="com_gw1_s" targetRef="com_gw1_j" isImmediate="true" />
    <sequenceFlow id="com_f4" sourceRef="com_t2" targetRef="com_gw1_j" isImmediate="true" />
    <sequenceFlow id="com_f5" sourceRef="com_gw1_j" targetRef="com_t3" isImmediate="true" />
    <sequenceFlow id="com_f6" sourceRef="com_t3" targetRef="com_gw2_s" isImmediate="true" />
    <sequenceFlow id="com_gw2_y" name="yes" sourceRef="com_gw2_s" targetRef="com_t4" isImmediate="true" />
    <sequenceFlow id="com_gw2_n" name="no" sourceRef="com_gw2_s" targetRef="com_gw2_j" isImmediate="true" />
    <sequenceFlow id="com_f7" sourceRef="com_t4" targetRef="com_gw2_j" isImmediate="true" />
    <sequenceFlow id="com_f8" sourceRef="com_gw2_j" targetRef="com_gw3_s" isImmediate="true" />
    <sequenceFlow id="com_gw3_y" name="yes" sourceRef="com_gw3_s" targetRef="com_t5" isImmediate="true" />
    <sequenceFlow id="com_gw3_n" name="no" sourceRef="com_gw3_s" targetRef="com_gw3_j" isImmediate="true" />
    <sequenceFlow id="com_f9" sourceRef="com_t5" targetRef="com_gw3_j" isImmediate="true" />
    <sequenceFlow id="com_f10" sourceRef="com_gw3_j" targetRef="com_end" isImmediate="true" />
  </process>

  <!-- PROCESS 3: Supervisory Body -->
  <process id="proc_sb" isExecutable="false">
    <startEvent id="sb_start" name="Start">
      <extensionElements><signavio:signavioLabel align="center" ref="text_name" valign="middle" x="15.0" y="35.0"/></extensionElements>
      <outgoing>sb_f1</outgoing>
    </startEvent>
    <task id="sb_t1" name="supervise qualified trust service providers">
      <incoming>sb_f1</incoming>
      <outgoing>sb_f2</outgoing>
    </task>
    <exclusiveGateway id="sb_gw1_s" gatewayDirection="Diverging" name="NQTSP do not meet requirements?" isMarkerVisible="true">
      <extensionElements><signavio:signavioLabel align="center" ref="text_name" valign="middle" x="20.0" y="45.0"/></extensionElements>
      <incoming>sb_f2</incoming>
      <outgoing>sb_gw1_y</outgoing>
      <outgoing>sb_gw1_n</outgoing>
    </exclusiveGateway>
    <task id="sb_t2" name="take action in relation to non-qualified trust service providers">
      <incoming>sb_gw1_y</incoming>
      <outgoing>sb_f3</outgoing>
    </task>
    <exclusiveGateway id="sb_gw1_j" gatewayDirection="Converging" isMarkerVisible="true">
      <incoming>sb_f3</incoming>
      <incoming>sb_gw1_n</incoming>
      <outgoing>sb_f4</outgoing>
    </exclusiveGateway>

    <parallelGateway id="sb_gw2_s" gatewayDirection="Diverging">
      <incoming>sb_f4</incoming>
      <outgoing>sb_p_f1</outgoing>
      <outgoing>sb_p_f2</outgoing>
      <outgoing>sb_p_f3</outgoing>
      <outgoing>sb_p_f4</outgoing>
      <outgoing>sb_p_f5</outgoing>
      <outgoing>sb_p_f6</outgoing>
      <outgoing>sb_p_f7</outgoing>
      <outgoing>sb_p_f8</outgoing>
      <outgoing>sb_p_f9</outgoing>
      <outgoing>sb_p_f10</outgoing>
      <outgoing>sb_p_f11</outgoing>
      <outgoing>sb_p_f12</outgoing>
    </parallelGateway>

    <task id="sb_p1" name="cooperate with other supervisory bodies"><incoming>sb_p_f1</incoming><outgoing>sb_p_o1</outgoing></task>
    <task id="sb_p2" name="provide other supervisory bodies with assistance"><incoming>sb_p_f2</incoming><outgoing>sb_p_o2</outgoing></task>
    <task id="sb_p3" name="analyse the conformity assessment reports"><incoming>sb_p_f3</incoming><outgoing>sb_p_o3</outgoing></task>
    <task id="sb_p4" name="inform other supervisory bodies and the public about breaches"><incoming>sb_p_f4</incoming><outgoing>sb_p_o4</outgoing></task>
    <task id="sb_p5" name="carry out audits"><incoming>sb_p_f5</incoming><outgoing>sb_p_o5</outgoing></task>
    <task id="sb_p6" name="request a conformity assessment body to perform a conformity assessment"><incoming>sb_p_f6</incoming><outgoing>sb_p_o6</outgoing></task>
    <task id="sb_p7" name="cooperate with the data protection authorities"><incoming>sb_p_f7</incoming><outgoing>sb_p_o7</outgoing></task>
    <task id="sb_p8" name="grant qualified status to trust service providers"><incoming>sb_p_f8</incoming><outgoing>sb_p_o8</outgoing></task>
    <task id="sb_p9" name="withdraw qualified status from trust service providers"><incoming>sb_p_f9</incoming><outgoing>sb_p_o9</outgoing></task>
    
    <!-- P10 has an inner XOR -->
    <exclusiveGateway id="sb_gw_inner_s" gatewayDirection="Diverging" name="is body also the supervisory body?" isMarkerVisible="true">
      <extensionElements><signavio:signavioLabel align="center" ref="text_name" valign="middle" x="20.0" y="45.0"/></extensionElements>
      <incoming>sb_p_f10</incoming>
      <outgoing>sb_inner_y</outgoing>
      <outgoing>sb_inner_n</outgoing>
    </exclusiveGateway>
    <task id="sb_p10" name="inform the body responsible for national trusted list about status change">
      <incoming>sb_inner_n</incoming>
      <outgoing>sb_inner_f1</outgoing>
    </task>
    <exclusiveGateway id="sb_gw_inner_j" gatewayDirection="Converging" isMarkerVisible="true">
      <incoming>sb_inner_f1</incoming>
      <incoming>sb_inner_y</incoming>
      <outgoing>sb_p_o10</outgoing>
    </exclusiveGateway>

    <task id="sb_p11" name="verify existence and correct application of termination plans"><incoming>sb_p_f11</incoming><outgoing>sb_p_o11</outgoing></task>
    <task id="sb_p12" name="require that trust service providers remedy any failure"><incoming>sb_p_f12</incoming><outgoing>sb_p_o12</outgoing></task>

    <parallelGateway id="sb_gw2_j" gatewayDirection="Converging">
      <incoming>sb_p_o1</incoming>
      <incoming>sb_p_o2</incoming>
      <incoming>sb_p_o3</incoming>
      <incoming>sb_p_o4</incoming>
      <incoming>sb_p_o5</incoming>
      <incoming>sb_p_o6</incoming>
      <incoming>sb_p_o7</incoming>
      <incoming>sb_p_o8</incoming>
      <incoming>sb_p_o9</incoming>
      <incoming>sb_p_o10</incoming>
      <incoming>sb_p_o11</incoming>
      <incoming>sb_p_o12</incoming>
      <outgoing>sb_f5</outgoing>
    </parallelGateway>

    <exclusiveGateway id="sb_gw3_s" gatewayDirection="Diverging" name="personal data protection rules breached?" isMarkerVisible="true">
      <extensionElements><signavio:signavioLabel align="center" ref="text_name" valign="middle" x="20.0" y="45.0"/></extensionElements>
      <incoming>sb_f5</incoming>
      <outgoing>sb_gw3_y</outgoing>
      <outgoing>sb_gw3_n</outgoing>
    </exclusiveGateway>
    <task id="sb_t3" name="inform the data protection authorities about the results">
      <incoming>sb_gw3_y</incoming>
      <outgoing>sb_f6</outgoing>
    </task>
    <exclusiveGateway id="sb_gw3_j" gatewayDirection="Converging" isMarkerVisible="true">
      <incoming>sb_f6</incoming>
      <incoming>sb_gw3_n</incoming>
      <outgoing>sb_f7</outgoing>
    </exclusiveGateway>

    <exclusiveGateway id="sb_gw4_s" gatewayDirection="Diverging" name="required by Member State?" isMarkerVisible="true">
      <extensionElements><signavio:signavioLabel align="center" ref="text_name" valign="middle" x="20.0" y="45.0"/></extensionElements>
      <incoming>sb_f7</incoming>
      <outgoing>sb_gw4_y</outgoing>
      <outgoing>sb_gw4_n</outgoing>
    </exclusiveGateway>
    <parallelGateway id="sb_gw5_s" gatewayDirection="Diverging">
      <incoming>sb_gw4_y</incoming>
      <outgoing>sb_p2_f1</outgoing>
      <outgoing>sb_p2_f2</outgoing>
      <outgoing>sb_p2_f3</outgoing>
    </parallelGateway>
    <task id="sb_t4" name="establish a trust infrastructure"><incoming>sb_p2_f1</incoming><outgoing>sb_p2_o1</outgoing></task>
    <task id="sb_t5" name="maintain a trust infrastructure"><incoming>sb_p2_f2</incoming><outgoing>sb_p2_o2</outgoing></task>
    <task id="sb_t6" name="update a trust infrastructure"><incoming>sb_p2_f3</incoming><outgoing>sb_p2_o3</outgoing></task>
    <parallelGateway id="sb_gw5_j" gatewayDirection="Converging">
      <incoming>sb_p2_o1</incoming>
      <incoming>sb_p2_o2</incoming>
      <incoming>sb_p2_o3</incoming>
      <outgoing>sb_f8</outgoing>
    </parallelGateway>
    <exclusiveGateway id="sb_gw4_j" gatewayDirection="Converging" isMarkerVisible="true">
      <incoming>sb_f8</incoming>
      <incoming>sb_gw4_n</incoming>
      <outgoing>sb_f9</outgoing>
    </exclusiveGateway>

    <task id="sb_t7" name="submit to the Commission a report on its previous year's main activities">
      <incoming>sb_f9</incoming>
      <outgoing>sb_f10</outgoing>
    </task>
    
    <intermediateCatchEvent id="sb_catch_req" name="receipt of a justified request">
      <extensionElements><signavio:signavioLabel align="center" ref="text_name" valign="middle" x="15.0" y="35.0"/></extensionElements>
      <incoming>sb_f10</incoming>
      <outgoing>sb_f11</outgoing>
      <messageEventDefinition id="med_sb_1" />
    </intermediateCatchEvent>

    <exclusiveGateway id="sb_gw6_s" gatewayDirection="Diverging" name="not competent or not proportionate or incompatible?" isMarkerVisible="true">
      <extensionElements><signavio:signavioLabel align="center" ref="text_name" valign="middle" x="20.0" y="45.0"/></extensionElements>
      <incoming>sb_f11</incoming>
      <outgoing>sb_gw6_t</outgoing>
      <outgoing>sb_gw6_f</outgoing>
    </exclusiveGateway>
    <task id="sb_t8" name="refuse assistance">
      <incoming>sb_gw6_t</incoming>
      <outgoing>sb_f12</outgoing>
    </task>
    <task id="sb_t9" name="provide assistance">
      <incoming>sb_gw6_f</incoming>
      <outgoing>sb_f13</outgoing>
    </task>
    <exclusiveGateway id="sb_gw6_j" gatewayDirection="Converging" isMarkerVisible="true">
      <incoming>sb_f12</incoming>
      <incoming>sb_f13</incoming>
      <outgoing>sb_f14</outgoing>
    </exclusiveGateway>

    <exclusiveGateway id="sb_gw7_s" gatewayDirection="Diverging" name="authorised?" isMarkerVisible="true">
