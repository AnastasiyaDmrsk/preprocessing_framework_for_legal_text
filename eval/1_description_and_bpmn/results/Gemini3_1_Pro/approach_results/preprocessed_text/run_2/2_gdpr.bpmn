<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" 
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" 
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" 
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" 
             xmlns:signavio="http://www.signavio.com" 
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
             exporter="Signavio Process Editor, http://www.signavio.com" 
             exporterVersion="19.2.2" 
             expressionLanguage="http://www.w3.org/TR/XPath" 
             id="sid-main-definitions" 
             targetNamespace="http://www.signavio.com" 
             typeLanguage="http://www.w3.org/2001/XMLSchema" 
             xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd">
             
   <collaboration id="sid-collaboration">
      <participant id="sid-P" name="Processor" processRef="sid-Process-P">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffff"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
      </participant>
      <participant id="sid-C" name="Controller" processRef="sid-Process-C">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffff"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
      </participant>
      <participant id="sid-S" name="Supervisory Authority" processRef="sid-Process-S">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffff"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
      </participant>
      
      <messageFlow id="sid-mf-1" name="" sourceRef="p_t1" targetRef="c_start">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
      </messageFlow>
      <messageFlow id="sid-mf-2" name="" sourceRef="c_t1" targetRef="s_start">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
      </messageFlow>
   </collaboration>

   <process id="sid-Process-P" isClosed="false" isExecutable="false" name="Processor" processType="None">
      <laneSet id="sid-laneSet-P">
         <lane id="lane_P">
            <extensionElements>
               <signavio:signavioMetaData metaKey="bgcolor" metaValue=""/>
               <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            </extensionElements>
            <flowNodeRef>p_start</flowNodeRef>
            <flowNodeRef>p_t1</flowNodeRef>
            <flowNodeRef>p_end</flowNodeRef>
         </lane>
      </laneSet>
      
      <startEvent id="p_start" name="Personal data breach">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffff"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/>
         </extensionElements>
         <outgoing>p_seq1</outgoing>
      </startEvent>
      <task completionQuantity="1" id="p_t1" isForCompensation="false" name="Notify the controller of a personal data breach" startQuantity="1">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffcc"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <incoming>p_seq1</incoming>
         <outgoing>p_seq2</outgoing>
      </task>
      <endEvent id="p_end" name="End">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffff"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioLabel bottom="true" left="false" ref="text_name" right="false" top="false" valign="top" x="14.0" y="32.0"/>
         </extensionElements>
         <incoming>p_seq2</incoming>
      </endEvent>
      <sequenceFlow id="p_seq1" isImmediate="true" name="" sourceRef="p_start" targetRef="p_t1"/>
      <sequenceFlow id="p_seq2" isImmediate="true" name="" sourceRef="p_t1" targetRef="p_end"/>
   </process>

   <process id="sid-Process-C" isClosed="false" isExecutable="false" name="Controller" processType="None">
      <laneSet id="sid-laneSet-C">
         <lane id="lane_C">
            <extensionElements>
               <signavio:signavioMetaData metaKey="bgcolor" metaValue=""/>
               <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            </extensionElements>
            <flowNodeRef>c_start</flowNodeRef>
            <flowNodeRef>c_gw1_s</flowNodeRef>
            <flowNodeRef>c_t1</flowNodeRef>
            <flowNodeRef>c_gw1_m</flowNodeRef>
            <flowNodeRef>c_gw2_s</flowNodeRef>
            <flowNodeRef>c_t2</flowNodeRef>
            <flowNodeRef>c_gw2_m</flowNodeRef>
            <flowNodeRef>c_gw3_s</flowNodeRef>
            <flowNodeRef>c_t3</flowNodeRef>
            <flowNodeRef>c_gw3_m</flowNodeRef>
            <flowNodeRef>c_t4</flowNodeRef>
            <flowNodeRef>c_gw4_s</flowNodeRef>
            <flowNodeRef>c_t5</flowNodeRef>
            <flowNodeRef>c_gw4_m</flowNodeRef>
            <flowNodeRef>c_gw5_s</flowNodeRef>
            <flowNodeRef>c_t6</flowNodeRef>
            <flowNodeRef>c_gw5_m</flowNodeRef>
            <flowNodeRef>c_end</flowNodeRef>
         </lane>
      </laneSet>

      <startEvent id="c_start" isInterrupting="true" name="Receive personal data breach">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffff"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/>
         </extensionElements>
         <outgoing>c_seq1</outgoing>
         <messageEventDefinition id="c_start_msg"/>
      </startEvent>

      <exclusiveGateway gatewayDirection="Diverging" id="c_gw1_s" isMarkerVisible="true" name="Risk likely?">
         <extensionElements>
            <signavio:signavioLabel bottom="true" left="false" ref="text_name" right="false" top="false" valign="top" x="20.0" y="45.0"/>
         </extensionElements>
         <incoming>c_seq1</incoming>
         <outgoing>c_seq_gw1_y</outgoing>
         <outgoing>c_seq_gw1_n</outgoing>
      </exclusiveGateway>

      <task completionQuantity="1" id="c_t1" isForCompensation="false" name="Notify the personal data breach to the supervisory authority" startQuantity="1">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffcc"/>
         </extensionElements>
         <incoming>c_seq_gw1_y</incoming>
         <outgoing>c_seq_t1_out</outgoing>
      </task>

      <exclusiveGateway gatewayDirection="Converging" id="c_gw1_m" isMarkerVisible="true" name="">
         <incoming>c_seq_t1_out</incoming>
         <incoming>c_seq_gw1_n</incoming>
         <outgoing>c_seq2</outgoing>
      </exclusiveGateway>

      <exclusiveGateway gatewayDirection="Diverging" id="c_gw2_s" isMarkerVisible="true" name="Not within 72h?">
         <extensionElements>
            <signavio:signavioLabel bottom="true" left="false" ref="text_name" right="false" top="false" valign="top" x="20.0" y="45.0"/>
         </extensionElements>
         <incoming>c_seq2</incoming>
         <outgoing>c_seq_gw2_y</outgoing>
         <outgoing>c_seq_gw2_n</outgoing>
      </exclusiveGateway>

      <task completionQuantity="1" id="c_t2" isForCompensation="false" name="Accompany the notification with reasons for the delay" startQuantity="1">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffcc"/>
         </extensionElements>
         <incoming>c_seq_gw2_y</incoming>
         <outgoing>c_seq_t2_out</outgoing>
      </task>

      <exclusiveGateway gatewayDirection="Converging" id="c_gw2_m" isMarkerVisible="true" name="">
         <incoming>c_seq_t2_out</incoming>
         <incoming>c_seq_gw2_n</incoming>
         <outgoing>c_seq3</outgoing>
      </exclusiveGateway>

      <exclusiveGateway gatewayDirection="Diverging" id="c_gw3_s" isMarkerVisible="true" name="Not possible at once?">
         <extensionElements>
            <signavio:signavioLabel bottom="true" left="false" ref="text_name" right="false" top="false" valign="top" x="20.0" y="45.0"/>
         </extensionElements>
         <incoming>c_seq3</incoming>
         <outgoing>c_seq_gw3_y</outgoing>
         <outgoing>c_seq_gw3_n</outgoing>
      </exclusiveGateway>

      <task completionQuantity="1" id="c_t3" isForCompensation="false" name="Provide the information" startQuantity="1">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffcc"/>
         </extensionElements>
         <incoming>c_seq_gw3_y</incoming>
         <outgoing>c_seq_t3_out</outgoing>
      </task>

      <exclusiveGateway gatewayDirection="Converging" id="c_gw3_m" isMarkerVisible="true" name="">
         <incoming>c_seq_t3_out</incoming>
         <incoming>c_seq_gw3_n</incoming>
         <outgoing>c_seq4</outgoing>
      </exclusiveGateway>

      <task completionQuantity="1" id="c_t4" isForCompensation="false" name="Document any personal data breaches" startQuantity="1">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffcc"/>
         </extensionElements>
         <incoming>c_seq4</incoming>
         <outgoing>c_seq5</outgoing>
      </task>

      <exclusiveGateway gatewayDirection="Diverging" id="c_gw4_s" isMarkerVisible="true" name="High risk?">
         <extensionElements>
            <signavio:signavioLabel bottom="true" left="false" ref="text_name" right="false" top="false" valign="top" x="20.0" y="45.0"/>
         </extensionElements>
         <incoming>c_seq5</incoming>
         <outgoing>c_seq_gw4_y</outgoing>
         <outgoing>c_seq_gw4_n</outgoing>
      </exclusiveGateway>

      <task completionQuantity="1" id="c_t5" isForCompensation="false" name="Communicate the personal data breach to the data subject" startQuantity="1">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffcc"/>
         </extensionElements>
         <incoming>c_seq_gw4_y</incoming>
         <outgoing>c_seq_t5_out</outgoing>
      </task>

      <exclusiveGateway gatewayDirection="Converging" id="c_gw4_m" isMarkerVisible="true" name="">
         <incoming>c_seq_t5_out</incoming>
         <incoming>c_seq_gw4_n</incoming>
         <outgoing>c_seq6</outgoing>
      </exclusiveGateway>

      <exclusiveGateway gatewayDirection="Diverging" id="c_gw5_s" isMarkerVisible="true" name="Disproportionate effort?">
         <extensionElements>
            <signavio:signavioLabel bottom="true" left="false" ref="text_name" right="false" top="false" valign="top" x="20.0" y="45.0"/>
         </extensionElements>
         <incoming>c_seq6</incoming>
         <outgoing>c_seq_gw5_y</outgoing>
         <outgoing>c_seq_gw5_n</outgoing>
      </exclusiveGateway>

      <task completionQuantity="1" id="c_t6" isForCompensation="false" name="Carry out a public communication or similar measure" startQuantity="1">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffcc"/>
         </extensionElements>
         <incoming>c_seq_gw5_y</incoming>
         <outgoing>c_seq_t6_out</outgoing>
      </task>

      <exclusiveGateway gatewayDirection="Converging" id="c_gw5_m" isMarkerVisible="true" name="">
         <incoming>c_seq_t6_out</incoming>
         <incoming>c_seq_gw5_n</incoming>
         <outgoing>c_seq7</outgoing>
      </exclusiveGateway>

      <endEvent id="c_end" name="End">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffff"/>
            <signavio:signavioLabel bottom="true" left="false" ref="text_name" right="false" top="false" valign="top" x="14.0" y="32.0"/>
         </extensionElements>
         <incoming>c_seq7</incoming>
      </endEvent>

      <sequenceFlow id="c_seq1" isImmediate="true" name="" sourceRef="c_start" targetRef="c_gw1_s"/>
      <sequenceFlow id="c_seq_gw1_y" isImmediate="true" name="yes" sourceRef="c_gw1_s" targetRef="c_t1"/>
      <sequenceFlow id="c_seq_gw1_n" isImmediate="true" name="no" sourceRef="c_gw1_s" targetRef="c_gw1_m"/>
      <sequenceFlow id="c_seq_t1_out" isImmediate="true" name="" sourceRef="c_t1" targetRef="c_gw1_m"/>
      <sequenceFlow id="c_seq2" isImmediate="true" name="" sourceRef="c_gw1_m" targetRef="c_gw2_s"/>
      <sequenceFlow id="c_seq_gw2_y" isImmediate="true" name="yes" sourceRef="c_gw2_s" targetRef="c_t2"/>
      <sequenceFlow id="c_seq_gw2_n" isImmediate="true" name="no" sourceRef="c_gw2_s" targetRef="c_gw2_m"/>
      <sequenceFlow id="c_seq_t2_out" isImmediate="true" name="" sourceRef="c_t2" targetRef="c_gw2_m"/>
      <sequenceFlow id="c_seq3" isImmediate="true" name="" sourceRef="c_gw2_m" targetRef="c_gw3_s"/>
      <sequenceFlow id="c_seq_gw3_y" isImmediate="true" name="yes" sourceRef="c_gw3_s" targetRef="c_t3"/>
      <sequenceFlow id="c_seq_gw3_n" isImmediate="true" name="no" sourceRef="c_gw3_s" targetRef="c_gw3_m"/>
      <sequenceFlow id="c_seq_t3_out" isImmediate="true" name="" sourceRef="c_t3" targetRef="c_gw3_m"/>
      <sequenceFlow id="c_seq4" isImmediate="true" name="" sourceRef="c_gw3_m" targetRef="c_t4"/>
      <sequenceFlow id="c_seq5" isImmediate="true" name="" sourceRef="c_t4" targetRef="c_gw4_s"/>
      <sequenceFlow id="c_seq_gw4_y" isImmediate="true" name="yes" sourceRef="c_gw4_s" targetRef="c_t5"/>
      <sequenceFlow id="c_seq_gw4_n" isImmediate="true" name="no" sourceRef="c_gw4_s" targetRef="c_gw4_m"/>
      <sequenceFlow id="c_seq_t5_out" isImmediate="true" name="" sourceRef="c_t5" targetRef="c_gw4_m"/>
      <sequenceFlow id="c_seq6" isImmediate="true" name="" sourceRef="c_gw4_m" targetRef="c_gw5_s"/>
      <sequenceFlow id="c_seq_gw5_y" isImmediate="true" name="yes" sourceRef="c_gw5_s" targetRef="c_t6"/>
      <sequenceFlow id="c_seq_gw5_n" isImmediate="true" name="no" sourceRef="c_gw5_s" targetRef="c_gw5_m"/>
      <sequenceFlow id="c_seq_t6_out" isImmediate="true" name="" sourceRef="c_t6" targetRef="c_gw5_m"/>
      <sequenceFlow id="c_seq7" isImmediate="true" name="" sourceRef="c_gw5_m" targetRef="c_end"/>
   </process>

   <process id="sid-Process-S" isClosed="false" isExecutable="false" name="Supervisory Authority" processType="None">
      <laneSet id="sid-laneSet-S">
         <lane id="lane_S">
            <extensionElements>
               <signavio:signavioMetaData metaKey="bgcolor" metaValue=""/>
               <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            </extensionElements>
            <flowNodeRef>s_start</flowNodeRef>
            <flowNodeRef>s_t1</flowNodeRef>
            <flowNodeRef>s_t2</flowNodeRef>
            <flowNodeRef>s_gw6_s</flowNodeRef>
            <flowNodeRef>s_t3</flowNodeRef>
            <flowNodeRef>s_gw6_m</flowNodeRef>
            <flowNodeRef>s_gw7_s</flowNodeRef>
            <flowNodeRef>s_t4</flowNodeRef>
            <flowNodeRef>s_gw7_m</flowNodeRef>
            <flowNodeRef>s_end</flowNodeRef>
         </lane>
      </laneSet>

      <startEvent id="s_start" isInterrupting="true" name="Receive personal data breach">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffff"/>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/>
         </extensionElements>
         <outgoing>s_seq1</outgoing>
         <messageEventDefinition id="s_start_msg"/>
      </startEvent>

      <task completionQuantity="1" id="s_t1" isForCompensation="false" name="Verify compliance" startQuantity="1">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffcc"/>
         </extensionElements>
         <incoming>s_seq1</incoming>
         <outgoing>s_seq2</outgoing>
      </task>

      <task completionQuantity="1" id="s_t2" isForCompensation="false" name="Consider the likelihood of the data breach resulting in a high risk" startQuantity="1">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffcc"/>
         </extensionElements>
         <incoming>s_seq2</incoming>
         <outgoing>s_seq3</outgoing>
      </task>

      <exclusiveGateway gatewayDirection="Diverging" id="s_gw6_s" isMarkerVisible="true" name="Require communication?">
         <extensionElements>
            <signavio:signavioLabel bottom="true" left="false" ref="text_name" right="false" top="false" valign="top" x="20.0" y="45.0"/>
         </extensionElements>
         <incoming>s_seq3</incoming>
         <outgoing>s_seq_gw6_y</outgoing>
         <outgoing>s_seq_gw6_n</outgoing>
      </exclusiveGateway>

      <task completionQuantity="1" id="s_t3" isForCompensation="false" name="Require the controller to communicate the data breach to the data subject" startQuantity="1">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffcc"/>
         </extensionElements>
         <incoming>s_seq_gw6_y</incoming>
         <outgoing>s_seq_t3_out</outgoing>
      </task>

      <exclusiveGateway gatewayDirection="Converging" id="s_gw6_m" isMarkerVisible="true" name="">
         <incoming>s_seq_t3_out</incoming>
         <incoming>s_seq_gw6_n</incoming>
         <outgoing>s_seq4</outgoing>
      </exclusiveGateway>

      <exclusiveGateway gatewayDirection="Diverging" id="s_gw7_s" isMarkerVisible="true" name="Conditions met?">
         <extensionElements>
            <signavio:signavioLabel bottom="true" left="false" ref="text_name" right="false" top="false" valign="top" x="20.0" y="45.0"/>
         </extensionElements>
         <incoming>s_seq4</incoming>
         <outgoing>s_seq_gw7_y</outgoing>
         <outgoing>s_seq_gw7_n</outgoing>
      </exclusiveGateway>

      <task completionQuantity="1" id="s_t4" isForCompensation="false" name="Decide that any of the conditions are met" startQuantity="1">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffcc"/>
         </extensionElements>
         <incoming>s_seq_gw7_y</incoming>
         <outgoing>s_seq_t4_out</outgoing>
      </task>

      <exclusiveGateway gatewayDirection="Converging" id="s_gw7_m" isMarkerVisible="true" name="">
         <incoming>s_seq_t4_out</incoming>
         <incoming>s_seq_gw7_n</incoming>
         <outgoing>s_seq5</outgoing>
      </exclusiveGateway>

      <endEvent id="s_end" name="End">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffff"/>
            <signavio:signavioLabel bottom="true" left="false" ref="text_name" right="false" top="false" valign="top" x="14.0" y="32.0"/>
         </extensionElements>
         <incoming>s_seq5</incoming>
      </endEvent>

      <sequenceFlow id="s_seq1" isImmediate="true" name="" sourceRef="s_start" targetRef="s_t1"/>
      <sequenceFlow id="s_seq2" isImmediate="true" name="" sourceRef="s_t1" targetRef="s_t2"/>
      <sequenceFlow id="s_seq3" isImmediate="true" name="" sourceRef="s_t2" targetRef="s_gw6_s"/>
      <sequenceFlow id="s_seq_gw6_y" isImmediate="true" name="yes" sourceRef="s_gw6_s" targetRef="s_t3"/>
      <sequenceFlow id="s_seq_gw6_n" isImmediate="true" name="no" sourceRef="s_gw6_s" targetRef="s_gw6_m"/>
      <sequenceFlow id="s_seq_t3_out" isImmediate="true" name="" sourceRef="s_t3" targetRef="s_gw6_m"/>
      <sequenceFlow id="s_seq4" isImmediate="true" name="" sourceRef="s_gw6_m" targetRef="s_gw7_s"/>
      <sequenceFlow id="s_seq_gw7_y" isImmediate="true" name="yes" sourceRef="s_gw7_s" targetRef="s_t4"/>
      <sequenceFlow id="s_seq_gw7_n" isImmediate="true" name="no" sourceRef="s_gw7_s" targetRef="s_gw7_m"/>
      <sequenceFlow id="s_seq_t4_out" isImmediate="true" name="" sourceRef="s_t4" targetRef="s_gw7_m"/>
      <sequenceFlow id="s_seq5" isImmediate="true" name="" sourceRef="s_gw7_m" targetRef="s_end"/>
   </process>

   <bpmndi:BPMNDiagram id="sid-diagram">
      <bpmndi:BPMNPlane bpmnElement="sid-collaboration" id="sid-plane">
         
         <bpmndi:BPMNShape bpmnElement="sid-P" id="sid-P_gui" isHorizontal="true">
            <omgdc:Bounds height="200.0" width="500.0" x="100.0" y="100.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="lane_P" id="lane_P_gui" isHorizontal="true">
            <omgdc:Bounds height="200.0" width="470.0" x="130.0" y="100.0"/>
         </bpmndi:BPMNShape>
         
         <bpmndi:BPMNShape bpmnElement="p_start" id="p_start_gui">
            <omgdc:Bounds height="30.0" width="30.0" x="180.0" y="185.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="p_t1" id="p_t1_gui">
            <omgdc:Bounds height="80.0" width="100.0" x="250.0" y="160.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="p_end" id="p_end_gui">
            <omgdc:Bounds height="28.0" width="28.0" x="400.0" y="186.0"/>
         </bpmndi:BPMNShape>

         <bpmndi:BPMNShape bpmnElement="sid-C" id="sid-C_gui" isHorizontal="true">
            <omgdc:Bounds height="200.0" width="2300.0" x="100.0" y="350.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="lane_C" id="lane_C_gui" isHorizontal="true">
            <omgdc:Bounds height="200.0" width="2270.0" x="130.0" y="350.0"/>
         </bpmndi:BPMNShape>
         
         <bpmndi:BPMNShape bpmnElement="c_start" id="c_start_gui">
            <omgdc:Bounds height="30.0" width="30.0" x="285.0" y="435.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="c_gw1_s" id="c_gw1_s_gui">
