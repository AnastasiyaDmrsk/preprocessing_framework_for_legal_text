      <participant id="part_com" name="Commission" processRef="proc_com" />
      <participant id="part_cg" name="Cooperation Group" processRef="proc_cg" />
      
      <!-- Message Flows -->
      <messageFlow id="mf_eie_csirt" sourceRef="eie_t6" targetRef="csirt_start" />
      <messageFlow id="mf_spoc_enisa" sourceRef="spoc_t2" targetRef="enisa_start" />
      <messageFlow id="mf_com_cg" sourceRef="com_t4" targetRef="cg_start" />
