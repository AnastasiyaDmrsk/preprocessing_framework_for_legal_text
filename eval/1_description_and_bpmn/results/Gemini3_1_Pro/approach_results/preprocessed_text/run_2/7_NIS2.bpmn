             id="sid-main-definition" 
             targetNamespace="http://www.signavio.com">
   <collaboration id="collab_1">
      <participant id="part_eie" name="Essential and Important Entity" processRef="proc_eie" />
      <participant id="part_tsp" name="Trust Service Provider" processRef="proc_tsp" />
      <participant id="part_ca" name="Competent Authority" processRef="proc_ca" />
      <participant id="part_csirt" name="CSIRT" processRef="proc_csirt" />
      <participant id="part_spoc" name="Single Point of Contact" processRef="proc_spoc" />
