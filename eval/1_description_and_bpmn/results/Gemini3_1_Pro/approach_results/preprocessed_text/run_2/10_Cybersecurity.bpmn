   <process id="Proc_IP" isClosed="false" isExecutable="false" name="Interested Party" processType="None">
      <laneSet id="LS_IP">
         <lane id="Lane_IP" name="Interested Party">
            <flowNodeRef>IP_Start</flowNodeRef>
            <flowNodeRef>IP_Tsk1</flowNodeRef>
            <flowNodeRef>IP_Tsk2</flowNodeRef>
            <flowNodeRef>IP_End</flowNodeRef>
         </lane>
      </laneSet>

      <startEvent id="IP_Start" name="Start">
         <outgoing>IP_S1</outgoing>
      </startEvent>
      <task id="IP_Tsk1" name="Provide feedback">
         <incoming>IP_S1</incoming>
         <outgoing>IP_S2</outgoing>
      </task>
      <task id="IP_Tsk2" name="Transmit feedback to ENISA">
         <incoming>IP_S2</incoming>
         <outgoing>IP_S3</outgoing>
      </task>
      <endEvent id="IP_End" name="feedback submission end event">
         <incoming>IP_S3</incoming>
      </endEvent>

      <sequenceFlow id="IP_S1" isImmediate="true" name="" sourceRef="IP_Start" targetRef="IP_Tsk1" />
      <sequenceFlow id="IP_S2" isImmediate="true" name="" sourceRef="IP_Tsk1" targetRef="IP_Tsk2" />
      <sequenceFlow id="IP_S3" isImmediate="true" name="" sourceRef="IP_Tsk2" targetRef="IP_End" />
   </process>

