<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" 
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" 
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" 
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" 
             xmlns:signavio="http://www.signavio.com" 
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
             exporter="Signavio Process Editor, http://www.signavio.com" 
             exporterVersion="19.2.2" 
             id="sid-main" 
             targetNamespace="http://www.signavio.com" 
             xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd">

   <collaboration id="Collab_1">
      <participant id="Part_C" name="Commission" processRef="Proc_C" />
      <participant id="Part_E" name="ECCG" processRef="Proc_E" />
      <participant id="Part_EN" name="ENISA" processRef="Proc_EN" />
      <participant id="Part_IP" name="Interested Party" processRef="Proc_IP" />

      <messageFlow id="MF_1" name="Transmit request" sourceRef="C_Tsk7" targetRef="EN_Start" />
      <messageFlow id="MF_2" name="Transmit request" sourceRef="E_Tsk4" targetRef="EN_Start" />
      <messageFlow id="MF_3" name="Transmit assistance" sourceRef="E_Tsk6" targetRef="EN_Catch_Assist" />
      <messageFlow id="MF_4" name="Transmit opinion" sourceRef="E_Tsk8" targetRef="EN_Catch_Op" />
      <messageFlow id="MF_5" name="Transmit scheme" sourceRef="EN_Tsk10" targetRef="C_Catch_Scheme" />
      <messageFlow id="MF_6" name="Transmit request (revision)" sourceRef="C_Tsk11" targetRef="EN_Catch_Rev" />
      <messageFlow id="MF_7" name="Transmit request (revision)" sourceRef="E_Tsk11" targetRef="EN_Catch_Rev" />
      <messageFlow id="MF_8" name="Transmit feedback" sourceRef="IP_Tsk2" targetRef="Part_EN" />
   </collaboration>

   <process id="Proc_C" isClosed="false" isExecutable="false" name="Commission" processType="None">
      <laneSet id="LS_C">
         <lane id="Lane_C" name="Commission">
            <flowNodeRef>C_Start</flowNodeRef>
            <flowNodeRef>C_Tsk1</flowNodeRef>
            <flowNodeRef>C_GW1_Div</flowNodeRef>
            <flowNodeRef>C_Tsk2</flowNodeRef>
            <flowNodeRef>C_Tsk3</flowNodeRef>
            <flowNodeRef>C_Tsk4</flowNodeRef>
            <flowNodeRef>C_Tsk5</flowNodeRef>
            <flowNodeRef>C_GW1_Conv</flowNodeRef>
            <flowNodeRef>C_Tsk6</flowNodeRef>
            <flowNodeRef>C_Tsk7</flowNodeRef>
            <flowNodeRef>C_Catch_Scheme</flowNodeRef>
            <flowNodeRef>C_Tsk8</flowNodeRef>
            <flowNodeRef>C_Tsk9</flowNodeRef>
            <flowNodeRef>C_GW2_Div</flowNodeRef>
            <flowNodeRef>C_Tsk10</flowNodeRef>
            <flowNodeRef>C_Tsk11</flowNodeRef>
            <flowNodeRef>C_End</flowNodeRef>
         </lane>
      </laneSet>

      <startEvent id="C_Start" name="prepare or review scheme">
         <outgoing>C_S1</outgoing>
      </startEvent>
      <task id="C_Tsk1" name="Assess whether scheme is included in rolling work programme">
         <incoming>C_S1</incoming>
         <outgoing>C_S2</outgoing>
      </task>
      <exclusiveGateway gatewayDirection="Diverging" id="C_GW1_Div" isMarkerVisible="true" name="Included?">
         <incoming>C_S2</incoming>
         <outgoing>C_S3</outgoing>
         <outgoing>C_S4</outgoing>
         <outgoing>C_S5</outgoing>
         <outgoing>C_S6</outgoing>
      </exclusiveGateway>
      <task id="C_Tsk2" name="Request ENISA to prepare scheme (included)">
         <incoming>C_S3</incoming>
         <outgoing>C_S7</outgoing>
      </task>
      <task id="C_Tsk3" name="Request ENISA to review scheme (included)">
         <incoming>C_S4</incoming>
         <outgoing>C_S8</outgoing>
      </task>
      <task id="C_Tsk4" name="Request ENISA to prepare scheme (not included)">
         <incoming>C_S5</incoming>
         <outgoing>C_S9</outgoing>
      </task>
      <task id="C_Tsk5" name="Request ENISA to review scheme (not included)">
         <incoming>C_S6</incoming>
         <outgoing>C_S10</outgoing>
      </task>
      <exclusiveGateway gatewayDirection="Converging" id="C_GW1_Conv" isMarkerVisible="true">
         <incoming>C_S7</incoming>
         <incoming>C_S8</incoming>
         <incoming>C_S9</incoming>
         <incoming>C_S10</incoming>
         <outgoing>C_S11</outgoing>
      </exclusiveGateway>
      <task id="C_Tsk6" name="Update the Union rolling work programme">
         <incoming>C_S11</incoming>
         <outgoing>C_S12</outgoing>
      </task>
      <task id="C_Tsk7" name="Transmit request to ENISA">
         <incoming>C_S12</incoming>
         <outgoing>C_S13</outgoing>
      </task>
      <intermediateCatchEvent id="C_Catch_Scheme" name="Receive candidate scheme">
         <incoming>C_S13</incoming>
         <outgoing>C_S14</outgoing>
         <messageEventDefinition id="med_C_Catch_Scheme" />
      </intermediateCatchEvent>
      <task id="C_Tsk8" name="Adopt implementing acts">
         <incoming>C_S14</incoming>
         <outgoing>C_S15</outgoing>
      </task>
      <task id="C_Tsk9" name="Assess whether revised scheme is necessary">
         <incoming>C_S15</incoming>
         <outgoing>C_S16</outgoing>
      </task>
      <exclusiveGateway gatewayDirection="Diverging" id="C_GW2_Div" isMarkerVisible="true" name="Necessary?">
         <incoming>C_S16</incoming>
         <outgoing>C_S17</outgoing>
         <outgoing>C_S20</outgoing>
      </exclusiveGateway>
      <task id="C_Tsk10" name="Request ENISA to start revised candidate scheme">
         <incoming>C_S17</incoming>
         <outgoing>C_S18</outgoing>
      </task>
      <task id="C_Tsk11" name="Transmit request to ENISA">
         <incoming>C_S18</incoming>
         <outgoing>C_S19</outgoing>
      </task>
      <endEvent id="C_End" name="scheme adoption or revision request end event">
         <incoming>C_S19</incoming>
         <incoming>C_S20</incoming>
      </endEvent>

      <sequenceFlow id="C_S1" isImmediate="true" name="" sourceRef="C_Start" targetRef="C_Tsk1" />
      <sequenceFlow id="C_S2" isImmediate="true" name="" sourceRef="C_Tsk1" targetRef="C_GW1_Div" />
      <sequenceFlow id="C_S3" isImmediate="true" name="included (prepare)" sourceRef="C_GW1_Div" targetRef="C_Tsk2" />
      <sequenceFlow id="C_S4" isImmediate="true" name="included (review)" sourceRef="C_GW1_Div" targetRef="C_Tsk3" />
      <sequenceFlow id="C_S5" isImmediate="true" name="not included (prepare)" sourceRef="C_GW1_Div" targetRef="C_Tsk4" />
      <sequenceFlow id="C_S6" isImmediate="true" name="not included (review)" sourceRef="C_GW1_Div" targetRef="C_Tsk5" />
      <sequenceFlow id="C_S7" isImmediate="true" name="" sourceRef="C_Tsk2" targetRef="C_GW1_Conv" />
      <sequenceFlow id="C_S8" isImmediate="true" name="" sourceRef="C_Tsk3" targetRef="C_GW1_Conv" />
      <sequenceFlow id="C_S9" isImmediate="true" name="" sourceRef="C_Tsk4" targetRef="C_GW1_Conv" />
      <sequenceFlow id="C_S10" isImmediate="true" name="" sourceRef="C_Tsk5" targetRef="C_GW1_Conv" />
      <sequenceFlow id="C_S11" isImmediate="true" name="" sourceRef="C_GW1_Conv" targetRef="C_Tsk6" />
      <sequenceFlow id="C_S12" isImmediate="true" name="" sourceRef="C_Tsk6" targetRef="C_Tsk7" />
      <sequenceFlow id="C_S13" isImmediate="true" name="" sourceRef="C_Tsk7" targetRef="C_Catch_Scheme" />
      <sequenceFlow id="C_S14" isImmediate="true" name="" sourceRef="C_Catch_Scheme" targetRef="C_Tsk8" />
      <sequenceFlow id="C_S15" isImmediate="true" name="" sourceRef="C_Tsk8" targetRef="C_Tsk9" />
      <sequenceFlow id="C_S16" isImmediate="true" name="" sourceRef="C_Tsk9" targetRef="C_GW2_Div" />
      <sequenceFlow id="C_S17" isImmediate="true" name="yes" sourceRef="C_GW2_Div" targetRef="C_Tsk10" />
      <sequenceFlow id="C_S18" isImmediate="true" name="" sourceRef="C_Tsk10" targetRef="C_Tsk11" />
      <sequenceFlow id="C_S19" isImmediate="true" name="" sourceRef="C_Tsk11" targetRef="C_End" />
      <sequenceFlow id="C_S20" isImmediate="true" name="no" sourceRef="C_GW2_Div" targetRef="C_End" />
   </process>

   <process id="Proc_E" isClosed="false" isExecutable="false" name="ECCG" processType="None">
      <laneSet id="LS_E">
         <lane id="Lane_E" name="ECCG">
            <flowNodeRef>E_Start</flowNodeRef>
            <flowNodeRef>E_Tsk1</flowNodeRef>
            <flowNodeRef>E_GW1_Div</flowNodeRef>
            <flowNodeRef>E_Tsk2</flowNodeRef>
            <flowNodeRef>E_Tsk3</flowNodeRef>
            <flowNodeRef>E_GW1_Conv</flowNodeRef>
            <flowNodeRef>E_Tsk4</flowNodeRef>
            <flowNodeRef>E_Tsk5</flowNodeRef>
            <flowNodeRef>E_Tsk6</flowNodeRef>
            <flowNodeRef>E_Tsk7</flowNodeRef>
            <flowNodeRef>E_Tsk8</flowNodeRef>
            <flowNodeRef>E_Tsk9</flowNodeRef>
            <flowNodeRef>E_GW2_Div</flowNodeRef>
            <flowNodeRef>E_Tsk10</flowNodeRef>
            <flowNodeRef>E_Tsk11</flowNodeRef>
            <flowNodeRef>E_End</flowNodeRef>
         </lane>
      </laneSet>

      <startEvent id="E_Start" name="Start">
         <outgoing>E_S1</outgoing>
      </startEvent>
      <task id="E_Tsk1" name="Assess whether a scheme needs to be prepared or reviewed">
         <incoming>E_S1</incoming>
         <outgoing>E_S2</outgoing>
      </task>
      <exclusiveGateway gatewayDirection="Diverging" id="E_GW1_Div" isMarkerVisible="true" name="Required?">
         <incoming>E_S2</incoming>
         <outgoing>E_S3</outgoing>
         <outgoing>E_S4</outgoing>
         <outgoing>E_S5</outgoing>
      </exclusiveGateway>
      <task id="E_Tsk2" name="Request ENISA to prepare scheme">
         <incoming>E_S3</incoming>
         <outgoing>E_S6</outgoing>
      </task>
      <task id="E_Tsk3" name="Request ENISA to review scheme">
         <incoming>E_S4</incoming>
         <outgoing>E_S7</outgoing>
      </task>
      <exclusiveGateway gatewayDirection="Converging" id="E_GW1_Conv" isMarkerVisible="true">
         <incoming>E_S5</incoming>
         <incoming>E_S6</incoming>
         <incoming>E_S7</incoming>
         <outgoing>E_S8</outgoing>
      </exclusiveGateway>
      <task id="E_Tsk4" name="Transmit request to ENISA">
         <incoming>E_S8</incoming>
         <outgoing>E_S9</outgoing>
      </task>
      <task id="E_Tsk5" name="Provide ENISA with assistance and expert advice">
         <incoming>E_S9</incoming>
         <outgoing>E_S10</outgoing>
      </task>
      <task id="E_Tsk6" name="Transmit assistance and expert advice to ENISA">
         <incoming>E_S10</incoming>
         <outgoing>E_S11</outgoing>
      </task>
      <task id="E_Tsk7" name="Adopt an opinion on the candidate scheme">
         <incoming>E_S11</incoming>
         <outgoing>E_S12</outgoing>
      </task>
      <task id="E_Tsk8" name="Transmit the opinion to ENISA">
         <incoming>E_S12</incoming>
         <outgoing>E_S13</outgoing>
      </task>
      <task id="E_Tsk9" name="Assess whether a revised scheme is necessary">
         <incoming>E_S13</incoming>
         <outgoing>E_S14</outgoing>
      </task>
      <exclusiveGateway gatewayDirection="Diverging" id="E_GW2_Div" isMarkerVisible="true" name="Necessary?">
         <incoming>E_S14</incoming>
         <outgoing>E_S15</outgoing>
         <outgoing>E_S18</outgoing>
      </exclusiveGateway>
      <task id="E_Tsk10" name="Request ENISA to start process of developing revised scheme">
         <incoming>E_S15</incoming>
         <outgoing>E_S16</outgoing>
      </task>
      <task id="E_Tsk11" name="Transmit request to ENISA">
         <incoming>E_S16</incoming>
         <outgoing>E_S17</outgoing>
      </task>
      <endEvent id="E_End" name="scheme opinion or revision request end event">
         <incoming>E_S17</incoming>
         <incoming>E_S18</incoming>
      </endEvent>

      <sequenceFlow id="E_S1" isImmediate="true" name="" sourceRef="E_Start" targetRef="E_Tsk1" />
      <sequenceFlow id="E_S2" isImmediate="true" name="" sourceRef="E_Tsk1" targetRef="E_GW1_Div" />
      <sequenceFlow id="E_S3" isImmediate="true" name="required (prepare)" sourceRef="E_GW1_Div" targetRef="E_Tsk2" />
      <sequenceFlow id="E_S4" isImmediate="true" name="required (review)" sourceRef="E_GW1_Div" targetRef="E_Tsk3" />
      <sequenceFlow id="E_S5" isImmediate="true" name="not required" sourceRef="E_GW1_Div" targetRef="E_GW1_Conv" />
      <sequenceFlow id="E_S6" isImmediate="true" name="" sourceRef="E_Tsk2" targetRef="E_GW1_Conv" />
      <sequenceFlow id="E_S7" isImmediate="true" name="" sourceRef="E_Tsk3" targetRef="E_GW1_Conv" />
      <sequenceFlow id="E_S8" isImmediate="true" name="" sourceRef="E_GW1_Conv" targetRef="E_Tsk4" />
      <sequenceFlow id="E_S9" isImmediate="true" name="" sourceRef="E_Tsk4" targetRef="E_Tsk5" />
      <sequenceFlow id="E_S10" isImmediate="true" name="" sourceRef="E_Tsk5" targetRef="E_Tsk6" />
      <sequenceFlow id="E_S11" isImmediate="true" name="" sourceRef="E_Tsk6" targetRef="E_Tsk7" />
      <sequenceFlow id="E_S12" isImmediate="true" name="" sourceRef="E_Tsk7" targetRef="E_Tsk8" />
      <sequenceFlow id="E_S13" isImmediate="true" name="" sourceRef="E_Tsk8" targetRef="E_Tsk9" />
      <sequenceFlow id="E_S14" isImmediate="true" name="" sourceRef="E_Tsk9" targetRef="E_GW2_Div" />
      <sequenceFlow id="E_S15" isImmediate="true" name="yes" sourceRef="E_GW2_Div" targetRef="E_Tsk10" />
      <sequenceFlow id="E_S16" isImmediate="true" name="" sourceRef="E_Tsk10" targetRef="E_Tsk11" />
      <sequenceFlow id="E_S17" isImmediate="true" name="" sourceRef="E_Tsk11" targetRef="E_End" />
      <sequenceFlow id="E_S18" isImmediate="true" name="no" sourceRef="E_GW2_Div" targetRef="E_End" />
   </process>

   <process id="Proc_EN" isClosed="false" isExecutable="false" name="ENISA" processType="None">
      <laneSet id="LS_EN">
         <lane id="Lane_EN_Main" name="ENISA">
            <flowNodeRef>EN_Start</flowNodeRef>
            <flowNodeRef>EN_Tsk1</flowNodeRef>
            <flowNodeRef>EN_GW1_Div</flowNodeRef>
            <flowNodeRef>EN_Tsk2</flowNodeRef>
            <flowNodeRef>EN_Tsk3</flowNodeRef>
            <flowNodeRef>EN_Tsk4</flowNodeRef>
            <flowNodeRef>EN_GW2_Div</flowNodeRef>
            <flowNodeRef>EN_Tsk5</flowNodeRef>
            <flowNodeRef>EN_End_Refused</flowNodeRef>
            <flowNodeRef>EN_GW1_Conv</flowNodeRef>
            <flowNodeRef>EN_GW3_Div</flowNodeRef>
            <flowNodeRef>EN_Tsk6</flowNodeRef>
            <flowNodeRef>EN_Tsk7</flowNodeRef>
            <flowNodeRef>EN_Tsk8</flowNodeRef>
            <flowNodeRef>EN_GW3_Conv</flowNodeRef>
            <flowNodeRef>EN_Catch_Assist</flowNodeRef>
            <flowNodeRef>EN_Catch_Op</flowNodeRef>
            <flowNodeRef>EN_Tsk9</flowNodeRef>
            <flowNodeRef>EN_Tsk10</flowNodeRef>
            <flowNodeRef>EN_Tsk11</flowNodeRef>
            <flowNodeRef>EN_Catch_Rev</flowNodeRef>
            <flowNodeRef>EN_Tsk12</flowNodeRef>
            <flowNodeRef>EN_End</flowNodeRef>
         </lane>
         <lane id="Lane_EN_MB" name="Management Board">
            <flowNodeRef>MB_Tsk1</flowNodeRef>
         </lane>
      </laneSet>

      <startEvent id="EN_Start" name="Receive request from Commission or ECCG">
         <outgoing>EN_S1</outgoing>
         <messageEventDefinition id="med_EN_Start" />
      </startEvent>
      <task id="EN_Tsk1" name="Assess whether request is from Commission or ECCG">
         <incoming>EN_S1</incoming>
         <outgoing>EN_S2</outgoing>
      </task>
      <exclusiveGateway gatewayDirection="Diverging" id="EN_GW1_Div" isMarkerVisible="true" name="From?">
         <incoming>EN_S2</incoming>
         <outgoing>EN_S3</outgoing>
         <outgoing>EN_S5</outgoing>
      </exclusiveGateway>
      <task id="EN_Tsk2" name="Prepare candidate cybersecurity certification scheme (Commission)">
         <incoming>EN_S3</incoming>
         <outgoing>EN_S4</outgoing>
      </task>
      <task id="EN_Tsk3" name="Prepare candidate cybersecurity certification scheme (ECCG)">
         <incoming>EN_S5</incoming>
         <outgoing>EN_S6</outgoing>
      </task>
      <task id="EN_Tsk4" name="Assess whether to refuse the request from the ECCG">
         <incoming>EN_S6</incoming>
         <outgoing>EN_S7</outgoing>
      </task>
      <exclusiveGateway gatewayDirection="Diverging" id="EN_GW2_Div" isMarkerVisible="true" name="Refuse?">
         <incoming>EN_S7</incoming>
         <outgoing>EN_S8</outgoing>
         <outgoing>EN_S11</outgoing>
      </exclusiveGateway>
      <task id="MB_Tsk1" name="Take decision to refuse a request">
         <incoming>EN_S8</incoming>
         <outgoing>EN_S9</outgoing>
      </task>
      <task id="EN_Tsk5" name="Give reasons for refusal of preparing a candidate scheme">
         <incoming>EN_S9</incoming>
         <outgoing>EN_S10</outgoing>
      </task>
      <endEvent id="EN_End_Refused" name="Refusal end event">
         <incoming>EN_S10</incoming>
      </endEvent>
      <exclusiveGateway gatewayDirection="Converging" id="EN_GW1_Conv" isMarkerVisible="true">
         <incoming>EN_S4</incoming>
         <incoming>EN_S11</incoming>
         <outgoing>EN_S12</outgoing>
      </exclusiveGateway>
      <parallelGateway gatewayDirection="Diverging" id="EN_GW3_Div">
         <incoming>EN_S12</incoming>
         <outgoing>EN_S13</outgoing>
         <outgoing>EN_S14</outgoing>
         <outgoing>EN_S15</outgoing>
      </parallelGateway>
      <task id="EN_Tsk6" name="Consult all relevant stakeholders">
         <incoming>EN_S13</incoming>
         <outgoing>EN_S16</outgoing>
      </task>
      <task id="EN_Tsk7" name="Establish an ad hoc working group">
         <incoming>EN_S14</incoming>
         <outgoing>EN_S17</outgoing>
      </task>
      <task id="EN_Tsk8" name="Cooperate with the ECCG">
         <incoming>EN_S15</incoming>
         <outgoing>EN_S18</outgoing>
      </task>
      <parallelGateway gatewayDirection="Converging" id="EN_GW3_Conv">
         <incoming>EN_S16</incoming>
         <incoming>EN_S17</incoming>
         <incoming>EN_S18</incoming>
         <outgoing>EN_S19</outgoing>
      </parallelGateway>
      <intermediateCatchEvent id="EN_Catch_Assist" name="Receive assistance and expert advice">
         <incoming>EN_S19</incoming>
         <outgoing>EN_S20</outgoing>
         <messageEventDefinition id="med_EN_Catch_Assist" />
      </intermediateCatchEvent>
      <intermediateCatchEvent id="EN_Catch_Op" name="Receive opinion from ECCG">
         <incoming>EN_S20</incoming>
         <outgoing>EN_S21</outgoing>
         <messageEventDefinition id="med_EN_Catch_Op" />
      </intermediateCatchEvent>
      <task id="EN_Tsk9" name="Take utmost account of the ECCG opinion">
         <incoming>EN_S21</incoming>
         <outgoing>EN_S22</outgoing>
      </task>
      <task id="EN_Tsk10" name="Transmit candidate scheme to Commission">
         <incoming>EN_S22</incoming>
         <outgoing>EN_S23</outgoing>
      </task>
      <task id="EN_Tsk11" name="Evaluate each adopted certification scheme">
         <incoming>EN_S23</incoming>
         <outgoing>EN_S24</outgoing>
      </task>
      <intermediateCatchEvent id="EN_Catch_Rev" name="Receive request for revision">
         <incoming>EN_S24</incoming>
         <outgoing>EN_S25</outgoing>
         <messageEventDefinition id="med_EN_Catch_Rev" />
      </intermediateCatchEvent>
      <task id="EN_Tsk12" name="Start developing a revised candidate scheme">
         <incoming>EN_S25</incoming>
         <outgoing>EN_S26</outgoing>
      </task>
      <endEvent id="EN_End" name="candidate scheme evaluation or revision end event">
         <incoming>EN_S26</incoming>
      </endEvent>

      <sequenceFlow id="EN_S1" isImmediate="true" name="" sourceRef="EN_Start" targetRef="EN_Tsk1" />
      <sequenceFlow id="EN_S2" isImmediate="true" name="" sourceRef="EN_Tsk1" targetRef="EN_GW1_Div" />
      <sequenceFlow id="EN_S3" isImmediate="true" name="Commission" sourceRef="EN_GW1_Div" targetRef="EN_Tsk2" />
      <sequenceFlow id="EN_S4" isImmediate="true" name="" sourceRef="EN_Tsk2" targetRef="EN_GW1_Conv" />
      <sequenceFlow id="EN_S5" isImmediate="true" name="ECCG" sourceRef="EN_GW1_Div" targetRef="EN_Tsk3" />
      <sequenceFlow id="EN_S6" isImmediate="true" name="" sourceRef="EN_Tsk3" targetRef="EN_Tsk4" />
      <sequenceFlow id="EN_S7" isImmediate="true" name="" sourceRef="EN_Tsk4" targetRef="EN_GW2_Div" />
      <sequenceFlow id="EN_S8" isImmediate="true" name="yes" sourceRef="EN_GW2_Div" targetRef="MB_Tsk1" />
      <sequenceFlow id="EN_S9" isImmediate="true" name="" sourceRef="MB_Tsk1" targetRef="EN_Tsk5" />
      <sequenceFlow id="EN_S10" isImmediate="true" name="" sourceRef="EN_Tsk5" targetRef="EN_End_Refused" />
      <sequenceFlow id="EN_S11" isImmediate="true" name="no" sourceRef="EN_GW2_Div" targetRef="EN_GW1_Conv" />
      <sequenceFlow id="EN_S12" isImmediate="true" name="" sourceRef="EN_GW1_Conv" targetRef="EN_GW3_Div" />
      <sequenceFlow id="EN_S13" isImmediate="true" name="" sourceRef="EN_GW3_Div" targetRef="EN_Tsk6" />
      <sequenceFlow id="EN_S14" isImmediate="true" name="" sourceRef="EN_GW3_Div" targetRef="EN_Tsk7" />
      <sequenceFlow id="EN_S15" isImmediate="true" name="" sourceRef="EN_GW3_Div" targetRef="EN_Tsk8" />
      <sequenceFlow id="EN_S16" isImmediate="true" name="" sourceRef="EN_Tsk6" targetRef="EN_GW3_Conv" />
      <sequenceFlow id="EN_S17" isImmediate="true" name="" sourceRef="EN_Tsk7" targetRef="EN_GW3_Conv" />
      <sequenceFlow id="EN_S18" isImmediate="true" name="" sourceRef="EN_Tsk8" targetRef="EN_GW3_Conv" />
