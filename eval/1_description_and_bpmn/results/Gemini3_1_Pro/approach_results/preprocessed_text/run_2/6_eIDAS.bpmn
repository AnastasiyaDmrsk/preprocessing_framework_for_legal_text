<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" 
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" 
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" 
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" 
             xmlns:signavio="http://www.signavio.com" 
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
             exporter="Signavio Process Editor, http://www.signavio.com" 
             exporterVersion="19.2.2" 
             expressionLanguage="http://www.w3.org/TR/XPath" 
             id="sid-trust-services" 
             targetNamespace="http://www.signavio.com" 
             typeLanguage="http://www.w3.org/2001/XMLSchema" 
             xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd">
   
   <collaboration id="collab_1">
      <participant id="P1" name="Member State" processRef="P1_process"/>
      <participant id="P2" name="Supervisory Body" processRef="P2_process"/>
      <participant id="P3" name="Another Supervisory Body" processRef="P3_process"/>
      <participant id="P4" name="Conformity Assessment Body" processRef="P4_process"/>
      <participant id="P5" name="Qualified or Non-qualified Trust Service Provider" processRef="P5_process"/>
      <participant id="P6" name="Commission" processRef="P6_process"/>
      
      <messageFlow id="MF1" sourceRef="P1_T3" targetRef="P6_START"/>
      <messageFlow id="MF2" sourceRef="P2_T17" targetRef="P6_START"/>
      <messageFlow id="MF3" sourceRef="P2_T_req_cab" targetRef="P4_START"/>
      <messageFlow id="MF4" sourceRef="P4_END" targetRef="P2"/>
      <messageFlow id="MF5" sourceRef="P3_T1" targetRef="P2_CATCH_REQ"/>
      <messageFlow id="MF6" sourceRef="P5_T5" targetRef="P2_CATCH_BREACH"/>
   </collaboration>

   <!-- Member State Process -->
   <process id="P1_process" isClosed="false" isExecutable="false" name="Member State" processType="None">
      <startEvent id="P1_START" name="Need to establish supervision">
         <extensionElements><signavio:signavioLabel align="center" ref="text_name" valign="middle" x="15.0" y="40.0"/></extensionElements>
         <outgoing>P1_F1</outgoing>
      </startEvent>
      <task id="P1_T1" name="Designate a supervisory body">
         <incoming>P1_F1</incoming>
         <outgoing>P1_F2</outgoing>
      </task>
      <task id="P1_T2" name="Give powers and resources">
         <incoming>P1_F2</incoming>
         <outgoing>P1_F3</outgoing>
      </task>
      <task id="P1_T3" name="Notify Commission">
         <incoming>P1_F3</incoming>
         <outgoing>P1_F4</outgoing>
      </task>
      <exclusiveGateway id="P1_GW1" name="Trust infrastructure required?" gatewayDirection="Diverging" isMarkerVisible="true">
         <extensionElements><signavio:signavioLabel align="center" ref="text_name" valign="middle" x="20.0" y="45.0"/></extensionElements>
         <incoming>P1_F4</incoming>
         <outgoing>P1_F5</outgoing>
         <outgoing>P1_F6</outgoing>
      </exclusiveGateway>
      <task id="P1_T4" name="Require trust infrastructure">
         <incoming>P1_F5</incoming>
         <outgoing>P1_F7</outgoing>
      </task>
      <exclusiveGateway id="P1_GW2" gatewayDirection="Converging" isMarkerVisible="true">
         <incoming>P1_F6</incoming>
         <incoming>P1_F7</incoming>
         <outgoing>P1_F8</outgoing>
      </exclusiveGateway>
      <exclusiveGateway id="P1_GW3" name="Authorise joint investigations?" gatewayDirection="Diverging" isMarkerVisible="true">
         <extensionElements><signavio:signavioLabel align="center" ref="text_name" valign="middle" x="20.0" y="45.0"/></extensionElements>
         <incoming>P1_F8</incoming>
         <outgoing>P1_F9</outgoing>
         <outgoing>P1_F13</outgoing>
      </exclusiveGateway>
      <task id="P1_T5" name="Authorise joint investigations">
         <incoming>P1_F9</incoming>
         <outgoing>P1_F10</outgoing>
      </task>
      <task id="P1_T6" name="Agree on arrangements">
         <incoming>P1_F10</incoming>
         <outgoing>P1_F11</outgoing>
      </task>
      <task id="P1_T7" name="Establish arrangements">
         <incoming>P1_F11</incoming>
         <outgoing>P1_F12</outgoing>
      </task>
      <exclusiveGateway id="P1_GW4" gatewayDirection="Converging" isMarkerVisible="true">
         <incoming>P1_F12</incoming>
         <incoming>P1_F13</incoming>
         <outgoing>P1_F14</outgoing>
      </exclusiveGateway>
      <endEvent id="P1_END" name="Completion of establishment">
         <extensionElements><signavio:signavioLabel align="center" ref="text_name" valign="middle" x="15.0" y="40.0"/></extensionElements>
         <incoming>P1_F14</incoming>
      </endEvent>

      <sequenceFlow id="P1_F1" isImmediate="true" sourceRef="P1_START" targetRef="P1_T1"/>
      <sequenceFlow id="P1_F2" isImmediate="true" sourceRef="P1_T1" targetRef="P1_T2"/>
      <sequenceFlow id="P1_F3" isImmediate="true" sourceRef="P1_T2" targetRef="P1_T3"/>
      <sequenceFlow id="P1_F4" isImmediate="true" sourceRef="P1_T3" targetRef="P1_GW1"/>
      <sequenceFlow id="P1_F5" name="yes" isImmediate="true" sourceRef="P1_GW1" targetRef="P1_T4"/>
      <sequenceFlow id="P1_F6" name="no" isImmediate="true" sourceRef="P1_GW1" targetRef="P1_GW2"/>
      <sequenceFlow id="P1_F7" isImmediate="true" sourceRef="P1_T4" targetRef="P1_GW2"/>
      <sequenceFlow id="P1_F8" isImmediate="true" sourceRef="P1_GW2" targetRef="P1_GW3"/>
      <sequenceFlow id="P1_F9" name="yes" isImmediate="true" sourceRef="P1_GW3" targetRef="P1_T5"/>
      <sequenceFlow id="P1_F10" isImmediate="true" sourceRef="P1_T5" targetRef="P1_T6"/>
      <sequenceFlow id="P1_F11" isImmediate="true" sourceRef="P1_T6" targetRef="P1_T7"/>
      <sequenceFlow id="P1_F12" isImmediate="true" sourceRef="P1_T7" targetRef="P1_GW4"/>
      <sequenceFlow id="P1_F13" name="no" isImmediate="true" sourceRef="P1_GW3" targetRef="P1_GW4"/>
      <sequenceFlow id="P1_F14" isImmediate="true" sourceRef="P1_GW4" targetRef="P1_END"/>
   </process>

   <!-- Supervisory Body Process -->
   <process id="P2_process" isClosed="false" isExecutable="false" name="Supervisory Body" processType="None">
      <startEvent id="P2_START" name="Designation by MS">
         <extensionElements><signavio:signavioLabel align="center" ref="text_name" valign="middle" x="15.0" y="40.0"/></extensionElements>
         <outgoing>P2_F1</outgoing>
      </startEvent>
      <parallelGateway id="P2_GW1" gatewayDirection="Diverging">
         <extensionElements><signavio:signavioLabel align="center" ref="text_name" valign="middle" x="20.0" y="45.0"/></extensionElements>
         <incoming>P2_F1</incoming>
         <outgoing>P2_F2</outgoing>
         <outgoing>P2_F3</outgoing>
      </parallelGateway>
      <task id="P2_T1" name="Supervise qualified providers"><incoming>P2_F2</incoming><outgoing>P2_F4</outgoing></task>
      <task id="P2_T2" name="Take action on non-qualified"><incoming>P2_F3</incoming><outgoing>P2_F5</outgoing></task>
      <parallelGateway id="P2_GW2" gatewayDirection="Converging">
         <incoming>P2_F4</incoming><incoming>P2_F5</incoming><outgoing>P2_F6</outgoing>
      </parallelGateway>
      <parallelGateway id="P2_GW3" gatewayDirection="Diverging">
         <extensionElements><signavio:signavioLabel align="center" ref="text_name" valign="middle" x="20.0" y="45.0"/></extensionElements>
         <incoming>P2_F6</incoming>
         <outgoing>P2_F7</outgoing> <outgoing>P2_F10</outgoing> <outgoing>P2_F12</outgoing> 
         <outgoing>P2_F14</outgoing> <outgoing>P2_F20</outgoing> <outgoing>P2_F23</outgoing> 
         <outgoing>P2_F26</outgoing> <outgoing>P2_F28</outgoing> <outgoing>P2_F30</outgoing>
      </parallelGateway>
      
      <!-- Path 1 -->
      <task id="P2_T3" name="Cooperate with bodies"><incoming>P2_F7</incoming><outgoing>P2_F8</outgoing></task>
      <task id="P2_T4" name="Provide assistance"><incoming>P2_F8</incoming><outgoing>P2_F9</outgoing></task>
      <!-- Path 2 -->
      <task id="P2_T5" name="Analyse conformity reports"><incoming>P2_F10</incoming><outgoing>P2_F11</outgoing></task>
      <!-- Path 3 -->
      <task id="P2_T6" name="Inform about breaches"><incoming>P2_F12</incoming><outgoing>P2_F13</outgoing></task>
      <!-- Path 4 -->
      <exclusiveGateway id="P2_GW_X1" name="Audit or Request CAB" gatewayDirection="Diverging" isMarkerVisible="true">
         <extensionElements><signavio:signavioLabel align="center" ref="text_name" valign="middle" x="20.0" y="45.0"/></extensionElements>
         <incoming>P2_F14</incoming>
         <outgoing>P2_F15</outgoing><outgoing>P2_F16</outgoing>
      </exclusiveGateway>
      <task id="P2_T_audit" name="Carry out audits"><incoming>P2_F15</incoming><outgoing>P2_F17</outgoing></task>
      <task id="P2_T_req_cab" name="Request CAB"><incoming>P2_F16</incoming><outgoing>P2_F18</outgoing></task>
      <exclusiveGateway id="P2_GW_X2" gatewayDirection="Converging" isMarkerVisible="true">
         <incoming>P2_F17</incoming><incoming>P2_F18</incoming><outgoing>P2_F19</outgoing>
      </exclusiveGateway>
      <!-- Path 5 -->
      <task id="P2_T7" name="Cooperate with DP"><incoming>P2_F20</incoming><outgoing>P2_F21</outgoing></task>
      <task id="P2_T8" name="Inform DP results"><incoming>P2_F21</incoming><outgoing>P2_F22</outgoing></task>
      <!-- Path 6 -->
      <task id="P2_T9" name="Grant qualified status"><incoming>P2_F23</incoming><outgoing>P2_F24</outgoing></task>
      <task id="P2_T10" name="Withdraw qualified status"><incoming>P2_F24</incoming><outgoing>P2_F25</outgoing></task>
      <!-- Path 7 -->
      <task id="P2_T11" name="Inform list body"><incoming>P2_F26</incoming><outgoing>P2_F27</outgoing></task>
      <!-- Path 8 -->
      <task id="P2_T12" name="Verify termination plans"><incoming>P2_F28</incoming><outgoing>P2_F29</outgoing></task>
      <!-- Path 9 -->
      <task id="P2_T13" name="Require remedy"><incoming>P2_F30</incoming><outgoing>P2_F31</outgoing></task>

      <parallelGateway id="P2_GW4" gatewayDirection="Converging">
         <incoming>P2_F9</incoming><incoming>P2_F11</incoming><incoming>P2_F13</incoming>
         <incoming>P2_F19</incoming><incoming>P2_F22</incoming><incoming>P2_F25</incoming>
         <incoming>P2_F27</incoming><incoming>P2_F29</incoming><incoming>P2_F31</incoming>
         <outgoing>P2_F32</outgoing>
      </parallelGateway>
      
      <task id="P2_T14" name="Establish infrastructure"><incoming>P2_F32</incoming><outgoing>P2_F33</outgoing></task>
      <task id="P2_T15" name="Maintain infrastructure"><incoming>P2_F33</incoming><outgoing>P2_F34</outgoing></task>
      <task id="P2_T16" name="Update infrastructure"><incoming>P2_F34</incoming><outgoing>P2_F35</outgoing></task>
      <task id="P2_T17" name="Submit report to Commission"><incoming>P2_F35</incoming><outgoing>P2_F36</outgoing></task>
      
      <intermediateCatchEvent id="P2_CATCH_REQ" name="Receive request">
         <extensionElements><signavio:signavioLabel align="center" ref="text_name" valign="middle" x="15.0" y="40.0"/></extensionElements>
         <incoming>P2_F36</incoming><outgoing>P2_F37</outgoing>
         <messageEventDefinition id="med_1"/>
      </intermediateCatchEvent>
      <exclusiveGateway id="P2_GW_R1" name="Refuse or Provide?" gatewayDirection="Diverging" isMarkerVisible="true">
         <extensionElements><signavio:signavioLabel align="center" ref="text_name" valign="middle" x="20.0" y="45.0"/></extensionElements>
         <incoming>P2_F37</incoming>
         <outgoing>P2_F38</outgoing><outgoing>P2_F39</outgoing>
      </exclusiveGateway>
      <task id="P2_T18" name="Refuse assistance"><incoming>P2_F38</incoming><outgoing>P2_F40</outgoing></task>
      <task id="P2_T19" name="Provide assistance"><incoming>P2_F39</incoming><outgoing>P2_F41</outgoing></task>
      <exclusiveGateway id="P2_GW_R2" gatewayDirection="Converging" isMarkerVisible="true">
         <incoming>P2_F40</incoming><incoming>P2_F41</incoming><outgoing>P2_F42</outgoing>
      </exclusiveGateway>
      <task id="P2_T20" name="Carry out joint investigations"><incoming>P2_F42</incoming><outgoing>P2_F43</outgoing></task>
      
      <intermediateCatchEvent id="P2_CATCH_BREACH" name="Receive breach notification">
         <extensionElements><signavio:signavioLabel align="center" ref="text_name" valign="middle" x="15.0" y="40.0"/></extensionElements>
         <incoming>P2_F43</incoming><outgoing>P2_F44</outgoing>
         <messageEventDefinition id="med_2"/>
      </intermediateCatchEvent>
      <exclusiveGateway id="P2_GW_B1" name="Concerns 2+ MS?" gatewayDirection="Diverging" isMarkerVisible="true">
         <extensionElements><signavio:signavioLabel align="center" ref="text_name" valign="middle" x="20.0" y="45.0"/></extensionElements>
         <incoming>P2_F44</incoming>
         <outgoing>P2_F45</outgoing><outgoing>P2_F46</outgoing>
      </exclusiveGateway>
      <task id="P2_T21" name="Inform other bodies"><incoming>P2_F45</incoming><outgoing>P2_F47</outgoing></task>
      <exclusiveGateway id="P2_GW_B2" gatewayDirection="Converging" isMarkerVisible="true">
         <incoming>P2_F46</incoming><incoming>P2_F47</incoming><outgoing>P2_F48</outgoing>
      </exclusiveGateway>
      
      <exclusiveGateway id="P2_GW_P1" name="In public interest?" gatewayDirection="Diverging" isMarkerVisible="true">
         <extensionElements><signavio:signavioLabel align="center" ref="text_name" valign="middle" x="20.0" y="45.0"/></extensionElements>
         <incoming>P2_F48</incoming>
         <outgoing>P2_F49</outgoing><outgoing>P2_F50</outgoing>
      </exclusiveGateway>
      <task id="P2_T22" name="Inform public"><incoming>P2_F49</incoming><outgoing>P2_F51</outgoing></task>
      <task id="P2_T23" name="Require TSP to inform"><incoming>P2_F51</incoming><outgoing>P2_F52</outgoing></task>
      <exclusiveGateway id="P2_GW_P2" gatewayDirection="Converging" isMarkerVisible="true">
         <incoming>P2_F50</incoming><incoming>P2_F52</incoming><outgoing>P2_F53</outgoing>
      </exclusiveGateway>
      <task id="P2_T24" name="Provide ENISA summary"><incoming>P2_F53</incoming><outgoing>P2_F54</outgoing></task>
      <endEvent id="P2_END" name="Completion of duties">
         <extensionElements><signavio:signavioLabel align="center" ref="text_name" valign="middle" x="15.0" y="40.0"/></extensionElements>
         <incoming>P2_F54</incoming>
      </endEvent>

      <sequenceFlow id="P2_F1" isImmediate="true" sourceRef="P2_START" targetRef="P2_GW1"/>
      <sequenceFlow id="P2_F2" isImmediate="true" sourceRef="P2_GW1" targetRef="P2_T1"/>
      <sequenceFlow id="P2_F3" isImmediate="true" sourceRef="P2_GW1" targetRef="P2_T2"/>
      <sequenceFlow id="P2_F4" isImmediate="true" sourceRef="P2_T1" targetRef="P2_GW2"/>
      <sequenceFlow id="P2_F5" isImmediate="true" sourceRef="P2_T2" targetRef="P2_GW2"/>
      <sequenceFlow id="P2_F6" isImmediate="true" sourceRef="P2_GW2" targetRef="P2_GW3"/>
      
      <sequenceFlow id="P2_F7" isImmediate="true" sourceRef="P2_GW3" targetRef="P2_T3"/>
      <sequenceFlow id="P2_F8" isImmediate="true" sourceRef="P2_T3" targetRef="P2_T4"/>
      <sequenceFlow id="P2_F9" isImmediate="true" sourceRef="P2_T4" targetRef="P2_GW4"/>
      <sequenceFlow id="P2_F10" isImmediate="true" sourceRef="P2_GW3" targetRef="P2_T5"/>
      <sequenceFlow id="P2_F11" isImmediate="true" sourceRef="P2_T5" targetRef="P2_GW4"/>
      <sequenceFlow id="P2_F12" isImmediate="true" sourceRef="P2_GW3" targetRef="P2_T6"/>
      <sequenceFlow id="P2_F13" isImmediate="true" sourceRef="P2_T6" targetRef="P2_GW4"/>
      
      <sequenceFlow id="P2_F14" isImmediate="true" sourceRef="P2_GW3" targetRef="P2_GW_X1"/>
      <sequenceFlow id="P2_F15" name="carry out audits" isImmediate="true" sourceRef="P2_GW_X1" targetRef="P2_T_audit"/>
      <sequenceFlow id="P2_F16" name="request conformity" isImmediate="true" sourceRef="P2_GW_X1" targetRef="P2_T_req_cab"/>
      <sequenceFlow id="P2_F17" isImmediate="true" sourceRef="P2_T_audit" targetRef="P2_GW_X2"/>
      <sequenceFlow id="P2_F18" isImmediate="true" sourceRef="P2_T_req_cab" targetRef="P2_GW_X2"/>
      <sequenceFlow id="P2_F19" isImmediate="true" sourceRef="P2_GW_X2" targetRef="P2_GW4"/>
      
      <sequenceFlow id="P2_F20" isImmediate="true" sourceRef="P2_GW3" targetRef="P2_T7"/>
      <sequenceFlow id="P2_F21" isImmediate="true" sourceRef="P2_T7" targetRef="P2_T8"/>
      <sequenceFlow id="P2_F22" isImmediate="true" sourceRef="P2_T8" targetRef="P2_GW4"/>
      
      <sequenceFlow id="P2_F23" isImmediate="true" sourceRef="P2_GW3" targetRef="P2_T9"/>
      <sequenceFlow id="P2_F24" isImmediate="true" sourceRef="P2_T9" targetRef="P2_T10"/>
      <sequenceFlow id="P2_F25" isImmediate="true" sourceRef="P2_T10" targetRef="P2_GW4"/>
      
      <sequenceFlow id="P2_F26" isImmediate="true" sourceRef="P2_GW3" targetRef="P2_T11"/>
      <sequenceFlow id="P2_F27" isImmediate="true" sourceRef="P2_T11" targetRef="P2_GW4"/>
      
      <sequenceFlow id="P2_F28" isImmediate="true" sourceRef="P2_GW3" targetRef="P2_T12"/>
      <sequenceFlow id="P2_F29" isImmediate="true" sourceRef="P2_T12" targetRef="P2_GW4"/>
      
      <sequenceFlow id="P2_F30" isImmediate="true" sourceRef="P2_GW3" targetRef="P2_T13"/>
      <sequenceFlow id="P2_F31" isImmediate="true" sourceRef="P2_T13" targetRef="P2_GW4"/>
      
      <sequenceFlow id="P2_F32" isImmediate="true" sourceRef="P2_GW4" targetRef="P2_T14"/>
      <sequenceFlow id="P2_F33" isImmediate="true" sourceRef="P2_T14" targetRef="P2_T15"/>
      <sequenceFlow id="P2_F34" isImmediate="true" sourceRef="P2_T15" targetRef="P2_T16"/>
      <sequenceFlow id="P2_F35" isImmediate="true" sourceRef="P2_T16" targetRef="P2_T17"/>
      <sequenceFlow id="P2_F36" isImmediate="true" sourceRef="P2_T17" targetRef="P2_CATCH_REQ"/>
      <sequenceFlow id="P2_F37" isImmediate="true" sourceRef="P2_CATCH_REQ" targetRef="P2_GW_R1"/>
      <sequenceFlow id="P2_F38" name="true" isImmediate="true" sourceRef="P2_GW_R1" targetRef="P2_T18"/>
      <sequenceFlow id="P2_F39" name="false" isImmediate="true" sourceRef="P2_GW_R1" targetRef="P2_T19"/>
      <sequenceFlow id="P2_F40" isImmediate="true" sourceRef="P2_T18" targetRef="P2_GW_R2"/>
      <sequenceFlow id="P2_F41" isImmediate="true" sourceRef="P2_T19" targetRef="P2_GW_R2"/>
      <sequenceFlow id="P2_F42" isImmediate="true" sourceRef="P2_GW_R2" targetRef="P2_T20"/>
      <sequenceFlow id="P2_F43" isImmediate="true" sourceRef="P2_T20" targetRef="P2_CATCH_BREACH"/>
      <sequenceFlow id="P2_F44" isImmediate="true" sourceRef="P2_CATCH_BREACH" targetRef="P2_GW_B1"/>
      <sequenceFlow id="P2_F45" name="true" isImmediate="true" sourceRef="P2_GW_B1" targetRef="P2_T21"/>
      <sequenceFlow id="P2_F46" name="false" isImmediate="true" sourceRef="P2_GW_B1" targetRef="P2_GW_B2"/>
      <sequenceFlow id="P2_F47" isImmediate="true" sourceRef="P2_T21" targetRef="P2_GW_B2"/>
      <sequenceFlow id="P2_F48" isImmediate="true" sourceRef="P2_GW_B2" targetRef="P2_GW_P1"/>
      <sequenceFlow id="P2_F49" name="yes" isImmediate="true" sourceRef="P2_GW_P1" targetRef="P2_T22"/>
      <sequenceFlow id="P2_F50" name="no" isImmediate="true" sourceRef="P2_GW_P1" targetRef="P2_GW_P2"/>
      <sequenceFlow id="P2_F51" isImmediate="true" sourceRef="P2_T22" targetRef="P2_T23"/>
      <sequenceFlow id="P2_F52" isImmediate="true" sourceRef="P2_T23" targetRef="P2_GW_P2"/>
      <sequenceFlow id="P2_F53" isImmediate="true" sourceRef="P2_GW_P2" targetRef="P2_T24"/>
      <sequenceFlow id="P2_F54" isImmediate="true" sourceRef="P2_T24" targetRef="P2_END"/>
   </process>

   <!-- Another Supervisory Body Process -->
   <process id="P3_process" isClosed="false" isExecutable="false" name="Another Supervisory Body" processType="None">
      <startEvent id="P3_START" name="Need for cooperation"><extensionElements><signavio:signavioLabel align="center" ref="text_name" valign="middle" x="15.0" y="40.0"/></extensionElements><outgoing>P3_F1</outgoing></startEvent>
      <task id="P3_T1" name="Request assistance"><incoming>P3_F1</incoming><outgoing>P3_F2</outgoing></task>
      <task id="P3_T2" name="Carry out joint investigations"><incoming>P3_F2</incoming><outgoing>P3_F3</outgoing></task>
      <endEvent id="P3_END" name="Completion of cooperation"><extensionElements><signavio:signavioLabel align="center" ref="text_name" valign="middle" x="15.0" y="40.0"/></extensionElements><incoming>P3_F3</incoming></endEvent>
      <sequenceFlow id="P3_F1" isImmediate="true" sourceRef="P3_START" targetRef="P3_T1"/>
      <sequenceFlow id="P3_F2" isImmediate="true" sourceRef="P3_T1" targetRef="P3_T2"/>
      <sequenceFlow id="P3_F3" isImmediate="true" sourceRef="P3_T2" targetRef="P3_END"/>
   </process>

   <!-- Conformity Assessment Body Process -->
   <process id="P4_process" isClosed="false" isExecutable="false" name="Conformity Assessment Body" processType="None">
      <startEvent id="P4_START" name="Receive request"><extensionElements><signavio:signavioLabel align="center" ref="text_name" valign="middle" x="15.0" y="40.0"/></extensionElements><outgoing>P4_F1</outgoing></startEvent>
      <task id="P4_T1" name="Perform conformity assessment"><incoming>P4_F1</incoming><outgoing>P4_F2</outgoing></task>
      <endEvent id="P4_END" name="Delivery of assessment"><extensionElements><signavio:signavioLabel align="center" ref="text_name" valign="middle" x="15.0" y="40.0"/></extensionElements><incoming>P4_F2</incoming></endEvent>
      <sequenceFlow id="P4_F1" isImmediate="true" sourceRef="P4_START" targetRef="P4_T1"/>
      <sequenceFlow id="P4_F2" isImmediate="true" sourceRef="P4_T1" targetRef="P4_END"/>
   </process>

   <!-- Trust Service Provider Process -->
   <process id="P5_process" isClosed="false" isExecutable="false" name="Trust Service Provider" processType="None">
      <startEvent id="P5_START" name="Provision of services"><extensionElements><signavio:signavioLabel align="center" ref="text_name" valign="middle" x="15.0" y="40.0"/></extensionElements><outgoing>P5_F1</outgoing></startEvent>
      <task id="P5_T1" name="Manage risks"><incoming>P5_F1</incoming><outgoing>P5_F2</outgoing></task>
      <task id="P5_T2" name="Prevent and minimise impact"><incoming>P5_F2</incoming><outgoing>P5_F3</outgoing></task>
      <task id="P5_T3" name="Inform stakeholders"><incoming>P5_F3</incoming><outgoing>P5_F4</outgoing></task>
      <task id="P5_T4" name="Remedy failures"><incoming>P5_F4</incoming><outgoing>P5_F5</outgoing></task>
      <task id="P5_T5" name="Notify supervisory body"><incoming>P5_F5</incoming><outgoing>P5_F6</outgoing></task>
      <task id="P5_T6" name="Notify person"><incoming>P5_F6</incoming><outgoing>P5_F7</outgoing></task>
      <task id="P5_T7" name="Inform public"><incoming>P5_F7</incoming><outgoing>P5_F8</outgoing></task>
      <endEvent id="P5_END" name="Continued operation"><extensionElements><signavio:signavioLabel align="center" ref="text_name" valign="middle" x="15.0" y="40.0"/></extensionElements><incoming>P5_F8</incoming></endEvent>
      <sequenceFlow id="P5_F1" isImmediate="true" sourceRef="P5_START" targetRef="P5_T1"/>
      <sequenceFlow id="P5_F2" isImmediate="true" sourceRef="P5_T1" targetRef="P5_T2"/>
      <sequenceFlow id="P5_F3" isImmediate="true" sourceRef="P5_T2" targetRef="P5_T3"/>
      <sequenceFlow id="P5_F4" isImmediate="true" sourceRef="P5_T3" targetRef="P5_T4"/>
      <sequenceFlow id="P5_F5" isImmediate="true" sourceRef="P5_T4" targetRef="P5_T5"/>
      <sequenceFlow id="P5_F6" isImmediate="true" sourceRef="P5_T5" targetRef="P5_T6"/>
      <sequenceFlow id="P5_F7" isImmediate="true" sourceRef="P5_T6" targetRef="P5_T7"/>
      <sequenceFlow id="P5_F8" isImmediate="true" sourceRef="P5_T7" targetRef="P5_END"/>
   </process>

   <!-- Commission Process -->
   <process id="P6_process" isClosed="false" isExecutable="false" name="Commission" processType="None">
      <startEvent id="P6_START" name="Receiving notifications"><extensionElements><signavio:signavioLabel align="center" ref="text_name" valign="middle" x="15.0" y="40.0"/></extensionElements><outgoing>P6_F1</outgoing></startEvent>
      <task id="P6_T1" name="Make report available"><incoming>P6_F1</incoming><outgoing>P6_F2</outgoing></task>
      <exclusiveGateway id="P6_GW1" name="Adjustments needed?" gatewayDirection="Diverging" isMarkerVisible="true">
         <extensionElements><signavio:signavioLabel align="center" ref="text_name" valign="middle" x="20.0" y="45.0"/></extensionElements>
         <incoming>P6_F2</incoming>
         <outgoing>P6_F3</outgoing><outgoing>P6_F4</outgoing>
      </exclusiveGateway>
      <task id="P6_T2" name="Define formats"><incoming>P6_F3</incoming><outgoing>P6_F5</outgoing></task>
      <exclusiveGateway id="P6_GW2" gatewayDirection="Converging" isMarkerVisible="true">
         <incoming>P6_F4</incoming><incoming>P6_F5</incoming><outgoing>P6_F6</outgoing>
      </exclusiveGateway>
      <task id="P6_T3" name="Adopt implementing acts"><incoming>P6_F6</incoming><outgoing>P6_F7</outgoing></task>
      <parallelGateway id="P6_GW3" gatewayDirection="Diverging">
         <extensionElements><signavio:signavioLabel align="center" ref="text_name" valign="middle" x="20.0" y="45.0"/></extensionElements>
         <incoming>P6_F7</incoming>
         <outgoing>P6_F8</outgoing><outgoing>P6_F9</outgoing>
      </parallelGateway>
      <task id="P6_T4" name="Specify measures"><incoming>P6_F8</incoming><outgoing>P6_F10</outgoing></task>
      <task id="P6_T5" name="Define formats procedures"><incoming>P6_F9</incoming><outgoing>P6_F11</outgoing></task>
      <parallelGateway id="P6_GW4" gatewayDirection="Converging">
         <incoming>P6_F10</incoming><incoming>P6_F11</incoming><outgoing>P6_F12</outgoing>
      </parallelGateway>
      <endEvent id="P6_END" name="Completion of tasks"><extensionElements><signavio:signavioLabel align="center" ref="text_name" valign="middle" x="15.0" y="40.0"/></extensionElements><incoming>P6_F12</incoming></endEvent>
      <sequenceFlow id="P6_F1" isImmediate="true" sourceRef="P6_START" targetRef="P6_T1"/>
      <sequenceFlow id="P6_F2" isImmediate="true" sourceRef="P6_T1" targetRef="P6_GW1"/>
      <sequenceFlow id="P6_F3" name="yes" isImmediate="true" sourceRef="P6_GW1" targetRef="P6_T2"/>
      <sequenceFlow id="P6_F4" name="no" isImmediate="true" sourceRef="P6_GW1" targetRef="P6_GW2"/>
      <sequenceFlow id="P6_F5" isImmediate="true" sourceRef="P6_T2" targetRef="P6_GW2"/>
      <sequenceFlow id="P6_F6" isImmediate="true" sourceRef="P6_GW2" targetRef="P6_T3"/>
      <sequenceFlow id="P6_F7" isImmediate="true" sourceRef="P6_T3" targetRef="P6_GW3"/>
      <sequenceFlow id="P6_F8" isImmediate="true" sourceRef="P6_GW3" targetRef="P6_T4"/>
      <sequenceFlow id="P6_F9" isImmediate="true" sourceRef="P6_GW3" targetRef="P6_T5"/>
      <sequenceFlow id="P6_F10" isImmediate="true" sourceRef="P6_T4" targetRef="P6_GW4"/>
      <sequenceFlow id="P6_F11" isImmediate="true" sourceRef="P6_T5" targetRef="P6_GW4"/>
      <sequenceFlow id="P6_F12" isImmediate="true" sourceRef="P6_GW4" targetRef="P6_END"/>
   </process>

