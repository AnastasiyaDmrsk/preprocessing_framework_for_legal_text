    <!-- PROCESS: COMMISSION -->
    <process id="proc_com" name="Commission" isExecutable="false" isClosed="false" processType="None">
        <startEvent id="com_start" name="Upon receiving the annual report">
            <extensionElements><signavio:signavioLabel ref="text_name" x="15" y="-15" align="center" valign="bottom"/></extensionElements>
            <outgoing>sf_com_1</outgoing>
            <messageEventDefinition id="med_com1"/>
        </startEvent>
        <task id="com_t1" name="make the annual report available to Member States"><incoming>sf_com_1</incoming><outgoing>sf_com_2</outgoing></task>

        <exclusiveGateway id="com_xgw1_div" name="adjustments needed?" gatewayDirection="Diverging" isMarkerVisible="true">
            <extensionElements><signavio:signavioLabel ref="text_name" x="20" y="-20" align="center" valign="bottom"/></extensionElements>
            <incoming>sf_com_2</incoming><outgoing>sf_com_xgw1_y</outgoing><outgoing>sf_com_xgw1_n</outgoing>
        </exclusiveGateway>
        <task id="com_t2" name="define the formats and procedures for the report"><incoming>sf_com_xgw1_y</incoming><outgoing>sf_com_xgw1_c</outgoing></task>
        <exclusiveGateway id="com_xgw1_conv" gatewayDirection="Converging" isMarkerVisible="true">
            <extensionElements><signavio:signavioLabel ref="text_name" x="20" y="-20" align="center" valign="bottom"/></extensionElements>
