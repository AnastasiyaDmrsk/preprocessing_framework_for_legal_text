<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" 
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" 
             xmlns:i18n="http://www.omg.org/spec/BPMN/non-normative/extensions/i18n/1.0" 
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" 
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" 
             xmlns:signavio="http://www.signavio.com" 
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
             exporter="Signavio Process Editor, http://www.signavio.com" 
             exporterVersion="19.2.2" 
             expressionLanguage="http://www.w3.org/TR/XPath" 
             id="sid-main-definitions" 
             targetNamespace="http://www.signavio.com" 
             typeLanguage="http://www.w3.org/2001/XMLSchema" 
             xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd">

    <collaboration id="collab_1">
        <participant id="pool_ms" name="Member State" processRef="proc_ms"/>
        <participant id="pool_asb" name="Another Supervisory Body" processRef="proc_asb"/>
        <participant id="pool_sb" name="Supervisory Body" processRef="proc_sb"/>
        <participant id="pool_cab" name="Conformity Assessment Body" processRef="proc_cab"/>
        <participant id="pool_tsp" name="Qualified Trust Service Provider or Non-qualified Trust Service Provider" processRef="proc_tsp"/>
        <participant id="pool_com" name="Commission" processRef="proc_com"/>

        <messageFlow id="mf_ms_to_com" sourceRef="ms_t3" targetRef="pool_com"/>
        <messageFlow id="mf_asb_to_sb" sourceRef="asb_t1" targetRef="sb_catch_req"/>
        <messageFlow id="mf_sb_to_com" sourceRef="sb_t7" targetRef="com_start"/>
        <messageFlow id="mf_sb_to_cab" sourceRef="sb_t9" targetRef="cab_start"/>
        <messageFlow id="mf_sb_to_tsp" sourceRef="sb_t16" targetRef="pool_tsp"/>
        <messageFlow id="mf_tsp_to_sb" sourceRef="tsp_t4" targetRef="pool_sb"/>
    </collaboration>

    <!-- PROCESS: MEMBER STATE -->
    <process id="proc_ms" name="Member State" isExecutable="false" isClosed="false" processType="None">
        <startEvent id="ms_start" name="regulatory obligation to establish a supervisory framework">
            <extensionElements><signavio:signavioLabel ref="text_name" x="15" y="-15" align="center" valign="bottom"/></extensionElements>
            <outgoing>sf_ms_1</outgoing>
        </startEvent>
        <task id="ms_t1" name="designate a supervisory body">
            <incoming>sf_ms_1</incoming><outgoing>sf_ms_2</outgoing>
        </task>
        <task id="ms_t2" name="give the necessary powers and adequate resources to a supervisory body">
            <incoming>sf_ms_2</incoming><outgoing>sf_ms_3</outgoing>
        </task>
        <task id="ms_t3" name="notify the names and the addresses of the supervisory bodies to the Commission">
            <incoming>sf_ms_3</incoming><outgoing>sf_ms_4</outgoing>
        </task>

        <exclusiveGateway id="ms_gw1_div" name="trust infrastructure is required?" gatewayDirection="Diverging" isMarkerVisible="true">
            <extensionElements><signavio:signavioLabel ref="text_name" x="20" y="-20" align="center" valign="bottom"/></extensionElements>
            <incoming>sf_ms_4</incoming>
            <outgoing>sf_ms_gw1_y</outgoing><outgoing>sf_ms_gw1_n</outgoing>
        </exclusiveGateway>
        <task id="ms_t4" name="require the supervisory body to establish, maintain and update a trust infrastructure">
            <incoming>sf_ms_gw1_y</incoming><outgoing>sf_ms_5</outgoing>
        </task>
        <exclusiveGateway id="ms_gw1_conv" gatewayDirection="Converging" isMarkerVisible="true">
            <extensionElements><signavio:signavioLabel ref="text_name" x="20" y="-20" align="center" valign="bottom"/></extensionElements>
            <incoming>sf_ms_5</incoming><incoming>sf_ms_gw1_n</incoming>
            <outgoing>sf_ms_6</outgoing>
        </exclusiveGateway>

        <exclusiveGateway id="ms_gw2_div" name="needed?" gatewayDirection="Diverging" isMarkerVisible="true">
            <extensionElements><signavio:signavioLabel ref="text_name" x="20" y="-20" align="center" valign="bottom"/></extensionElements>
            <incoming>sf_ms_6</incoming>
            <outgoing>sf_ms_gw2_y</outgoing><outgoing>sf_ms_gw2_n</outgoing>
        </exclusiveGateway>
        <task id="ms_t5" name="authorise their supervisory bodies to carry out joint investigations">
            <incoming>sf_ms_gw2_y</incoming><outgoing>sf_ms_7</outgoing>
        </task>
        <exclusiveGateway id="ms_gw2_conv" gatewayDirection="Converging" isMarkerVisible="true">
            <extensionElements><signavio:signavioLabel ref="text_name" x="20" y="-20" align="center" valign="bottom"/></extensionElements>
            <incoming>sf_ms_7</incoming><incoming>sf_ms_gw2_n</incoming>
            <outgoing>sf_ms_8</outgoing>
        </exclusiveGateway>

        <exclusiveGateway id="ms_gw3_div" name="Member States authorise their supervisory bodies to carry out joint investigations?" gatewayDirection="Diverging" isMarkerVisible="true">
            <extensionElements><signavio:signavioLabel ref="text_name" x="20" y="-20" align="center" valign="bottom"/></extensionElements>
            <incoming>sf_ms_8</incoming>
            <outgoing>sf_ms_gw3_y</outgoing><outgoing>sf_ms_gw3_n</outgoing>
        </exclusiveGateway>
        <task id="ms_t6" name="agree upon the arrangements and procedures for such joint actions">
            <incoming>sf_ms_gw3_y</incoming><outgoing>sf_ms_9</outgoing>
        </task>
        <task id="ms_t7" name="establish the arrangements and procedures for such joint actions">
            <incoming>sf_ms_9</incoming><outgoing>sf_ms_10</outgoing>
        </task>
        <exclusiveGateway id="ms_gw3_conv" gatewayDirection="Converging" isMarkerVisible="true">
            <extensionElements><signavio:signavioLabel ref="text_name" x="20" y="-20" align="center" valign="bottom"/></extensionElements>
            <incoming>sf_ms_10</incoming><incoming>sf_ms_gw3_n</incoming>
            <outgoing>sf_ms_11</outgoing>
        </exclusiveGateway>

        <endEvent id="ms_end" name="framework established end event">
            <extensionElements><signavio:signavioLabel ref="text_name" x="15" y="30" align="center" valign="top"/></extensionElements>
            <incoming>sf_ms_11</incoming>
        </endEvent>

        <sequenceFlow id="sf_ms_1" isImmediate="true" sourceRef="ms_start" targetRef="ms_t1"/>
        <sequenceFlow id="sf_ms_2" isImmediate="true" sourceRef="ms_t1" targetRef="ms_t2"/>
        <sequenceFlow id="sf_ms_3" isImmediate="true" sourceRef="ms_t2" targetRef="ms_t3"/>
        <sequenceFlow id="sf_ms_4" isImmediate="true" sourceRef="ms_t3" targetRef="ms_gw1_div"/>
        <sequenceFlow id="sf_ms_gw1_y" isImmediate="true" name="trust infrastructure is required" sourceRef="ms_gw1_div" targetRef="ms_t4"/>
        <sequenceFlow id="sf_ms_gw1_n" isImmediate="true" name="not required" sourceRef="ms_gw1_div" targetRef="ms_gw1_conv"/>
        <sequenceFlow id="sf_ms_5" isImmediate="true" sourceRef="ms_t4" targetRef="ms_gw1_conv"/>
        <sequenceFlow id="sf_ms_6" isImmediate="true" sourceRef="ms_gw1_conv" targetRef="ms_gw2_div"/>
        <sequenceFlow id="sf_ms_gw2_y" isImmediate="true" name="needed" sourceRef="ms_gw2_div" targetRef="ms_t5"/>
        <sequenceFlow id="sf_ms_gw2_n" isImmediate="true" name="not needed" sourceRef="ms_gw2_div" targetRef="ms_gw2_conv"/>
        <sequenceFlow id="sf_ms_7" isImmediate="true" sourceRef="ms_t5" targetRef="ms_gw2_conv"/>
        <sequenceFlow id="sf_ms_8" isImmediate="true" sourceRef="ms_gw2_conv" targetRef="ms_gw3_div"/>
        <sequenceFlow id="sf_ms_gw3_y" isImmediate="true" name="authorise" sourceRef="ms_gw3_div" targetRef="ms_t6"/>
        <sequenceFlow id="sf_ms_gw3_n" isImmediate="true" name="not authorise" sourceRef="ms_gw3_div" targetRef="ms_gw3_conv"/>
        <sequenceFlow id="sf_ms_9" isImmediate="true" sourceRef="ms_t6" targetRef="ms_t7"/>
        <sequenceFlow id="sf_ms_10" isImmediate="true" sourceRef="ms_t7" targetRef="ms_gw3_conv"/>
        <sequenceFlow id="sf_ms_11" isImmediate="true" sourceRef="ms_gw3_conv" targetRef="ms_end"/>
    </process>

    <!-- PROCESS: ANOTHER SUPERVISORY BODY -->
    <process id="proc_asb" name="Another Supervisory Body" isExecutable="false" isClosed="false" processType="None">
        <startEvent id="asb_start" name="Start">
            <extensionElements><signavio:signavioLabel ref="text_name" x="15" y="-15" align="center" valign="bottom"/></extensionElements>
            <outgoing>sf_asb_1</outgoing>
        </startEvent>
        <task id="asb_t1" name="request assistance from the Supervisory Body">
            <incoming>sf_asb_1</incoming><outgoing>sf_asb_2</outgoing>
        </task>
        <exclusiveGateway id="asb_gw1_div" name="authorised?" gatewayDirection="Diverging" isMarkerVisible="true">
            <extensionElements><signavio:signavioLabel ref="text_name" x="20" y="-20" align="center" valign="bottom"/></extensionElements>
            <incoming>sf_asb_2</incoming>
            <outgoing>sf_asb_gw1_y</outgoing><outgoing>sf_asb_gw1_n</outgoing>
        </exclusiveGateway>
        <task id="asb_t2" name="carry out joint investigations">
            <incoming>sf_asb_gw1_y</incoming><outgoing>sf_asb_3</outgoing>
        </task>
        <exclusiveGateway id="asb_gw1_conv" gatewayDirection="Converging" isMarkerVisible="true">
            <extensionElements><signavio:signavioLabel ref="text_name" x="20" y="-20" align="center" valign="bottom"/></extensionElements>
            <incoming>sf_asb_3</incoming><incoming>sf_asb_gw1_n</incoming>
            <outgoing>sf_asb_4</outgoing>
        </exclusiveGateway>
        <endEvent id="asb_end" name="assistance requested end event">
            <extensionElements><signavio:signavioLabel ref="text_name" x="15" y="30" align="center" valign="top"/></extensionElements>
            <incoming>sf_asb_4</incoming>
        </endEvent>

        <sequenceFlow id="sf_asb_1" isImmediate="true" sourceRef="asb_start" targetRef="asb_t1"/>
        <sequenceFlow id="sf_asb_2" isImmediate="true" sourceRef="asb_t1" targetRef="asb_gw1_div"/>
        <sequenceFlow id="sf_asb_gw1_y" isImmediate="true" name="authorised" sourceRef="asb_gw1_div" targetRef="asb_t2"/>
        <sequenceFlow id="sf_asb_gw1_n" isImmediate="true" name="not authorised" sourceRef="asb_gw1_div" targetRef="asb_gw1_conv"/>
        <sequenceFlow id="sf_asb_3" isImmediate="true" sourceRef="asb_t2" targetRef="asb_gw1_conv"/>
        <sequenceFlow id="sf_asb_4" isImmediate="true" sourceRef="asb_gw1_conv" targetRef="asb_end"/>
    </process>

    <!-- PROCESS: SUPERVISORY BODY -->
    <process id="proc_sb" name="Supervisory Body" isExecutable="false" isClosed="false" processType="None">
        <startEvent id="sb_start" name="Start">
            <extensionElements><signavio:signavioLabel ref="text_name" x="15" y="-15" align="center" valign="bottom"/></extensionElements>
            <outgoing>sf_sb_1</outgoing>
        </startEvent>
        
        <parallelGateway id="sb_pgw1_div" gatewayDirection="Diverging">
            <extensionElements><signavio:signavioLabel ref="text_name" x="20" y="-20" align="center" valign="bottom"/></extensionElements>
            <incoming>sf_sb_1</incoming>
            <outgoing>sf_sb_pgw1_1</outgoing><outgoing>sf_sb_pgw1_2</outgoing>
        </parallelGateway>
        
        <task id="sb_t1" name="supervise qualified trust service providers">
            <incoming>sf_sb_pgw1_1</incoming><outgoing>sf_sb_2</outgoing>
        </task>
        
        <exclusiveGateway id="sb_xgw1_div" name="informed that those do not meet the requirements?" gatewayDirection="Diverging" isMarkerVisible="true">
            <extensionElements><signavio:signavioLabel ref="text_name" x="20" y="-20" align="center" valign="bottom"/></extensionElements>
            <incoming>sf_sb_pgw1_2</incoming>
            <outgoing>sf_sb_xgw1_y</outgoing><outgoing>sf_sb_xgw1_n</outgoing>
        </exclusiveGateway>
        <task id="sb_t2" name="take action in relation to non-qualified trust service providers">
            <incoming>sf_sb_xgw1_y</incoming><outgoing>sf_sb_3</outgoing>
        </task>
        <exclusiveGateway id="sb_xgw1_conv" gatewayDirection="Converging" isMarkerVisible="true">
            <extensionElements><signavio:signavioLabel ref="text_name" x="20" y="-20" align="center" valign="bottom"/></extensionElements>
            <incoming>sf_sb_3</incoming><incoming>sf_sb_xgw1_n</incoming>
            <outgoing>sf_sb_4</outgoing>
        </exclusiveGateway>

        <parallelGateway id="sb_pgw1_conv" gatewayDirection="Converging">
            <extensionElements><signavio:signavioLabel ref="text_name" x="20" y="-20" align="center" valign="bottom"/></extensionElements>
            <incoming>sf_sb_2</incoming><incoming>sf_sb_4</incoming>
            <outgoing>sf_sb_5</outgoing>
        </parallelGateway>

        <parallelGateway id="sb_pgw2_div" gatewayDirection="Diverging">
            <extensionElements><signavio:signavioLabel ref="text_name" x="20" y="-20" align="center" valign="bottom"/></extensionElements>
            <incoming>sf_sb_5</incoming>
            <outgoing>sf_sb_p1</outgoing><outgoing>sf_sb_p2</outgoing><outgoing>sf_sb_p3</outgoing><outgoing>sf_sb_p4</outgoing>
            <outgoing>sf_sb_p5</outgoing><outgoing>sf_sb_p6</outgoing><outgoing>sf_sb_p7</outgoing><outgoing>sf_sb_p8</outgoing>
            <outgoing>sf_sb_p9</outgoing><outgoing>sf_sb_p10</outgoing><outgoing>sf_sb_p11</outgoing><outgoing>sf_sb_p12</outgoing>
            <outgoing>sf_sb_p13</outgoing><outgoing>sf_sb_p14</outgoing>
        </parallelGateway>

        <task id="sb_t3" name="cooperate with other supervisory bodies"><incoming>sf_sb_p1</incoming><outgoing>sf_sb_c1</outgoing></task>
        <task id="sb_t4" name="provide other supervisory bodies with assistance"><incoming>sf_sb_p2</incoming><outgoing>sf_sb_c2</outgoing></task>
        <task id="sb_t5" name="analyse the conformity assessment reports"><incoming>sf_sb_p3</incoming><outgoing>sf_sb_c3</outgoing></task>
        <task id="sb_t6" name="inform other supervisory bodies and the public about breaches of security"><incoming>sf_sb_p4</incoming><outgoing>sf_sb_c4</outgoing></task>
        <task id="sb_t7" name="submit to the Commission a report on its previous year's main activities"><incoming>sf_sb_p5</incoming><outgoing>sf_sb_c5</outgoing></task>
        <task id="sb_t8" name="carry out audits"><incoming>sf_sb_p6</incoming><outgoing>sf_sb_c6</outgoing></task>
        <task id="sb_t9" name="request a conformity assessment body to perform a conformity assessment"><incoming>sf_sb_p7</incoming><outgoing>sf_sb_c7</outgoing></task>
        <task id="sb_t10" name="cooperate with the data protection authorities"><incoming>sf_sb_p8</incoming><outgoing>sf_sb_c8</outgoing></task>

        <exclusiveGateway id="sb_xgw2_div" name="personal data protection rules have been breached?" gatewayDirection="Diverging" isMarkerVisible="true">
            <extensionElements><signavio:signavioLabel ref="text_name" x="20" y="-20" align="center" valign="bottom"/></extensionElements>
            <incoming>sf_sb_p9</incoming><outgoing>sf_sb_xgw2_y</outgoing><outgoing>sf_sb_xgw2_n</outgoing>
        </exclusiveGateway>
        <task id="sb_t11" name="inform the data protection authorities about the results"><incoming>sf_sb_xgw2_y</incoming><outgoing>sf_sb_xgw2_c</outgoing></task>
        <exclusiveGateway id="sb_xgw2_conv" gatewayDirection="Converging" isMarkerVisible="true">
            <extensionElements><signavio:signavioLabel ref="text_name" x="20" y="-20" align="center" valign="bottom"/></extensionElements>
            <incoming>sf_sb_xgw2_c</incoming><incoming>sf_sb_xgw2_n</incoming><outgoing>sf_sb_c9</outgoing>
        </exclusiveGateway>

        <task id="sb_t12" name="grant qualified status to trust service providers"><incoming>sf_sb_p10</incoming><outgoing>sf_sb_c10</outgoing></task>
        <task id="sb_t13" name="withdraw qualified status from trust service providers"><incoming>sf_sb_p11</incoming><outgoing>sf_sb_c11</outgoing></task>
        <task id="sb_t14" name="inform the body responsible for the national trusted list about the status change"><incoming>sf_sb_p12</incoming><outgoing>sf_sb_c12</outgoing></task>

        <exclusiveGateway id="sb_xgw3_div" name="in cases where the qualified trust service provider ceases its activities?" gatewayDirection="Diverging" isMarkerVisible="true">
            <extensionElements><signavio:signavioLabel ref="text_name" x="20" y="-20" align="center" valign="bottom"/></extensionElements>
            <incoming>sf_sb_p13</incoming><outgoing>sf_sb_xgw3_y</outgoing><outgoing>sf_sb_xgw3_n</outgoing>
        </exclusiveGateway>
        <task id="sb_t15" name="verify the existence and correct application of provisions on termination plans"><incoming>sf_sb_xgw3_y</incoming><outgoing>sf_sb_xgw3_c</outgoing></task>
        <exclusiveGateway id="sb_xgw3_conv" gatewayDirection="Converging" isMarkerVisible="true">
            <extensionElements><signavio:signavioLabel ref="text_name" x="20" y="-20" align="center" valign="bottom"/></extensionElements>
            <incoming>sf_sb_xgw3_c</incoming><incoming>sf_sb_xgw3_n</incoming><outgoing>sf_sb_c13</outgoing>
        </exclusiveGateway>

        <task id="sb_t16" name="require that trust service providers remedy any failure to fulfil the requirements"><incoming>sf_sb_p14</incoming><outgoing>sf_sb_c14</outgoing></task>

        <parallelGateway id="sb_pgw2_conv" gatewayDirection="Converging">
            <extensionElements><signavio:signavioLabel ref="text_name" x="20" y="-20" align="center" valign="bottom"/></extensionElements>
            <incoming>sf_sb_c1</incoming><incoming>sf_sb_c2</incoming><incoming>sf_sb_c3</incoming><incoming>sf_sb_c4</incoming>
            <incoming>sf_sb_c5</incoming><incoming>sf_sb_c6</incoming><incoming>sf_sb_c7</incoming><incoming>sf_sb_c8</incoming>
            <incoming>sf_sb_c9</incoming><incoming>sf_sb_c10</incoming><incoming>sf_sb_c11</incoming><incoming>sf_sb_c12</incoming>
            <incoming>sf_sb_c13</incoming><incoming>sf_sb_c14</incoming>
            <outgoing>sf_sb_post14</outgoing>
        </parallelGateway>

        <exclusiveGateway id="sb_xgw4_div" name="required by Member State?" gatewayDirection="Diverging" isMarkerVisible="true">
            <extensionElements><signavio:signavioLabel ref="text_name" x="20" y="-20" align="center" valign="bottom"/></extensionElements>
            <incoming>sf_sb_post14</incoming>
            <outgoing>sf_sb_xgw4_y</outgoing><outgoing>sf_sb_xgw4_n</outgoing>
        </exclusiveGateway>
        <task id="sb_t17" name="establish a trust infrastructure"><incoming>sf_sb_xgw4_y</incoming><outgoing>sf_sb_17</outgoing></task>
        <task id="sb_t18" name="maintain a trust infrastructure"><incoming>sf_sb_17</incoming><outgoing>sf_sb_18</outgoing></task>
        <task id="sb_t19" name="update a trust infrastructure"><incoming>sf_sb_18</incoming><outgoing>sf_sb_19</outgoing></task>
        <exclusiveGateway id="sb_xgw4_conv" gatewayDirection="Converging" isMarkerVisible="true">
            <extensionElements><signavio:signavioLabel ref="text_name" x="20" y="-20" align="center" valign="bottom"/></extensionElements>
            <incoming>sf_sb_19</incoming><incoming>sf_sb_xgw4_n</incoming>
            <outgoing>sf_sb_to_catch</outgoing>
        </exclusiveGateway>

        <intermediateCatchEvent id="sb_catch_req" name="Upon receipt of a justified request from another supervisory body">
            <extensionElements><signavio:signavioLabel ref="text_name" x="20" y="-20" align="center" valign="bottom"/></extensionElements>
            <incoming>sf_sb_to_catch</incoming><outgoing>sf_sb_catch1</outgoing>
            <messageEventDefinition id="med_sb1"/>
        </intermediateCatchEvent>

        <task id="sb_t20" name="provide assistance"><incoming>sf_sb_catch1</incoming><outgoing>sf_sb_catch_out</outgoing></task>

        <parallelGateway id="sb_pgw3_div" gatewayDirection="Diverging">
            <extensionElements><signavio:signavioLabel ref="text_name" x="20" y="-20" align="center" valign="bottom"/></extensionElements>
            <incoming>sf_sb_catch_out</incoming>
            <outgoing>sf_sb_p15</outgoing><outgoing>sf_sb_p16</outgoing><outgoing>sf_sb_p17</outgoing>
        </parallelGateway>

        <exclusiveGateway id="sb_xgw5_div" name="not competent?" gatewayDirection="Diverging" isMarkerVisible="true"><incoming>sf_sb_p15</incoming><outgoing>sf_sb_xgw5_y</outgoing><outgoing>sf_sb_xgw5_n</outgoing></exclusiveGateway>
        <task id="sb_t21" name="refuse assistance (not competent)"><incoming>sf_sb_xgw5_y</incoming><outgoing>sf_sb_xgw5_c</outgoing></task>
        <exclusiveGateway id="sb_xgw5_conv" gatewayDirection="Converging" isMarkerVisible="true"><incoming>sf_sb_xgw5_c</incoming><incoming>sf_sb_xgw5_n</incoming><outgoing>sf_sb_c15</outgoing></exclusiveGateway>

        <exclusiveGateway id="sb_xgw6_div" name="not proportionate?" gatewayDirection="Diverging" isMarkerVisible="true"><incoming>sf_sb_p16</incoming><outgoing>sf_sb_xgw6_y</outgoing><outgoing>sf_sb_xgw6_n</outgoing></exclusiveGateway>
        <task id="sb_t22" name="refuse assistance (not proportionate)"><incoming>sf_sb_xgw6_y</incoming><outgoing>sf_sb_xgw6_c</outgoing></task>
        <exclusiveGateway id="sb_xgw6_conv" gatewayDirection="Converging" isMarkerVisible="true"><incoming>sf_sb_xgw6_c</incoming><incoming>sf_sb_xgw6_n</incoming><outgoing>sf_sb_c16</outgoing></exclusiveGateway>

        <exclusiveGateway id="sb_xgw7_div" name="incompatible?" gatewayDirection="Diverging" isMarkerVisible="true"><incoming>sf_sb_p17</incoming><outgoing>sf_sb_xgw7_y</outgoing><outgoing>sf_sb_xgw7_n</outgoing></exclusiveGateway>
        <task id="sb_t23" name="refuse assistance (incompatible)"><incoming>sf_sb_xgw7_y</incoming><outgoing>sf_sb_xgw7_c</outgoing></task>
        <exclusiveGateway id="sb_xgw7_conv" gatewayDirection="Converging" isMarkerVisible="true"><incoming>sf_sb_xgw7_c</incoming><incoming>sf_sb_xgw7_n</incoming><outgoing>sf_sb_c17</outgoing></exclusiveGateway>

        <parallelGateway id="sb_pgw3_conv" gatewayDirection="Converging">
            <extensionElements><signavio:signavioLabel ref="text_name" x="20" y="-20" align="center" valign="bottom"/></extensionElements>
            <incoming>sf_sb_c15</incoming><incoming>sf_sb_c16</incoming><incoming>sf_sb_c17</incoming><outgoing>sf_sb_post_p3</outgoing>
        </parallelGateway>

        <exclusiveGateway id="sb_xgw8_div" name="authorised?" gatewayDirection="Diverging" isMarkerVisible="true">
            <extensionElements><signavio:signavioLabel ref="text_name" x="20" y="-20" align="center" valign="bottom"/></extensionElements>
            <incoming>sf_sb_post_p3</incoming><outgoing>sf_sb_xgw8_y</outgoing><outgoing>sf_sb_xgw8_n</outgoing>
        </exclusiveGateway>
