        </exclusiveGateway>

        <task id="com_t3" name="adopt those implementing acts"><incoming>sf_com_3</incoming><outgoing>sf_com_4</outgoing></task>

        <exclusiveGateway id="com_xgw2_div" name="specification is required?" gatewayDirection="Diverging" isMarkerVisible="true">
            <extensionElements><signavio:signavioLabel ref="text_name" x="20" y="-20" align="center" valign="bottom"/></extensionElements>
            <incoming>sf_com_4</incoming><outgoing>sf_com_xgw2_y</outgoing><outgoing>sf_com_xgw2_n</outgoing>
        </exclusiveGateway>

        <parallelGateway id="com_pgw_div" gatewayDirection="Diverging">
            <extensionElements><signavio:signavioLabel ref="text_name" x="20" y="-20" align="center" valign="bottom"/></extensionElements>
