            <incoming>sf_tsp_6</incoming><outgoing>sf_tsp_xgw3_y</outgoing><outgoing>sf_tsp_xgw3_n</outgoing>
        </exclusiveGateway>
        <task id="tsp_t7" name="inform the public about the breach of security"><incoming>sf_tsp_xgw3_y</incoming><outgoing>sf_tsp_xgw3_c</outgoing></task>
