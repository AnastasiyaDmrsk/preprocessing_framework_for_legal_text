    <!-- PROCESS: CONFORMITY ASSESSMENT BODY -->
    <process id="proc_cab" name="Conformity Assessment Body" isExecutable="false" isClosed="false" processType="None">
        <startEvent id="cab_start" name="Upon request">
            <extensionElements><signavio:signavioLabel ref="text_name" x="15" y="-15" align="center" valign="bottom"/></extensionElements>
            <outgoing>sf_cab_1</outgoing>
            <messageEventDefinition id="med_cab1"/>
        </startEvent>
        <task id="cab_t1" name="perform a conformity assessment of the qualified trust service providers">
            <incoming>sf_cab_1</incoming><outgoing>sf_cab_2</outgoing>
        </task>
        <endEvent id="cab_end" name="assessment completed end event">
            <extensionElements><signavio:signavioLabel ref="text_name" x="15" y="30" align="center" valign="top"/></extensionElements>
            <incoming>sf_cab_2</incoming>
        </endEvent>

        <sequenceFlow id="sf_cab_1" isImmediate="true" sourceRef="cab_start" targetRef="cab_t1"/>
        <sequenceFlow id="sf_cab_2" isImmediate="true" sourceRef="cab_t1" targetRef="cab_end"/>
    </process>

    <!-- PROCESS: TSP -->
    <process id="proc_tsp" name="Qualified Trust Service Provider or Non-qualified Trust Service Provider" isExecutable="false" isClosed="false" processType="None">
        <startEvent id="tsp_start" name="Start">
            <extensionElements><signavio:signavioLabel ref="text_name" x="15" y="-15" align="center" valign="bottom"/></extensionElements>
            <outgoing>sf_tsp_1</outgoing>
        </startEvent>
        <task id="tsp_t1" name="take appropriate technical and organisational measures"><incoming>sf_tsp_1</incoming><outgoing>sf_tsp_2</outgoing></task>
        <task id="tsp_t2" name="take measures to prevent and minimise the impact"><incoming>sf_tsp_2</incoming><outgoing>sf_tsp_3</outgoing></task>
        <task id="tsp_t3" name="inform stakeholders of the adverse effects"><incoming>sf_tsp_3</incoming><outgoing>sf_tsp_4</outgoing></task>

        <exclusiveGateway id="tsp_xgw1_div" name="significant impact?" gatewayDirection="Diverging" isMarkerVisible="true">
