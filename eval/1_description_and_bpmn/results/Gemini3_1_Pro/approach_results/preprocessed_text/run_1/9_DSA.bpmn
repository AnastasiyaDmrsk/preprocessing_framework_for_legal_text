<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" 
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" 
             xmlns:i18n="http://www.omg.org/spec/BPMN/non-normative/extensions/i18n/1.0" 
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" 
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" 
             xmlns:signavio="http://www.signavio.com" 
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
             exporter="Signavio Process Editor, http://www.signavio.com" 
             exporterVersion="19.2.2" 
             expressionLanguage="http://www.w3.org/TR/XPath" 
             id="sid-process-definitions" 
             targetNamespace="http://www.signavio.com" 
             typeLanguage="http://www.w3.org/2001/XMLSchema" 
             xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd">
   <collaboration id="sid-collaboration-main">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="revisionid" metaValue="1"/>
      </extensionElements>
      <participant id="sid-participant-opp" name="Online Platform Provider" processRef="sid-process-opp">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffff"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
      </participant>
      <participant id="sid-participant-dsc" name="Digital Services Coordinator" processRef="sid-process-dsc">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffff"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
      </participant>
      <participant id="sid-participant-tf" name="Trusted Flagger" processRef="sid-process-tf">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffff"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
      </participant>
      <participant id="sid-participant-c" name="Commission" processRef="sid-process-c">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffff"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
      </participant>
      <participant id="sid-participant-b" name="Board" processRef="sid-process-b">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffff"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
      </participant>
      
      <messageFlow id="mf-1" name="" sourceRef="sid-task-opp-5" targetRef="sid-catch-dsc-1">
         <extensionElements><signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/></extensionElements>
      </messageFlow>
      <messageFlow id="mf-2" name="" sourceRef="sid-task-dsc-2" targetRef="sid-catch-c-1">
         <extensionElements><signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/></extensionElements>
      </messageFlow>
      <messageFlow id="mf-3" name="" sourceRef="sid-task-dsc-2" targetRef="sid-catch-b-1">
         <extensionElements><signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/></extensionElements>
      </messageFlow>
      <messageFlow id="mf-4" name="" sourceRef="sid-task-dsc-5" targetRef="sid-catch-tf-1">
         <extensionElements><signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/></extensionElements>
      </messageFlow>
      <messageFlow id="mf-5" name="" sourceRef="sid-task-tf-2" targetRef="sid-participant-dsc">
         <extensionElements><signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/></extensionElements>
      </messageFlow>
   </collaboration>
   
   <process id="sid-process-opp" isClosed="false" isExecutable="false" name="Online Platform Provider" processType="None">
      <laneSet id="sid-laneset-opp">
         <lane id="sid-lane-opp">
            <extensionElements>
               <signavio:signavioMetaData metaKey="bgcolor" metaValue=""/>
               <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            </extensionElements>
            <flowNodeRef>sid-start-opp</flowNodeRef>
            <flowNodeRef>sid-task-opp-1</flowNodeRef>
            <flowNodeRef>sid-xor-opp-1-div</flowNodeRef>
            <flowNodeRef>sid-and-opp-1-div</flowNodeRef>
            <flowNodeRef>sid-task-opp-2</flowNodeRef>
            <flowNodeRef>sid-task-opp-3</flowNodeRef>
            <flowNodeRef>sid-task-opp-4</flowNodeRef>
            <flowNodeRef>sid-and-opp-1-conv</flowNodeRef>
            <flowNodeRef>sid-xor-opp-1-conv</flowNodeRef>
            <flowNodeRef>sid-xor-opp-2-div</flowNodeRef>
            <flowNodeRef>sid-task-opp-5</flowNodeRef>
            <flowNodeRef>sid-xor-opp-2-conv</flowNodeRef>
            <flowNodeRef>sid-end-opp</flowNodeRef>
         </lane>
      </laneSet>
      <startEvent id="sid-start-opp" name="Start">
         <outgoing>sf-opp-start</outgoing>
      </startEvent>
      <task id="sid-task-opp-1" name="take the necessary technical and organisational measures for notices">
         <incoming>sf-opp-start</incoming>
         <outgoing>sf-opp-t1</outgoing>
      </task>
      <exclusiveGateway id="sid-xor-opp-1-div" name="assess whether notices submitted within their designated area of expertise and notices submitted through the mechanisms referred to in Article 16" gatewayDirection="Diverging" isMarkerVisible="true">
         <incoming>sf-opp-t1</incoming>
         <outgoing>sf-opp-x1-y</outgoing>
         <outgoing>sf-opp-x1-n</outgoing>
      </exclusiveGateway>
      <parallelGateway id="sid-and-opp-1-div" gatewayDirection="Diverging">
         <incoming>sf-opp-x1-y</incoming>
         <outgoing>sf-opp-a1-1</outgoing>
         <outgoing>sf-opp-a1-2</outgoing>
         <outgoing>sf-opp-a1-3</outgoing>
      </parallelGateway>
      <task id="sid-task-opp-2" name="give priority for notices">
         <incoming>sf-opp-a1-1</incoming>
         <outgoing>sf-opp-t2-a</outgoing>
      </task>
      <task id="sid-task-opp-3" name="process notices">
         <incoming>sf-opp-a1-2</incoming>
         <outgoing>sf-opp-t3-a</outgoing>
      </task>
      <task id="sid-task-opp-4" name="decide upon notices">
         <incoming>sf-opp-a1-3</incoming>
         <outgoing>sf-opp-t4-a</outgoing>
      </task>
      <parallelGateway id="sid-and-opp-1-conv" gatewayDirection="Converging">
         <incoming>sf-opp-t2-a</incoming>
         <incoming>sf-opp-t3-a</incoming>
         <incoming>sf-opp-t4-a</incoming>
         <outgoing>sf-opp-a-c</outgoing>
      </parallelGateway>
      <exclusiveGateway id="sid-xor-opp-1-conv" gatewayDirection="Converging" isMarkerVisible="true">
         <incoming>sf-opp-a-c</incoming>
         <incoming>sf-opp-x1-n</incoming>
         <outgoing>sf-opp-xc1</outgoing>
      </exclusiveGateway>
      <exclusiveGateway id="sid-xor-opp-2-div" name="assess whether a trusted flagger has submitted insufficiently precise, inaccurate or inadequately substantiated notices" gatewayDirection="Diverging" isMarkerVisible="true">
         <incoming>sf-opp-xc1</incoming>
         <outgoing>sf-opp-x2-y</outgoing>
         <outgoing>sf-opp-x2-n</outgoing>
      </exclusiveGateway>
      <task id="sid-task-opp-5" name="communicate information to the Digital Services Coordinator">
         <incoming>sf-opp-x2-y</incoming>
         <outgoing>sf-opp-t5-xc</outgoing>
      </task>
      <exclusiveGateway id="sid-xor-opp-2-conv" gatewayDirection="Converging" isMarkerVisible="true">
         <incoming>sf-opp-t5-xc</incoming>
         <incoming>sf-opp-x2-n</incoming>
         <outgoing>sf-opp-xc2</outgoing>
      </exclusiveGateway>
      <endEvent id="sid-end-opp" name="End">
         <incoming>sf-opp-xc2</incoming>
      </endEvent>
      <sequenceFlow id="sf-opp-start" name="" sourceRef="sid-start-opp" targetRef="sid-task-opp-1" isImmediate="true"/>
      <sequenceFlow id="sf-opp-t1" name="" sourceRef="sid-task-opp-1" targetRef="sid-xor-opp-1-div" isImmediate="true"/>
      <sequenceFlow id="sf-opp-x1-y" name="yes" sourceRef="sid-xor-opp-1-div" targetRef="sid-and-opp-1-div" isImmediate="true"/>
      <sequenceFlow id="sf-opp-x1-n" name="no" sourceRef="sid-xor-opp-1-div" targetRef="sid-xor-opp-1-conv" isImmediate="true"/>
      <sequenceFlow id="sf-opp-a1-1" name="" sourceRef="sid-and-opp-1-div" targetRef="sid-task-opp-2" isImmediate="true"/>
      <sequenceFlow id="sf-opp-a1-2" name="" sourceRef="sid-and-opp-1-div" targetRef="sid-task-opp-3" isImmediate="true"/>
      <sequenceFlow id="sf-opp-a1-3" name="" sourceRef="sid-and-opp-1-div" targetRef="sid-task-opp-4" isImmediate="true"/>
      <sequenceFlow id="sf-opp-t2-a" name="" sourceRef="sid-task-opp-2" targetRef="sid-and-opp-1-conv" isImmediate="true"/>
      <sequenceFlow id="sf-opp-t3-a" name="" sourceRef="sid-task-opp-3" targetRef="sid-and-opp-1-conv" isImmediate="true"/>
      <sequenceFlow id="sf-opp-t4-a" name="" sourceRef="sid-task-opp-4" targetRef="sid-and-opp-1-conv" isImmediate="true"/>
      <sequenceFlow id="sf-opp-a-c" name="" sourceRef="sid-and-opp-1-conv" targetRef="sid-xor-opp-1-conv" isImmediate="true"/>
      <sequenceFlow id="sf-opp-xc1" name="" sourceRef="sid-xor-opp-1-conv" targetRef="sid-xor-opp-2-div" isImmediate="true"/>
      <sequenceFlow id="sf-opp-x2-y" name="yes" sourceRef="sid-xor-opp-2-div" targetRef="sid-task-opp-5" isImmediate="true"/>
      <sequenceFlow id="sf-opp-x2-n" name="no" sourceRef="sid-xor-opp-2-div" targetRef="sid-xor-opp-2-conv" isImmediate="true"/>
      <sequenceFlow id="sf-opp-t5-xc" name="" sourceRef="sid-task-opp-5" targetRef="sid-xor-opp-2-conv" isImmediate="true"/>
      <sequenceFlow id="sf-opp-xc2" name="" sourceRef="sid-xor-opp-2-conv" targetRef="sid-end-opp" isImmediate="true"/>
   </process>

   <process id="sid-process-dsc" isClosed="false" isExecutable="false" name="Digital Services Coordinator" processType="None">
      <laneSet id="sid-laneset-dsc">
         <lane id="sid-lane-dsc">
            <extensionElements>
               <signavio:signavioMetaData metaKey="bgcolor" metaValue=""/>
               <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            </extensionElements>
            <flowNodeRef>sid-start-dsc</flowNodeRef>
            <flowNodeRef>sid-xor-dsc-1-div</flowNodeRef>
            <flowNodeRef>sid-task-dsc-1</flowNodeRef>
            <flowNodeRef>sid-xor-dsc-1-conv</flowNodeRef>
            <flowNodeRef>sid-xor-dsc-2-div</flowNodeRef>
            <flowNodeRef>sid-task-dsc-2</flowNodeRef>
            <flowNodeRef>sid-xor-dsc-2-conv</flowNodeRef>
            <flowNodeRef>sid-catch-dsc-1</flowNodeRef>
            <flowNodeRef>sid-xor-dsc-3-div</flowNodeRef>
            <flowNodeRef>sid-task-dsc-3</flowNodeRef>
            <flowNodeRef>sid-task-dsc-4</flowNodeRef>
            <flowNodeRef>sid-xor-dsc-3-conv</flowNodeRef>
            <flowNodeRef>sid-xor-dsc-4-div</flowNodeRef>
            <flowNodeRef>sid-task-dsc-5</flowNodeRef>
            <flowNodeRef>sid-xor-dsc-4-conv</flowNodeRef>
            <flowNodeRef>sid-xor-dsc-5-div</flowNodeRef>
            <flowNodeRef>sid-task-dsc-6</flowNodeRef>
            <flowNodeRef>sid-xor-dsc-5-conv</flowNodeRef>
            <flowNodeRef>sid-end-dsc</flowNodeRef>
         </lane>
      </laneSet>
      <startEvent id="sid-start-dsc" name="Start">
         <outgoing>sf-dsc-start</outgoing>
      </startEvent>
      <exclusiveGateway id="sid-xor-dsc-1-div" name="assess whether upon application by any entity, the applicant is established and the applicant meets all of the conditions" gatewayDirection="Diverging" isMarkerVisible="true">
         <incoming>sf-dsc-start</incoming>
         <outgoing>sf-dsc-x1-y</outgoing>
         <outgoing>sf-dsc-x1-n</outgoing>
      </exclusiveGateway>
      <task id="sid-task-dsc-1" name="award the status of trusted flagger">
         <incoming>sf-dsc-x1-y</incoming>
         <outgoing>sf-dsc-t1-xc</outgoing>
      </task>
      <exclusiveGateway id="sid-xor-dsc-1-conv" gatewayDirection="Converging" isMarkerVisible="true">
         <incoming>sf-dsc-t1-xc</incoming>
         <incoming>sf-dsc-x1-n</incoming>
         <outgoing>sf-dsc-xc1</outgoing>
      </exclusiveGateway>
      <exclusiveGateway id="sid-xor-dsc-2-div" name="assess whether following award of trusted flagger status in accordance with paragraph 2, or following suspension... or following revocation..." gatewayDirection="Diverging" isMarkerVisible="true">
         <incoming>sf-dsc-xc1</incoming>
         <outgoing>sf-dsc-x2-y</outgoing>
         <outgoing>sf-dsc-x2-n</outgoing>
      </exclusiveGateway>
      <task id="sid-task-dsc-2" name="communicate to the Commission and the Board the names, addresses and email addresses of entities awarded, suspended, or revoked trusted flagger status">
         <incoming>sf-dsc-x2-y</incoming>
         <outgoing>sf-dsc-t2-xc</outgoing>
      </task>
      <exclusiveGateway id="sid-xor-dsc-2-conv" gatewayDirection="Converging" isMarkerVisible="true">
         <incoming>sf-dsc-t2-xc</incoming>
         <incoming>sf-dsc-x2-n</incoming>
         <outgoing>sf-dsc-xc2</outgoing>
      </exclusiveGateway>
      <intermediateCatchEvent id="sid-catch-dsc-1" name="Upon receiving information from a provider of online platforms">
         <incoming>sf-dsc-xc2</incoming>
         <outgoing>sf-dsc-c1-x3</outgoing>
         <messageEventDefinition id="med-dsc-1"/>
      </intermediateCatchEvent>
      <exclusiveGateway id="sid-xor-dsc-3-div" name="assess whether there are legitimate reasons to open an investigation" gatewayDirection="Diverging" isMarkerVisible="true">
         <incoming>sf-dsc-c1-x3</incoming>
         <outgoing>sf-dsc-x3-y</outgoing>
         <outgoing>sf-dsc-x3-n</outgoing>
      </exclusiveGateway>
      <task id="sid-task-dsc-3" name="suspend the status of trusted flagger">
         <incoming>sf-dsc-x3-y</incoming>
         <outgoing>sf-dsc-t3-t4</outgoing>
      </task>
      <task id="sid-task-dsc-4" name="carry out the investigation">
         <incoming>sf-dsc-t3-t4</incoming>
         <outgoing>sf-dsc-t4-xc</outgoing>
      </task>
      <exclusiveGateway id="sid-xor-dsc-3-conv" gatewayDirection="Converging" isMarkerVisible="true">
         <incoming>sf-dsc-t4-xc</incoming>
         <incoming>sf-dsc-x3-n</incoming>
         <outgoing>sf-dsc-xc3</outgoing>
      </exclusiveGateway>
      <exclusiveGateway id="sid-xor-dsc-4-div" name="assess whether before revoking the trusted flagger status of an entity" gatewayDirection="Diverging" isMarkerVisible="true">
         <incoming>sf-dsc-xc3</incoming>
         <outgoing>sf-dsc-x4-y</outgoing>
         <outgoing>sf-dsc-x4-n</outgoing>
      </exclusiveGateway>
      <task id="sid-task-dsc-5" name="afford the entity an opportunity to react to the investigation findings">
         <incoming>sf-dsc-x4-y</incoming>
         <outgoing>sf-dsc-t5-xc</outgoing>
      </task>
      <exclusiveGateway id="sid-xor-dsc-4-conv" gatewayDirection="Converging" isMarkerVisible="true">
         <incoming>sf-dsc-t5-xc</incoming>
         <incoming>sf-dsc-x4-n</incoming>
         <outgoing>sf-dsc-xc4</outgoing>
      </exclusiveGateway>
      <exclusiveGateway id="sid-xor-dsc-5-div" name="assess whether the entity no longer meets the conditions" gatewayDirection="Diverging" isMarkerVisible="true">
         <incoming>sf-dsc-xc4</incoming>
         <outgoing>sf-dsc-x5-y</outgoing>
         <outgoing>sf-dsc-x5-n</outgoing>
      </exclusiveGateway>
      <task id="sid-task-dsc-6" name="revoke the trusted flagger status">
         <incoming>sf-dsc-x5-y</incoming>
         <outgoing>sf-dsc-t6-xc</outgoing>
      </task>
      <exclusiveGateway id="sid-xor-dsc-5-conv" gatewayDirection="Converging" isMarkerVisible="true">
         <incoming>sf-dsc-t6-xc</incoming>
         <incoming>sf-dsc-x5-n</incoming>
         <outgoing>sf-dsc-xc5</outgoing>
      </exclusiveGateway>
      <endEvent id="sid-end-dsc" name="End">
         <incoming>sf-dsc-xc5</incoming>
      </endEvent>
      <sequenceFlow id="sf-dsc-start" name="" sourceRef="sid-start-dsc" targetRef="sid-xor-dsc-1-div" isImmediate="true"/>
      <sequenceFlow id="sf-dsc-x1-y" name="yes" sourceRef="sid-xor-dsc-1-div" targetRef="sid-task-dsc-1" isImmediate="true"/>
      <sequenceFlow id="sf-dsc-x1-n" name="no" sourceRef="sid-xor-dsc-1-div" targetRef="sid-xor-dsc-1-conv" isImmediate="true"/>
      <sequenceFlow id="sf-dsc-t1-xc" name="" sourceRef="sid-task-dsc-1" targetRef="sid-xor-dsc-1-conv" isImmediate="true"/>
      <sequenceFlow id="sf-dsc-xc1" name="" sourceRef="sid-xor-dsc-1-conv" targetRef="sid-xor-dsc-2-div" isImmediate="true"/>
      <sequenceFlow id="sf-dsc-x2-y" name="yes" sourceRef="sid-xor-dsc-2-div" targetRef="sid-task-dsc-2" isImmediate="true"/>
      <sequenceFlow id="sf-dsc-x2-n" name="no" sourceRef="sid-xor-dsc-2-div" targetRef="sid-xor-dsc-2-conv" isImmediate="true"/>
      <sequenceFlow id="sf-dsc-t2-xc" name="" sourceRef="sid-task-dsc-2" targetRef="sid-xor-dsc-2-conv" isImmediate="true"/>
      <sequenceFlow id="sf-dsc-xc2" name="" sourceRef="sid-xor-dsc-2-conv" targetRef="sid-catch-dsc-1" isImmediate="true"/>
      <sequenceFlow id="sf-dsc-c1-x3" name="" sourceRef="sid-catch-dsc-1" targetRef="sid-xor-dsc-3-div" isImmediate="true"/>
      <sequenceFlow id="sf-dsc-x3-y" name="yes" sourceRef="sid-xor-dsc-3-div" targetRef="sid-task-dsc-3" isImmediate="true"/>
      <sequenceFlow id="sf-dsc-t3-t4" name="" sourceRef="sid-task-dsc-3" targetRef="sid-task-dsc-4" isImmediate="true"/>
      <sequenceFlow id="sf-dsc-t4-xc" name="" sourceRef="sid-task-dsc-4" targetRef="sid-xor-dsc-3-conv" isImmediate="true"/>
      <sequenceFlow id="sf-dsc-x3-n" name="no" sourceRef="sid-xor-dsc-3-div" targetRef="sid-xor-dsc-3-conv" isImmediate="true"/>
      <sequenceFlow id="sf-dsc-xc3" name="" sourceRef="sid-xor-dsc-3-conv" targetRef="sid-xor-dsc-4-div" isImmediate="true"/>
      <sequenceFlow id="sf-dsc-x4-y" name="yes" sourceRef="sid-xor-dsc-4-div" targetRef="sid-task-dsc-5" isImmediate="true"/>
      <sequenceFlow id="sf-dsc-t5-xc" name="" sourceRef="sid-task-dsc-5" targetRef="sid-xor-dsc-4-conv" isImmediate="true"/>
      <sequenceFlow id="sf-dsc-x4-n" name="no" sourceRef="sid-xor-dsc-4-div" targetRef="sid-xor-dsc-4-conv" isImmediate="true"/>
      <sequenceFlow id="sf-dsc-xc4" name="" sourceRef="sid-xor-dsc-4-conv" targetRef="sid-xor-dsc-5-div" isImmediate="true"/>
      <sequenceFlow id="sf-dsc-x5-y" name="yes" sourceRef="sid-xor-dsc-5-div" targetRef="sid-task-dsc-6" isImmediate="true"/>
      <sequenceFlow id="sf-dsc-t6-xc" name="" sourceRef="sid-task-dsc-6" targetRef="sid-xor-dsc-5-conv" isImmediate="true"/>
      <sequenceFlow id="sf-dsc-x5-n" name="no" sourceRef="sid-xor-dsc-5-div" targetRef="sid-xor-dsc-5-conv" isImmediate="true"/>
      <sequenceFlow id="sf-dsc-xc5" name="" sourceRef="sid-xor-dsc-5-conv" targetRef="sid-end-dsc" isImmediate="true"/>
   </process>

   <process id="sid-process-tf" isClosed="false" isExecutable="false" name="Trusted Flagger" processType="None">
      <laneSet id="sid-laneset-tf">
         <lane id="sid-lane-tf">
            <extensionElements>
               <signavio:signavioMetaData metaKey="bgcolor" metaValue=""/>
               <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            </extensionElements>
            <flowNodeRef>sid-start-tf</flowNodeRef>
            <flowNodeRef>sid-task-tf-1</flowNodeRef>
            <flowNodeRef>sid-task-tf-2</flowNodeRef>
            <flowNodeRef>sid-task-tf-3</flowNodeRef>
            <flowNodeRef>sid-catch-tf-1</flowNodeRef>
            <flowNodeRef>sid-task-tf-4</flowNodeRef>
            <flowNodeRef>sid-end-tf</flowNodeRef>
         </lane>
      </laneSet>
      <startEvent id="sid-start-tf" name="Start">
         <outgoing>sf-tf-start</outgoing>
      </startEvent>
      <task id="sid-task-tf-1" name="publish reports on notices submitted">
         <incoming>sf-tf-start</incoming>
         <outgoing>sf-tf-t1-t2</outgoing>
      </task>
      <task id="sid-task-tf-2" name="send reports to the Digital Services Coordinator">
         <incoming>sf-tf-t1-t2</incoming>
         <outgoing>sf-tf-t2-t3</outgoing>
      </task>
      <task id="sid-task-tf-3" name="make reports publicly available">
         <incoming>sf-tf-t2-t3</incoming>
         <outgoing>sf-tf-t3-c1</outgoing>
      </task>
      <intermediateCatchEvent id="sid-catch-tf-1" name="Upon receiving the opportunity to react to the investigation findings">
         <incoming>sf-tf-t3-c1</incoming>
         <outgoing>sf-tf-c1-t4</outgoing>
         <messageEventDefinition id="med-tf-1"/>
      </intermediateCatchEvent>
      <task id="sid-task-tf-4" name="react to the investigation findings">
         <incoming>sf-tf-c1-t4</incoming>
         <outgoing>sf-tf-t4-end</outgoing>
      </task>
      <endEvent id="sid-end-tf" name="End">
         <incoming>sf-tf-t4-end</incoming>
      </endEvent>
      <sequenceFlow id="sf-tf-start" name="" sourceRef="sid-start-tf" targetRef="sid-task-tf-1" isImmediate="true"/>
      <sequenceFlow id="sf-tf-t1-t2" name="" sourceRef="sid-task-tf-1" targetRef="sid-task-tf-2" isImmediate="true"/>
      <sequenceFlow id="sf-tf-t2-t3" name="" sourceRef="sid-task-tf-2" targetRef="sid-task-tf-3" isImmediate="true"/>
      <sequenceFlow id="sf-tf-t3-c1" name="" sourceRef="sid-task-tf-3" targetRef="sid-catch-tf-1" isImmediate="true"/>
      <sequenceFlow id="sf-tf-c1-t4" name="" sourceRef="sid-catch-tf-1" targetRef="sid-task-tf-4" isImmediate="true"/>
      <sequenceFlow id="sf-tf-t4-end" name="" sourceRef="sid-task-tf-4" targetRef="sid-end-tf" isImmediate="true"/>
   </process>

   <process id="sid-process-c" isClosed="false" isExecutable="false" name="Commission" processType="None">
      <laneSet id="sid-laneset-c">
         <lane id="sid-lane-c">
            <extensionElements>
               <signavio:signavioMetaData metaKey="bgcolor" metaValue=""/>
               <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            </extensionElements>
            <flowNodeRef>sid-start-c</flowNodeRef>
            <flowNodeRef>sid-catch-c-1</flowNodeRef>
            <flowNodeRef>sid-task-c-1</flowNodeRef>
            <flowNodeRef>sid-task-c-2</flowNodeRef>
            <flowNodeRef>sid-task-c-3</flowNodeRef>
            <flowNodeRef>sid-xor-c-1-div</flowNodeRef>
            <flowNodeRef>sid-task-c-4</flowNodeRef>
            <flowNodeRef>sid-xor-c-1-conv</flowNodeRef>
            <flowNodeRef>sid-end-c</flowNodeRef>
         </lane>
      </laneSet>
      <startEvent id="sid-start-c" name="Start">
         <outgoing>sf-c-start</outgoing>
      </startEvent>
      <intermediateCatchEvent id="sid-catch-c-1" name="Upon receiving the names, addresses and email addresses of entities awarded, suspended, or revoked trusted flagger status">
         <incoming>sf-c-start</incoming>
         <outgoing>sf-c-c1-t1</outgoing>
         <messageEventDefinition id="med-c-1"/>
      </intermediateCatchEvent>
      <task id="sid-task-c-1" name="publish information in a publicly available database">
         <incoming>sf-c-c1-t1</incoming>
         <outgoing>sf-c-t1-t2</outgoing>
      </task>
      <task id="sid-task-c-2" name="keep database up to date">
         <incoming>sf-c-t1-t2</incoming>
         <outgoing>sf-c-t2-t3</outgoing>
      </task>
      <task id="sid-task-c-3" name="consult before issuing guidelines under paragraph 8">
         <incoming>sf-c-t2-t3</incoming>
         <outgoing>sf-c-t3-x1</outgoing>
      </task>
      <exclusiveGateway id="sid-xor-c-1-div" name="assess whether where necessary and after consulting the Board" gatewayDirection="Diverging" isMarkerVisible="true">
         <incoming>sf-c-t3-x1</incoming>
         <outgoing>sf-c-x1-y</outgoing>
         <outgoing>sf-c-x1-n</outgoing>
      </exclusiveGateway>
      <task id="sid-task-c-4" name="issue guidelines">
         <incoming>sf-c-x1-y</incoming>
         <outgoing>sf-c-t4-xc</outgoing>
      </task>
      <exclusiveGateway id="sid-xor-c-1-conv" gatewayDirection="Converging" isMarkerVisible="true">
         <incoming>sf-c-t4-xc</incoming>
         <incoming>sf-c-x1-n</incoming>
         <outgoing>sf-c-xc-end</outgoing>
      </exclusiveGateway>
      <endEvent id="sid-end-c" name="End">
         <incoming>sf-c-xc-end</incoming>
      </endEvent>
      <sequenceFlow id="sf-c-start" name="" sourceRef="sid-start-c" targetRef="sid-catch-c-1" isImmediate="true"/>
      <sequenceFlow id="sf-c-c1-t1" name="" sourceRef="sid-catch-c-1" targetRef="sid-task-c-1" isImmediate="true"/>
      <sequenceFlow id="sf-c-t1-t2" name="" sourceRef="sid-task-c-1" targetRef="sid-task-c-2" isImmediate="true"/>
      <sequenceFlow id="sf-c-t2-t3" name="" sourceRef="sid-task-c-2" targetRef="sid-task-c-3" isImmediate="true"/>
      <sequenceFlow id="sf-c-t3-x1" name="" sourceRef="sid-task-c-3" targetRef="sid-xor-c-1-div" isImmediate="true"/>
      <sequenceFlow id="sf-c-x1-y" name="yes" sourceRef="sid-xor-c-1-div" targetRef="sid-task-c-4" isImmediate="true"/>
      <sequenceFlow id="sf-c-x1-n" name="no" sourceRef="sid-xor-c-1-div" targetRef="sid-xor-c-1-conv" isImmediate="true"/>
      <sequenceFlow id="sf-c-t4-xc" name="" sourceRef="sid-task-c-4" targetRef="sid-xor-c-1-conv" isImmediate="true"/>
      <sequenceFlow id="sf-c-xc-end" name="" sourceRef="sid-xor-c-1-conv" targetRef="sid-end-c" isImmediate="true"/>
   </process>

   <process id="sid-process-b" isClosed="false" isExecutable="false" name="Board" processType="None">
