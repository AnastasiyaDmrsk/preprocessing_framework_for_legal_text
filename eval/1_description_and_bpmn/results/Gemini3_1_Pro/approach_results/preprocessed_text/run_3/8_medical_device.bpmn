    <sequenceFlow id="P_F8" name="no" sourceRef="P_G3" targetRef="P_G4" isImmediate="true"/>
    <sequenceFlow id="P_F9" sourceRef="P_G4" targetRef="P_E1" isImmediate="true"/>
  </process>

