  <process id="Proc_QMS" isExecutable="false" name="Quality Management System">
    <startEvent id="Q_S1" name="Start process for QMS"/>
    <task id="Q_T1" name="cover all parts and elements of a manufacturer's organisation"/>
    <task id="Q_T2" name="govern the structure, responsibilities, procedures, processes and management resources"/>
    <task id="Q_T3" name="address at least the aspects set out in paragraph 9"/>
    <endEvent id="Q_E1" name="system specifications addressed end event">
      <extensionElements><signavio:signavioLabel ref="text_name" x="15.0" y="-8.0"/></extensionElements>
    </endEvent>

    <sequenceFlow id="Q_F1" sourceRef="Q_S1" targetRef="Q_T1" isImmediate="true"/>
    <sequenceFlow id="Q_F2" sourceRef="Q_T1" targetRef="Q_T2" isImmediate="true"/>
    <sequenceFlow id="Q_F3" sourceRef="Q_T2" targetRef="Q_T3" isImmediate="true"/>
    <sequenceFlow id="Q_F4" sourceRef="Q_T3" targetRef="Q_E1" isImmediate="true"/>
  </process>

  <process id="Proc_CA" isExecutable="false" name="Competent Authority">
    <startEvent id="CA_S1" name="Start process for CA"/>
    
    <exclusiveGateway id="CA_G1" name="send request tech doc?" gatewayDirection="Diverging" isMarkerVisible="true">
      <extensionElements><signavio:signavioLabel ref="text_name" x="20.0" y="-8.0"/></extensionElements>
    </exclusiveGateway>
    <task id="CA_T1" name="send a request for technical documentation"/>
    <exclusiveGateway id="CA_G2" gatewayDirection="Converging" isMarkerVisible="true"/>
    
    <exclusiveGateway id="CA_G3" name="send request doc conformity?" gatewayDirection="Diverging" isMarkerVisible="true">
      <extensionElements><signavio:signavioLabel ref="text_name" x="20.0" y="-8.0"/></extensionElements>
    </exclusiveGateway>
    <task id="CA_T2" name="send a request for documentation necessary to demonstrate the conformity of the device"/>
    <exclusiveGateway id="CA_G4" gatewayDirection="Converging" isMarkerVisible="true"/>
    
    <exclusiveGateway id="CA_G5" name="send require samples?" gatewayDirection="Diverging" isMarkerVisible="true">
      <extensionElements><signavio:signavioLabel ref="text_name" x="20.0" y="-8.0"/></extensionElements>
    </exclusiveGateway>
    <task id="CA_T3" name="send a requirement to provide samples of the device free of charge"/>
    <exclusiveGateway id="CA_G6" gatewayDirection="Converging" isMarkerVisible="true"/>
    
    <exclusiveGateway id="CA_G7" name="send require access?" gatewayDirection="Diverging" isMarkerVisible="true">
      <extensionElements><signavio:signavioLabel ref="text_name" x="20.0" y="-8.0"/></extensionElements>
    </exclusiveGateway>
    <task id="CA_T4" name="send a requirement to grant access to the device"/>
    <exclusiveGateway id="CA_G8" gatewayDirection="Converging" isMarkerVisible="true"/>
    
    <exclusiveGateway id="CA_G9" name="send request collaboration?" gatewayDirection="Diverging" isMarkerVisible="true">
      <extensionElements><signavio:signavioLabel ref="text_name" x="20.0" y="-8.0"/></extensionElements>
    </exclusiveGateway>
    <task id="CA_T5" name="send a request for collaboration"/>
    <exclusiveGateway id="CA_G10" gatewayDirection="Converging" isMarkerVisible="true"/>
    
    <task id="CA_T6" name="assess whether the manufacturer fails to cooperate or the information and documentation provided is incomplete or incorrect"/>
    <exclusiveGateway id="CA_G11" name="manufacturer fails?" gatewayDirection="Diverging" isMarkerVisible="true">
      <extensionElements><signavio:signavioLabel ref="text_name" x="20.0" y="-8.0"/></extensionElements>
    </exclusiveGateway>
    <task id="CA_T7" name="take all appropriate measures to prohibit or restrict the device"/>
    <task id="CA_T8" name="withdraw the device from that market"/>
    <task id="CA_T9" name="recall the device until the manufacturer cooperates or provides information"/>
    <exclusiveGateway id="CA_G12" gatewayDirection="Converging" isMarkerVisible="true"/>
    
    <intermediateCatchEvent id="CA_EV1" name="Upon receiving a request for provision of information related to device damage">
      <extensionElements><signavio:signavioLabel ref="text_name" x="15.0" y="-8.0"/></extensionElements>
      <messageEventDefinition/>
    </intermediateCatchEvent>
    <task id="CA_T10" name="facilitate the provision of the information and documentation to the potentially injured patient"/>
    <endEvent id="CA_E1" name="regulatory actions completed end event">
