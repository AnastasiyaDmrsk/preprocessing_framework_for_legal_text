  <process id="Proc_Pat" isExecutable="false" name="Patient / User">
    <startEvent id="P_S1" name="Start process for Patient"/>
    <exclusiveGateway id="P_G1" name="send request?" gatewayDirection="Diverging" isMarkerVisible="true">
      <extensionElements><signavio:signavioLabel ref="text_name" x="20.0" y="-8.0"/></extensionElements>
    </exclusiveGateway>
    <task id="P_T1" name="send a request for provision of information related to device damage to the Competent Authority"/>
    <exclusiveGateway id="P_G2" gatewayDirection="Converging" isMarkerVisible="true"/>
    
    <exclusiveGateway id="P_G3" name="claim compensation?" gatewayDirection="Diverging" isMarkerVisible="true">
      <extensionElements><signavio:signavioLabel ref="text_name" x="20.0" y="-8.0"/></extensionElements>
    </exclusiveGateway>
    <task id="P_T2" name="claim compensation for damage caused by a defective device"/>
    <exclusiveGateway id="P_G4" gatewayDirection="Converging" isMarkerVisible="true"/>
    
    <endEvent id="P_E1" name="compensation claimed end event">
      <extensionElements><signavio:signavioLabel ref="text_name" x="15.0" y="-8.0"/></extensionElements>
    </endEvent>

    <sequenceFlow id="P_F1" sourceRef="P_S1" targetRef="P_G1" isImmediate="true"/>
    <sequenceFlow id="P_F2" name="yes" sourceRef="P_G1" targetRef="P_T1" isImmediate="true"/>
