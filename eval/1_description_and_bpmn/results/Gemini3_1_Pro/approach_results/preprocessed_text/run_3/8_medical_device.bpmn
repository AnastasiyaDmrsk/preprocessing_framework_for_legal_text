        <flowNodeRef>M_T43</flowNodeRef>
        <flowNodeRef>M_EV4</flowNodeRef>
        <flowNodeRef>M_T44</flowNodeRef>
        <flowNodeRef>M_EV5</flowNodeRef>
        <flowNodeRef>M_T45</flowNodeRef>
        <flowNodeRef>M_T46</flowNodeRef>
        <flowNodeRef>M_T47</flowNodeRef>
        <flowNodeRef>M_E1</flowNodeRef>
      </lane>
      <lane id="L_Cst" name="Manufacturer of custom-made devices">
        <flowNodeRef>M_T8</flowNodeRef>
        <flowNodeRef>M_T9</flowNodeRef>
        <flowNodeRef>M_T10</flowNodeRef>
      </lane>
      <lane id="L_Imp" name="Manufacturer of implantable devices">
        <flowNodeRef>M_T18</flowNodeRef>
      </lane>
    </laneSet>

    <startEvent id="M_S1" name="placing devices on the market or putting them into service"/>
    <task id="M_T1" name="ensure that devices have been designed and manufactured IAW the requirements"/>
    <task id="M_T2" name="establish a system for risk management"/>
    <task id="M_T3" name="document a system for risk management"/>
    <task id="M_T4" name="implement a system for risk management"/>
    <task id="M_T5" name="maintain a system for risk management"/>
    <task id="M_T6" name="conduct a clinical evaluation"/>
    <task id="M_T7" name="assess whether they are a manufacturer of custom-made devices"/>
    
    <exclusiveGateway id="M_G1" name="manufacturer of custom-made devices?" gatewayDirection="Diverging" isMarkerVisible="true">
      <extensionElements><signavio:signavioLabel ref="text_name" x="20.0" y="-8.0"/></extensionElements>
    </exclusiveGateway>
    
    <task id="M_T8" name="draw up documentation"/>
    <task id="M_T9" name="keep up to date documentation"/>
    <task id="M_T10" name="keep available for competent authorities documentation"/>
    
    <task id="M_T11" name="draw up technical documentation"/>
    <task id="M_T12" name="keep up to date technical documentation"/>
    
    <exclusiveGateway id="M_G2" gatewayDirection="Converging" isMarkerVisible="true"/>
    
    <task id="M_T13" name="assess whether compliance with the applicable requirements has been demonstrated"/>
    
    <exclusiveGateway id="M_G3" name="compliance demonstrated?" gatewayDirection="Diverging" isMarkerVisible="true">
      <extensionElements><signavio:signavioLabel ref="text_name" x="20.0" y="-8.0"/></extensionElements>
    </exclusiveGateway>
    
    <task id="M_T14" name="draw up an EU declaration of conformity"/>
    <task id="M_T15" name="affix the CE marking of conformity"/>
    
    <exclusiveGateway id="M_G4" gatewayDirection="Converging" isMarkerVisible="true"/>
    
    <task id="M_T16" name="comply with the obligations"/>
    <task id="M_T17" name="assess whether they are a manufacturer of implantable devices"/>
    
    <exclusiveGateway id="M_G5" name="manufacturer of implantable devices?" gatewayDirection="Diverging" isMarkerVisible="true">
      <extensionElements><signavio:signavioLabel ref="text_name" x="20.0" y="-8.0"/></extensionElements>
    </exclusiveGateway>
    
    <task id="M_T18" name="keep the technical documentation, the EU declaration of conformity and a copy of any relevant certificate"/>
    <task id="M_T19" name="keep the technical documentation, the EU declaration of conformity and a copy of any relevant certificate"/>
    
    <exclusiveGateway id="M_G6" gatewayDirection="Converging" isMarkerVisible="true"/>
    
    <intermediateCatchEvent id="M_EV1" name="Upon receiving a request for technical documentation">
      <extensionElements><signavio:signavioLabel ref="text_name" x="15.0" y="-8.0"/></extensionElements>
      <messageEventDefinition/>
    </intermediateCatchEvent>
    
    <task id="M_T20" name="provide technical documentation in its entirety or a summary"/>
    <task id="M_T21" name="assess whether the manufacturer has a registered place of business outside the Union and allow the authorised representative to fulfil the tasks"/>
    
    <exclusiveGateway id="M_G7" name="conditions are true?" gatewayDirection="Diverging" isMarkerVisible="true">
      <extensionElements><signavio:signavioLabel ref="text_name" x="20.0" y="-8.0"/></extensionElements>
    </exclusiveGateway>
    
    <task id="M_T22" name="ensure that the authorised representative has the necessary documentation available"/>
    
    <exclusiveGateway id="M_G8" gatewayDirection="Converging" isMarkerVisible="true"/>
    
    <task id="M_T23" name="ensure that procedures are in place to keep series production in conformity with the requirements"/>
    <task id="M_T24" name="take into account changes in device design or characteristics and changes in the harmonised standards"/>
    <task id="M_T25" name="establish a quality management system"/>
    <task id="M_T26" name="document a quality management system"/>
    <task id="M_T27" name="implement a quality management system"/>
    <task id="M_T28" name="maintain a quality management system"/>
    <task id="M_T29" name="keep up to date a quality management system"/>
    <task id="M_T30" name="improve a quality management system"/>
    <task id="M_T31" name="implement the post-market surveillance system"/>
    <task id="M_T32" name="keep up to date the post-market surveillance system"/>
    <task id="M_T33" name="ensure that the device is accompanied by the information"/>
    <task id="M_T34" name="assess whether the device is not in conformity with this Regulation"/>
    
    <exclusiveGateway id="M_G9" name="device is not in conformity?" gatewayDirection="Diverging" isMarkerVisible="true">
      <extensionElements><signavio:signavioLabel ref="text_name" x="20.0" y="-8.0"/></extensionElements>
    </exclusiveGateway>
    
    <task id="M_T35" name="bring the device into conformity"/>
    <task id="M_T36" name="withdraw the device"/>
    <task id="M_T37" name="recall the device"/>
    <task id="M_T38" name="inform the distributors of the device, the authorised representative and importers"/>
    
    <exclusiveGateway id="M_G10" gatewayDirection="Converging" isMarkerVisible="true"/>
    
    <task id="M_T39" name="assess whether the device is not in conformity with this Regulation and the device presents a serious risk"/>
    
    <exclusiveGateway id="M_G11" name="conditions are true?" gatewayDirection="Diverging" isMarkerVisible="true">
      <extensionElements><signavio:signavioLabel ref="text_name" x="20.0" y="-8.0"/></extensionElements>
    </exclusiveGateway>
    
    <task id="M_T40" name="notify the non-compliance to the competent authorities and the notified body"/>
    
    <exclusiveGateway id="M_G12" gatewayDirection="Converging" isMarkerVisible="true"/>
    
    <task id="M_T41" name="have a system for recording and reporting of incidents and corrective actions"/>
    
    <intermediateCatchEvent id="M_EV2" name="Upon receiving a request for documentation necessary to demonstrate the conformity">
      <extensionElements><signavio:signavioLabel ref="text_name" x="15.0" y="-8.0"/></extensionElements>
      <messageEventDefinition/>
    </intermediateCatchEvent>
    
    <task id="M_T42" name="provide the competent authority with all the information and documentation"/>
    
    <intermediateCatchEvent id="M_EV3" name="Upon receiving a requirement to provide samples of the device free of charge">
      <extensionElements><signavio:signavioLabel ref="text_name" x="15.0" y="-8.0"/></extensionElements>
      <messageEventDefinition/>
    </intermediateCatchEvent>
    
    <task id="M_T43" name="provide samples of the device"/>
    
    <intermediateCatchEvent id="M_EV4" name="Upon receiving a requirement to grant access to the device">
      <extensionElements><signavio:signavioLabel ref="text_name" x="15.0" y="-8.0"/></extensionElements>
      <messageEventDefinition/>
    </intermediateCatchEvent>
    
    <task id="M_T44" name="grant access to the device"/>
    
    <intermediateCatchEvent id="M_EV5" name="Upon receiving a request for collaboration">
      <extensionElements><signavio:signavioLabel ref="text_name" x="15.0" y="-8.0"/></extensionElements>
      <messageEventDefinition/>
    </intermediateCatchEvent>
    
    <task id="M_T45" name="cooperate with a competent authority"/>
    <task id="M_T46" name="ensure that the information on the person identity is part of the submitted information"/>
    <task id="M_T47" name="have measures to provide sufficient financial coverage"/>
    
    <endEvent id="M_E1" name="general obligations fulfilled end event">
      <extensionElements><signavio:signavioLabel ref="text_name" x="15.0" y="-8.0"/></extensionElements>
    </endEvent>

    <!-- Sequence Flows Manufacturer -->
    <sequenceFlow id="M_F1" sourceRef="M_S1" targetRef="M_T1" isImmediate="true"/>
    <sequenceFlow id="M_F2" sourceRef="M_T1" targetRef="M_T2" isImmediate="true"/>
    <sequenceFlow id="M_F3" sourceRef="M_T2" targetRef="M_T3" isImmediate="true"/>
