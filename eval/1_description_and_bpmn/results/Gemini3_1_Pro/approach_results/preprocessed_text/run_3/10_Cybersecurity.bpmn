      <sequenceFlow id="SF_EN22" sourceRef="T_EN14" targetRef="E_EN" isImmediate="true"/>
   </process>

   <process id="PR_IP" isClosed="false" isExecutable="false" name="Interested Party" processType="None">
      <laneSet id="LS_IP">
         <lane id="L_IP" name="Interested Party">
            <flowNodeRef>S_IP</flowNodeRef>
            <flowNodeRef>T_IP1</flowNodeRef>
            <flowNodeRef>T_IP2</flowNodeRef>
            <flowNodeRef>E_IP</flowNodeRef>
         </lane>
      </laneSet>

      <startEvent id="S_IP" name="Start">
         <extensionElements>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/>
         </extensionElements>
         <outgoing>SF_IP_S</outgoing>
      </startEvent>

      <task id="T_IP1" name="provide feedback">
         <incoming>SF_IP_S</incoming>
         <outgoing>SF_IP1</outgoing>
      </task>

      <task id="T_IP2" name="transmit the feedback to ENISA">
         <incoming>SF_IP1</incoming>
         <outgoing>SF_IP2</outgoing>
      </task>

      <endEvent id="E_IP" name="feedback transmission end event">
         <extensionElements>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="15.0" y="-8.0"/>
         </extensionElements>
         <incoming>SF_IP2</incoming>
      </endEvent>

      <sequenceFlow id="SF_IP_S" sourceRef="S_IP" targetRef="T_IP1" isImmediate="true"/>
      <sequenceFlow id="SF_IP1" sourceRef="T_IP1" targetRef="T_IP2" isImmediate="true"/>
      <sequenceFlow id="SF_IP2" sourceRef="T_IP2" targetRef="E_IP" isImmediate="true"/>
   </process>

