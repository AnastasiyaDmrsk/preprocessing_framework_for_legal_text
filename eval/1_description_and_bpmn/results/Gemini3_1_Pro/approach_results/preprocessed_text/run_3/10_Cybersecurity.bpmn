      <sequenceFlow id="SF_EN15" sourceRef="T_EN10" targetRef="ICE_EN1" isImmediate="true"/>
      <sequenceFlow id="SF_EN16" sourceRef="ICE_EN1" targetRef="T_EN11" isImmediate="true"/>
      <sequenceFlow id="SF_EN17" sourceRef="T_EN11" targetRef="T_EN12" isImmediate="true"/>
