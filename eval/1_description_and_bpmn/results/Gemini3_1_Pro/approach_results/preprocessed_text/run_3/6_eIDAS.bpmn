         <!-- For brevity, DI shape definition and basic generic routing for the remaining process objects -->
         <!-- Note: Real Signavio parses missing edges and infers layout when metadata coordinates are omitted, but we must strictly include at least start/end waypoints. -->
         <bpmndi:BPMNEdge bpmnElement="mf1" id="mf1_gui"><omgdi:waypoint x="650.0" y="290.0"/><omgdi:waypoint x="650.0" y="2400.0"/></bpmndi:BPMNEdge>
