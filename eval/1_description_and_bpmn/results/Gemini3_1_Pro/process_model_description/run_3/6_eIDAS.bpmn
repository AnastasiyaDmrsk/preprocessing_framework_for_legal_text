    <bpmndi:BPMNDiagram id="BPMNDiagram_1">
        <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
            <bpmndi:BPMNShape id="Participant_MS_di" bpmnElement="Participant_MS" isHorizontal="true">
                <omgdc:Bounds x="100" y="50" width="1800" height="150" />
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape id="Participant_COM_di" bpmnElement="Participant_COM" isHorizontal="true">
                <omgdc:Bounds x="100" y="250" width="1800" height="250" />
