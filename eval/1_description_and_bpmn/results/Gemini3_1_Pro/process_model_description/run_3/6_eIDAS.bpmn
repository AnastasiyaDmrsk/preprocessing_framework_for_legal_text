             exporter="AI Process Modeler" exporterVersion="1.0"
             id="definitions_1" targetNamespace="http://www.signavio.com">

    <collaboration id="Collaboration_1">
        <participant id="Participant_MS" name="Member States" processRef="Process_MS" />
        <participant id="Participant_COM" name="Commission" processRef="Process_COM" />
        <participant id="Participant_ASB" name="Another supervisory body" processRef="Process_ASB" />
        <participant id="Participant_TSP" name="Trust service providers" processRef="Process_TSP" />
        <participant id="Participant_SB" name="Supervisory body" processRef="Process_SB" />

        <messageFlow id="Flow_MF1" sourceRef="MS_T4" targetRef="COM_T1" />
        <messageFlow id="Flow_MF2" sourceRef="SB_T25" targetRef="COM_T2" />
        <messageFlow id="Flow_MF3" sourceRef="ASB_T1" targetRef="SB_T14" />
        <messageFlow id="Flow_MF4" sourceRef="SB_T16" targetRef="ASB_T2" />
