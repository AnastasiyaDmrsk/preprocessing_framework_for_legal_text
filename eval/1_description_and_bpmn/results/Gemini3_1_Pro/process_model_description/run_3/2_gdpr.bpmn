         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="Task_Assess_Effort" id="Shape_Task_Assess_Effort">
            <omgdc:Bounds height="80.0" width="100.0" x="2800.0" y="375.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="ExclusiveGateway_Effort" id="Shape_ExclusiveGateway_Effort">
            <omgdc:Bounds height="40.0" width="40.0" x="2950.0" y="395.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="Task_Public_Comm" id="Shape_Task_Public_Comm">
            <omgdc:Bounds height="80.0" width="100.0" x="3050.0" y="280.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="EndEvent_Controller_Main" id="Shape_EndEvent_Controller_Main">
            <omgdc:Bounds height="30.0" width="30.0" x="3200.0" y="400.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="StartEvent_Req_SA" id="Shape_StartEvent_Req_SA">
            <omgdc:Bounds height="30.0" width="30.0" x="150.0" y="600.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="Task_Comm_DS_Req" id="Shape_Task_Comm_DS_Req">
            <omgdc:Bounds height="80.0" width="100.0" x="250.0" y="575.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="EndEvent_Controller_Req" id="Shape_EndEvent_Controller_Req">
            <omgdc:Bounds height="30.0" width="30.0" x="400.0" y="600.0"/>
         </bpmndi:BPMNShape>

         <bpmndi:BPMNShape bpmnElement="StartEvent_SA" id="Shape_StartEvent_SA">
