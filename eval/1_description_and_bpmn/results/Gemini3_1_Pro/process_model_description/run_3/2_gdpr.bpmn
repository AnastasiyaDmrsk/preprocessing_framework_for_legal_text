            <omgdc:Bounds height="80.0" width="100.0" x="2350.0" y="375.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="Task_Describe_Clear" id="Shape_Task_Describe_Clear">
            <omgdc:Bounds height="80.0" width="100.0" x="2500.0" y="375.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="Task_Include_Info" id="Shape_Task_Include_Info">
