<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             targetNamespace="http://www.signavio.com"
             xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd">

   <collaboration id="Collaboration_1">
      <participant id="Participant_Entities" name="Entities" processRef="Process_Entities" />
      <participant id="Participant_DSC" name="Digital Services Coordinator" processRef="Process_DSC" />
      <participant id="Participant_TF" name="Trusted flaggers" processRef="Process_TF" />
      <participant id="Participant_POP" name="Providers of online platforms" processRef="Process_POP" />
      <participant id="Participant_COM" name="Commission" processRef="Process_COM" />
      <participant id="Participant_BRD" name="Board" processRef="Process_BRD" />

      <messageFlow id="MF1" sourceRef="ENT_T1" targetRef="DSC_S1" />
      <messageFlow id="MF2" sourceRef="DSC_T3" targetRef="COM_S1" />
      <messageFlow id="MF3" sourceRef="DSC_T4" targetRef="BRD_S1" />
      <messageFlow id="MF4" sourceRef="TF_T1" targetRef="POP_T2" />
      <messageFlow id="MF5" sourceRef="TF_T6" targetRef="DSC_S2" />
      <messageFlow id="MF6" sourceRef="POP_T4" targetRef="DSC_S3" />
      <messageFlow id="MF6b" sourceRef="POP_T5" targetRef="DSC_S3" />
      <messageFlow id="MF7" sourceRef="DSC_T10" targetRef="TF_S2" />
      <messageFlow id="MF8" sourceRef="COM_T4" targetRef="BRD_S2" />
   </collaboration>

   <process id="Process_Entities" isExecutable="true">
      <startEvent id="ENT_S" name="Process starts">
         <outgoing>ENT_F1</outgoing>
      </startEvent>
      <task id="ENT_T1" name="Send application for trusted flagger status">
         <incoming>ENT_F1</incoming>
         <outgoing>ENT_F2</outgoing>
      </task>
      <parallelGateway id="ENT_G1">
         <incoming>ENT_F2</incoming>
         <outgoing>ENT_F3</outgoing>
         <outgoing>ENT_F4</outgoing>
         <outgoing>ENT_F5</outgoing>
      </parallelGateway>
      <task id="ENT_T2" name="Demonstrate expertise and competence">
         <incoming>ENT_F3</incoming>
         <outgoing>ENT_F6</outgoing>
      </task>
      <task id="ENT_T3" name="Demonstrate independence">
         <incoming>ENT_F4</incoming>
         <outgoing>ENT_F7</outgoing>
      </task>
      <task id="ENT_T4" name="Demonstrate diligence, accuracy and objectivity">
         <incoming>ENT_F5</incoming>
         <outgoing>ENT_F8</outgoing>
      </task>
      <parallelGateway id="ENT_G2">
         <incoming>ENT_F6</incoming>
         <incoming>ENT_F7</incoming>
         <incoming>ENT_F8</incoming>
         <outgoing>ENT_F9</outgoing>
      </parallelGateway>
      <endEvent id="ENT_E" name="Application submitted">
         <incoming>ENT_F9</incoming>
      </endEvent>

      <sequenceFlow id="ENT_F1" sourceRef="ENT_S" targetRef="ENT_T1" />
      <sequenceFlow id="ENT_F2" sourceRef="ENT_T1" targetRef="ENT_G1" />
      <sequenceFlow id="ENT_F3" sourceRef="ENT_G1" targetRef="ENT_T2" />
      <sequenceFlow id="ENT_F4" sourceRef="ENT_G1" targetRef="ENT_T3" />
      <sequenceFlow id="ENT_F5" sourceRef="ENT_G1" targetRef="ENT_T4" />
      <sequenceFlow id="ENT_F6" sourceRef="ENT_T2" targetRef="ENT_G2" />
      <sequenceFlow id="ENT_F7" sourceRef="ENT_T3" targetRef="ENT_G2" />
      <sequenceFlow id="ENT_F8" sourceRef="ENT_T4" targetRef="ENT_G2" />
      <sequenceFlow id="ENT_F9" sourceRef="ENT_G2" targetRef="ENT_E" />
   </process>

   <process id="Process_DSC" isExecutable="true">
      <startEvent id="DSC_S1" name="Receive application">
         <outgoing>DSC_F1</outgoing>
      </startEvent>
      <task id="DSC_T1" name="Assess applicant conditions">
         <incoming>DSC_F1</incoming>
         <outgoing>DSC_F2</outgoing>
      </task>
      <exclusiveGateway id="DSC_G1" name="Meets conditions?">
         <incoming>DSC_F2</incoming>
         <outgoing>DSC_F3</outgoing>
      </exclusiveGateway>
      <task id="DSC_T2" name="Award status of trusted flagger">
         <incoming>DSC_F3</incoming>
         <outgoing>DSC_F4</outgoing>
      </task>
      <parallelGateway id="DSC_G2">
         <incoming>DSC_F4</incoming>
         <outgoing>DSC_F5</outgoing>
         <outgoing>DSC_F6</outgoing>
      </parallelGateway>
      <task id="DSC_T3" name="Send entities info to Commission">
         <incoming>DSC_F5</incoming>
         <outgoing>DSC_F7</outgoing>
      </task>
      <task id="DSC_T4" name="Send entities info to Board">
         <incoming>DSC_F6</incoming>
         <outgoing>DSC_F8</outgoing>
      </task>
      <parallelGateway id="DSC_G3">
         <incoming>DSC_F7</incoming>
         <incoming>DSC_F8</incoming>
         <outgoing>DSC_F9</outgoing>
      </parallelGateway>
      <endEvent id="DSC_E1" name="Initial processing end">
         <incoming>DSC_F9</incoming>
      </endEvent>

      <startEvent id="DSC_S2" name="Receive reports">
         <outgoing>DSC_F10</outgoing>
      </startEvent>
      <task id="DSC_T5" name="Process the reports">
         <incoming>DSC_F10</incoming>
         <outgoing>DSC_F11</outgoing>
      </task>
      <endEvent id="DSC_E2" name="Reports processed">
         <incoming>DSC_F11</incoming>
      </endEvent>

      <startEvent id="DSC_S3" name="Receive information">
         <outgoing>DSC_F12</outgoing>
      </startEvent>
      <task id="DSC_T6" name="Assess legitimate reasons to open investigation">
         <incoming>DSC_F12</incoming>
         <outgoing>DSC_F13</outgoing>
      </task>
      <exclusiveGateway id="DSC_G4" name="Legitimate reasons?">
         <incoming>DSC_F13</incoming>
         <outgoing>DSC_F14</outgoing>
      </exclusiveGateway>
      <task id="DSC_T7" name="Suspend status">
         <incoming>DSC_F14</incoming>
         <outgoing>DSC_F15</outgoing>
      </task>
      <task id="DSC_T8" name="Carry out investigation">
         <incoming>DSC_F15</incoming>
         <outgoing>DSC_F16</outgoing>
      </task>
      <task id="DSC_T9" name="Assess if entity meets conditions">
         <incoming>DSC_F16</incoming>
         <outgoing>DSC_F17</outgoing>
      </task>
      <exclusiveGateway id="DSC_G5" name="No longer meets?">
         <incoming>DSC_F17</incoming>
         <outgoing>DSC_F18</outgoing>
      </exclusiveGateway>
      <task id="DSC_T10" name="Send opportunity to react">
         <incoming>DSC_F18</incoming>
         <outgoing>DSC_F19</outgoing>
      </task>
      <task id="DSC_T11" name="Revoke status">
         <incoming>DSC_F19</incoming>
         <outgoing>DSC_F20</outgoing>
      </task>
      <endEvent id="DSC_E3" name="Status managed">
         <incoming>DSC_F20</incoming>
      </endEvent>

      <sequenceFlow id="DSC_F1" sourceRef="DSC_S1" targetRef="DSC_T1" />
      <sequenceFlow id="DSC_F2" sourceRef="DSC_T1" targetRef="DSC_G1" />
      <sequenceFlow id="DSC_F3" sourceRef="DSC_G1" targetRef="DSC_T2" />
      <sequenceFlow id="DSC_F4" sourceRef="DSC_T2" targetRef="DSC_G2" />
      <sequenceFlow id="DSC_F5" sourceRef="DSC_G2" targetRef="DSC_T3" />
      <sequenceFlow id="DSC_F6" sourceRef="DSC_G2" targetRef="DSC_T4" />
      <sequenceFlow id="DSC_F7" sourceRef="DSC_T3" targetRef="DSC_G3" />
      <sequenceFlow id="DSC_F8" sourceRef="DSC_T4" targetRef="DSC_G3" />
      <sequenceFlow id="DSC_F9" sourceRef="DSC_G3" targetRef="DSC_E1" />
      <sequenceFlow id="DSC_F10" sourceRef="DSC_S2" targetRef="DSC_T5" />
      <sequenceFlow id="DSC_F11" sourceRef="DSC_T5" targetRef="DSC_E2" />
      <sequenceFlow id="DSC_F12" sourceRef="DSC_S3" targetRef="DSC_T6" />
      <sequenceFlow id="DSC_F13" sourceRef="DSC_T6" targetRef="DSC_G4" />
      <sequenceFlow id="DSC_F14" sourceRef="DSC_G4" targetRef="DSC_T7" />
      <sequenceFlow id="DSC_F15" sourceRef="DSC_T7" targetRef="DSC_T8" />
      <sequenceFlow id="DSC_F16" sourceRef="DSC_T8" targetRef="DSC_T9" />
      <sequenceFlow id="DSC_F17" sourceRef="DSC_T9" targetRef="DSC_G5" />
      <sequenceFlow id="DSC_F18" sourceRef="DSC_G5" targetRef="DSC_T10" />
      <sequenceFlow id="DSC_F19" sourceRef="DSC_T10" targetRef="DSC_T11" />
      <sequenceFlow id="DSC_F20" sourceRef="DSC_T11" targetRef="DSC_E3" />
   </process>

   <process id="Process_TF" isExecutable="true">
      <startEvent id="TF_S1" name="Process starts">
         <outgoing>TF_F1</outgoing>
      </startEvent>
      <task id="TF_T1" name="Send notices">
         <incoming>TF_F1</incoming>
         <outgoing>TF_F2</outgoing>
      </task>
      <task id="TF_T2" name="Publish detailed reports">
         <incoming>TF_F2</incoming>
         <outgoing>TF_F3</outgoing>
      </task>
      <parallelGateway id="TF_G1">
         <incoming>TF_F3</incoming>
         <outgoing>TF_F4</outgoing>
         <outgoing>TF_F5</outgoing>
         <outgoing>TF_F6</outgoing>
      </parallelGateway>
      <task id="TF_T3" name="List number of notices">
         <incoming>TF_F4</incoming>
         <outgoing>TF_F7</outgoing>
      </task>
      <task id="TF_T4" name="Include explanation of procedures">
         <incoming>TF_F5</incoming>
         <outgoing>TF_F8</outgoing>
      </task>
      <task id="TF_T5" name="Ensure no personal data">
         <incoming>TF_F6</incoming>
         <outgoing>TF_F9</outgoing>
      </task>
      <parallelGateway id="TF_G2">
         <incoming>TF_F7</incoming>
         <incoming>TF_F8</incoming>
         <incoming>TF_F9</incoming>
         <outgoing>TF_F10</outgoing>
      </parallelGateway>
      <parallelGateway id="TF_G3">
         <incoming>TF_F10</incoming>
         <outgoing>TF_F11</outgoing>
         <outgoing>TF_F12</outgoing>
      </parallelGateway>
      <task id="TF_T6" name="Send reports to DSC">
         <incoming>TF_F11</incoming>
         <outgoing>TF_F13</outgoing>
      </task>
      <task id="TF_T7" name="Make reports publicly available">
         <incoming>TF_F12</incoming>
         <outgoing>TF_F14</outgoing>
      </task>
      <parallelGateway id="TF_G4">
         <incoming>TF_F13</incoming>
         <incoming>TF_F14</incoming>
         <outgoing>TF_F15</outgoing>
      </parallelGateway>
      <endEvent id="TF_E1" name="Duties fulfilled">
         <incoming>TF_F15</incoming>
      </endEvent>

      <startEvent id="TF_S2" name="Receive opportunity">
         <outgoing>TF_F16</outgoing>
      </startEvent>
      <task id="TF_T8" name="React to findings">
         <incoming>TF_F16</incoming>
         <outgoing>TF_F17</outgoing>
      </task>
      <endEvent id="TF_E2" name="Reaction completed">
         <incoming>TF_F17</incoming>
      </endEvent>

      <sequenceFlow id="TF_F1" sourceRef="TF_S1" targetRef="TF_T1" />
      <sequenceFlow id="TF_F2" sourceRef="TF_T1" targetRef="TF_T2" />
      <sequenceFlow id="TF_F3" sourceRef="TF_T2" targetRef="TF_G1" />
      <sequenceFlow id="TF_F4" sourceRef="TF_G1" targetRef="TF_T3" />
      <sequenceFlow id="TF_F5" sourceRef="TF_G1" targetRef="TF_T4" />
      <sequenceFlow id="TF_F6" sourceRef="TF_G1" targetRef="TF_T5" />
      <sequenceFlow id="TF_F7" sourceRef="TF_T3" targetRef="TF_G2" />
      <sequenceFlow id="TF_F8" sourceRef="TF_T4" targetRef="TF_G2" />
      <sequenceFlow id="TF_F9" sourceRef="TF_T5" targetRef="TF_G2" />
      <sequenceFlow id="TF_F10" sourceRef="TF_G2" targetRef="TF_G3" />
      <sequenceFlow id="TF_F11" sourceRef="TF_G3" targetRef="TF_T6" />
      <sequenceFlow id="TF_F12" sourceRef="TF_G3" targetRef="TF_T7" />
      <sequenceFlow id="TF_F13" sourceRef="TF_T6" targetRef="TF_G4" />
      <sequenceFlow id="TF_F14" sourceRef="TF_T7" targetRef="TF_G4" />
      <sequenceFlow id="TF_F15" sourceRef="TF_G4" targetRef="TF_E1" />
      <sequenceFlow id="TF_F16" sourceRef="TF_S2" targetRef="TF_T8" />
      <sequenceFlow id="TF_F17" sourceRef="TF_T8" targetRef="TF_E2" />
   </process>

   <process id="Process_POP" isExecutable="true">
      <startEvent id="POP_S1" name="Process starts">
         <outgoing>POP_F1</outgoing>
      </startEvent>
      <task id="POP_T1" name="Take necessary technical measures">
         <incoming>POP_F1</incoming>
         <outgoing>POP_F2</outgoing>
      </task>
      <task id="POP_T2" name="Process the notices">
         <incoming>POP_F2</incoming>
         <outgoing>POP_F3</outgoing>
      </task>
      <task id="POP_T3" name="Assess inaccurate notices">
         <incoming>POP_F3</incoming>
         <outgoing>POP_F4</outgoing>
      </task>
      <exclusiveGateway id="POP_G1" name="Have information?">
         <incoming>POP_F4</incoming>
         <outgoing>POP_F5</outgoing>
      </exclusiveGateway>
      <parallelGateway id="POP_G2">
         <incoming>POP_F5</incoming>
         <outgoing>POP_F6</outgoing>
         <outgoing>POP_F7</outgoing>
      </parallelGateway>
      <task id="POP_T4" name="Send information to DSC">
         <incoming>POP_F6</incoming>
         <outgoing>POP_F8</outgoing>
      </task>
      <task id="POP_T5" name="Send explanations to DSC">
         <incoming>POP_F7</incoming>
         <outgoing>POP_F9</outgoing>
      </task>
      <parallelGateway id="POP_G3">
         <incoming>POP_F8</incoming>
         <incoming>POP_F9</incoming>
         <outgoing>POP_F10</outgoing>
      </parallelGateway>
      <endEvent id="POP_E1" name="Notices processed">
