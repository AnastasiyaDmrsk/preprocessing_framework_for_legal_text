      <sequenceFlow id="COM_F1" sourceRef="COM_S1" targetRef="COM_G1" />
      <sequenceFlow id="COM_F2" sourceRef="COM_G1" targetRef="COM_T1" />
      <sequenceFlow id="COM_F3" sourceRef="COM_G1" targetRef="COM_T2" />
      <sequenceFlow id="COM_F4" sourceRef="COM_T1" targetRef="COM_G2" />
      <sequenceFlow id="COM_F5" sourceRef="COM_T2" targetRef="COM_G2" />
      <sequenceFlow id="COM_F6" sourceRef="COM_G2" targetRef="COM_T3" />
      <sequenceFlow id="COM_F7" sourceRef="COM_T3" targetRef="COM_G3" />
      <sequenceFlow id="COM_F8" sourceRef="COM_G3" targetRef="COM_T4" />
      <sequenceFlow id="COM_F9" sourceRef="COM_T4" targetRef="COM_T5" />
      <sequenceFlow id="COM_F10" sourceRef="COM_T5" targetRef="COM_E1" />
   </process>

   <process id="Process_BRD" isExecutable="true">
