      <sequenceFlow id="POP_F1" sourceRef="POP_S1" targetRef="POP_T1" />
      <sequenceFlow id="POP_F2" sourceRef="POP_T1" targetRef="POP_T2" />
      <sequenceFlow id="POP_F3" sourceRef="POP_T2" targetRef="POP_T3" />
      <sequenceFlow id="POP_F4" sourceRef="POP_T3" targetRef="POP_G1" />
      <sequenceFlow id="POP_F5" sourceRef="POP_G1" targetRef="POP_G2" />
      <sequenceFlow id="POP_F6" sourceRef="POP_G2" targetRef="POP_T4" />
      <sequenceFlow id="POP_F7" sourceRef="POP_G2" targetRef="POP_T5" />
      <sequenceFlow id="POP_F8" sourceRef="POP_T4" targetRef="POP_G3" />
      <sequenceFlow id="POP_F9" sourceRef="POP_T5" targetRef="POP_G3" />
      <sequenceFlow id="POP_F10" sourceRef="POP_G3" targetRef="POP_E1" />
   </process>

   <process id="Process_COM" isExecutable="true">
      <startEvent id="COM_S1" name="Receive info">
         <outgoing>COM_F1</outgoing>
      </startEvent>
      <parallelGateway id="COM_G1">
         <incoming>COM_F1</incoming>
         <outgoing>COM_F2</outgoing>
         <outgoing>COM_F3</outgoing>
      </parallelGateway>
      <task id="COM_T1" name="Publish information in database">
         <incoming>COM_F2</incoming>
         <outgoing>COM_F4</outgoing>
      </task>
      <task id="COM_T2" name="Keep database up to date">
         <incoming>COM_F3</incoming>
         <outgoing>COM_F5</outgoing>
      </task>
      <parallelGateway id="COM_G2">
         <incoming>COM_F4</incoming>
         <incoming>COM_F5</incoming>
         <outgoing>COM_F6</outgoing>
      </parallelGateway>
      <task id="COM_T3" name="Assess necessary guidelines">
         <incoming>COM_F6</incoming>
         <outgoing>COM_F7</outgoing>
      </task>
      <exclusiveGateway id="COM_G3" name="Necessary?">
         <incoming>COM_F7</incoming>
         <outgoing>COM_F8</outgoing>
      </exclusiveGateway>
      <task id="COM_T4" name="Send consultation to Board">
         <incoming>COM_F8</incoming>
         <outgoing>COM_F9</outgoing>
      </task>
      <task id="COM_T5" name="Issue guidelines">
         <incoming>COM_F9</incoming>
         <outgoing>COM_F10</outgoing>
      </task>
      <endEvent id="COM_E1" name="Guidelines managed">
         <incoming>COM_F10</incoming>
