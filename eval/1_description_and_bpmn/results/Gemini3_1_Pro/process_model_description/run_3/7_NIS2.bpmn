      <sequenceFlow id="f_eie_47" sourceRef="g_eie_p2_j" targetRef="t_eie_25" />
      <sequenceFlow id="f_eie_48" sourceRef="t_eie_25" targetRef="g_eie_ex5_s" />
      <sequenceFlow id="f_eie_49" sourceRef="g_eie_ex5_s" targetRef="t_eie_26" />
      <sequenceFlow id="f_eie_50" sourceRef="g_eie_ex5_s" targetRef="t_eie_27" />
      <sequenceFlow id="f_eie_51" sourceRef="g_eie_ex5_s" targetRef="g_eie_ex5_j" />
      <sequenceFlow id="f_eie_52" sourceRef="t_eie_26" targetRef="g_eie_ex5_j" />
      <sequenceFlow id="f_eie_53" sourceRef="t_eie_27" targetRef="g_eie_ex5_j" />
      <sequenceFlow id="f_eie_54" sourceRef="g_eie_ex5_j" targetRef="t_eie_28" />
      <sequenceFlow id="f_eie_55" sourceRef="t_eie_28" targetRef="e_eie" />
   </process>

   <process id="proc_ca" isExecutable="false" processType="None">
      <startEvent id="s_ca" name="Receive notification" />
      <task id="t_ca_1" name="send notification to CSIRT" />
      <task id="t_ca_2" name="provide response to entity" />
      <task id="t_ca_3" name="include initial feedback" />
      <task id="t_ca_4" name="provide guidance or operational advice" />
      <task id="t_ca_5" name="assess whether CSIRT not initial recipient" />
      <exclusiveGateway id="g_ca_ex1_s" name="If CSIRT not initial?" />
      <task id="t_ca_6" name="provide guidance in cooperation with CSIRT" />
      <exclusiveGateway id="g_ca_ex1_j" />
      <task id="t_ca_7" name="assess criminal nature" />
      <exclusiveGateway id="g_ca_ex2_s" name="If criminal?" />
      <task id="t_ca_8" name="provide guidance on reporting to law enforcement" />
      <exclusiveGateway id="g_ca_ex2_j" />
      <task id="t_ca_9" name="assess concerns 2+ MS or appropriate" />
      <exclusiveGateway id="g_ca_ex3_s" name="If appropriate?" />
      <parallelGateway id="g_ca_p1_s" />
      <task id="t_ca_10" name="inform affected MS" />
      <task id="t_ca_11" name="inform ENISA" />
      <parallelGateway id="g_ca_p1_j" />
      <exclusiveGateway id="g_ca_ex3_j" />
      <task id="t_ca_12" name="include type of information" />
      <task id="t_ca_13" name="preserve security/commercial interests" />
      <task id="t_ca_14" name="assess public awareness necessity" />
      <exclusiveGateway id="g_ca_ex4_s" name="If public awareness?" />
      <task id="t_ca_15" name="consult entity concerned" />
      <task id="t_ca_16" name="inform public" />
      <task id="t_ca_17" name="send requirement to inform public" />
      <exclusiveGateway id="g_ca_ex4_j" />
      <task id="t_ca_18" name="send request for intermediate report" />
      <task id="t_ca_19" name="send request to forward notifications" />
      <task id="t_ca_20" name="provide info to competent authorities" />
      <endEvent id="e_ca" name="incident handled" />

      <sequenceFlow id="f_ca_1" sourceRef="s_ca" targetRef="t_ca_1" />
      <sequenceFlow id="f_ca_2" sourceRef="t_ca_1" targetRef="t_ca_2" />
      <sequenceFlow id="f_ca_3" sourceRef="t_ca_2" targetRef="t_ca_3" />
      <sequenceFlow id="f_ca_4" sourceRef="t_ca_3" targetRef="t_ca_4" />
      <sequenceFlow id="f_ca_5" sourceRef="t_ca_4" targetRef="t_ca_5" />
      <sequenceFlow id="f_ca_6" sourceRef="t_ca_5" targetRef="g_ca_ex1_s" />
      <sequenceFlow id="f_ca_7" sourceRef="g_ca_ex1_s" targetRef="t_ca_6" />
      <sequenceFlow id="f_ca_8" sourceRef="g_ca_ex1_s" targetRef="g_ca_ex1_j" />
      <sequenceFlow id="f_ca_9" sourceRef="t_ca_6" targetRef="g_ca_ex1_j" />
      <sequenceFlow id="f_ca_10" sourceRef="g_ca_ex1_j" targetRef="t_ca_7" />
      <sequenceFlow id="f_ca_11" sourceRef="t_ca_7" targetRef="g_ca_ex2_s" />
      <sequenceFlow id="f_ca_12" sourceRef="g_ca_ex2_s" targetRef="t_ca_8" />
      <sequenceFlow id="f_ca_13" sourceRef="g_ca_ex2_s" targetRef="g_ca_ex2_j" />
      <sequenceFlow id="f_ca_14" sourceRef="t_ca_8" targetRef="g_ca_ex2_j" />
      <sequenceFlow id="f_ca_15" sourceRef="g_ca_ex2_j" targetRef="t_ca_9" />
      <sequenceFlow id="f_ca_16" sourceRef="t_ca_9" targetRef="g_ca_ex3_s" />
      <sequenceFlow id="f_ca_17" sourceRef="g_ca_ex3_s" targetRef="g_ca_p1_s" />
      <sequenceFlow id="f_ca_18" sourceRef="g_ca_ex3_s" targetRef="g_ca_ex3_j" />
      <sequenceFlow id="f_ca_19" sourceRef="g_ca_p1_s" targetRef="t_ca_10" />
      <sequenceFlow id="f_ca_20" sourceRef="g_ca_p1_s" targetRef="t_ca_11" />
      <sequenceFlow id="f_ca_21" sourceRef="t_ca_10" targetRef="g_ca_p1_j" />
      <sequenceFlow id="f_ca_22" sourceRef="t_ca_11" targetRef="g_ca_p1_j" />
      <sequenceFlow id="f_ca_23" sourceRef="g_ca_p1_j" targetRef="g_ca_ex3_j" />
      <sequenceFlow id="f_ca_24" sourceRef="g_ca_ex3_j" targetRef="t_ca_12" />
      <sequenceFlow id="f_ca_25" sourceRef="t_ca_12" targetRef="t_ca_13" />
      <sequenceFlow id="f_ca_26" sourceRef="t_ca_13" targetRef="t_ca_14" />
      <sequenceFlow id="f_ca_27" sourceRef="t_ca_14" targetRef="g_ca_ex4_s" />
      <sequenceFlow id="f_ca_28" sourceRef="g_ca_ex4_s" targetRef="t_ca_15" />
      <sequenceFlow id="f_ca_29" sourceRef="t_ca_15" targetRef="t_ca_16" />
      <sequenceFlow id="f_ca_30" sourceRef="t_ca_16" targetRef="t_ca_17" />
      <sequenceFlow id="f_ca_31" sourceRef="t_ca_17" targetRef="g_ca_ex4_j" />
      <sequenceFlow id="f_ca_32" sourceRef="g_ca_ex4_s" targetRef="g_ca_ex4_j" />
      <sequenceFlow id="f_ca_33" sourceRef="g_ca_ex4_j" targetRef="t_ca_18" />
      <sequenceFlow id="f_ca_34" sourceRef="t_ca_18" targetRef="t_ca_19" />
      <sequenceFlow id="f_ca_35" sourceRef="t_ca_19" targetRef="t_ca_20" />
      <sequenceFlow id="f_ca_36" sourceRef="t_ca_20" targetRef="e_ca" />
   </process>

   <process id="proc_csirt" isExecutable="false" processType="None">
      <startEvent id="s_csirt" name="Receive notification/warning" />
      <task id="t_cs_1" name="process notification" />
      <task id="t_cs_2" name="provide response" />
      <task id="t_cs_3" name="include initial feedback" />
      <task id="t_cs_4" name="provide guidance or operational advice" />
      <task id="t_cs_5" name="provide additional technical support" />
      <task id="t_cs_6" name="assess criminal nature" />
      <exclusiveGateway id="g_cs_ex1_s" name="If criminal?" />
      <task id="t_cs_7" name="provide guidance on reporting" />
      <exclusiveGateway id="g_cs_ex1_j" />
      <task id="t_cs_8" name="assess concerns 2+ MS" />
      <exclusiveGateway id="g_cs_ex2_s" name="If appropriate?" />
      <parallelGateway id="g_cs_p1_s" />
      <task id="t_cs_9" name="inform MS" />
      <task id="t_cs_10" name="inform ENISA" />
      <parallelGateway id="g_cs_p1_j" />
      <exclusiveGateway id="g_cs_ex2_j" />
      <task id="t_cs_11" name="include type of information" />
      <task id="t_cs_12" name="preserve security" />
      <task id="t_cs_13" name="assess public awareness" />
      <exclusiveGateway id="g_cs_ex3_s" name="If public awareness?" />
      <task id="t_cs_14" name="consult entity" />
      <task id="t_cs_15" name="inform public" />
      <task id="t_cs_16" name="send requirement to inform public" />
      <exclusiveGateway id="g_cs_ex3_j" />
      <task id="t_cs_17" name="send request intermediate" />
      <task id="t_cs_18" name="send request forward" />
      <task id="t_cs_19" name="provide info to CA" />
      <endEvent id="e_csirt" name="incident handled" />

      <sequenceFlow id="f_cs_1" sourceRef="s_csirt" targetRef="t_cs_1" />
      <sequenceFlow id="f_cs_2" sourceRef="t_cs_1" targetRef="t_cs_2" />
      <sequenceFlow id="f_cs_3" sourceRef="t_cs_2" targetRef="t_cs_3" />
      <sequenceFlow id="f_cs_4" sourceRef="t_cs_3" targetRef="t_cs_4" />
      <sequenceFlow id="f_cs_5" sourceRef="t_cs_4" targetRef="t_cs_5" />
      <sequenceFlow id="f_cs_6" sourceRef="t_cs_5" targetRef="t_cs_6" />
      <sequenceFlow id="f_cs_7" sourceRef="t_cs_6" targetRef="g_cs_ex1_s" />
      <sequenceFlow id="f_cs_8" sourceRef="g_cs_ex1_s" targetRef="t_cs_7" />
      <sequenceFlow id="f_cs_9" sourceRef="g_cs_ex1_s" targetRef="g_cs_ex1_j" />
      <sequenceFlow id="f_cs_10" sourceRef="t_cs_7" targetRef="g_cs_ex1_j" />
      <sequenceFlow id="f_cs_11" sourceRef="g_cs_ex1_j" targetRef="t_cs_8" />
      <sequenceFlow id="f_cs_12" sourceRef="t_cs_8" targetRef="g_cs_ex2_s" />
      <sequenceFlow id="f_cs_13" sourceRef="g_cs_ex2_s" targetRef="g_cs_p1_s" />
      <sequenceFlow id="f_cs_14" sourceRef="g_cs_ex2_s" targetRef="g_cs_ex2_j" />
      <sequenceFlow id="f_cs_15" sourceRef="g_cs_p1_s" targetRef="t_cs_9" />
      <sequenceFlow id="f_cs_16" sourceRef="g_cs_p1_s" targetRef="t_cs_10" />
      <sequenceFlow id="f_cs_17" sourceRef="t_cs_9" targetRef="g_cs_p1_j" />
      <sequenceFlow id="f_cs_18" sourceRef="t_cs_10" targetRef="g_cs_p1_j" />
