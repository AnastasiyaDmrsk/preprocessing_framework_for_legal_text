         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape id="Task_Comm_1_gui" bpmnElement="Task_Comm_1">
            <omgdc:Bounds height="80.0" width="100.0" x="350.0" y="80.0" />
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape id="Task_Comm_2_gui" bpmnElement="Task_Comm_2">
            <omgdc:Bounds height="80.0" width="100.0" x="350.0" y="200.0" />
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape id="Gateway_Comm_Merge_gui" bpmnElement="Gateway_Comm_Merge">
            <omgdc:Bounds height="50.0" width="50.0" x="500.0" y="143.0" />
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape id="EndEvent_Commission_gui" bpmnElement="EndEvent_Commission">
            <omgdc:Bounds height="36.0" width="36.0" x="600.0" y="150.0" />
         </bpmndi:BPMNShape>

         <bpmndi:BPMNEdge id="Flow_Comm_1_gui" bpmnElement="Flow_Comm_1">
            <omgdi:waypoint x="186.0" y="168.0" />
            <omgdi:waypoint x="250.0" y="168.0" />
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge id="Flow_Comm_2_gui" bpmnElement="Flow_Comm_2">
            <omgdi:waypoint x="275.0" y="143.0" />
            <omgdi:waypoint x="275.0" y="120.0" />
            <omgdi:waypoint x="350.0" y="120.0" />
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge id="Flow_Comm_3_gui" bpmnElement="Flow_Comm_3">
            <omgdi:waypoint x="275.0" y="193.0" />
            <omgdi:waypoint x="275.0" y="240.0" />
            <omgdi:waypoint x="350.0" y="240.0" />
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge id="Flow_Comm_4_gui" bpmnElement="Flow_Comm_4">
            <omgdi:waypoint x="450.0" y="120.0" />
            <omgdi:waypoint x="525.0" y="120.0" />
            <omgdi:waypoint x="525.0" y="143.0" />
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge id="Flow_Comm_5_gui" bpmnElement="Flow_Comm_5">
            <omgdi:waypoint x="450.0" y="240.0" />
