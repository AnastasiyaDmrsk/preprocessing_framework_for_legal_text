      <sequenceFlow id="Flow_MS_G5_6" name="Yes" sourceRef="Gateway_MS_5" targetRef="Task_MS_6" />
      <sequenceFlow id="Flow_MS_G5_G6" name="No" sourceRef="Gateway_MS_5" targetRef="Gateway_MS_6" />
      <sequenceFlow id="Flow_MS_6_G6" sourceRef="Task_MS_6" targetRef="Gateway_MS_6" />
      <sequenceFlow id="Flow_MS_G6_7" sourceRef="Gateway_MS_6" targetRef="Task_MS_7" />
      <sequenceFlow id="Flow_MS_7_G7" sourceRef="Task_MS_7" targetRef="Gateway_MS_7" />
      <sequenceFlow id="Flow_MS_G7_8" name="Yes" sourceRef="Gateway_MS_7" targetRef="Task_MS_8" />
