   <process id="Process_AP" isExecutable="false">
      <startEvent id="Event_AP_Start" name="Application for issuance or renewal">
         <outgoing>Flow_AP_S_1</outgoing>
      </startEvent>
      <task id="Task_AP_1" name="Assess whether a driving licence is renewed">
         <incoming>Flow_AP_S_1</incoming>
         <outgoing>Flow_AP_1_G1</outgoing>
      </task>
      <exclusiveGateway id="Gateway_AP_1" name="Renewed?">
         <incoming>Flow_AP_1_G1</incoming>
         <outgoing>Flow_AP_G1_2</outgoing>
         <outgoing>Flow_AP_G1_G2</outgoing>
      </exclusiveGateway>
      <task id="Task_AP_2" name="Undergo a medical examination">
         <incoming>Flow_AP_G1_2</incoming>
         <outgoing>Flow_AP_2_G2</outgoing>
      </task>
      <exclusiveGateway id="Gateway_AP_2">
         <incoming>Flow_AP_2_G2</incoming>
         <incoming>Flow_AP_G1_G2</incoming>
         <outgoing>Flow_AP_G2_3</outgoing>
      </exclusiveGateway>
      <task id="Task_AP_3" name="Assess whether the renewal is for driving licences in category AM">
         <incoming>Flow_AP_G2_3</incoming>
         <outgoing>Flow_AP_3_G3</outgoing>
      </task>
      <exclusiveGateway id="Gateway_AP_3" name="Category AM?">
         <incoming>Flow_AP_3_G3</incoming>
         <outgoing>Flow_AP_G3_4</outgoing>
         <outgoing>Flow_AP_G3_G4</outgoing>
      </exclusiveGateway>
      <task id="Task_AP_4" name="Undergo the medical examination">
         <incoming>Flow_AP_G3_4</incoming>
         <outgoing>Flow_AP_4_G4</outgoing>
      </task>
      <exclusiveGateway id="Gateway_AP_4">
         <incoming>Flow_AP_4_G4</incoming>
         <incoming>Flow_AP_G3_G4</incoming>
         <outgoing>Flow_AP_G4_Msg</outgoing>
      </exclusiveGateway>
      <intermediateCatchEvent id="Event_AP_Msg" name="Receive requirement to fill in self-assessment form">
         <incoming>Flow_AP_G4_Msg</incoming>
         <outgoing>Flow_AP_Msg_5</outgoing>
         <messageEventDefinition id="MsgDef_AP_1" />
      </intermediateCatchEvent>
      <task id="Task_AP_5" name="Fill in a self-assessment form">
         <incoming>Flow_AP_Msg_5</incoming>
         <outgoing>Flow_AP_5_E</outgoing>
      </task>
      <endEvent id="Event_AP_End" name="Application requirements fulfilled">
         <incoming>Flow_AP_5_E</incoming>
      </endEvent>

      <sequenceFlow id="Flow_AP_S_1" sourceRef="Event_AP_Start" targetRef="Task_AP_1" />
      <sequenceFlow id="Flow_AP_1_G1" sourceRef="Task_AP_1" targetRef="Gateway_AP_1" />
      <sequenceFlow id="Flow_AP_G1_2" name="Yes" sourceRef="Gateway_AP_1" targetRef="Task_AP_2" />
      <sequenceFlow id="Flow_AP_G1_G2" name="No" sourceRef="Gateway_AP_1" targetRef="Gateway_AP_2" />
      <sequenceFlow id="Flow_AP_2_G2" sourceRef="Task_AP_2" targetRef="Gateway_AP_2" />
      <sequenceFlow id="Flow_AP_G2_3" sourceRef="Gateway_AP_2" targetRef="Task_AP_3" />
      <sequenceFlow id="Flow_AP_3_G3" sourceRef="Task_AP_3" targetRef="Gateway_AP_3" />
      <sequenceFlow id="Flow_AP_G3_4" name="Yes" sourceRef="Gateway_AP_3" targetRef="Task_AP_4" />
      <sequenceFlow id="Flow_AP_G3_G4" name="No" sourceRef="Gateway_AP_3" targetRef="Gateway_AP_4" />
      <sequenceFlow id="Flow_AP_4_G4" sourceRef="Task_AP_4" targetRef="Gateway_AP_4" />
      <sequenceFlow id="Flow_AP_G4_Msg" sourceRef="Gateway_AP_4" targetRef="Event_AP_Msg" />
      <sequenceFlow id="Flow_AP_Msg_5" sourceRef="Event_AP_Msg" targetRef="Task_AP_5" />
      <sequenceFlow id="Flow_AP_5_E" sourceRef="Task_AP_5" targetRef="Event_AP_End" />
   </process>

   <process id="Process_CO" isExecutable="false">
      <startEvent id="Event_CO_Start" name="Process start">
         <outgoing>Flow_CO_S_G1</outgoing>
      </startEvent>
      <parallelGateway id="Gateway_CO_1">
         <incoming>Flow_CO_S_G1</incoming>
         <outgoing>Flow_CO_G1_M1</outgoing>
         <outgoing>Flow_CO_G1_M2</outgoing>
      </parallelGateway>
      <intermediateCatchEvent id="Event_CO_M1" name="Receive adopted guidelines">
         <incoming>Flow_CO_G1_M1</incoming>
         <outgoing>Flow_CO_M1_1</outgoing>
         <messageEventDefinition id="MsgDef_CO_1" />
      </intermediateCatchEvent>
      <task id="Task_CO_1" name="Make the guidelines available to the other Member States">
         <incoming>Flow_CO_M1_1</incoming>
         <outgoing>Flow_CO_1_G2</outgoing>
      </task>
      <intermediateCatchEvent id="Event_CO_M2" name="Receive information regarding campaigns">
         <incoming>Flow_CO_G1_M2</incoming>
         <outgoing>Flow_CO_M2_2</outgoing>
         <messageEventDefinition id="MsgDef_CO_2" />
      </intermediateCatchEvent>
      <task id="Task_CO_2" name="Make the information available to the other Member States">
         <incoming>Flow_CO_M2_2</incoming>
         <outgoing>Flow_CO_2_G2</outgoing>
      </task>
      <parallelGateway id="Gateway_CO_2">
         <incoming>Flow_CO_1_G2</incoming>
         <incoming>Flow_CO_2_G2</incoming>
         <outgoing>Flow_CO_G2_E</outgoing>
      </parallelGateway>
      <endEvent id="Event_CO_End" name="Information distributed">
         <incoming>Flow_CO_G2_E</incoming>
      </endEvent>

      <sequenceFlow id="Flow_CO_S_G1" sourceRef="Event_CO_Start" targetRef="Gateway_CO_1" />
      <sequenceFlow id="Flow_CO_G1_M1" sourceRef="Gateway_CO_1" targetRef="Event_CO_M1" />
      <sequenceFlow id="Flow_CO_M1_1" sourceRef="Event_CO_M1" targetRef="Task_CO_1" />
      <sequenceFlow id="Flow_CO_1_G2" sourceRef="Task_CO_1" targetRef="Gateway_CO_2" />
      <sequenceFlow id="Flow_CO_G1_M2" sourceRef="Gateway_CO_1" targetRef="Event_CO_M2" />
      <sequenceFlow id="Flow_CO_M2_2" sourceRef="Event_CO_M2" targetRef="Task_CO_2" />
      <sequenceFlow id="Flow_CO_2_G2" sourceRef="Task_CO_2" targetRef="Gateway_CO_2" />
      <sequenceFlow id="Flow_CO_G2_E" sourceRef="Gateway_CO_2" targetRef="Event_CO_End" />
   </process>

   <bpmndi:BPMNDiagram id="BPMNDiagram_1">
      <bpmndi:BPMNPlane bpmnElement="Collaboration_1" id="BPMNPlane_1">
         <bpmndi:BPMNShape bpmnElement="Participant_MS" id="Participant_MS_di" isHorizontal="true">
