      <sequenceFlow id="Flow_MS_G11_16" name="Yes" sourceRef="Gateway_MS_11" targetRef="Task_MS_16" />
      <sequenceFlow id="Flow_MS_G11_G12" name="No" sourceRef="Gateway_MS_11" targetRef="Gateway_MS_12" />
      <sequenceFlow id="Flow_MS_16_G12" sourceRef="Task_MS_16" targetRef="Gateway_MS_12" />
      <sequenceFlow id="Flow_MS_G12_17" sourceRef="Gateway_MS_12" targetRef="Task_MS_17" />
      <sequenceFlow id="Flow_MS_17_18" sourceRef="Task_MS_17" targetRef="Task_MS_18" />
      <sequenceFlow id="Flow_MS_18_19" sourceRef="Task_MS_18" targetRef="Task_MS_19" />
      <sequenceFlow id="Flow_MS_19_G13" sourceRef="Task_MS_19" targetRef="Gateway_MS_13" />
