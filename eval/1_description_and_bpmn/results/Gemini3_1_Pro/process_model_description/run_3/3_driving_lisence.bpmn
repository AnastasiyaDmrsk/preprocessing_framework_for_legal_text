<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             targetNamespace="http://www.signavio.com"
             xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd">
   <collaboration id="Collaboration_1">
      <participant id="Participant_MS" name="Member States" processRef="Process_MS" />
      <participant id="Participant_AP" name="Applicants or holders" processRef="Process_AP" />
      <participant id="Participant_CO" name="Commission" processRef="Process_CO" />
      <messageFlow id="MessageFlow_1" sourceRef="Task_MS_9" targetRef="Event_AP_Msg" />
      <messageFlow id="MessageFlow_2" sourceRef="Task_MS_20" targetRef="Event_CO_M1" />
      <messageFlow id="MessageFlow_3" sourceRef="Task_MS_22" targetRef="Event_CO_M2" />
   </collaboration>

   <process id="Process_MS" isExecutable="false">
      <startEvent id="Event_MS_Start" name="Application for issuance or renewal">
         <outgoing>Flow_MS_S_1</outgoing>
      </startEvent>
      <task id="Task_MS_1" name="Assess whether a driving licence is issued for the first time">
         <incoming>Flow_MS_S_1</incoming>
         <outgoing>Flow_MS_1_G1</outgoing>
      </task>
      <exclusiveGateway id="Gateway_MS_1" name="First time?">
         <incoming>Flow_MS_1_G1</incoming>
         <outgoing>Flow_MS_G1_2</outgoing>
         <outgoing>Flow_MS_G1_G2</outgoing>
      </exclusiveGateway>
      <task id="Task_MS_2" name="Ensure applicants undergo a medical examination">
         <incoming>Flow_MS_G1_2</incoming>
         <outgoing>Flow_MS_2_G2</outgoing>
      </task>
      <exclusiveGateway id="Gateway_MS_2">
         <incoming>Flow_MS_2_G2</incoming>
         <incoming>Flow_MS_G1_G2</incoming>
         <outgoing>Flow_MS_G2_3</outgoing>
      </exclusiveGateway>
      <task id="Task_MS_3" name="Assess whether the driving licence is in category AM">
         <incoming>Flow_MS_G2_3</incoming>
         <outgoing>Flow_MS_3_G3</outgoing>
      </task>
      <exclusiveGateway id="Gateway_MS_3" name="Category AM?">
         <incoming>Flow_MS_3_G3</incoming>
         <outgoing>Flow_MS_G3_4</outgoing>
         <outgoing>Flow_MS_G3_G4</outgoing>
      </exclusiveGateway>
      <task id="Task_MS_4" name="Require the medical examination for issuance">
         <incoming>Flow_MS_G3_4</incoming>
         <outgoing>Flow_MS_4_G4</outgoing>
      </task>
      <exclusiveGateway id="Gateway_MS_4">
         <incoming>Flow_MS_4_G4</incoming>
         <incoming>Flow_MS_G3_G4</incoming>
         <outgoing>Flow_MS_G4_5</outgoing>
      </exclusiveGateway>
      <task id="Task_MS_5" name="Assess whether application is for categories C, CE, C1, C1E, D, D1, DE or D1E">
         <incoming>Flow_MS_G4_5</incoming>
         <outgoing>Flow_MS_5_G5</outgoing>
      </task>
      <exclusiveGateway id="Gateway_MS_5" name="Categories C, D...?">
         <incoming>Flow_MS_5_G5</incoming>
         <outgoing>Flow_MS_G5_6</outgoing>
         <outgoing>Flow_MS_G5_G6</outgoing>
      </exclusiveGateway>
      <task id="Task_MS_6" name="Require a medical examination">
         <incoming>Flow_MS_G5_6</incoming>
         <outgoing>Flow_MS_6_G6</outgoing>
      </task>
      <exclusiveGateway id="Gateway_MS_6">
         <incoming>Flow_MS_6_G6</incoming>
         <incoming>Flow_MS_G5_G6</incoming>
         <outgoing>Flow_MS_G6_7</outgoing>
      </exclusiveGateway>
      <task id="Task_MS_7" name="Assess whether application is for categories AM, A, A1, A2, B, B1 and BE">
         <incoming>Flow_MS_G6_7</incoming>
         <outgoing>Flow_MS_7_G7</outgoing>
      </task>
      <exclusiveGateway id="Gateway_MS_7" name="Categories AM, A, B...?">
         <incoming>Flow_MS_7_G7</incoming>
         <outgoing>Flow_MS_G7_8</outgoing>
         <outgoing>Flow_MS_G7_G8</outgoing>
      </exclusiveGateway>
      <task id="Task_MS_8" name="Apply alternative measures">
         <incoming>Flow_MS_G7_8</incoming>
         <outgoing>Flow_MS_8_G8</outgoing>
      </task>
      <exclusiveGateway id="Gateway_MS_8">
         <incoming>Flow_MS_8_G8</incoming>
         <incoming>Flow_MS_G7_G8</incoming>
         <outgoing>Flow_MS_G8_9</outgoing>
      </exclusiveGateway>
      <task id="Task_MS_9" name="Send a requirement to fill in a self-assessment form">
         <incoming>Flow_MS_G8_9</incoming>
         <outgoing>Flow_MS_9_10</outgoing>
      </task>
      <task id="Task_MS_10" name="Establish a national system of assessment of fitness to drive">
         <incoming>Flow_MS_9_10</incoming>
         <outgoing>Flow_MS_10_11</outgoing>
      </task>
      <task id="Task_MS_11" name="Provide for appropriate measures to address non-compliance">
         <incoming>Flow_MS_10_11</incoming>
         <outgoing>Flow_MS_11_12</outgoing>
      </task>
      <task id="Task_MS_12" name="Provide for appropriate measures to address knowingly providing incorrect information">
         <incoming>Flow_MS_11_12</incoming>
         <outgoing>Flow_MS_12_13</outgoing>
      </task>
      <task id="Task_MS_13" name="Provide for appropriate measures to address failing to meet any requirement">
         <incoming>Flow_MS_12_13</incoming>
         <outgoing>Flow_MS_13_14</outgoing>
      </task>
      <task id="Task_MS_14" name="Apply the alternative measure of the national system">
         <incoming>Flow_MS_13_14</incoming>
         <outgoing>Flow_MS_14_15</outgoing>
      </task>
      <task id="Task_MS_15" name="Assess whether it becomes apparent that the applicant is likely to have medical conditions">
         <incoming>Flow_MS_14_15</incoming>
         <outgoing>Flow_MS_15_G11</outgoing>
      </task>
      <exclusiveGateway id="Gateway_MS_11" name="Likely medical condition?">
         <incoming>Flow_MS_15_G11</incoming>
         <outgoing>Flow_MS_G11_16</outgoing>
         <outgoing>Flow_MS_G11_G12</outgoing>
      </exclusiveGateway>
      <task id="Task_MS_16" name="Ensure applicant undergoes a medical examination">
         <incoming>Flow_MS_G11_16</incoming>
         <outgoing>Flow_MS_16_G12</outgoing>
      </task>
      <exclusiveGateway id="Gateway_MS_12">
         <incoming>Flow_MS_16_G12</incoming>
         <incoming>Flow_MS_G11_G12</incoming>
         <outgoing>Flow_MS_G12_17</outgoing>
      </exclusiveGateway>
      <task id="Task_MS_17" name="Take measures to raise awareness">
         <incoming>Flow_MS_G12_17</incoming>
         <outgoing>Flow_MS_17_18</outgoing>
      </task>
      <task id="Task_MS_18" name="Take measures to improve the knowledge">
         <incoming>Flow_MS_17_18</incoming>
         <outgoing>Flow_MS_18_19</outgoing>
      </task>
      <task id="Task_MS_19" name="Assess whether they adopt guidelines for medical practitioners">
         <incoming>Flow_MS_18_19</incoming>
         <outgoing>Flow_MS_19_G13</outgoing>
      </task>
      <exclusiveGateway id="Gateway_MS_13" name="Adopt guidelines?">
         <incoming>Flow_MS_19_G13</incoming>
         <outgoing>Flow_MS_G13_20</outgoing>
         <outgoing>Flow_MS_G13_G14</outgoing>
      </exclusiveGateway>
      <task id="Task_MS_20" name="Notify the adopted guidelines to the Commission">
         <incoming>Flow_MS_G13_20</incoming>
         <outgoing>Flow_MS_20_G14</outgoing>
      </task>
      <exclusiveGateway id="Gateway_MS_14">
         <incoming>Flow_MS_20_G14</incoming>
         <incoming>Flow_MS_G13_G14</incoming>
         <outgoing>Flow_MS_G14_21</outgoing>
      </exclusiveGateway>
      <task id="Task_MS_21" name="Assess whether they develop public awareness campaigns">
         <incoming>Flow_MS_G14_21</incoming>
         <outgoing>Flow_MS_21_G15</outgoing>
      </task>
      <exclusiveGateway id="Gateway_MS_15" name="Develop campaigns?">
         <incoming>Flow_MS_21_G15</incoming>
         <outgoing>Flow_MS_G15_22</outgoing>
         <outgoing>Flow_MS_G15_G16</outgoing>
      </exclusiveGateway>
      <task id="Task_MS_22" name="Notify the information regarding the campaigns to the Commission">
         <incoming>Flow_MS_G15_22</incoming>
         <outgoing>Flow_MS_22_G16</outgoing>
      </task>
      <exclusiveGateway id="Gateway_MS_16">
         <incoming>Flow_MS_22_G16</incoming>
         <incoming>Flow_MS_G15_G16</incoming>
         <outgoing>Flow_MS_G16_23</outgoing>
      </exclusiveGateway>
      <task id="Task_MS_23" name="Set stricter standards">
         <incoming>Flow_MS_G16_23</incoming>
         <outgoing>Flow_MS_23_E</outgoing>
      </task>
      <endEvent id="Event_MS_End" name="Application processed">
         <incoming>Flow_MS_23_E</incoming>
      </endEvent>

      <sequenceFlow id="Flow_MS_S_1" sourceRef="Event_MS_Start" targetRef="Task_MS_1" />
      <sequenceFlow id="Flow_MS_1_G1" sourceRef="Task_MS_1" targetRef="Gateway_MS_1" />
      <sequenceFlow id="Flow_MS_G1_2" name="Yes" sourceRef="Gateway_MS_1" targetRef="Task_MS_2" />
      <sequenceFlow id="Flow_MS_G1_G2" name="No" sourceRef="Gateway_MS_1" targetRef="Gateway_MS_2" />
