<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             id="Definitions_Incident_Process"
             targetNamespace="http://bpmn.io/schema/bpmn"
             xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL BPMN20.xsd">

  <collaboration id="Collaboration_1">
    <participant id="Participant_MemberStates" name="Member States" processRef="Process_MemberStates" />
    <participant id="Participant_Entities" name="Essential and important entities" processRef="Process_Entities" />
    <participant id="Participant_CompetentAuthority" name="Competent authority" processRef="Process_CompetentAuthority" />
    <participant id="Participant_CSIRT" name="CSIRT" processRef="Process_CSIRT" />
    <participant id="Participant_SPOC" name="Single point of contact" processRef="Process_SPOC" />
    <participant id="Participant_ENISA" name="ENISA" processRef="Process_ENISA" />
    <participant id="Participant_Commission" name="Commission" processRef="Process_Commission" />
  </collaboration>

  <process id="Process_MemberStates" isExecutable="false">
    <startEvent id="Start_MS" name="Process starts">
      <outgoing>Flow_MS_1</outgoing>
    </startEvent>
    <sequenceFlow id="Flow_MS_1" sourceRef="Start_MS" targetRef="Gateway_MS_Split" />

    <parallelGateway id="Gateway_MS_Split">
      <incoming>Flow_MS_1</incoming>
      <outgoing>Flow_MS_T1</outgoing>
      <outgoing>Flow_MS_T2</outgoing>
      <outgoing>Flow_MS_T3</outgoing>
      <outgoing>Flow_MS_T4</outgoing>
      <outgoing>Flow_MS_T5</outgoing>
      <outgoing>Flow_MS_T6</outgoing>
      <outgoing>Flow_MS_T7</outgoing>
      <outgoing>Flow_MS_T8</outgoing>
      <outgoing>Flow_MS_T9</outgoing>
      <outgoing>Flow_MS_T10</outgoing>
      <outgoing>Flow_MS_T11</outgoing>
    </parallelGateway>

    <task id="Task_MS_1" name="Ensure entities notify CSIRT/CA">
      <incoming>Flow_MS_T1</incoming>
      <outgoing>Flow_MS_J1</outgoing>
    </task>
    <task id="Task_MS_2" name="Ensure entities report cross-border info">
      <incoming>Flow_MS_T2</incoming>
      <outgoing>Flow_MS_J2</outgoing>
    </task>
    <task id="Task_MS_3" name="Ensure CA forwards notification">
      <incoming>Flow_MS_T3</incoming>
      <outgoing>Flow_MS_J3</outgoing>
    </task>
    <task id="Task_MS_4" name="Ensure SPOCs provided with info">
      <incoming>Flow_MS_T4</incoming>
      <outgoing>Flow_MS_J4</outgoing>
    </task>
    <task id="Task_MS_5" name="Ensure entities communicate measures to recipients">
      <incoming>Flow_MS_T5</incoming>
      <outgoing>Flow_MS_J5</outgoing>
    </task>
    <task id="Task_MS_6" name="Ensure entities submit early warning">
      <incoming>Flow_MS_T6</incoming>
      <outgoing>Flow_MS_J6</outgoing>
    </task>
    <task id="Task_MS_7" name="Ensure entities submit incident notification">
      <incoming>Flow_MS_T7</incoming>
      <outgoing>Flow_MS_J7</outgoing>
    </task>
    <task id="Task_MS_8" name="Ensure entities submit intermediate report">
      <incoming>Flow_MS_T8</incoming>
      <outgoing>Flow_MS_J8</outgoing>
    </task>
    <task id="Task_MS_9" name="Ensure entities submit final report">
      <incoming>Flow_MS_T9</incoming>
      <outgoing>Flow_MS_J9</outgoing>
    </task>
    <task id="Task_MS_10" name="Ensure entities provide progress report">
      <incoming>Flow_MS_T10</incoming>
      <outgoing>Flow_MS_J10</outgoing>
    </task>
    <task id="Task_MS_11" name="Ensure entities provide final report for ongoing">
      <incoming>Flow_MS_T11</incoming>
      <outgoing>Flow_MS_J11</outgoing>
    </task>

    <sequenceFlow id="Flow_MS_T1" sourceRef="Gateway_MS_Split" targetRef="Task_MS_1" />
    <sequenceFlow id="Flow_MS_T2" sourceRef="Gateway_MS_Split" targetRef="Task_MS_2" />
    <sequenceFlow id="Flow_MS_T3" sourceRef="Gateway_MS_Split" targetRef="Task_MS_3" />
    <sequenceFlow id="Flow_MS_T4" sourceRef="Gateway_MS_Split" targetRef="Task_MS_4" />
    <sequenceFlow id="Flow_MS_T5" sourceRef="Gateway_MS_Split" targetRef="Task_MS_5" />
    <sequenceFlow id="Flow_MS_T6" sourceRef="Gateway_MS_Split" targetRef="Task_MS_6" />
    <sequenceFlow id="Flow_MS_T7" sourceRef="Gateway_MS_Split" targetRef="Task_MS_7" />
    <sequenceFlow id="Flow_MS_T8" sourceRef="Gateway_MS_Split" targetRef="Task_MS_8" />
    <sequenceFlow id="Flow_MS_T9" sourceRef="Gateway_MS_Split" targetRef="Task_MS_9" />
    <sequenceFlow id="Flow_MS_T10" sourceRef="Gateway_MS_Split" targetRef="Task_MS_10" />
    <sequenceFlow id="Flow_MS_T11" sourceRef="Gateway_MS_Split" targetRef="Task_MS_11" />

    <parallelGateway id="Gateway_MS_Join">
      <incoming>Flow_MS_J1</incoming>
      <incoming>Flow_MS_J2</incoming>
      <incoming>Flow_MS_J3</incoming>
      <incoming>Flow_MS_J4</incoming>
      <incoming>Flow_MS_J5</incoming>
      <incoming>Flow_MS_J6</incoming>
      <incoming>Flow_MS_J7</incoming>
      <incoming>Flow_MS_J8</incoming>
      <incoming>Flow_MS_J9</incoming>
      <incoming>Flow_MS_J10</incoming>
      <incoming>Flow_MS_J11</incoming>
      <outgoing>Flow_MS_Join_Out</outgoing>
    </parallelGateway>

    <sequenceFlow id="Flow_MS_J1" sourceRef="Task_MS_1" targetRef="Gateway_MS_Join" />
    <sequenceFlow id="Flow_MS_J2" sourceRef="Task_MS_2" targetRef="Gateway_MS_Join" />
    <sequenceFlow id="Flow_MS_J3" sourceRef="Task_MS_3" targetRef="Gateway_MS_Join" />
    <sequenceFlow id="Flow_MS_J4" sourceRef="Task_MS_4" targetRef="Gateway_MS_Join" />
    <sequenceFlow id="Flow_MS_J5" sourceRef="Task_MS_5" targetRef="Gateway_MS_Join" />
    <sequenceFlow id="Flow_MS_J6" sourceRef="Task_MS_6" targetRef="Gateway_MS_Join" />
    <sequenceFlow id="Flow_MS_J7" sourceRef="Task_MS_7" targetRef="Gateway_MS_Join" />
    <sequenceFlow id="Flow_MS_J8" sourceRef="Task_MS_8" targetRef="Gateway_MS_Join" />
    <sequenceFlow id="Flow_MS_J9" sourceRef="Task_MS_9" targetRef="Gateway_MS_Join" />
    <sequenceFlow id="Flow_MS_J10" sourceRef="Task_MS_10" targetRef="Gateway_MS_Join" />
    <sequenceFlow id="Flow_MS_J11" sourceRef="Task_MS_11" targetRef="Gateway_MS_Join" />

    <task id="Task_MS_12" name="Ensure act of notification does not increase liability">
      <incoming>Flow_MS_Join_Out</incoming>
      <outgoing>Flow_MS_End</outgoing>
    </task>
    <sequenceFlow id="Flow_MS_Join_Out" sourceRef="Gateway_MS_Join" targetRef="Task_MS_12" />

    <endEvent id="End_MS" name="Reporting obligations established">
      <incoming>Flow_MS_End</incoming>
    </endEvent>
    <sequenceFlow id="Flow_MS_End" sourceRef="Task_MS_12" targetRef="End_MS" />
  </process>

  <process id="Process_Entities" isExecutable="false">
    <startEvent id="Start_Ent" name="Process starts">
      <outgoing>Flow_Ent_1</outgoing>
    </startEvent>

    <task id="Task_Ent_1" name="Assess incident severity">
      <incoming>Flow_Ent_1</incoming>
      <outgoing>Flow_Ent_2</outgoing>
    </task>
    <sequenceFlow id="Flow_Ent_1" sourceRef="Start_Ent" targetRef="Task_Ent_1" />

    <task id="Task_Ent_2" name="Consider incident significant">
      <incoming>Flow_Ent_2</incoming>
      <outgoing>Flow_Ent_3</outgoing>
    </task>
    <sequenceFlow id="Flow_Ent_2" sourceRef="Task_Ent_1" targetRef="Task_Ent_2" />

    <task id="Task_Ent_3" name="Send notification to CSIRT/CA">
      <incoming>Flow_Ent_3</incoming>
      <outgoing>Flow_Ent_4</outgoing>
    </task>
    <sequenceFlow id="Flow_Ent_3" sourceRef="Task_Ent_2" targetRef="Task_Ent_3" />

    <task id="Task_Ent_4" name="Report cross-border info">
      <incoming>Flow_Ent_4</incoming>
      <outgoing>Flow_Ent_5</outgoing>
    </task>
    <sequenceFlow id="Flow_Ent_4" sourceRef="Task_Ent_3" targetRef="Task_Ent_4" />

    <task id="Task_Ent_5" name="Assess appropriate to notify recipients">
      <incoming>Flow_Ent_5</incoming>
      <outgoing>Flow_Ent_6</outgoing>
    </task>
    <sequenceFlow id="Flow_Ent_5" sourceRef="Task_Ent_4" targetRef="Task_Ent_5" />

    <task id="Task_Ent_6" name="Notify recipients of services">
      <incoming>Flow_Ent_6</incoming>
      <outgoing>Flow_Ent_7</outgoing>
    </task>
    <sequenceFlow id="Flow_Ent_6" sourceRef="Task_Ent_5" targetRef="Task_Ent_6" />

    <task id="Task_Ent_7" name="Communicate measures or remedies">
      <incoming>Flow_Ent_7</incoming>
      <outgoing>Flow_Ent_8</outgoing>
    </task>
    <sequenceFlow id="Flow_Ent_7" sourceRef="Task_Ent_6" targetRef="Task_Ent_7" />

    <task id="Task_Ent_8" name="Assess inform recipients of threat">
      <incoming>Flow_Ent_8</incoming>
      <outgoing>Flow_Ent_9</outgoing>
    </task>
    <sequenceFlow id="Flow_Ent_8" sourceRef="Task_Ent_7" targetRef="Task_Ent_8" />

    <task id="Task_Ent_9" name="Inform recipients of threat">
      <incoming>Flow_Ent_9</incoming>
      <outgoing>Flow_Ent_10</outgoing>
    </task>
    <sequenceFlow id="Flow_Ent_9" sourceRef="Task_Ent_8" targetRef="Task_Ent_9" />

    <task id="Task_Ent_10" name="Send early warning to CSIRT/CA">
      <incoming>Flow_Ent_10</incoming>
      <outgoing>Flow_Ent_11</outgoing>
    </task>
    <sequenceFlow id="Flow_Ent_10" sourceRef="Task_Ent_9" targetRef="Task_Ent_10" />

    <task id="Task_Ent_11" name="Indicate suspicion of malicious acts">
      <incoming>Flow_Ent_11</incoming>
      <outgoing>Flow_Ent_12</outgoing>
    </task>
    <sequenceFlow id="Flow_Ent_11" sourceRef="Task_Ent_10" targetRef="Task_Ent_11" />

    <task id="Task_Ent_12" name="Assess if trust service provider">
      <incoming>Flow_Ent_12</incoming>
      <outgoing>Flow_Ent_13</outgoing>
    </task>
    <sequenceFlow id="Flow_Ent_12" sourceRef="Task_Ent_11" targetRef="Task_Ent_12" />

    <task id="Task_Ent_13" name="Send incident notification">
      <incoming>Flow_Ent_13</incoming>
      <outgoing>Flow_Ent_14</outgoing>
    </task>
    <sequenceFlow id="Flow_Ent_13" sourceRef="Task_Ent_12" targetRef="Task_Ent_13" />

    <task id="Task_Ent_14" name="Update notification info">
      <incoming>Flow_Ent_14</incoming>
      <outgoing>Flow_Ent_15</outgoing>
    </task>
    <sequenceFlow id="Flow_Ent_14" sourceRef="Task_Ent_13" targetRef="Task_Ent_14" />

    <task id="Task_Ent_15" name="Indicate initial assessment">
      <incoming>Flow_Ent_15</incoming>
      <outgoing>Flow_Ent_16</outgoing>
    </task>
    <sequenceFlow id="Flow_Ent_15" sourceRef="Task_Ent_14" targetRef="Task_Ent_15" />

    <task id="Task_Ent_16" name="Indicate severity and impact">
      <incoming>Flow_Ent_16</incoming>
      <outgoing>Flow_Ent_17</outgoing>
    </task>
    <sequenceFlow id="Flow_Ent_16" sourceRef="Task_Ent_15" targetRef="Task_Ent_16" />

    <task id="Task_Ent_17" name="Indicate indicators of compromise">
      <incoming>Flow_Ent_17</incoming>
      <outgoing>Flow_Ent_18</outgoing>
    </task>
    <sequenceFlow id="Flow_Ent_17" sourceRef="Task_Ent_16" targetRef="Task_Ent_17" />

    <task id="Task_Ent_18" name="Send intermediate report upon request">
      <incoming>Flow_Ent_18</incoming>
      <outgoing>Flow_Ent_19</outgoing>
    </task>
    <sequenceFlow id="Flow_Ent_18" sourceRef="Task_Ent_17" targetRef="Task_Ent_18" />

    <task id="Task_Ent_19" name="Send final report">
      <incoming>Flow_Ent_19</incoming>
      <outgoing>Flow_Ent_20</outgoing>
    </task>
    <sequenceFlow id="Flow_Ent_19" sourceRef="Task_Ent_18" targetRef="Task_Ent_19" />

    <parallelGateway id="Gateway_Ent_Split">
      <incoming>Flow_Ent_20</incoming>
      <outgoing>Flow_Ent_T1</outgoing>
      <outgoing>Flow_Ent_T2</outgoing>
      <outgoing>Flow_Ent_T3</outgoing>
      <outgoing>Flow_Ent_T4</outgoing>
    </parallelGateway>
    <sequenceFlow id="Flow_Ent_20" sourceRef="Task_Ent_19" targetRef="Gateway_Ent_Split" />

    <task id="Task_Ent_20" name="Include detailed description"><incoming>Flow_Ent_T1</incoming><outgoing>Flow_Ent_J1</outgoing></task>
    <task id="Task_Ent_21" name="Include type of threat"><incoming>Flow_Ent_T2</incoming><outgoing>Flow_Ent_J2</outgoing></task>
    <task id="Task_Ent_22" name="Include mitigation measures"><incoming>Flow_Ent_T3</incoming><outgoing>Flow_Ent_J3</outgoing></task>
    <task id="Task_Ent_23" name="Include cross-border impact"><incoming>Flow_Ent_T4</incoming><outgoing>Flow_Ent_J4</outgoing></task>

    <sequenceFlow id="Flow_Ent_T1" sourceRef="Gateway_Ent_Split" targetRef="Task_Ent_20" />
    <sequenceFlow id="Flow_Ent_T2" sourceRef="Gateway_Ent_Split" targetRef="Task_Ent_21" />
    <sequenceFlow id="Flow_Ent_T3" sourceRef="Gateway_Ent_Split" targetRef="Task_Ent_22" />
    <sequenceFlow id="Flow_Ent_T4" sourceRef="Gateway_Ent_Split" targetRef="Task_Ent_23" />

    <parallelGateway id="Gateway_Ent_Join">
      <incoming>Flow_Ent_J1</incoming>
      <incoming>Flow_Ent_J2</incoming>
      <incoming>Flow_Ent_J3</incoming>
      <incoming>Flow_Ent_J4</incoming>
      <outgoing>Flow_Ent_21</outgoing>
    </parallelGateway>

    <sequenceFlow id="Flow_Ent_J1" sourceRef="Task_Ent_20" targetRef="Gateway_Ent_Join" />
    <sequenceFlow id="Flow_Ent_J2" sourceRef="Task_Ent_21" targetRef="Gateway_Ent_Join" />
    <sequenceFlow id="Flow_Ent_J3" sourceRef="Task_Ent_22" targetRef="Gateway_Ent_Join" />
    <sequenceFlow id="Flow_Ent_J4" sourceRef="Task_Ent_23" targetRef="Gateway_Ent_Join" />

    <task id="Task_Ent_24" name="Assess ongoing incident">
      <incoming>Flow_Ent_21</incoming>
      <outgoing>Flow_Ent_22</outgoing>
    </task>
    <sequenceFlow id="Flow_Ent_21" sourceRef="Gateway_Ent_Join" targetRef="Task_Ent_24" />

    <task id="Task_Ent_25" name="Send progress report for ongoing">
      <incoming>Flow_Ent_22</incoming>
      <outgoing>Flow_Ent_23</outgoing>
    </task>
    <sequenceFlow id="Flow_Ent_22" sourceRef="Task_Ent_24" targetRef="Task_Ent_25" />

    <task id="Task_Ent_26" name="Inform public upon requirement">
      <incoming>Flow_Ent_23</incoming>
      <outgoing>Flow_Ent_End</outgoing>
    </task>
    <sequenceFlow id="Flow_Ent_23" sourceRef="Task_Ent_25" targetRef="Task_Ent_26" />

    <endEvent id="End_Ent" name="Reporting completed">
      <incoming>Flow_Ent_End</incoming>
    </endEvent>
    <sequenceFlow id="Flow_Ent_End" sourceRef="Task_Ent_26" targetRef="End_Ent" />
  </process>

  <process id="Process_CompetentAuthority" isExecutable="false">
    <startEvent id="Start_CA" name="Process starts">
      <outgoing>Flow_CA_1</outgoing>
    </startEvent>

    <task id="Task_CA_1" name="Send notification to CSIRT">
      <incoming>Flow_CA_1</incoming>
      <outgoing>Flow_CA_2</outgoing>
    </task>
    <sequenceFlow id="Flow_CA_1" sourceRef="Start_CA" targetRef="Task_CA_1" />

    <task id="Task_CA_2" name="Provide response to notifying entity">
      <incoming>Flow_CA_2</incoming>
      <outgoing>Flow_CA_3</outgoing>
    </task>
    <sequenceFlow id="Flow_CA_2" sourceRef="Task_CA_1" targetRef="Task_CA_2" />

    <task id="Task_CA_3" name="Include initial feedback">
      <incoming>Flow_CA_3</incoming>
      <outgoing>Flow_CA_4</outgoing>
    </task>
    <sequenceFlow id="Flow_CA_3" sourceRef="Task_CA_2" targetRef="Task_CA_3" />

    <task id="Task_CA_4" name="Provide guidance on mitigation">
      <incoming>Flow_CA_4</incoming>
      <outgoing>Flow_CA_5</outgoing>
    </task>
    <sequenceFlow id="Flow_CA_4" sourceRef="Task_CA_3" targetRef="Task_CA_4" />

    <task id="Task_CA_5" name="Assess if CSIRT is not initial recipient">
      <incoming>Flow_CA_5</incoming>
      <outgoing>Flow_CA_6</outgoing>
    </task>
    <sequenceFlow id="Flow_CA_5" sourceRef="Task_CA_4" targetRef="Task_CA_5" />

    <task id="Task_CA_6" name="Provide guidance in cooperation with CSIRT">
      <incoming>Flow_CA_6</incoming>
      <outgoing>Flow_CA_7</outgoing>
    </task>
    <sequenceFlow id="Flow_CA_6" sourceRef="Task_CA_5" targetRef="Task_CA_6" />

    <task id="Task_CA_7" name="Assess criminal nature">
      <incoming>Flow_CA_7</incoming>
      <outgoing>Flow_CA_8</outgoing>
    </task>
    <sequenceFlow id="Flow_CA_7" sourceRef="Task_CA_6" targetRef="Task_CA_7" />

    <task id="Task_CA_8" name="Provide guidance on law enforcement">
      <incoming>Flow_CA_8</incoming>
      <outgoing>Flow_CA_9</outgoing>
    </task>
    <sequenceFlow id="Flow_CA_8" sourceRef="Task_CA_7" targetRef="Task_CA_8" />

    <task id="Task_CA_9" name="Assess cross-border concerns">
      <incoming>Flow_CA_9</incoming>
      <outgoing>Flow_CA_10</outgoing>
    </task>
    <sequenceFlow id="Flow_CA_9" sourceRef="Task_CA_8" targetRef="Task_CA_9" />

    <parallelGateway id="Gateway_CA_Split">
      <incoming>Flow_CA_10</incoming>
      <outgoing>Flow_CA_T1</outgoing>
      <outgoing>Flow_CA_T2</outgoing>
    </parallelGateway>
    <sequenceFlow id="Flow_CA_10" sourceRef="Task_CA_9" targetRef="Gateway_CA_Split" />

    <task id="Task_CA_10" name="Inform affected Member States"><incoming>Flow_CA_T1</incoming><outgoing>Flow_CA_J1</outgoing></task>
    <task id="Task_CA_11" name="Inform ENISA"><incoming>Flow_CA_T2</incoming><outgoing>Flow_CA_J2</outgoing></task>

    <sequenceFlow id="Flow_CA_T1" sourceRef="Gateway_CA_Split" targetRef="Task_CA_10" />
    <sequenceFlow id="Flow_CA_T2" sourceRef="Gateway_CA_Split" targetRef="Task_CA_11" />

    <parallelGateway id="Gateway_CA_Join">
      <incoming>Flow_CA_J1</incoming>
      <incoming>Flow_CA_J2</incoming>
      <outgoing>Flow_CA_11</outgoing>
    </parallelGateway>
    <sequenceFlow id="Flow_CA_J1" sourceRef="Task_CA_10" targetRef="Gateway_CA_Join" />
    <sequenceFlow id="Flow_CA_J2" sourceRef="Task_CA_11" targetRef="Gateway_CA_Join" />

    <task id="Task_CA_12" name="Include info type and preserve security">
      <incoming>Flow_CA_11</incoming>
      <outgoing>Flow_CA_13</outgoing>
    </task>
    <sequenceFlow id="Flow_CA_11" sourceRef="Gateway_CA_Join" targetRef="Task_CA_12" />

    <task id="Task_CA_13" name="Assess public awareness necessary">
      <incoming>Flow_CA_13</incoming>
      <outgoing>Flow_CA_14</outgoing>
    </task>
    <sequenceFlow id="Flow_CA_13" sourceRef="Task_CA_12" targetRef="Task_CA_13" />

    <task id="Task_CA_14" name="Inform public and send requirements">
      <incoming>Flow_CA_14</incoming>
      <outgoing>Flow_CA_15</outgoing>
    </task>
    <sequenceFlow id="Flow_CA_14" sourceRef="Task_CA_13" targetRef="Task_CA_14" />

    <task id="Task_CA_15" name="Provide info to competent authorities">
      <incoming>Flow_CA_15</incoming>
      <outgoing>Flow_CA_End</outgoing>
    </task>
    <sequenceFlow id="Flow_CA_15" sourceRef="Task_CA_14" targetRef="Task_CA_15" />

    <endEvent id="End_CA" name="Incident handled">
      <incoming>Flow_CA_End</incoming>
    </endEvent>
    <sequenceFlow id="Flow_CA_End" sourceRef="Task_CA_15" targetRef="End_CA" />
  </process>

  <process id="Process_CSIRT" isExecutable="false">
    <startEvent id="Start_CSIRT" name="Process starts">
      <outgoing>Flow_CS_1</outgoing>
    </startEvent>

    <task id="Task_CS_1" name="Process notification">
      <incoming>Flow_CS_1</incoming>
      <outgoing>Flow_CS_2</outgoing>
    </task>
    <sequenceFlow id="Flow_CS_1" sourceRef="Start_CSIRT" targetRef="Task_CS_1" />

    <task id="Task_CS_2" name="Provide response with initial feedback">
      <incoming>Flow_CS_2</incoming>
      <outgoing>Flow_CS_3</outgoing>
    </task>
    <sequenceFlow id="Flow_CS_2" sourceRef="Task_CS_1" targetRef="Task_CS_2" />

    <task id="Task_CS_3" name="Provide guidance and technical support">
      <incoming>Flow_CS_3</incoming>
      <outgoing>Flow_CS_4</outgoing>
    </task>
    <sequenceFlow id="Flow_CS_3" sourceRef="Task_CS_2" targetRef="Task_CS_3" />

    <task id="Task_CS_4" name="Assess criminal nature and inform">
      <incoming>Flow_CS_4</incoming>
      <outgoing>Flow_CS_5</outgoing>
    </task>
    <sequenceFlow id="Flow_CS_4" sourceRef="Task_CS_3" targetRef="Task_CS_4" />

    <task id="Task_CS_5" name="Assess cross-border concerns">
      <incoming>Flow_CS_5</incoming>
      <outgoing>Flow_CS_6</outgoing>
    </task>
    <sequenceFlow id="Flow_CS_5" sourceRef="Task_CS_4" targetRef="Task_CS_5" />

    <parallelGateway id="Gateway_CS_Split">
      <incoming>Flow_CS_6</incoming>
      <outgoing>Flow_CS_T1</outgoing>
      <outgoing>Flow_CS_T2</outgoing>
    </parallelGateway>
    <sequenceFlow id="Flow_CS_6" sourceRef="Task_CS_5" targetRef="Gateway_CS_Split" />

    <task id="Task_CS_6" name="Inform affected Member States"><incoming>Flow_CS_T1</incoming><outgoing>Flow_CS_J1</outgoing></task>
    <task id="Task_CS_7" name="Inform ENISA"><incoming>Flow_CS_T2</incoming><outgoing>Flow_CS_J2</outgoing></task>

    <sequenceFlow id="Flow_CS_T1" sourceRef="Gateway_CS_Split" targetRef="Task_CS_6" />
    <sequenceFlow id="Flow_CS_T2" sourceRef="Gateway_CS_Split" targetRef="Task_CS_7" />

    <parallelGateway id="Gateway_CS_Join">
      <incoming>Flow_CS_J1</incoming>
      <incoming>Flow_CS_J2</incoming>
      <outgoing>Flow_CS_7</outgoing>
    </parallelGateway>
