                <omgdc:Bounds x="620" y="110" width="100" height="80"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape id="Shape_GW_C2" bpmnElement="GW_C2">
                <omgdc:Bounds x="770" y="130" width="40" height="40"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape id="Shape_Task_C4" bpmnElement="Task_C4">
                <omgdc:Bounds x="860" y="110" width="100" height="80"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape id="Shape_GW_C2_Merge" bpmnElement="GW_C2_Merge">
                <omgdc:Bounds x="1010" y="130" width="40" height="40"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape id="Shape_Catch_C1" bpmnElement="Catch_C1">
                <omgdc:Bounds x="1100" y="135" width="30" height="30"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape id="Shape_Task_C5" bpmnElement="Task_C5">
                <omgdc:Bounds x="1180" y="110" width="100" height="80"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape id="Shape_Task_C6" bpmnElement="Task_C6">
                <omgdc:Bounds x="1330" y="110" width="100" height="80"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape id="Shape_Task_C7" bpmnElement="Task_C7">
                <omgdc:Bounds x="1480" y="110" width="100" height="80"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape id="Shape_GW_C3" bpmnElement="GW_C3">
                <omgdc:Bounds x="1630" y="130" width="40" height="40"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape id="Shape_Task_C8" bpmnElement="Task_C8">
                <omgdc:Bounds x="1720" y="110" width="100" height="80"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape id="Shape_End_C" bpmnElement="End_C">
                <omgdc:Bounds x="1870" y="135" width="30" height="30"/>
            </bpmndi:BPMNShape>

            <bpmndi:BPMNShape id="Shape_Participant_ECCG" bpmnElement="Participant_ECCG" isHorizontal="true">
                <omgdc:Bounds x="100" y="300" width="2800" height="200"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape id="Shape_Start_E" bpmnElement="Start_E">
                <omgdc:Bounds x="150" y="385" width="30" height="30"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape id="Shape_Task_E1" bpmnElement="Task_E1">
                <omgdc:Bounds x="230" y="360" width="100" height="80"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape id="Shape_GW_E1" bpmnElement="GW_E1">
                <omgdc:Bounds x="380" y="380" width="40" height="40"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape id="Shape_Task_E2" bpmnElement="Task_E2">
                <omgdc:Bounds x="470" y="360" width="100" height="80"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape id="Shape_GW_E1_Merge" bpmnElement="GW_E1_Merge">
                <omgdc:Bounds x="620" y="380" width="40" height="40"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape id="Shape_Catch_E1" bpmnElement="Catch_E1">
                <omgdc:Bounds x="710" y="385" width="30" height="30"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape id="Shape_Task_E3" bpmnElement="Task_E3">
                <omgdc:Bounds x="790" y="360" width="100" height="80"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape id="Shape_Task_E4" bpmnElement="Task_E4">
                <omgdc:Bounds x="940" y="360" width="100" height="80"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape id="Shape_Task_E5" bpmnElement="Task_E5">
                <omgdc:Bounds x="1090" y="360" width="100" height="80"/>
