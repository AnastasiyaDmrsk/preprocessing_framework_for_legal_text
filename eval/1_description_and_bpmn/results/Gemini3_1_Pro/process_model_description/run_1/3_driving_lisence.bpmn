   <process id="Process_COM" isExecutable="true">
      <startEvent id="start_com" name="Start">
         <outgoing>s_com_1</outgoing>
      </startEvent>
      <parallelGateway id="gw_com_split">
         <incoming>s_com_1</incoming>
         <outgoing>s_com_2</outgoing>
         <outgoing>s_com_3</outgoing>
      </parallelGateway>
      <intermediateCatchEvent id="ev_com_msg1" name="Receive adopted guidelines">
         <incoming>s_com_2</incoming>
         <outgoing>s_com_4</outgoing>
         <messageEventDefinition id="med2" />
      </intermediateCatchEvent>
      <task id="t_com1" name="Make guidelines available">
         <incoming>s_com_4</incoming>
         <outgoing>s_com_5</outgoing>
      </task>
      <intermediateCatchEvent id="ev_com_msg2" name="Receive developed campaigns">
         <incoming>s_com_3</incoming>
         <outgoing>s_com_6</outgoing>
         <messageEventDefinition id="med3" />
      </intermediateCatchEvent>
      <task id="t_com2" name="Make information available">
         <incoming>s_com_6</incoming>
         <outgoing>s_com_7</outgoing>
      </task>
      <parallelGateway id="join_com">
         <incoming>s_com_5</incoming>
         <incoming>s_com_7</incoming>
         <outgoing>s_com_8</outgoing>
      </parallelGateway>
      <endEvent id="end_com" name="information distributed">
         <incoming>s_com_8</incoming>
      </endEvent>
      <sequenceFlow id="s_com_1" sourceRef="start_com" targetRef="gw_com_split" />
      <sequenceFlow id="s_com_2" sourceRef="gw_com_split" targetRef="ev_com_msg1" />
      <sequenceFlow id="s_com_3" sourceRef="gw_com_split" targetRef="ev_com_msg2" />
      <sequenceFlow id="s_com_4" sourceRef="ev_com_msg1" targetRef="t_com1" />
      <sequenceFlow id="s_com_5" sourceRef="t_com1" targetRef="join_com" />
      <sequenceFlow id="s_com_6" sourceRef="ev_com_msg2" targetRef="t_com2" />
      <sequenceFlow id="s_com_7" sourceRef="t_com2" targetRef="join_com" />
      <sequenceFlow id="s_com_8" sourceRef="join_com" targetRef="end_com" />
   </process>

