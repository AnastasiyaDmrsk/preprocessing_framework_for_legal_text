   <process id="Process_AH" isExecutable="true">
      <startEvent id="start_ah" name="Start">
         <outgoing>s_ah_1</outgoing>
      </startEvent>
      <task id="t_ah1" name="Undergo medical examination">
         <incoming>s_ah_1</incoming>
         <outgoing>s_ah_2</outgoing>
      </task>
      <task id="t_ah2" name="Assess renewal category AM">
         <incoming>s_ah_2</incoming>
         <outgoing>s_ah_3</outgoing>
      </task>
      <exclusiveGateway id="gw_ah1" name="Category AM?">
         <incoming>s_ah_3</incoming>
         <outgoing>s_ah_4</outgoing>
         <outgoing>s_ah_5</outgoing>
      </exclusiveGateway>
      <task id="t_ah3" name="Undergo medical examination if required">
         <incoming>s_ah_4</incoming>
         <outgoing>s_ah_6</outgoing>
      </task>
      <exclusiveGateway id="join_ah1">
         <incoming>s_ah_5</incoming>
         <incoming>s_ah_6</incoming>
         <outgoing>s_ah_7</outgoing>
      </exclusiveGateway>
      <intermediateCatchEvent id="ev_ah_msg" name="Receive requirement">
         <incoming>s_ah_7</incoming>
         <outgoing>s_ah_8</outgoing>
         <messageEventDefinition id="med1" />
      </intermediateCatchEvent>
      <task id="t_ah4" name="Fill self-assessment form">
         <incoming>s_ah_8</incoming>
         <outgoing>s_ah_9</outgoing>
      </task>
      <endEvent id="end_ah" name="application requirements fulfilled">
         <incoming>s_ah_9</incoming>
      </endEvent>
