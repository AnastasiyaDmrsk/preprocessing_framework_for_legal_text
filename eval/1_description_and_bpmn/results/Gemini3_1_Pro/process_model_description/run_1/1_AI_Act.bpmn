<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" 
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" 
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" 
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" 
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
             targetNamespace="http://www.signavio.com" 
             xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd"
             id="Definitions_1">

  <collaboration id="Collaboration_1">
    <participant id="Participant_MemberStates" name="Member States" processRef="Process_MemberStates" />
    <participant id="Participant_Board" name="The Board" processRef="Process_Board" />
    <participant id="Participant_AIOffice" name="The AI Office" processRef="Process_AIOffice" />
    <messageFlow id="MessageFlow_Request" sourceRef="Task_SendRequest" targetRef="Event_ReceiveRequest" />
  </collaboration>

  <process id="Process_MemberStates" isExecutable="true">
    <startEvent id="StartEvent_MS" name="Obligation to implement measures starts">
      <outgoing>Flow_MS_1</outgoing>
    </startEvent>
    
    <sequenceFlow id="Flow_MS_1" sourceRef="StartEvent_MS" targetRef="Gateway_MS_Split" />
    <parallelGateway id="Gateway_MS_Split">
      <incoming>Flow_MS_1</incoming>
      <outgoing>Flow_MS_Branch1</outgoing>
      <outgoing>Flow_MS_Branch2</outgoing>
      <outgoing>Flow_MS_Branch3</outgoing>
      <outgoing>Flow_MS_Branch4</outgoing>
      <outgoing>Flow_MS_Branch5</outgoing>
    </parallelGateway>

    <sequenceFlow id="Flow_MS_Branch1" sourceRef="Gateway_MS_Split" targetRef="Task_AssessSME" />
    <task id="Task_AssessSME" name="Assess whether SMEs fulfil conditions">
      <incoming>Flow_MS_Branch1</incoming>
      <outgoing>Flow_MS_B1_1</outgoing>
    </task>
    <sequenceFlow id="Flow_MS_B1_1" sourceRef="Task_AssessSME" targetRef="Gateway_SME_XOR" />
    <exclusiveGateway id="Gateway_SME_XOR" name="SMEs fulfil conditions?">
      <incoming>Flow_MS_B1_1</incoming>
      <outgoing>Flow_SME_Yes</outgoing>
      <outgoing>Flow_SME_No</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="Flow_SME_Yes" name="Yes" sourceRef="Gateway_SME_XOR" targetRef="Task_ProvidePriority" />
    <sequenceFlow id="Flow_SME_No" name="No" sourceRef="Gateway_SME_XOR" targetRef="Gateway_SME_Merge" />
    <task id="Task_ProvidePriority" name="Provide SMEs with priority access">
      <incoming>Flow_SME_Yes</incoming>
      <outgoing>Flow_SME_Yes_Out</outgoing>
    </task>
    <sequenceFlow id="Flow_SME_Yes_Out" sourceRef="Task_ProvidePriority" targetRef="Gateway_SME_Merge" />
    <exclusiveGateway id="Gateway_SME_Merge">
      <incoming>Flow_SME_No</incoming>
      <incoming>Flow_SME_Yes_Out</incoming>
      <outgoing>Flow_MS_B1_2</outgoing>
    </exclusiveGateway>
    
    <sequenceFlow id="Flow_MS_B1_2" sourceRef="Gateway_SME_Merge" targetRef="Task_AssessOtherSME" />
    <task id="Task_AssessOtherSME" name="Assess whether other SMEs fulfil conditions">
      <incoming>Flow_MS_B1_2</incoming>
      <outgoing>Flow_MS_B1_3</outgoing>
    </task>
    <sequenceFlow id="Flow_MS_B1_3" sourceRef="Task_AssessOtherSME" targetRef="Gateway_OtherSME_XOR" />
    <exclusiveGateway id="Gateway_OtherSME_XOR" name="Other SMEs fulfil?">
      <incoming>Flow_MS_B1_3</incoming>
      <outgoing>Flow_OtherSME_Yes</outgoing>
      <outgoing>Flow_OtherSME_No</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="Flow_OtherSME_Yes" name="Yes" sourceRef="Gateway_OtherSME_XOR" targetRef="Task_ProvideOtherAccess" />
    <sequenceFlow id="Flow_OtherSME_No" name="No" sourceRef="Gateway_OtherSME_XOR" targetRef="Gateway_OtherSME_Merge" />
    <task id="Task_ProvideOtherAccess" name="Provide other SMEs with access">
      <incoming>Flow_OtherSME_Yes</incoming>
      <outgoing>Flow_OtherSME_Yes_Out</outgoing>
    </task>
    <sequenceFlow id="Flow_OtherSME_Yes_Out" sourceRef="Task_ProvideOtherAccess" targetRef="Gateway_OtherSME_Merge" />
    <exclusiveGateway id="Gateway_OtherSME_Merge">
      <incoming>Flow_OtherSME_No</incoming>
      <incoming>Flow_OtherSME_Yes_Out</incoming>
      <outgoing>Flow_B1_End</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="Flow_B1_End" sourceRef="Gateway_OtherSME_Merge" targetRef="Gateway_MS_Join" />

    <sequenceFlow id="Flow_MS_Branch2" sourceRef="Gateway_MS_Split" targetRef="Task_OrgAwareness" />
    <task id="Task_OrgAwareness" name="Organise awareness raising activities">
      <incoming>Flow_MS_Branch2</incoming>
      <outgoing>Flow_MS_B2_1</outgoing>
    </task>
    <sequenceFlow id="Flow_MS_B2_1" sourceRef="Task_OrgAwareness" targetRef="Task_OrgTraining" />
    <task id="Task_OrgTraining" name="Organise training activities">
      <incoming>Flow_MS_B2_1</incoming>
      <outgoing>Flow_B2_End</outgoing>
    </task>
    <sequenceFlow id="Flow_B2_End" sourceRef="Task_OrgTraining" targetRef="Gateway_MS_Join" />

    <sequenceFlow id="Flow_MS_Branch3" sourceRef="Gateway_MS_Split" targetRef="Task_UtiliseChannels" />
    <task id="Task_UtiliseChannels" name="Utilise existing dedicated channels">
      <incoming>Flow_MS_Branch3</incoming>
      <outgoing>Flow_MS_B3_1</outgoing>
    </task>
    <sequenceFlow id="Flow_MS_B3_1" sourceRef="Task_UtiliseChannels" targetRef="Task_AssessChannels" />
    <task id="Task_AssessChannels" name="Assess whether appropriate to establish new channels">
      <incoming>Flow_MS_B3_1</incoming>
      <outgoing>Flow_MS_B3_2</outgoing>
    </task>
    <sequenceFlow id="Flow_MS_B3_2" sourceRef="Task_AssessChannels" targetRef="Gateway_Channel_XOR" />
    <exclusiveGateway id="Gateway_Channel_XOR" name="Appropriate?">
      <incoming>Flow_MS_B3_2</incoming>
      <outgoing>Flow_Channel_Yes</outgoing>
      <outgoing>Flow_Channel_No</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="Flow_Channel_Yes" name="Yes" sourceRef="Gateway_Channel_XOR" targetRef="Task_EstChannels" />
    <sequenceFlow id="Flow_Channel_No" name="No" sourceRef="Gateway_Channel_XOR" targetRef="Gateway_Channel_Merge" />
    <task id="Task_EstChannels" name="Establish new channels">
      <incoming>Flow_Channel_Yes</incoming>
      <outgoing>Flow_Channel_Yes_Out</outgoing>
    </task>
    <sequenceFlow id="Flow_Channel_Yes_Out" sourceRef="Task_EstChannels" targetRef="Gateway_Channel_Merge" />
    <exclusiveGateway id="Gateway_Channel_Merge">
      <incoming>Flow_Channel_No</incoming>
      <incoming>Flow_Channel_Yes_Out</incoming>
      <outgoing>Flow_MS_B3_3</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="Flow_MS_B3_3" sourceRef="Gateway_Channel_Merge" targetRef="Task_ProvideAdvice" />
    <task id="Task_ProvideAdvice" name="Provide advice about implementation">
      <incoming>Flow_MS_B3_3</incoming>
      <outgoing>Flow_MS_B3_4</outgoing>
    </task>
    <sequenceFlow id="Flow_MS_B3_4" sourceRef="Task_ProvideAdvice" targetRef="Task_RespondQueries" />
    <task id="Task_RespondQueries" name="Respond to queries">
      <incoming>Flow_MS_B3_4</incoming>
      <outgoing>Flow_B3_End</outgoing>
    </task>
    <sequenceFlow id="Flow_B3_End" sourceRef="Task_RespondQueries" targetRef="Gateway_MS_Join" />

    <sequenceFlow id="Flow_MS_Branch4" sourceRef="Gateway_MS_Split" targetRef="Task_FacilitateSME" />
    <task id="Task_FacilitateSME" name="Facilitate participation of SMEs">
      <incoming>Flow_MS_Branch4</incoming>
      <outgoing>Flow_MS_B4_1</outgoing>
    </task>
    <sequenceFlow id="Flow_MS_B4_1" sourceRef="Task_FacilitateSME" targetRef="Task_FacilitateOthers" />
    <task id="Task_FacilitateOthers" name="Facilitate participation of other stakeholders">
      <incoming>Flow_MS_B4_1</incoming>
      <outgoing>Flow_B4_End</outgoing>
    </task>
    <sequenceFlow id="Flow_B4_End" sourceRef="Task_FacilitateOthers" targetRef="Gateway_MS_Join" />

    <sequenceFlow id="Flow_MS_Branch5" sourceRef="Gateway_MS_Split" targetRef="Task_TakeInterests" />
    <task id="Task_TakeInterests" name="Take into account specific interests of SME">
      <incoming>Flow_MS_Branch5</incoming>
      <outgoing>Flow_MS_B5_1</outgoing>
    </task>
    <sequenceFlow id="Flow_MS_B5_1" sourceRef="Task_TakeInterests" targetRef="Task_ReduceFees" />
    <task id="Task_ReduceFees" name="Reduce fees proportionately">
      <incoming>Flow_MS_B5_1</incoming>
      <outgoing>Flow_B5_End</outgoing>
    </task>
    <sequenceFlow id="Flow_B5_End" sourceRef="Task_ReduceFees" targetRef="Gateway_MS_Join" />

    <parallelGateway id="Gateway_MS_Join">
      <incoming>Flow_B1_End</incoming>
      <incoming>Flow_B2_End</incoming>
      <incoming>Flow_B3_End</incoming>
      <incoming>Flow_B4_End</incoming>
      <incoming>Flow_B5_End</incoming>
      <outgoing>Flow_MS_Final</outgoing>
    </parallelGateway>
    <sequenceFlow id="Flow_MS_Final" sourceRef="Gateway_MS_Join" targetRef="EndEvent_MS" />
    
    <endEvent id="EndEvent_MS" name="Measures implemented">
      <incoming>Flow_MS_Final</incoming>
    </endEvent>
  </process>

  <process id="Process_Board" isExecutable="true">
    <startEvent id="StartEvent_Board" name="Obligation to implement measures starts">
      <outgoing>Flow_Board_1</outgoing>
    </startEvent>
    <sequenceFlow id="Flow_Board_1" sourceRef="StartEvent_Board" targetRef="Task_SendRequest" />
    
    <task id="Task_SendRequest" name="Send request specifying standardised templates">
      <incoming>Flow_Board_1</incoming>
      <outgoing>Flow_Board_End</outgoing>
    </task>
    <sequenceFlow id="Flow_Board_End" sourceRef="Task_SendRequest" targetRef="EndEvent_Board" />
    
    <endEvent id="EndEvent_Board" name="Request sent">
      <incoming>Flow_Board_End</incoming>
    </endEvent>
  </process>

  <process id="Process_AIOffice" isExecutable="true">
    <startEvent id="StartEvent_AI" name="Obligation to implement measures starts">
      <outgoing>Flow_AI_1</outgoing>
    </startEvent>
    
    <sequenceFlow id="Flow_AI_1" sourceRef="StartEvent_AI" targetRef="Gateway_AI_Split" />
    <parallelGateway id="Gateway_AI_Split">
      <incoming>Flow_AI_1</incoming>
      <outgoing>Flow_AI_Branch1</outgoing>
      <outgoing>Flow_AI_Branch2</outgoing>
      <outgoing>Flow_AI_Branch3</outgoing>
      <outgoing>Flow_AI_Branch4</outgoing>
    </parallelGateway>

    <sequenceFlow id="Flow_AI_Branch1" sourceRef="Gateway_AI_Split" targetRef="Event_ReceiveRequest" />
    <intermediateCatchEvent id="Event_ReceiveRequest" name="Receive request">
      <incoming>Flow_AI_Branch1</incoming>
      <outgoing>Flow_AI_B1_1</outgoing>
      <messageEventDefinition id="MessageDef_1" />
    </intermediateCatchEvent>
    <sequenceFlow id="Flow_AI_B1_1" sourceRef="Event_ReceiveRequest" targetRef="Task_ProvideTemplates" />
    <task id="Task_ProvideTemplates" name="Provide standardised templates">
      <incoming>Flow_AI_B1_1</incoming>
      <outgoing>Flow_AI_B1_End</outgoing>
    </task>
    <sequenceFlow id="Flow_AI_B1_End" sourceRef="Task_ProvideTemplates" targetRef="Gateway_AI_Join" />

    <sequenceFlow id="Flow_AI_Branch2" sourceRef="Gateway_AI_Split" targetRef="Task_DevPlatform" />
    <task id="Task_DevPlatform" name="Develop single information platform">
      <incoming>Flow_AI_Branch2</incoming>
      <outgoing>Flow_AI_B2_1</outgoing>
    </task>
    <sequenceFlow id="Flow_AI_B2_1" sourceRef="Task_DevPlatform" targetRef="Task_MaintainPlatform" />
    <task id="Task_MaintainPlatform" name="Maintain single information platform">
      <incoming>Flow_AI_B2_1</incoming>
      <outgoing>Flow_AI_B2_End</outgoing>
    </task>
    <sequenceFlow id="Flow_AI_B2_End" sourceRef="Task_MaintainPlatform" targetRef="Gateway_AI_Join" />

    <sequenceFlow id="Flow_AI_Branch3" sourceRef="Gateway_AI_Split" targetRef="Task_OrgCampaigns" />
    <task id="Task_OrgCampaigns" name="Organise appropriate communication campaigns">
      <incoming>Flow_AI_Branch3</incoming>
      <outgoing>Flow_AI_B3_End</outgoing>
    </task>
    <sequenceFlow id="Flow_AI_B3_End" sourceRef="Task_OrgCampaigns" targetRef="Gateway_AI_Join" />

    <sequenceFlow id="Flow_AI_Branch4" sourceRef="Gateway_AI_Split" targetRef="Task_EvalConv" />
    <task id="Task_EvalConv" name="Evaluate convergence of best practices">
      <incoming>Flow_AI_Branch4</incoming>
      <outgoing>Flow_AI_B4_1</outgoing>
    </task>
    <sequenceFlow id="Flow_AI_B4_1" sourceRef="Task_EvalConv" targetRef="Task_PromoteConv" />
    <task id="Task_PromoteConv" name="Promote convergence of best practices">
      <incoming>Flow_AI_B4_1</incoming>
      <outgoing>Flow_AI_B4_End</outgoing>
    </task>
    <sequenceFlow id="Flow_AI_B4_End" sourceRef="Task_PromoteConv" targetRef="Gateway_AI_Join" />

    <parallelGateway id="Gateway_AI_Join">
      <incoming>Flow_AI_B1_End</incoming>
      <incoming>Flow_AI_B2_End</incoming>
      <incoming>Flow_AI_B3_End</incoming>
      <incoming>Flow_AI_B4_End</incoming>
      <outgoing>Flow_AI_Final</outgoing>
    </parallelGateway>
    <sequenceFlow id="Flow_AI_Final" sourceRef="Gateway_AI_Join" targetRef="EndEvent_AI" />
    
    <endEvent id="EndEvent_AI" name="Measures implemented">
      <incoming>Flow_AI_Final</incoming>
    </endEvent>
  </process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane bpmnElement="Collaboration_1" id="BPMNPlane_1">
      <bpmndi:BPMNShape bpmnElement="Participant_MemberStates" id="Shape_Participant_MS" isHorizontal="true">
        <omgdc:Bounds height="500.0" width="1600.0" x="50.0" y="50.0" />
      </bpmndi:BPMNShape>
      
      <bpmndi:BPMNShape bpmnElement="Participant_Board" id="Shape_Participant_Board" isHorizontal="true">
        <omgdc:Bounds height="200.0" width="1600.0" x="50.0" y="580.0" />
      </bpmndi:BPMNShape>
      
      <bpmndi:BPMNShape bpmnElement="Participant_AIOffice" id="Shape_Participant_AI" isHorizontal="true">
        <omgdc:Bounds height="450.0" width="1600.0" x="50.0" y="810.0" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape bpmnElement="StartEvent_MS" id="Shape_StartEvent_MS">
        <omgdc:Bounds height="36.0" width="36.0" x="120.0" y="250.0" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="StartEvent_Board" id="Shape_StartEvent_Board">
        <omgdc:Bounds height="36.0" width="36.0" x="120.0" y="660.0" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="StartEvent_AI" id="Shape_StartEvent_AI">
        <omgdc:Bounds height="36.0" width="36.0" x="120.0" y="1000.0" />
      </bpmndi:BPMNShape>
      
      <bpmndi:BPMNShape bpmnElement="Gateway_MS_Split" id="Shape_Gateway_MS_Split">
        <omgdc:Bounds height="50.0" width="50.0" x="200.0" y="243.0" />
      </bpmndi:BPMNShape>
      
      <bpmndi:BPMNEdge bpmnElement="MessageFlow_Request" id="Edge_MessageFlow_Request">
        <omgdi:waypoint x="400.0" y="700.0" />
        <omgdi:waypoint x="400.0" y="850.0" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</definitions>