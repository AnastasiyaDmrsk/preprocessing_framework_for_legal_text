<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             id="Definitions_1"
             targetNamespace="http://bpmn.io/schema/bpmn"
             exporter="Manual" exporterVersion="1.0">
  <collaboration id="Collaboration_1">
    <participant id="Participant_MemberStates" name="Member States" processRef="Process_MemberStates" />
    <participant id="Participant_Commission" name="The Commission" processRef="Process_Commission" />
    <participant id="Participant_AnotherSB" name="Another supervisory body" processRef="Process_AnotherSB" />
    <participant id="Participant_TSP" name="Trust service providers" processRef="Process_TSP" />
    <participant id="Participant_SB" name="Supervisory body" processRef="Process_SB" />

    <messageFlow id="Flow_Msg_MS_Comm" sourceRef="Task_MS_4" targetRef="Task_C_1" />
    <messageFlow id="Flow_Msg_ASB_SB" sourceRef="Task_ASB_1" targetRef="Task_SB_15" />
    <messageFlow id="Flow_Msg_SB_ASB" sourceRef="Task_SB_17" targetRef="Task_ASB_2" />
    <messageFlow id="Flow_Msg_TSP_SB" sourceRef="Task_TSP_6" targetRef="Task_SB_18" />
    <messageFlow id="Flow_Msg_SB_TSP_Inform" sourceRef="Task_SB_24" targetRef="Task_TSP_9" />
    <messageFlow id="Flow_Msg_SB_TSP_Remedy" sourceRef="Task_SB_14" targetRef="Task_TSP_10" />
    <messageFlow id="Flow_Msg_SB_Comm" sourceRef="Task_SB_25" targetRef="Task_C_2" />
    <messageFlow id="Flow_Msg_Comm_MS" sourceRef="Task_C_3" targetRef="Task_MS_12" />
  </collaboration>

  <process id="Process_MemberStates" isExecutable="true">
    <startEvent id="Start_MS" name="Start Member States Process">
      <outgoing>Flow_MS_1</outgoing>
    </startEvent>
    <task id="Task_MS_1" name="Designate a supervisory body">
      <incoming>Flow_MS_1</incoming>
      <outgoing>Flow_MS_2</outgoing>
    </task>
    <task id="Task_MS_2" name="Give the necessary powers">
      <incoming>Flow_MS_2</incoming>
      <outgoing>Flow_MS_3</outgoing>
    </task>
    <task id="Task_MS_3" name="Give adequate resources">
      <incoming>Flow_MS_3</incoming>
      <outgoing>Flow_MS_4</outgoing>
    </task>
    <task id="Task_MS_4" name="Notify names and addresses to Commission">
      <incoming>Flow_MS_4</incoming>
      <outgoing>Flow_MS_5</outgoing>
    </task>
    <task id="Task_MS_5" name="Require to establish trust infrastructure">
      <incoming>Flow_MS_5</incoming>
      <outgoing>Flow_MS_6</outgoing>
    </task>
    <task id="Task_MS_6" name="Require to maintain trust infrastructure">
      <incoming>Flow_MS_6</incoming>
      <outgoing>Flow_MS_7</outgoing>
    </task>
    <task id="Task_MS_7" name="Require to update trust infrastructure">
      <incoming>Flow_MS_7</incoming>
      <outgoing>Flow_MS_8</outgoing>
    </task>
    <task id="Task_MS_8" name="Assess appropriate to authorise joint investigations">
      <incoming>Flow_MS_8</incoming>
      <outgoing>Flow_MS_9</outgoing>
    </task>
    <exclusiveGateway id="Gateway_MS_1" name="Is appropriate?">
      <incoming>Flow_MS_9</incoming>
      <outgoing>Flow_MS_10</outgoing>
      <outgoing>Flow_MS_11</outgoing>
    </exclusiveGateway>
    <task id="Task_MS_9" name="Authorise joint investigations">
      <incoming>Flow_MS_10</incoming>
      <outgoing>Flow_MS_12</outgoing>
    </task>
    <task id="Task_MS_10" name="Agree upon arrangements">
      <incoming>Flow_MS_12</incoming>
      <outgoing>Flow_MS_13</outgoing>
    </task>
    <task id="Task_MS_11" name="Establish arrangements">
      <incoming>Flow_MS_13</incoming>
      <outgoing>Flow_MS_14</outgoing>
    </task>
    <exclusiveGateway id="Gateway_MS_2">
      <incoming>Flow_MS_11</incoming>
      <incoming>Flow_MS_14</incoming>
      <outgoing>Flow_MS_15</outgoing>
    </exclusiveGateway>
    <task id="Task_MS_12" name="Access the annual report">
      <incoming>Flow_MS_15</incoming>
      <outgoing>Flow_MS_16</outgoing>
    </task>
    <endEvent id="End_MS" name="supervision framework established">
      <incoming>Flow_MS_16</incoming>
    </endEvent>

    <sequenceFlow id="Flow_MS_1" sourceRef="Start_MS" targetRef="Task_MS_1" />
    <sequenceFlow id="Flow_MS_2" sourceRef="Task_MS_1" targetRef="Task_MS_2" />
    <sequenceFlow id="Flow_MS_3" sourceRef="Task_MS_2" targetRef="Task_MS_3" />
    <sequenceFlow id="Flow_MS_4" sourceRef="Task_MS_3" targetRef="Task_MS_4" />
    <sequenceFlow id="Flow_MS_5" sourceRef="Task_MS_4" targetRef="Task_MS_5" />
    <sequenceFlow id="Flow_MS_6" sourceRef="Task_MS_5" targetRef="Task_MS_6" />
    <sequenceFlow id="Flow_MS_7" sourceRef="Task_MS_6" targetRef="Task_MS_7" />
    <sequenceFlow id="Flow_MS_8" sourceRef="Task_MS_7" targetRef="Task_MS_8" />
    <sequenceFlow id="Flow_MS_9" sourceRef="Task_MS_8" targetRef="Gateway_MS_1" />
    <sequenceFlow id="Flow_MS_10" sourceRef="Gateway_MS_1" targetRef="Task_MS_9" name="Yes" />
    <sequenceFlow id="Flow_MS_11" sourceRef="Gateway_MS_1" targetRef="Gateway_MS_2" name="No" />
    <sequenceFlow id="Flow_MS_12" sourceRef="Task_MS_9" targetRef="Task_MS_10" />
    <sequenceFlow id="Flow_MS_13" sourceRef="Task_MS_10" targetRef="Task_MS_11" />
    <sequenceFlow id="Flow_MS_14" sourceRef="Task_MS_11" targetRef="Gateway_MS_2" />
    <sequenceFlow id="Flow_MS_15" sourceRef="Gateway_MS_2" targetRef="Task_MS_12" />
    <sequenceFlow id="Flow_MS_16" sourceRef="Task_MS_12" targetRef="End_MS" />
  </process>

  <process id="Process_Commission" isExecutable="true">
    <startEvent id="Start_C" name="Start Commission Process">
      <outgoing>Flow_C_1</outgoing>
    </startEvent>
    <task id="Task_C_1" name="Receive the notification">
      <incoming>Flow_C_1</incoming>
      <outgoing>Flow_C_2</outgoing>
    </task>
    <task id="Task_C_2" name="Receive the annual report">
      <incoming>Flow_C_2</incoming>
      <outgoing>Flow_C_3</outgoing>
    </task>
    <task id="Task_C_3" name="Make report available to Member States">
      <incoming>Flow_C_3</incoming>
      <outgoing>Flow_C_4</outgoing>
    </task>
    <task id="Task_C_4" name="Define formats and procedures for report">
      <incoming>Flow_C_4</incoming>
      <outgoing>Flow_C_5</outgoing>
    </task>
    <task id="Task_C_5" name="Specify the measures">
      <incoming>Flow_C_5</incoming>
      <outgoing>Flow_C_6</outgoing>
    </task>
    <task id="Task_C_6" name="Define formats applicable">
      <incoming>Flow_C_6</incoming>
      <outgoing>Flow_C_7</outgoing>
    </task>
    <task id="Task_C_7" name="Adopt implementing acts">
      <incoming>Flow_C_7</incoming>
      <outgoing>Flow_C_8</outgoing>
    </task>
    <endEvent id="End_C" name="reporting and formats defined">
      <incoming>Flow_C_8</incoming>
    </endEvent>

    <sequenceFlow id="Flow_C_1" sourceRef="Start_C" targetRef="Task_C_1" />
    <sequenceFlow id="Flow_C_2" sourceRef="Task_C_1" targetRef="Task_C_2" />
    <sequenceFlow id="Flow_C_3" sourceRef="Task_C_2" targetRef="Task_C_3" />
    <sequenceFlow id="Flow_C_4" sourceRef="Task_C_3" targetRef="Task_C_4" />
    <sequenceFlow id="Flow_C_5" sourceRef="Task_C_4" targetRef="Task_C_5" />
    <sequenceFlow id="Flow_C_6" sourceRef="Task_C_5" targetRef="Task_C_6" />
    <sequenceFlow id="Flow_C_7" sourceRef="Task_C_6" targetRef="Task_C_7" />
    <sequenceFlow id="Flow_C_8" sourceRef="Task_C_7" targetRef="End_C" />
  </process>

  <process id="Process_AnotherSB" isExecutable="true">
    <startEvent id="Start_ASB" name="Start Another SB Process">
      <outgoing>Flow_ASB_1</outgoing>
    </startEvent>
    <task id="Task_ASB_1" name="Send justified request for assistance">
      <incoming>Flow_ASB_1</incoming>
      <outgoing>Flow_ASB_2</outgoing>
    </task>
    <task id="Task_ASB_2" name="Carry out activities in consistent manner">
      <incoming>Flow_ASB_2</incoming>
      <outgoing>Flow_ASB_3</outgoing>
    </task>
    <endEvent id="End_ASB" name="request sent">
      <incoming>Flow_ASB_3</incoming>
    </endEvent>

    <sequenceFlow id="Flow_ASB_1" sourceRef="Start_ASB" targetRef="Task_ASB_1" />
    <sequenceFlow id="Flow_ASB_2" sourceRef="Task_ASB_1" targetRef="Task_ASB_2" />
    <sequenceFlow id="Flow_ASB_3" sourceRef="Task_ASB_2" targetRef="End_ASB" />
  </process>

  <process id="Process_TSP" isExecutable="true">
    <startEvent id="Start_TSP" name="Start TSP Process">
      <outgoing>Flow_TSP_1</outgoing>
    </startEvent>
    <task id="Task_TSP_1" name="Take appropriate technical measures">
      <incoming>Flow_TSP_1</incoming>
      <outgoing>Flow_TSP_2</outgoing>
    </task>
    <task id="Task_TSP_2" name="Ensure security level is commensurate">
      <incoming>Flow_TSP_2</incoming>
      <outgoing>Flow_TSP_3</outgoing>
    </task>
    <task id="Task_TSP_3" name="Take measures to prevent impact">
      <incoming>Flow_TSP_3</incoming>
      <outgoing>Flow_TSP_4</outgoing>
    </task>
    <task id="Task_TSP_4" name="Take measures to minimise impact">
      <incoming>Flow_TSP_4</incoming>
      <outgoing>Flow_TSP_5</outgoing>
    </task>
    <task id="Task_TSP_5" name="Inform stakeholders of adverse effects">
      <incoming>Flow_TSP_5</incoming>
      <outgoing>Flow_TSP_6</outgoing>
    </task>
    <task id="Task_TSP_6" name="Notify breach of security to SB">
      <incoming>Flow_TSP_6</incoming>
      <outgoing>Flow_TSP_7</outgoing>
    </task>
    <task id="Task_TSP_7" name="Assess if breach affects a person">
      <incoming>Flow_TSP_7</incoming>
      <outgoing>Flow_TSP_8</outgoing>
    </task>
    <exclusiveGateway id="Gateway_TSP_1" name="Likely to affect?">
      <incoming>Flow_TSP_8</incoming>
      <outgoing>Flow_TSP_9</outgoing>
      <outgoing>Flow_TSP_10</outgoing>
    </exclusiveGateway>
    <task id="Task_TSP_8" name="Notify breach to person">
      <incoming>Flow_TSP_9</incoming>
      <outgoing>Flow_TSP_11</outgoing>
    </task>
    <exclusiveGateway id="Gateway_TSP_2">
      <incoming>Flow_TSP_10</incoming>
      <incoming>Flow_TSP_11</incoming>
      <outgoing>Flow_TSP_12</outgoing>
    </exclusiveGateway>
    <task id="Task_TSP_9" name="Inform the public">
      <incoming>Flow_TSP_12</incoming>
      <outgoing>Flow_TSP_13</outgoing>
    </task>
    <task id="Task_TSP_10" name="Remedy any failure">
      <incoming>Flow_TSP_13</incoming>
      <outgoing>Flow_TSP_14</outgoing>
    </task>
    <endEvent id="End_TSP" name="trust services secured">
      <incoming>Flow_TSP_14</incoming>
    </endEvent>

    <sequenceFlow id="Flow_TSP_1" sourceRef="Start_TSP" targetRef="Task_TSP_1" />
    <sequenceFlow id="Flow_TSP_2" sourceRef="Task_TSP_1" targetRef="Task_TSP_2" />
    <sequenceFlow id="Flow_TSP_3" sourceRef="Task_TSP_2" targetRef="Task_TSP_3" />
    <sequenceFlow id="Flow_TSP_4" sourceRef="Task_TSP_3" targetRef="Task_TSP_4" />
    <sequenceFlow id="Flow_TSP_5" sourceRef="Task_TSP_4" targetRef="Task_TSP_5" />
    <sequenceFlow id="Flow_TSP_6" sourceRef="Task_TSP_5" targetRef="Task_TSP_6" />
    <sequenceFlow id="Flow_TSP_7" sourceRef="Task_TSP_6" targetRef="Task_TSP_7" />
    <sequenceFlow id="Flow_TSP_8" sourceRef="Task_TSP_7" targetRef="Gateway_TSP_1" />
    <sequenceFlow id="Flow_TSP_9" sourceRef="Gateway_TSP_1" targetRef="Task_TSP_8" name="Yes" />
    <sequenceFlow id="Flow_TSP_10" sourceRef="Gateway_TSP_1" targetRef="Gateway_TSP_2" name="No" />
    <sequenceFlow id="Flow_TSP_11" sourceRef="Task_TSP_8" targetRef="Gateway_TSP_2" />
    <sequenceFlow id="Flow_TSP_12" sourceRef="Gateway_TSP_2" targetRef="Task_TSP_9" />
    <sequenceFlow id="Flow_TSP_13" sourceRef="Task_TSP_9" targetRef="Task_TSP_10" />
    <sequenceFlow id="Flow_TSP_14" sourceRef="Task_TSP_10" targetRef="End_TSP" />
  </process>

  <process id="Process_SB" isExecutable="true">
    <startEvent id="Start_SB" name="Start SB Process">
      <outgoing>Flow_SB_1</outgoing>
    </startEvent>
    <parallelGateway id="Gateway_SB_Par_Split">
      <incoming>Flow_SB_1</incoming>
      <outgoing>Flow_SB_B1</outgoing>
      <outgoing>Flow_SB_B2</outgoing>
      <outgoing>Flow_SB_B3</outgoing>
      <outgoing>Flow_SB_B4</outgoing>
      <outgoing>Flow_SB_B5</outgoing>
      <outgoing>Flow_SB_B6</outgoing>
      <outgoing>Flow_SB_B7</outgoing>
      <outgoing>Flow_SB_B8</outgoing>
      <outgoing>Flow_SB_B9</outgoing>
      <outgoing>Flow_SB_B10</outgoing>
    </parallelGateway>

    <task id="Task_SB_1" name="Supervise qualified trust SP">
      <incoming>Flow_SB_B1</incoming>
      <outgoing>Flow_SB_J1</outgoing>
    </task>

    <task id="Task_SB_2" name="Assess if informed of non-qualified SP">
      <incoming>Flow_SB_B2</incoming>
      <outgoing>Flow_SB_B2_1</outgoing>
    </task>
    <exclusiveGateway id="Gateway_SB_B2_Split">
      <incoming>Flow_SB_B2_1</incoming>
      <outgoing>Flow_SB_B2_Y</outgoing>
      <outgoing>Flow_SB_B2_N</outgoing>
    </exclusiveGateway>
    <task id="Task_SB_3" name="Take action through ex post">
      <incoming>Flow_SB_B2_Y</incoming>
      <outgoing>Flow_SB_B2_Y_Out</outgoing>
    </task>
    <exclusiveGateway id="Gateway_SB_B2_Join">
      <incoming>Flow_SB_B2_N</incoming>
      <incoming>Flow_SB_B2_Y_Out</incoming>
      <outgoing>Flow_SB_J2</outgoing>
    </exclusiveGateway>

    <task id="Task_SB_4" name="Cooperate with other bodies">
      <incoming>Flow_SB_B3</incoming>
      <outgoing>Flow_SB_J3</outgoing>
    </task>

    <task id="Task_SB_5" name="Analyse conformity reports">
      <incoming>Flow_SB_B4</incoming>
      <outgoing>Flow_SB_J4</outgoing>
    </task>

    <task id="Task_SB_6" name="Carry out audits">
      <incoming>Flow_SB_B5</incoming>
      <outgoing>Flow_SB_B5_1</outgoing>
    </task>
    <task id="Task_SB_7" name="Request conformity assessment">
      <incoming>Flow_SB_B5_1</incoming>
      <outgoing>Flow_SB_J5</outgoing>
    </task>

    <task id="Task_SB_8" name="Cooperate with data protection">
      <incoming>Flow_SB_B6</incoming>
      <outgoing>Flow_SB_J6</outgoing>
    </task>

    <task id="Task_SB_9" name="Grant qualified status">
      <incoming>Flow_SB_B7</incoming>
      <outgoing>Flow_SB_B7_1</outgoing>
    </task>
    <task id="Task_SB_10" name="Withdraw qualified status">
      <incoming>Flow_SB_B7_1</incoming>
      <outgoing>Flow_SB_J7</outgoing>
    </task>

    <task id="Task_SB_11" name="Assess if list body is SB">
      <incoming>Flow_SB_B8</incoming>
      <outgoing>Flow_SB_B8_1</outgoing>
    </task>
    <exclusiveGateway id="Gateway_SB_B8_Split">
      <incoming>Flow_SB_B8_1</incoming>
      <outgoing>Flow_SB_B8_Y</outgoing>
      <outgoing>Flow_SB_B8_N</outgoing>
    </exclusiveGateway>
    <task id="Task_SB_12" name="Inform body of decisions">
      <incoming>Flow_SB_B8_Y</incoming>
      <outgoing>Flow_SB_B8_Y_Out</outgoing>
    </task>
    <exclusiveGateway id="Gateway_SB_B8_Join">
      <incoming>Flow_SB_B8_N</incoming>
      <incoming>Flow_SB_B8_Y_Out</incoming>
      <outgoing>Flow_SB_J8</outgoing>
    </exclusiveGateway>

    <task id="Task_SB_13" name="Verify termination plans">
      <incoming>Flow_SB_B9</incoming>
      <outgoing>Flow_SB_J9</outgoing>
    </task>

    <task id="Task_SB_14" name="Send requirement to remedy failure">
      <incoming>Flow_SB_B10</incoming>
      <outgoing>Flow_SB_J10</outgoing>
    </task>

    <parallelGateway id="Gateway_SB_Par_Join">
      <incoming>Flow_SB_J1</incoming>
      <incoming>Flow_SB_J2</incoming>
      <incoming>Flow_SB_J3</incoming>
      <incoming>Flow_SB_J4</incoming>
      <incoming>Flow_SB_J5</incoming>
      <incoming>Flow_SB_J6</incoming>
      <incoming>Flow_SB_J7</incoming>
      <incoming>Flow_SB_J8</incoming>
      <incoming>Flow_SB_J9</incoming>
      <incoming>Flow_SB_J10</incoming>
      <outgoing>Flow_SB_2</outgoing>
    </parallelGateway>

    <task id="Task_SB_15" name="Assess justified request from ASB">
      <incoming>Flow_SB_2</incoming>
      <outgoing>Flow_SB_3</outgoing>
    </task>
    <exclusiveGateway id="Gateway_SB_Req" name="Grounds met?">
      <incoming>Flow_SB_3</incoming>
      <outgoing>Flow_SB_Req_Y</outgoing>
      <outgoing>Flow_SB_Req_N</outgoing>
    </exclusiveGateway>
    <task id="Task_SB_16" name="Refuse request">
      <incoming>Flow_SB_Req_Y</incoming>
      <outgoing>Flow_SB_Req_Y_Out</outgoing>
    </task>
    <task id="Task_SB_17" name="Provide assistance">
      <incoming>Flow_SB_Req_N</incoming>
      <outgoing>Flow_SB_Req_N_Out</outgoing>
    </task>
    <exclusiveGateway id="Gateway_SB_Req_Join">
      <incoming>Flow_SB_Req_Y_Out</incoming>
      <incoming>Flow_SB_Req_N_Out</incoming>
      <outgoing>Flow_SB_4</outgoing>
    </exclusiveGateway>

    <task id="Task_SB_18" name="Assess breach notification">
      <incoming>Flow_SB_4</incoming>
      <outgoing>Flow_SB_5</outgoing>
    </task>
    <exclusiveGateway id="Gateway_SB_Breach" name="Concerns 2+ MS?">
      <incoming>Flow_SB_5</incoming>
      <outgoing>Flow_SB_Breach_Y</outgoing>
      <outgoing>Flow_SB_Breach_N</outgoing>
    </exclusiveGateway>
    <task id="Task_SB_19" name="Inform SBs in other MS">
      <incoming>Flow_SB_Breach_Y</incoming>
      <outgoing>Flow_SB_19_Out</outgoing>
    </task>
    <task id="Task_SB_20" name="Inform ENISA">
      <incoming>Flow_SB_19_Out</incoming>
      <outgoing>Flow_SB_Breach_Y_Out</outgoing>
    </task>
    <exclusiveGateway id="Gateway_SB_Breach_Join">
      <incoming>Flow_SB_Breach_Y_Out</incoming>
      <incoming>Flow_SB_Breach_N</incoming>
      <outgoing>Flow_SB_6</outgoing>
    </exclusiveGateway>

    <task id="Task_SB_21" name="Assess disclosure public interest">
      <incoming>Flow_SB_6</incoming>
      <outgoing>Flow_SB_7</outgoing>
    </task>
    <exclusiveGateway id="Gateway_SB_PI" name="In public interest?">
      <incoming>Flow_SB_7</incoming>
      <outgoing>Flow_SB_PI_Y</outgoing>
      <outgoing>Flow_SB_PI_N</outgoing>
    </exclusiveGateway>
    <task id="Task_SB_22" name="Assess if informs directly">
      <incoming>Flow_SB_PI_Y</incoming>
      <outgoing>Flow_SB_8</outgoing>
    </task>
    <exclusiveGateway id="Gateway_SB_Dir" name="Inform directly?">
      <incoming>Flow_SB_8</incoming>
      <outgoing>Flow_SB_Dir_Y</outgoing>
      <outgoing>Flow_SB_Dir_N</outgoing>
    </exclusiveGateway>
    <task id="Task_SB_23" name="Inform the public">
      <incoming>Flow_SB_Dir_Y</incoming>
      <outgoing>Flow_SB_Dir_Y_Out</outgoing>
    </task>
    <task id="Task_SB_24" name="Send requirement to inform">
      <incoming>Flow_SB_Dir_N</incoming>
      <outgoing>Flow_SB_Dir_N_Out</outgoing>
    </task>
    <exclusiveGateway id="Gateway_SB_Dir_Join">
      <incoming>Flow_SB_Dir_Y_Out</incoming>
      <incoming>Flow_SB_Dir_N_Out</incoming>
      <outgoing>Flow_SB_PI_Y_Out</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="Gateway_SB_PI_Join">
      <incoming>Flow_SB_PI_Y_Out</incoming>
      <incoming>Flow_SB_PI_N</incoming>
      <outgoing>Flow_SB_9</outgoing>
    </exclusiveGateway>

    <task id="Task_SB_25" name="Submit report to Commission">
      <incoming>Flow_SB_9</incoming>
      <outgoing>Flow_SB_10</outgoing>
    </task>
    <task id="Task_SB_26" name="Provide summary to ENISA">
      <incoming>Flow_SB_10</incoming>
      <outgoing>Flow_SB_11</outgoing>
    </task>
    <endEvent id="End_SB" name="supervision completed">
      <incoming>Flow_SB_11</incoming>
    </endEvent>

    <sequenceFlow id="Flow_SB_1" sourceRef="Start_SB" targetRef="Gateway_SB_Par_Split" />
    <sequenceFlow id="Flow_SB_B1" sourceRef="Gateway_SB_Par_Split" targetRef="Task_SB_1" />
    <sequenceFlow id="Flow_SB_B2" sourceRef="Gateway_SB_Par_Split" targetRef="Task_SB_2" />
    <sequenceFlow id="Flow_SB_B3" sourceRef="Gateway_SB_Par_Split" targetRef="Task_SB_4" />
    <sequenceFlow id="Flow_SB_B4" sourceRef="Gateway_SB_Par_Split" targetRef="Task_SB_5" />
    <sequenceFlow id="Flow_SB_B5" sourceRef="Gateway_SB_Par_Split" targetRef="Task_SB_6" />
