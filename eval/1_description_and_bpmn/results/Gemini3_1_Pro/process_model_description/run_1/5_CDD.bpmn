      <sequenceFlow id="oe_flow6" sourceRef="oe_gw1_join" targetRef="oe_task3" />
      <sequenceFlow id="oe_flow7" sourceRef="oe_task3" targetRef="oe_gw2" />
      <sequenceFlow id="oe_flow8" sourceRef="oe_gw2" targetRef="oe_split1" />
      <sequenceFlow id="oe_flow9" sourceRef="oe_gw2" targetRef="oe_gw2_join" />
      <sequenceFlow id="oe_flow10" sourceRef="oe_split1" targetRef="oe_task4" />
      <sequenceFlow id="oe_flow11" sourceRef="oe_split1" targetRef="oe_task5" />
      <sequenceFlow id="oe_flow12" sourceRef="oe_split1" targetRef="oe_task6" />
      <sequenceFlow id="oe_flow13" sourceRef="oe_split1" targetRef="oe_task7" />
      <sequenceFlow id="oe_flow14" sourceRef="oe_split1" targetRef="oe_task8" />
      <sequenceFlow id="oe_flow15" sourceRef="oe_task4" targetRef="oe_join1" />
      <sequenceFlow id="oe_flow16" sourceRef="oe_task5" targetRef="oe_join1" />
      <sequenceFlow id="oe_flow17" sourceRef="oe_task6" targetRef="oe_join1" />
      <sequenceFlow id="oe_flow18" sourceRef="oe_task7" targetRef="oe_join1" />
      <sequenceFlow id="oe_flow19" sourceRef="oe_task8" targetRef="oe_join1" />
      <sequenceFlow id="oe_flow20" sourceRef="oe_join1" targetRef="oe_gw2_join" />
      <sequenceFlow id="oe_flow21" sourceRef="oe_gw2_join" targetRef="oe_split2" />
      <sequenceFlow id="oe_flow22" sourceRef="oe_split2" targetRef="oe_task9" />
      <sequenceFlow id="oe_flow23" sourceRef="oe_split2" targetRef="oe_task10" />
      <sequenceFlow id="oe_flow24" sourceRef="oe_task9" targetRef="oe_join2" />
      <sequenceFlow id="oe_flow25" sourceRef="oe_task10" targetRef="oe_join2" />
      <sequenceFlow id="oe_flow26" sourceRef="oe_join2" targetRef="oe_end" />
   </process>

