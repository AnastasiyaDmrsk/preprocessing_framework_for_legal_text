      <sequenceFlow id="ms_flow28" sourceRef="ms_task13" targetRef="ms_join2" />
      <sequenceFlow id="ms_flow29" sourceRef="ms_join2" targetRef="ms_end" />
   </process>

   <process id="proc_oe" isExecutable="true" name="Obliged entities">
      <startEvent id="oe_start" name="Start customer due diligence" />
      <task id="oe_task1" name="Verify the identity of the customer and beneficial owner" />
      <exclusiveGateway id="oe_gw1" name="MS allow verification?" />
      <task id="oe_task2" name="Complete procedures as soon as practicable" />
      <exclusiveGateway id="oe_gw1_join" />
      <task id="oe_task3" name="Assess whether unable to comply with due diligence" />
      <exclusiveGateway id="oe_gw2" name="Unable to comply?" />
      <parallelGateway id="oe_split1" />
      <task id="oe_task4" name="Not carry out a transaction through a bank account" />
      <task id="oe_task5" name="Not establish a business relationship" />
      <task id="oe_task6" name="Not carry out the transaction" />
      <task id="oe_task7" name="Terminate the business relationship" />
      <task id="oe_task8" name="Consider making a suspicious transaction report to FIU" />
      <parallelGateway id="oe_join1" />
      <exclusiveGateway id="oe_gw2_join" />
      <parallelGateway id="oe_split2" />
      <task id="oe_task9" name="Apply customer due diligence to all new customers" />
      <task id="oe_task10" name="Apply customer due diligence to existing customers" />
      <parallelGateway id="oe_join2" />
      <endEvent id="oe_end" name="Customer due diligence applied" />

      <sequenceFlow id="oe_flow1" sourceRef="oe_start" targetRef="oe_task1" />
      <sequenceFlow id="oe_flow2" sourceRef="oe_task1" targetRef="oe_gw1" />
      <sequenceFlow id="oe_flow3" sourceRef="oe_gw1" targetRef="oe_task2" />
