   <collaboration id="collaboration_1">
      <participant id="part_ms" name="Member States" processRef="proc_ms" />
      <participant id="part_oe" name="Obliged entities" processRef="proc_oe" />
      <participant id="part_fiu" name="FIU" processRef="proc_fiu" />
      <messageFlow id="msg_report" sourceRef="oe_task8" targetRef="fiu_start" />
   </collaboration>

   <process id="proc_ms" isExecutable="true" name="Member States">
      <startEvent id="ms_start" name="Start customer due diligence" />
      <task id="ms_task1" name="Require verification of the identity of the customer and beneficial owner" />
      <task id="ms_task2" name="Assess whether verification during establishment is necessary" />
      <exclusiveGateway id="ms_gw1" name="Is verification necessary?" />
      <task id="ms_task3" name="Allow verification of identity to be completed" />
      <exclusiveGateway id="ms_gw1_join" />
      <task id="ms_task4" name="Assess whether adequate safeguards in place" />
      <exclusiveGateway id="ms_gw2" name="Adequate safeguards?" />
      <task id="ms_task5" name="Allow the opening of an account" />
      <exclusiveGateway id="ms_gw2_join" />
      <parallelGateway id="ms_split1" />
      <task id="ms_task6" name="Require not carry out a transaction through a bank account" />
      <task id="ms_task7" name="Require not establish a business relationship" />
      <task id="ms_task8" name="Require not carry out the transaction" />
      <task id="ms_task9" name="Require terminates the business relationship" />
      <task id="ms_task10" name="Require considers making a suspicious transaction report to FIU" />
      <parallelGateway id="ms_join1" />
      <task id="ms_task11" name="Apply the first subparagraph to obliged entities" />
      <parallelGateway id="ms_split2" />
      <task id="ms_task12" name="Require apply customer due diligence to all new customers" />
      <task id="ms_task13" name="Require apply customer due diligence to existing customers" />
      <parallelGateway id="ms_join2" />
      <endEvent id="ms_end" name="Requirements established" />

      <sequenceFlow id="ms_flow1" sourceRef="ms_start" targetRef="ms_task1" />
      <sequenceFlow id="ms_flow2" sourceRef="ms_task1" targetRef="ms_task2" />
      <sequenceFlow id="ms_flow3" sourceRef="ms_task2" targetRef="ms_gw1" />
      <sequenceFlow id="ms_flow4" sourceRef="ms_gw1" targetRef="ms_task3" />
      <sequenceFlow id="ms_flow5" sourceRef="ms_task3" targetRef="ms_gw1_join" />
      <sequenceFlow id="ms_flow6" sourceRef="ms_gw1" targetRef="ms_gw1_join" />
      <sequenceFlow id="ms_flow7" sourceRef="ms_gw1_join" targetRef="ms_task4" />
      <sequenceFlow id="ms_flow8" sourceRef="ms_task4" targetRef="ms_gw2" />
      <sequenceFlow id="ms_flow9" sourceRef="ms_gw2" targetRef="ms_task5" />
      <sequenceFlow id="ms_flow10" sourceRef="ms_task5" targetRef="ms_gw2_join" />
      <sequenceFlow id="ms_flow11" sourceRef="ms_gw2" targetRef="ms_gw2_join" />
      <sequenceFlow id="ms_flow12" sourceRef="ms_gw2_join" targetRef="ms_split1" />
      <sequenceFlow id="ms_flow13" sourceRef="ms_split1" targetRef="ms_task6" />
      <sequenceFlow id="ms_flow14" sourceRef="ms_split1" targetRef="ms_task7" />
      <sequenceFlow id="ms_flow15" sourceRef="ms_split1" targetRef="ms_task8" />
      <sequenceFlow id="ms_flow16" sourceRef="ms_split1" targetRef="ms_task9" />
      <sequenceFlow id="ms_flow17" sourceRef="ms_split1" targetRef="ms_task10" />
