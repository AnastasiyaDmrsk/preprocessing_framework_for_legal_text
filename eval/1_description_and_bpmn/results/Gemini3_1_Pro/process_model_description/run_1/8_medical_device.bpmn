      <outgoing>F_M_55</outgoing>
    </task>
    <task id="T_M23" name="Cooperate on any corrective action taken">
      <incoming>F_M_55</incoming>
      <outgoing>F_M_56</outgoing>
    </task>
    <task id="T_M24" name="Assess if device manufactured by another person">
