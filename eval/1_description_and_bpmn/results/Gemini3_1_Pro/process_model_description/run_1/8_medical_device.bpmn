             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn">
  <collaboration id="Collaboration_1">
    <participant id="Part_M" name="Manufacturers" processRef="Proc_M" />
    <participant id="Part_C" name="Commission" processRef="Proc_C" />
    <participant id="Part_A" name="Competent authority" processRef="Proc_A" />
  </collaboration>

  <process id="Proc_M" isExecutable="false">
    <startEvent id="S_M" name="Placement on market / put into service">
      <outgoing>F_M_0</outgoing>
    </startEvent>
    <task id="T_M1" name="Ensure designed and manufactured in accordance with requirements">
      <incoming>F_M_0</incoming>
      <outgoing>F_M_1</outgoing>
    </task>
    <parallelGateway id="G_M1S">
      <incoming>F_M_1</incoming>
      <outgoing>F_M_2a</outgoing>
      <outgoing>F_M_2b</outgoing>
      <outgoing>F_M_2c</outgoing>
    </parallelGateway>
    <task id="T_M2a" name="Establish system for risk management">
      <incoming>F_M_2a</incoming>
      <outgoing>F_M_3a</outgoing>
    </task>
    <task id="T_M2b" name="Document system for risk management">
      <incoming>F_M_2b</incoming>
      <outgoing>F_M_3b</outgoing>
    </task>
    <task id="T_M2c" name="Implement and maintain system for risk management">
      <incoming>F_M_2c</incoming>
      <outgoing>F_M_3c</outgoing>
    </task>
    <parallelGateway id="G_M1J">
      <incoming>F_M_3a</incoming>
      <incoming>F_M_3b</incoming>
      <incoming>F_M_3c</incoming>
      <outgoing>F_M_4</outgoing>
    </parallelGateway>
    <task id="T_M3" name="Conduct clinical evaluation">
      <incoming>F_M_4</incoming>
      <outgoing>F_M_5</outgoing>
    </task>
    <task id="T_M4" name="Assess whether devices are custom-made">
      <incoming>F_M_5</incoming>
      <outgoing>F_M_6</outgoing>
    </task>
    <exclusiveGateway id="G_M2S" name="Custom-made?">
      <incoming>F_M_6</incoming>
      <outgoing>F_M_7a</outgoing>
      <outgoing>F_M_7b</outgoing>
    </exclusiveGateway>
    <task id="T_M4a" name="Draw up technical documentation">
      <incoming>F_M_7a</incoming>
      <outgoing>F_M_8a</outgoing>
    </task>
    <task id="T_M4b" name="Keep up to date technical documentation">
      <incoming>F_M_8a</incoming>
      <outgoing>F_M_9a</outgoing>
    </task>
    <task id="T_M4c" name="Include elements of Annexes II and III">
      <incoming>F_M_9a</incoming>
      <outgoing>F_M_10a</outgoing>
    </task>
    <parallelGateway id="G_M3S">
      <incoming>F_M_7b</incoming>
      <outgoing>F_M_11a</outgoing>
      <outgoing>F_M_11b</outgoing>
      <outgoing>F_M_11c</outgoing>
    </parallelGateway>
    <task id="T_M5a" name="Draw up documentation (Annex XIII)">
      <incoming>F_M_11a</incoming>
      <outgoing>F_M_12a</outgoing>
    </task>
    <task id="T_M5b" name="Keep up to date documentation (Annex XIII)">
      <incoming>F_M_11b</incoming>
      <outgoing>F_M_12b</outgoing>
    </task>
    <task id="T_M5c" name="Keep documentation available for authorities">
      <incoming>F_M_11c</incoming>
      <outgoing>F_M_12c</outgoing>
    </task>
    <parallelGateway id="G_M3J">
      <incoming>F_M_12a</incoming>
      <incoming>F_M_12b</incoming>
      <incoming>F_M_12c</incoming>
      <outgoing>F_M_10b</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G_M2J">
      <incoming>F_M_10a</incoming>
      <incoming>F_M_10b</incoming>
      <outgoing>F_M_13</outgoing>
    </exclusiveGateway>
    <task id="T_M6" name="Assess compliance and if not custom/investigational">
      <incoming>F_M_13</incoming>
      <outgoing>F_M_14</outgoing>
    </task>
    <exclusiveGateway id="G_M4S" name="Compliance demonstrated &amp; other than custom?">
      <incoming>F_M_14</incoming>
      <outgoing>F_M_15a</outgoing>
      <outgoing>F_M_15b</outgoing>
    </exclusiveGateway>
    <task id="T_M7a" name="Draw up EU declaration of conformity">
      <incoming>F_M_15a</incoming>
      <outgoing>F_M_16a</outgoing>
    </task>
    <task id="T_M7b" name="Affix CE marking of conformity">
      <incoming>F_M_16a</incoming>
      <outgoing>F_M_17a</outgoing>
    </task>
    <exclusiveGateway id="G_M4J">
      <incoming>F_M_17a</incoming>
      <incoming>F_M_15b</incoming>
      <outgoing>F_M_18</outgoing>
    </exclusiveGateway>
    <parallelGateway id="G_M5S">
      <incoming>F_M_18</incoming>
      <outgoing>F_M_19a</outgoing>
      <outgoing>F_M_19b</outgoing>
    </parallelGateway>
    <task id="T_M8a" name="Comply with UDI system obligations">
      <incoming>F_M_19a</incoming>
      <outgoing>F_M_20a</outgoing>
    </task>
    <task id="T_M8b" name="Comply with registration obligations">
      <incoming>F_M_19b</incoming>
      <outgoing>F_M_20b</outgoing>
    </task>
    <parallelGateway id="G_M5J">
      <incoming>F_M_20a</incoming>
      <incoming>F_M_20b</incoming>
      <outgoing>F_M_21</outgoing>
    </parallelGateway>
    <task id="T_M9" name="Keep documentation available for at least 10 years">
      <incoming>F_M_21</incoming>
      <outgoing>F_M_22</outgoing>
    </task>
    <task id="T_M10" name="Assess whether device is implantable">
      <incoming>F_M_22</incoming>
      <outgoing>F_M_23</outgoing>
    </task>
    <exclusiveGateway id="G_M6S" name="Is implantable?">
      <incoming>F_M_23</incoming>
      <outgoing>F_M_24a</outgoing>
      <outgoing>F_M_24b</outgoing>
    </exclusiveGateway>
    <task id="T_M10a" name="Keep technical documentation available for 15 years">
      <incoming>F_M_24a</incoming>
      <outgoing>F_M_25a</outgoing>
