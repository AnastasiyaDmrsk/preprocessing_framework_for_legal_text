  <process id="Proc_C" isExecutable="false">
    <startEvent id="S_C" name="Placement on market / put into service">
      <outgoing>F_C_0</outgoing>
    </startEvent>
    <task id="T_C1" name="Adopt delegated acts amending Annexes II and III">
      <incoming>F_C_0</incoming>
      <outgoing>F_C_1</outgoing>
