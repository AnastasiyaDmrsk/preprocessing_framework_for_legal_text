<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             id="sid-main-definitions"
             targetNamespace="http://www.signavio.com"
             typeLanguage="http://www.w3.org/2001/XMLSchema"
             xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd">

   <collaboration id="Collaboration_1">
      <participant id="Participant_Entities" name="Entities" processRef="Process_Entities" />
      <participant id="Participant_DSC" name="Digital Services Coordinator" processRef="Process_DSC" />
      <participant id="Participant_TF" name="Trusted flaggers" processRef="Process_TF" />
      <participant id="Participant_PoP" name="Providers of online platforms" processRef="Process_PoP" />
      <participant id="Participant_Commission" name="Commission" processRef="Process_Commission" />
      <participant id="Participant_Board" name="Board" processRef="Process_Board" />

      <messageFlow id="MessageFlow_1" sourceRef="Task_Ent_1" targetRef="StartEvent_DSC_1" />
      <messageFlow id="MessageFlow_2" sourceRef="Task_PoP_3" targetRef="StartEvent_DSC_2" />
      <messageFlow id="MessageFlow_3" sourceRef="Task_TF_5" targetRef="StartEvent_DSC_3" />
      <messageFlow id="MessageFlow_4" sourceRef="Task_DSC_7" targetRef="StartEvent_TF_2" />
      <messageFlow id="MessageFlow_5" sourceRef="Task_DSC_9" targetRef="StartEvent_Comm_1" />
      <messageFlow id="MessageFlow_6" sourceRef="Task_DSC_10" targetRef="StartEvent_Board_1" />
      <messageFlow id="MessageFlow_7" sourceRef="Task_Comm_4" targetRef="StartEvent_Board_2" />
   </collaboration>

   <process id="Process_Entities" isExecutable="false" name="Entities">
      <startEvent id="StartEvent_Ent" name="Start">
         <outgoing>SeqFlow_Ent_1</outgoing>
      </startEvent>
      <task id="Task_Ent_1" name="Send application for status of trusted flagger">
         <incoming>SeqFlow_Ent_1</incoming>
         <outgoing>SeqFlow_Ent_2</outgoing>
      </task>
      <parallelGateway id="Gateway_Ent_Split">
         <incoming>SeqFlow_Ent_2</incoming>
         <outgoing>SeqFlow_Ent_3</outgoing>
         <outgoing>SeqFlow_Ent_4</outgoing>
         <outgoing>SeqFlow_Ent_5</outgoing>
      </parallelGateway>
      <task id="Task_Ent_2" name="Demonstrate expertise and competence">
         <incoming>SeqFlow_Ent_3</incoming>
         <outgoing>SeqFlow_Ent_6</outgoing>
      </task>
      <task id="Task_Ent_3" name="Demonstrate independence">
         <incoming>SeqFlow_Ent_4</incoming>
         <outgoing>SeqFlow_Ent_7</outgoing>
      </task>
      <task id="Task_Ent_4" name="Demonstrate diligence, accuracy and objectivity">
         <incoming>SeqFlow_Ent_5</incoming>
         <outgoing>SeqFlow_Ent_8</outgoing>
      </task>
      <parallelGateway id="Gateway_Ent_Join">
         <incoming>SeqFlow_Ent_6</incoming>
         <incoming>SeqFlow_Ent_7</incoming>
         <incoming>SeqFlow_Ent_8</incoming>
         <outgoing>SeqFlow_Ent_9</outgoing>
      </parallelGateway>
      <endEvent id="EndEvent_Ent" name="Application submitted">
         <incoming>SeqFlow_Ent_9</incoming>
      </endEvent>

      <sequenceFlow id="SeqFlow_Ent_1" sourceRef="StartEvent_Ent" targetRef="Task_Ent_1" />
      <sequenceFlow id="SeqFlow_Ent_2" sourceRef="Task_Ent_1" targetRef="Gateway_Ent_Split" />
      <sequenceFlow id="SeqFlow_Ent_3" sourceRef="Gateway_Ent_Split" targetRef="Task_Ent_2" />
      <sequenceFlow id="SeqFlow_Ent_4" sourceRef="Gateway_Ent_Split" targetRef="Task_Ent_3" />
      <sequenceFlow id="SeqFlow_Ent_5" sourceRef="Gateway_Ent_Split" targetRef="Task_Ent_4" />
      <sequenceFlow id="SeqFlow_Ent_6" sourceRef="Task_Ent_2" targetRef="Gateway_Ent_Join" />
      <sequenceFlow id="SeqFlow_Ent_7" sourceRef="Task_Ent_3" targetRef="Gateway_Ent_Join" />
      <sequenceFlow id="SeqFlow_Ent_8" sourceRef="Task_Ent_4" targetRef="Gateway_Ent_Join" />
      <sequenceFlow id="SeqFlow_Ent_9" sourceRef="Gateway_Ent_Join" targetRef="EndEvent_Ent" />
   </process>

   <process id="Process_DSC" isExecutable="false" name="Digital Services Coordinator">
      <startEvent id="StartEvent_DSC_1" name="Receive application">
         <outgoing>SeqFlow_DSC_1</outgoing>
         <messageEventDefinition id="MsgDef_1" />
      </startEvent>
      <task id="Task_DSC_1" name="Assess applicant conditions">
         <incoming>SeqFlow_DSC_1</incoming>
         <outgoing>SeqFlow_DSC_2</outgoing>
      </task>
      <exclusiveGateway id="Gateway_DSC_1">
         <incoming>SeqFlow_DSC_2</incoming>
         <outgoing>SeqFlow_DSC_3</outgoing>
      </exclusiveGateway>
      <task id="Task_DSC_2" name="Award status of trusted flagger">
         <incoming>SeqFlow_DSC_3</incoming>
         <outgoing>SeqFlow_DSC_4</outgoing>
      </task>
      <endEvent id="EndEvent_DSC_1" name="Status managed">
         <incoming>SeqFlow_DSC_4</incoming>
      </endEvent>

      <startEvent id="StartEvent_DSC_2" name="Receive information">
         <outgoing>SeqFlow_DSC_5</outgoing>
         <messageEventDefinition id="MsgDef_2" />
      </startEvent>
      <task id="Task_DSC_3" name="Assess legitimate reasons to investigate">
         <incoming>SeqFlow_DSC_5</incoming>
         <outgoing>SeqFlow_DSC_6</outgoing>
      </task>
      <exclusiveGateway id="Gateway_DSC_2">
         <incoming>SeqFlow_DSC_6</incoming>
         <outgoing>SeqFlow_DSC_7</outgoing>
      </exclusiveGateway>
      <task id="Task_DSC_4" name="Suspend status">
         <incoming>SeqFlow_DSC_7</incoming>
         <outgoing>SeqFlow_DSC_8</outgoing>
      </task>
      <task id="Task_DSC_5" name="Carry out investigation">
         <incoming>SeqFlow_DSC_8</incoming>
         <outgoing>SeqFlow_DSC_9</outgoing>
      </task>
      <task id="Task_DSC_6" name="Assess if entity no longer meets conditions">
         <incoming>SeqFlow_DSC_9</incoming>
         <outgoing>SeqFlow_DSC_10</outgoing>
      </task>
      <exclusiveGateway id="Gateway_DSC_3">
         <incoming>SeqFlow_DSC_10</incoming>
         <outgoing>SeqFlow_DSC_11</outgoing>
      </exclusiveGateway>
      <task id="Task_DSC_7" name="Send opportunity to react">
         <incoming>SeqFlow_DSC_11</incoming>
         <outgoing>SeqFlow_DSC_12</outgoing>
      </task>
      <task id="Task_DSC_8" name="Revoke status">
         <incoming>SeqFlow_DSC_12</incoming>
         <outgoing>SeqFlow_DSC_13</outgoing>
      </task>
      <parallelGateway id="Gateway_DSC_4">
         <incoming>SeqFlow_DSC_13</incoming>
         <outgoing>SeqFlow_DSC_14</outgoing>
         <outgoing>SeqFlow_DSC_15</outgoing>
      </parallelGateway>
      <task id="Task_DSC_9" name="Send info to Commission">
         <incoming>SeqFlow_DSC_14</incoming>
         <outgoing>SeqFlow_DSC_16</outgoing>
      </task>
      <task id="Task_DSC_10" name="Send info to Board">
         <incoming>SeqFlow_DSC_15</incoming>
         <outgoing>SeqFlow_DSC_17</outgoing>
      </task>
      <parallelGateway id="Gateway_DSC_5">
         <incoming>SeqFlow_DSC_16</incoming>
         <incoming>SeqFlow_DSC_17</incoming>
         <outgoing>SeqFlow_DSC_18</outgoing>
      </parallelGateway>
      <endEvent id="EndEvent_DSC_2" name="Status managed">
         <incoming>SeqFlow_DSC_18</incoming>
      </endEvent>

      <startEvent id="StartEvent_DSC_3" name="Receive reports">
         <outgoing>SeqFlow_DSC_19</outgoing>
         <messageEventDefinition id="MsgDef_3" />
      </startEvent>
      <task id="Task_DSC_11" name="Process the reports">
         <incoming>SeqFlow_DSC_19</incoming>
         <outgoing>SeqFlow_DSC_20</outgoing>
      </task>
      <endEvent id="EndEvent_DSC_3" name="Status managed">
         <incoming>SeqFlow_DSC_20</incoming>
      </endEvent>

      <sequenceFlow id="SeqFlow_DSC_1" sourceRef="StartEvent_DSC_1" targetRef="Task_DSC_1" />
      <sequenceFlow id="SeqFlow_DSC_2" sourceRef="Task_DSC_1" targetRef="Gateway_DSC_1" />
      <sequenceFlow id="SeqFlow_DSC_3" sourceRef="Gateway_DSC_1" targetRef="Task_DSC_2" />
      <sequenceFlow id="SeqFlow_DSC_4" sourceRef="Task_DSC_2" targetRef="EndEvent_DSC_1" />
      <sequenceFlow id="SeqFlow_DSC_5" sourceRef="StartEvent_DSC_2" targetRef="Task_DSC_3" />
      <sequenceFlow id="SeqFlow_DSC_6" sourceRef="Task_DSC_3" targetRef="Gateway_DSC_2" />
      <sequenceFlow id="SeqFlow_DSC_7" sourceRef="Gateway_DSC_2" targetRef="Task_DSC_4" />
      <sequenceFlow id="SeqFlow_DSC_8" sourceRef="Task_DSC_4" targetRef="Task_DSC_5" />
      <sequenceFlow id="SeqFlow_DSC_9" sourceRef="Task_DSC_5" targetRef="Task_DSC_6" />
      <sequenceFlow id="SeqFlow_DSC_10" sourceRef="Task_DSC_6" targetRef="Gateway_DSC_3" />
      <sequenceFlow id="SeqFlow_DSC_11" sourceRef="Gateway_DSC_3" targetRef="Task_DSC_7" />
      <sequenceFlow id="SeqFlow_DSC_12" sourceRef="Task_DSC_7" targetRef="Task_DSC_8" />
      <sequenceFlow id="SeqFlow_DSC_13" sourceRef="Task_DSC_8" targetRef="Gateway_DSC_4" />
      <sequenceFlow id="SeqFlow_DSC_14" sourceRef="Gateway_DSC_4" targetRef="Task_DSC_9" />
      <sequenceFlow id="SeqFlow_DSC_15" sourceRef="Gateway_DSC_4" targetRef="Task_DSC_10" />
      <sequenceFlow id="SeqFlow_DSC_16" sourceRef="Task_DSC_9" targetRef="Gateway_DSC_5" />
      <sequenceFlow id="SeqFlow_DSC_17" sourceRef="Task_DSC_10" targetRef="Gateway_DSC_5" />
      <sequenceFlow id="SeqFlow_DSC_18" sourceRef="Gateway_DSC_5" targetRef="EndEvent_DSC_2" />
      <sequenceFlow id="SeqFlow_DSC_19" sourceRef="StartEvent_DSC_3" targetRef="Task_DSC_11" />
      <sequenceFlow id="SeqFlow_DSC_20" sourceRef="Task_DSC_11" targetRef="EndEvent_DSC_3" />
   </process>

   <process id="Process_TF" isExecutable="false" name="Trusted flaggers">
      <startEvent id="StartEvent_TF_1" name="Process starts">
         <outgoing>SeqFlow_TF_1</outgoing>
      </startEvent>
      <task id="Task_TF_1" name="Publish detailed reports on notices">
         <incoming>SeqFlow_TF_1</incoming>
         <outgoing>SeqFlow_TF_2</outgoing>
      </task>
      <parallelGateway id="Gateway_TF_1">
         <incoming>SeqFlow_TF_2</incoming>
         <outgoing>SeqFlow_TF_3</outgoing>
         <outgoing>SeqFlow_TF_4</outgoing>
         <outgoing>SeqFlow_TF_5</outgoing>
      </parallelGateway>
      <task id="Task_TF_2" name="List number of notices">
         <incoming>SeqFlow_TF_3</incoming>
         <outgoing>SeqFlow_TF_6</outgoing>
      </task>
      <task id="Task_TF_3" name="Include explanation of procedures">
         <incoming>SeqFlow_TF_4</incoming>
         <outgoing>SeqFlow_TF_7</outgoing>
      </task>
      <task id="Task_TF_4" name="Ensure information does not contain personal data">
         <incoming>SeqFlow_TF_5</incoming>
         <outgoing>SeqFlow_TF_8</outgoing>
      </task>
      <parallelGateway id="Gateway_TF_2">
         <incoming>SeqFlow_TF_6</incoming>
         <incoming>SeqFlow_TF_7</incoming>
         <incoming>SeqFlow_TF_8</incoming>
         <outgoing>SeqFlow_TF_9</outgoing>
      </parallelGateway>
      <parallelGateway id="Gateway_TF_3">
         <incoming>SeqFlow_TF_9</incoming>
         <outgoing>SeqFlow_TF_10</outgoing>
         <outgoing>SeqFlow_TF_11</outgoing>
      </parallelGateway>
      <task id="Task_TF_5" name="Send reports to DSC">
         <incoming>SeqFlow_TF_10</incoming>
         <outgoing>SeqFlow_TF_12</outgoing>
      </task>
      <task id="Task_TF_6" name="Make reports publicly available">
         <incoming>SeqFlow_TF_11</incoming>
         <outgoing>SeqFlow_TF_13</outgoing>
      </task>
      <parallelGateway id="Gateway_TF_4">
         <incoming>SeqFlow_TF_12</incoming>
         <incoming>SeqFlow_TF_13</incoming>
         <outgoing>SeqFlow_TF_14</outgoing>
      </parallelGateway>
      <endEvent id="EndEvent_TF_1" name="Duties fulfilled">
         <incoming>SeqFlow_TF_14</incoming>
      </endEvent>

      <startEvent id="StartEvent_TF_2" name="Receive opportunity to react">
         <outgoing>SeqFlow_TF_15</outgoing>
         <messageEventDefinition id="MsgDef_4" />
      </startEvent>
      <task id="Task_TF_7" name="React to findings and intention">
         <incoming>SeqFlow_TF_15</incoming>
         <outgoing>SeqFlow_TF_16</outgoing>
      </task>
      <endEvent id="EndEvent_TF_2" name="Duties fulfilled">
         <incoming>SeqFlow_TF_16</incoming>
      </endEvent>

      <sequenceFlow id="SeqFlow_TF_1" sourceRef="StartEvent_TF_1" targetRef="Task_TF_1" />
      <sequenceFlow id="SeqFlow_TF_2" sourceRef="Task_TF_1" targetRef="Gateway_TF_1" />
      <sequenceFlow id="SeqFlow_TF_3" sourceRef="Gateway_TF_1" targetRef="Task_TF_2" />
      <sequenceFlow id="SeqFlow_TF_4" sourceRef="Gateway_TF_1" targetRef="Task_TF_3" />
      <sequenceFlow id="SeqFlow_TF_5" sourceRef="Gateway_TF_1" targetRef="Task_TF_4" />
      <sequenceFlow id="SeqFlow_TF_6" sourceRef="Task_TF_2" targetRef="Gateway_TF_2" />
      <sequenceFlow id="SeqFlow_TF_7" sourceRef="Task_TF_3" targetRef="Gateway_TF_2" />
      <sequenceFlow id="SeqFlow_TF_8" sourceRef="Task_TF_4" targetRef="Gateway_TF_2" />
      <sequenceFlow id="SeqFlow_TF_9" sourceRef="Gateway_TF_2" targetRef="Gateway_TF_3" />
      <sequenceFlow id="SeqFlow_TF_10" sourceRef="Gateway_TF_3" targetRef="Task_TF_5" />
      <sequenceFlow id="SeqFlow_TF_11" sourceRef="Gateway_TF_3" targetRef="Task_TF_6" />
      <sequenceFlow id="SeqFlow_TF_12" sourceRef="Task_TF_5" targetRef="Gateway_TF_4" />
      <sequenceFlow id="SeqFlow_TF_13" sourceRef="Task_TF_6" targetRef="Gateway_TF_4" />
      <sequenceFlow id="SeqFlow_TF_14" sourceRef="Gateway_TF_4" targetRef="EndEvent_TF_1" />
      <sequenceFlow id="SeqFlow_TF_15" sourceRef="StartEvent_TF_2" targetRef="Task_TF_7" />
      <sequenceFlow id="SeqFlow_TF_16" sourceRef="Task_TF_7" targetRef="EndEvent_TF_2" />
   </process>

   <process id="Process_PoP" isExecutable="false" name="Providers of online platforms">
      <startEvent id="StartEvent_PoP" name="Process starts">
         <outgoing>SeqFlow_PoP_1</outgoing>
      </startEvent>
      <task id="Task_PoP_1" name="Take necessary technical and organisational measures">
         <incoming>SeqFlow_PoP_1</incoming>
         <outgoing>SeqFlow_PoP_2</outgoing>
      </task>
      <task id="Task_PoP_2" name="Assess information on notices">
         <incoming>SeqFlow_PoP_2</incoming>
         <outgoing>SeqFlow_PoP_3</outgoing>
      </task>
      <exclusiveGateway id="Gateway_PoP_1">
         <incoming>SeqFlow_PoP_3</incoming>
         <outgoing>SeqFlow_PoP_4</outgoing>
      </exclusiveGateway>
      <parallelGateway id="Gateway_PoP_2">
         <incoming>SeqFlow_PoP_4</incoming>
         <outgoing>SeqFlow_PoP_5</outgoing>
         <outgoing>SeqFlow_PoP_6</outgoing>
      </parallelGateway>
      <task id="Task_PoP_3" name="Send information to DSC">
         <incoming>SeqFlow_PoP_5</incoming>
         <outgoing>SeqFlow_PoP_7</outgoing>
      </task>
      <task id="Task_PoP_4" name="Send explanations and documents">
         <incoming>SeqFlow_PoP_6</incoming>
         <outgoing>SeqFlow_PoP_8</outgoing>
      </task>
      <parallelGateway id="Gateway_PoP_3">
         <incoming>SeqFlow_PoP_7</incoming>
         <incoming>SeqFlow_PoP_8</incoming>
         <outgoing>SeqFlow_PoP_9</outgoing>
      </parallelGateway>
      <endEvent id="EndEvent_PoP" name="Notices processed">
         <incoming>SeqFlow_PoP_9</incoming>
      </endEvent>

      <sequenceFlow id="SeqFlow_PoP_1" sourceRef="StartEvent_PoP" targetRef="Task_PoP_1" />
      <sequenceFlow id="SeqFlow_PoP_2" sourceRef="Task_PoP_1" targetRef="Task_PoP_2" />
      <sequenceFlow id="SeqFlow_PoP_3" sourceRef="Task_PoP_2" targetRef="Gateway_PoP_1" />
      <sequenceFlow id="SeqFlow_PoP_4" sourceRef="Gateway_PoP_1" targetRef="Gateway_PoP_2" />
      <sequenceFlow id="SeqFlow_PoP_5" sourceRef="Gateway_PoP_2" targetRef="Task_PoP_3" />
      <sequenceFlow id="SeqFlow_PoP_6" sourceRef="Gateway_PoP_2" targetRef="Task_PoP_4" />
      <sequenceFlow id="SeqFlow_PoP_7" sourceRef="Task_PoP_3" targetRef="Gateway_PoP_3" />
      <sequenceFlow id="SeqFlow_PoP_8" sourceRef="Task_PoP_4" targetRef="Gateway_PoP_3" />
      <sequenceFlow id="SeqFlow_PoP_9" sourceRef="Gateway_PoP_3" targetRef="EndEvent_PoP" />
   </process>

   <process id="Process_Commission" isExecutable="false" name="Commission">
      <startEvent id="StartEvent_Comm_1" name="Receive entities info">
         <outgoing>SeqFlow_Comm_1</outgoing>
         <messageEventDefinition id="MsgDef_5" />
      </startEvent>
      <task id="Task_Comm_1" name="Publish info in database">
         <incoming>SeqFlow_Comm_1</incoming>
         <outgoing>SeqFlow_Comm_2</outgoing>
      </task>
      <task id="Task_Comm_2" name="Keep database up to date">
         <incoming>SeqFlow_Comm_2</incoming>
         <outgoing>SeqFlow_Comm_3</outgoing>
      </task>
      <endEvent id="EndEvent_Comm_1" name="Guidelines managed">
         <incoming>SeqFlow_Comm_3</incoming>
      </endEvent>

      <startEvent id="StartEvent_Comm_2" name="Process starts">
         <outgoing>SeqFlow_Comm_4</outgoing>
      </startEvent>
      <task id="Task_Comm_3" name="Assess necessity to issue guidelines">
         <incoming>SeqFlow_Comm_4</incoming>
         <outgoing>SeqFlow_Comm_5</outgoing>
      </task>
      <exclusiveGateway id="Gateway_Comm_1">
         <incoming>SeqFlow_Comm_5</incoming>
         <outgoing>SeqFlow_Comm_6</outgoing>
      </exclusiveGateway>
      <task id="Task_Comm_4" name="Send consultation to Board">
         <incoming>SeqFlow_Comm_6</incoming>
         <outgoing>SeqFlow_Comm_7</outgoing>
      </task>
      <task id="Task_Comm_5" name="Issue guidelines">
         <incoming>SeqFlow_Comm_7</incoming>
         <outgoing>SeqFlow_Comm_8</outgoing>
      </task>
      <endEvent id="EndEvent_Comm_2" name="Guidelines managed">
         <incoming>SeqFlow_Comm_8</incoming>
      </endEvent>

      <sequenceFlow id="SeqFlow_Comm_1" sourceRef="StartEvent_Comm_1" targetRef="Task_Comm_1" />
      <sequenceFlow id="SeqFlow_Comm_2" sourceRef="Task_Comm_1" targetRef="Task_Comm_2" />
      <sequenceFlow id="SeqFlow_Comm_3" sourceRef="Task_Comm_2" targetRef="EndEvent_Comm_1" />
      <sequenceFlow id="SeqFlow_Comm_4" sourceRef="StartEvent_Comm_2" targetRef="Task_Comm_3" />
      <sequenceFlow id="SeqFlow_Comm_5" sourceRef="Task_Comm_3" targetRef="Gateway_Comm_1" />
      <sequenceFlow id="SeqFlow_Comm_6" sourceRef="Gateway_Comm_1" targetRef="Task_Comm_4" />
      <sequenceFlow id="SeqFlow_Comm_7" sourceRef="Task_Comm_4" targetRef="Task_Comm_5" />
      <sequenceFlow id="SeqFlow_Comm_8" sourceRef="Task_Comm_5" targetRef="EndEvent_Comm_2" />
   </process>

   <process id="Process_Board" isExecutable="false" name="Board">
      <startEvent id="StartEvent_Board_1" name="Receive info">
         <outgoing>SeqFlow_Board_1</outgoing>
         <messageEventDefinition id="MsgDef_6" />
      </startEvent>
      <task id="Task_Board_1" name="Process communication">
         <incoming>SeqFlow_Board_1</incoming>
         <outgoing>SeqFlow_Board_2</outgoing>
      </task>
      <endEvent id="EndEvent_Board_1" name="Consultation completed">
         <incoming>SeqFlow_Board_2</incoming>
      </endEvent>

      <startEvent id="StartEvent_Board_2" name="Receive consultation">
         <outgoing>SeqFlow_Board_3</outgoing>
         <messageEventDefinition id="MsgDef_7" />
      </startEvent>
      <task id="Task_Board_2" name="Provide advice">
         <incoming>SeqFlow_Board_3</incoming>
         <outgoing>SeqFlow_Board_4</outgoing>
      </task>
      <endEvent id="EndEvent_Board_2" name="Consultation completed">
         <incoming>SeqFlow_Board_4</incoming>
      </endEvent>

      <sequenceFlow id="SeqFlow_Board_1" sourceRef="StartEvent_Board_1" targetRef="Task_Board_1" />
      <sequenceFlow id="SeqFlow_Board_2" sourceRef="Task_Board_1" targetRef="EndEvent_Board_1" />
      <sequenceFlow id="SeqFlow_Board_3" sourceRef="StartEvent_Board_2" targetRef="Task_Board_2" />
      <sequenceFlow id="SeqFlow_Board_4" sourceRef="Task_Board_2" targetRef="EndEvent_Board_2" />
   </process>

   <bpmndi:BPMNDiagram id="BPMNDiagram_1">
      <bpmndi:BPMNPlane bpmnElement="Collaboration_1" id="BPMNPlane_1">

         <bpmndi:BPMNShape bpmnElement="Participant_Entities" id="Shape_Participant_Entities" isHorizontal="true">
            <omgdc:Bounds height="250.0" width="1600.0" x="100.0" y="50.0" />
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="StartEvent_Ent" id="Shape_StartEvent_Ent">
            <omgdc:Bounds height="30.0" width="30.0" x="200.0" y="135.0" />
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="Task_Ent_1" id="Shape_Task_Ent_1">
            <omgdc:Bounds height="80.0" width="100.0" x="260.0" y="110.0" />
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="Gateway_Ent_Split" id="Shape_Gateway_Ent_Split">
            <omgdc:Bounds height="50.0" width="50.0" x="400.0" y="125.0" />
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="Task_Ent_2" id="Shape_Task_Ent_2">
            <omgdc:Bounds height="80.0" width="100.0" x="500.0" y="60.0" />
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="Task_Ent_3" id="Shape_Task_Ent_3">
            <omgdc:Bounds height="80.0" width="100.0" x="500.0" y="160.0" />
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="Task_Ent_4" id="Shape_Task_Ent_4">
