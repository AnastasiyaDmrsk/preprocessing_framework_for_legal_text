      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="MS_Task_Utilise_Channels_di" bpmnElement="MS_Task_Utilise_Channels">
        <omgdc:Bounds x="350" y="1190" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="MS_Task_Assess_New_Channels_di" bpmnElement="MS_Task_Assess_New_Channels">
        <omgdc:Bounds x="500" y="1190" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="MS_XOR_3_di" bpmnElement="MS_XOR_3">
        <omgdc:Bounds x="650" y="1210" width="40" height="40"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="MS_Task_Establish_New_di" bpmnElement="MS_Task_Establish_New">
        <omgdc:Bounds x="740" y="1130" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="MS_XOR_Merge_3_di" bpmnElement="MS_XOR_Merge_3">
        <omgdc:Bounds x="880" y="1210" width="40" height="40"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="MS_Task_Provide_Advice_di" bpmnElement="MS_Task_Provide_Advice">
        <omgdc:Bounds x="960" y="1190" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="MS_Task_Respond_Queries_di" bpmnElement="MS_Task_Respond_Queries">
        <omgdc:Bounds x="1110" y="1190" width="100" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="MS_Task_Facilitate_SMEs_di" bpmnElement="MS_Task_Facilitate_SMEs">
        <omgdc:Bounds x="350" y="1360" width="100" height="80"/>
      </bpmndi:BPMNShape>
