        <omgdc:Bounds x="500" y="880" width="40" height="40"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="MS_Task_Provide_Priority_di" bpmnElement="MS_Task_Provide_Priority">
