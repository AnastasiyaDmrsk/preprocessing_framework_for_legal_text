      <bpmndi:BPMNShape id="AIO_Task_Provide_Templates_di" bpmnElement="AIO_Task_Provide_Templates">
        <omgdc:Bounds x="450" y="275" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="AIO_Task_Develop_Platform_di" bpmnElement="AIO_Task_Develop_Platform">
        <omgdc:Bounds x="350" y="400" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="AIO_Task_Maintain_Platform_di" bpmnElement="AIO_Task_Maintain_Platform">
