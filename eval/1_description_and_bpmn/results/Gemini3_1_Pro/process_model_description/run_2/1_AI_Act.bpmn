      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="MS_Start_di" bpmnElement="MS_Start">
        <omgdc:Bounds x="150" y="1180" width="30" height="30"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="MS_Split_di" bpmnElement="MS_Split">
        <omgdc:Bounds x="230" y="1175" width="40" height="40"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="MS_Task_Assess_SMEs_1_di" bpmnElement="MS_Task_Assess_SMEs_1">
        <omgdc:Bounds x="350" y="860" width="100" height="80"/>
      </bpmndi:BPMNShape>
