      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="MS_XOR_Merge_1_di" bpmnElement="MS_XOR_Merge_1">
        <omgdc:Bounds x="720" y="880" width="40" height="40"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="MS_Task_Assess_SMEs_2_di" bpmnElement="MS_Task_Assess_SMEs_2">
