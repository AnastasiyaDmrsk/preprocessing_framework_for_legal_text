<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             targetNamespace="http://www.signavio.com"
             id="sid-AI-Regulation-Implementation"
             xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd">

  <collaboration id="Collaboration_1">
    <participant id="Participant_Board" name="The Board" processRef="Process_Board"/>
    <participant id="Participant_AI_Office" name="The AI Office" processRef="Process_AI_Office"/>
    <participant id="Participant_MS" name="Member States" processRef="Process_MS"/>
    <messageFlow id="Flow_Message_Request" sourceRef="Board_Task_Send_Request" targetRef="AIO_Catch_Request"/>
  </collaboration>

  <process id="Process_Board" isExecutable="true">
    <startEvent id="Board_Start" name="Start">
      <outgoing>Board_Flow_1</outgoing>
    </startEvent>
    <task id="Board_Task_Send_Request" name="Send request specifying standardised templates">
      <incoming>Board_Flow_1</incoming>
      <outgoing>Board_Flow_2</outgoing>
    </task>
    <endEvent id="Board_End" name="Request sent">
      <incoming>Board_Flow_2</incoming>
    </endEvent>

    <sequenceFlow id="Board_Flow_1" sourceRef="Board_Start" targetRef="Board_Task_Send_Request"/>
    <sequenceFlow id="Board_Flow_2" sourceRef="Board_Task_Send_Request" targetRef="Board_End"/>
  </process>

  <process id="Process_AI_Office" isExecutable="true">
    <startEvent id="AIO_Start" name="Need to implement measures">
      <outgoing>AIO_Flow_Start</outgoing>
    </startEvent>
    <parallelGateway id="AIO_Split" name="Parallel Start">
      <incoming>AIO_Flow_Start</incoming>
      <outgoing>AIO_Flow_B1</outgoing>
      <outgoing>AIO_Flow_B2</outgoing>
      <outgoing>AIO_Flow_B3</outgoing>
      <outgoing>AIO_Flow_B4</outgoing>
    </parallelGateway>

    <intermediateCatchEvent id="AIO_Catch_Request" name="Receive request">
      <incoming>AIO_Flow_B1</incoming>
      <outgoing>AIO_Flow_B1_1</outgoing>
      <messageEventDefinition id="MsgDef_1"/>
    </intermediateCatchEvent>
    <task id="AIO_Task_Provide_Templates" name="Provide standardised templates">
      <incoming>AIO_Flow_B1_1</incoming>
      <outgoing>AIO_Flow_B1_End</outgoing>
    </task>

    <task id="AIO_Task_Develop_Platform" name="Develop a single information platform">
      <incoming>AIO_Flow_B2</incoming>
      <outgoing>AIO_Flow_B2_1</outgoing>
    </task>
    <task id="AIO_Task_Maintain_Platform" name="Maintain a single information platform">
      <incoming>AIO_Flow_B2_1</incoming>
      <outgoing>AIO_Flow_B2_End</outgoing>
    </task>

    <task id="AIO_Task_Organise_Campaigns" name="Organise appropriate communication campaigns">
      <incoming>AIO_Flow_B3</incoming>
      <outgoing>AIO_Flow_B3_End</outgoing>
    </task>

    <task id="AIO_Task_Evaluate_Convergence" name="Evaluate convergence of best practices">
      <incoming>AIO_Flow_B4</incoming>
      <outgoing>AIO_Flow_B4_1</outgoing>
    </task>
    <task id="AIO_Task_Promote_Convergence" name="Promote convergence of best practices">
      <incoming>AIO_Flow_B4_1</incoming>
      <outgoing>AIO_Flow_B4_End</outgoing>
    </task>

    <parallelGateway id="AIO_Join" name="Parallel End">
      <incoming>AIO_Flow_B1_End</incoming>
      <incoming>AIO_Flow_B2_End</incoming>
      <incoming>AIO_Flow_B3_End</incoming>
      <incoming>AIO_Flow_B4_End</incoming>
      <outgoing>AIO_Flow_End</outgoing>
    </parallelGateway>
    <endEvent id="AIO_End" name="Measures implemented">
      <incoming>AIO_Flow_End</incoming>
    </endEvent>

    <sequenceFlow id="AIO_Flow_Start" sourceRef="AIO_Start" targetRef="AIO_Split"/>
    <sequenceFlow id="AIO_Flow_B1" sourceRef="AIO_Split" targetRef="AIO_Catch_Request"/>
    <sequenceFlow id="AIO_Flow_B1_1" sourceRef="AIO_Catch_Request" targetRef="AIO_Task_Provide_Templates"/>
    <sequenceFlow id="AIO_Flow_B1_End" sourceRef="AIO_Task_Provide_Templates" targetRef="AIO_Join"/>

    <sequenceFlow id="AIO_Flow_B2" sourceRef="AIO_Split" targetRef="AIO_Task_Develop_Platform"/>
    <sequenceFlow id="AIO_Flow_B2_1" sourceRef="AIO_Task_Develop_Platform" targetRef="AIO_Task_Maintain_Platform"/>
    <sequenceFlow id="AIO_Flow_B2_End" sourceRef="AIO_Task_Maintain_Platform" targetRef="AIO_Join"/>

    <sequenceFlow id="AIO_Flow_B3" sourceRef="AIO_Split" targetRef="AIO_Task_Organise_Campaigns"/>
    <sequenceFlow id="AIO_Flow_B3_End" sourceRef="AIO_Task_Organise_Campaigns" targetRef="AIO_Join"/>

    <sequenceFlow id="AIO_Flow_B4" sourceRef="AIO_Split" targetRef="AIO_Task_Evaluate_Convergence"/>
    <sequenceFlow id="AIO_Flow_B4_1" sourceRef="AIO_Task_Evaluate_Convergence" targetRef="AIO_Task_Promote_Convergence"/>
    <sequenceFlow id="AIO_Flow_B4_End" sourceRef="AIO_Task_Promote_Convergence" targetRef="AIO_Join"/>

    <sequenceFlow id="AIO_Flow_End" sourceRef="AIO_Join" targetRef="AIO_End"/>
  </process>

  <process id="Process_MS" isExecutable="true">
    <startEvent id="MS_Start" name="Need to implement measures">
      <outgoing>MS_Flow_Start</outgoing>
    </startEvent>
    <parallelGateway id="MS_Split" name="Parallel Start">
      <incoming>MS_Flow_Start</incoming>
      <outgoing>MS_Flow_B1</outgoing>
      <outgoing>MS_Flow_B2</outgoing>
      <outgoing>MS_Flow_B3</outgoing>
      <outgoing>MS_Flow_B4</outgoing>
      <outgoing>MS_Flow_B5</outgoing>
    </parallelGateway>

    <task id="MS_Task_Assess_SMEs_1" name="Assess whether SMEs fulfil conditions">
      <incoming>MS_Flow_B1</incoming>
      <outgoing>MS_Flow_B1_1</outgoing>
    </task>
    <exclusiveGateway id="MS_XOR_1" name="Fulfil?">
      <incoming>MS_Flow_B1_1</incoming>
      <outgoing>MS_Flow_B1_Yes_1</outgoing>
      <outgoing>MS_Flow_B1_No_1</outgoing>
    </exclusiveGateway>
    <task id="MS_Task_Provide_Priority" name="Provide SMEs priority access">
      <incoming>MS_Flow_B1_Yes_1</incoming>
      <outgoing>MS_Flow_B1_Merge1_A</outgoing>
    </task>
    <exclusiveGateway id="MS_XOR_Merge_1">
      <incoming>MS_Flow_B1_Merge1_A</incoming>
      <incoming>MS_Flow_B1_No_1</incoming>
      <outgoing>MS_Flow_B1_2</outgoing>
    </exclusiveGateway>
    <task id="MS_Task_Assess_SMEs_2" name="Assess whether other SMEs fulfil conditions">
      <incoming>MS_Flow_B1_2</incoming>
      <outgoing>MS_Flow_B1_3</outgoing>
    </task>
    <exclusiveGateway id="MS_XOR_2" name="Fulfil?">
      <incoming>MS_Flow_B1_3</incoming>
      <outgoing>MS_Flow_B1_Yes_2</outgoing>
      <outgoing>MS_Flow_B1_No_2</outgoing>
    </exclusiveGateway>
    <task id="MS_Task_Provide_Access" name="Provide other SMEs access">
      <incoming>MS_Flow_B1_Yes_2</incoming>
      <outgoing>MS_Flow_B1_Merge2_A</outgoing>
    </task>
    <exclusiveGateway id="MS_XOR_Merge_2">
      <incoming>MS_Flow_B1_Merge2_A</incoming>
      <incoming>MS_Flow_B1_No_2</incoming>
      <outgoing>MS_Flow_B1_End</outgoing>
    </exclusiveGateway>

    <task id="MS_Task_Organise_Awareness" name="Organise specific awareness raising activities">
      <incoming>MS_Flow_B2</incoming>
      <outgoing>MS_Flow_B2_1</outgoing>
    </task>
    <task id="MS_Task_Organise_Training" name="Organise training activities">
      <incoming>MS_Flow_B2_1</incoming>
      <outgoing>MS_Flow_B2_End</outgoing>
    </task>

    <task id="MS_Task_Utilise_Channels" name="Utilise existing dedicated channels">
      <incoming>MS_Flow_B3</incoming>
      <outgoing>MS_Flow_B3_1</outgoing>
    </task>
    <task id="MS_Task_Assess_New_Channels" name="Assess whether appropriate to establish new channels">
      <incoming>MS_Flow_B3_1</incoming>
      <outgoing>MS_Flow_B3_2</outgoing>
    </task>
    <exclusiveGateway id="MS_XOR_3" name="Appropriate?">
      <incoming>MS_Flow_B3_2</incoming>
      <outgoing>MS_Flow_B3_Yes</outgoing>
      <outgoing>MS_Flow_B3_No</outgoing>
    </exclusiveGateway>
    <task id="MS_Task_Establish_New" name="Establish new channels for communication">
      <incoming>MS_Flow_B3_Yes</incoming>
      <outgoing>MS_Flow_B3_Merge_A</outgoing>
    </task>
    <exclusiveGateway id="MS_XOR_Merge_3">
      <incoming>MS_Flow_B3_Merge_A</incoming>
      <incoming>MS_Flow_B3_No</incoming>
      <outgoing>MS_Flow_B3_3</outgoing>
    </exclusiveGateway>
    <task id="MS_Task_Provide_Advice" name="Provide advice about implementation">
      <incoming>MS_Flow_B3_3</incoming>
      <outgoing>MS_Flow_B3_4</outgoing>
    </task>
    <task id="MS_Task_Respond_Queries" name="Respond to queries about implementation">
      <incoming>MS_Flow_B3_4</incoming>
      <outgoing>MS_Flow_B3_End</outgoing>
    </task>

    <task id="MS_Task_Facilitate_SMEs" name="Facilitate participation of SMEs">
      <incoming>MS_Flow_B4</incoming>
      <outgoing>MS_Flow_B4_1</outgoing>
    </task>
    <task id="MS_Task_Facilitate_Stakeholders" name="Facilitate participation of other relevant stakeholders">
      <incoming>MS_Flow_B4_1</incoming>
      <outgoing>MS_Flow_B4_End</outgoing>
    </task>

    <task id="MS_Task_Take_Into_Account" name="Take into account specific interests and needs">
      <incoming>MS_Flow_B5</incoming>
      <outgoing>MS_Flow_B5_1</outgoing>
    </task>
    <task id="MS_Task_Reduce_Fees" name="Reduce fees proportionately">
      <incoming>MS_Flow_B5_1</incoming>
      <outgoing>MS_Flow_B5_End</outgoing>
    </task>

    <parallelGateway id="MS_Join" name="Parallel End">
      <incoming>MS_Flow_B1_End</incoming>
      <incoming>MS_Flow_B2_End</incoming>
      <incoming>MS_Flow_B3_End</incoming>
      <incoming>MS_Flow_B4_End</incoming>
      <incoming>MS_Flow_B5_End</incoming>
      <outgoing>MS_Flow_End</outgoing>
    </parallelGateway>
    <endEvent id="MS_End" name="Measures implemented">
      <incoming>MS_Flow_End</incoming>
    </endEvent>

    <sequenceFlow id="MS_Flow_Start" sourceRef="MS_Start" targetRef="MS_Split"/>

    <sequenceFlow id="MS_Flow_B1" sourceRef="MS_Split" targetRef="MS_Task_Assess_SMEs_1"/>
    <sequenceFlow id="MS_Flow_B1_1" sourceRef="MS_Task_Assess_SMEs_1" targetRef="MS_XOR_1"/>
    <sequenceFlow id="MS_Flow_B1_Yes_1" name="Yes" sourceRef="MS_XOR_1" targetRef="MS_Task_Provide_Priority"/>
    <sequenceFlow id="MS_Flow_B1_No_1" name="No" sourceRef="MS_XOR_1" targetRef="MS_XOR_Merge_1"/>
    <sequenceFlow id="MS_Flow_B1_Merge1_A" sourceRef="MS_Task_Provide_Priority" targetRef="MS_XOR_Merge_1"/>
    <sequenceFlow id="MS_Flow_B1_2" sourceRef="MS_XOR_Merge_1" targetRef="MS_Task_Assess_SMEs_2"/>
    <sequenceFlow id="MS_Flow_B1_3" sourceRef="MS_Task_Assess_SMEs_2" targetRef="MS_XOR_2"/>
    <sequenceFlow id="MS_Flow_B1_Yes_2" name="Yes" sourceRef="MS_XOR_2" targetRef="MS_Task_Provide_Access"/>
    <sequenceFlow id="MS_Flow_B1_No_2" name="No" sourceRef="MS_XOR_2" targetRef="MS_XOR_Merge_2"/>
    <sequenceFlow id="MS_Flow_B1_Merge2_A" sourceRef="MS_Task_Provide_Access" targetRef="MS_XOR_Merge_2"/>
    <sequenceFlow id="MS_Flow_B1_End" sourceRef="MS_XOR_Merge_2" targetRef="MS_Join"/>

    <sequenceFlow id="MS_Flow_B2" sourceRef="MS_Split" targetRef="MS_Task_Organise_Awareness"/>
    <sequenceFlow id="MS_Flow_B2_1" sourceRef="MS_Task_Organise_Awareness" targetRef="MS_Task_Organise_Training"/>
    <sequenceFlow id="MS_Flow_B2_End" sourceRef="MS_Task_Organise_Training" targetRef="MS_Join"/>

    <sequenceFlow id="MS_Flow_B3" sourceRef="MS_Split" targetRef="MS_Task_Utilise_Channels"/>
    <sequenceFlow id="MS_Flow_B3_1" sourceRef="MS_Task_Utilise_Channels" targetRef="MS_Task_Assess_New_Channels"/>
    <sequenceFlow id="MS_Flow_B3_2" sourceRef="MS_Task_Assess_New_Channels" targetRef="MS_XOR_3"/>
    <sequenceFlow id="MS_Flow_B3_Yes" name="Yes" sourceRef="MS_XOR_3" targetRef="MS_Task_Establish_New"/>
    <sequenceFlow id="MS_Flow_B3_No" name="No" sourceRef="MS_XOR_3" targetRef="MS_XOR_Merge_3"/>
    <sequenceFlow id="MS_Flow_B3_Merge_A" sourceRef="MS_Task_Establish_New" targetRef="MS_XOR_Merge_3"/>
    <sequenceFlow id="MS_Flow_B3_3" sourceRef="MS_XOR_Merge_3" targetRef="MS_Task_Provide_Advice"/>
    <sequenceFlow id="MS_Flow_B3_4" sourceRef="MS_Task_Provide_Advice" targetRef="MS_Task_Respond_Queries"/>
    <sequenceFlow id="MS_Flow_B3_End" sourceRef="MS_Task_Respond_Queries" targetRef="MS_Join"/>

    <sequenceFlow id="MS_Flow_B4" sourceRef="MS_Split" targetRef="MS_Task_Facilitate_SMEs"/>
    <sequenceFlow id="MS_Flow_B4_1" sourceRef="MS_Task_Facilitate_SMEs" targetRef="MS_Task_Facilitate_Stakeholders"/>
    <sequenceFlow id="MS_Flow_B4_End" sourceRef="MS_Task_Facilitate_Stakeholders" targetRef="MS_Join"/>

    <sequenceFlow id="MS_Flow_B5" sourceRef="MS_Split" targetRef="MS_Task_Take_Into_Account"/>
    <sequenceFlow id="MS_Flow_B5_1" sourceRef="MS_Task_Take_Into_Account" targetRef="MS_Task_Reduce_Fees"/>
    <sequenceFlow id="MS_Flow_B5_End" sourceRef="MS_Task_Reduce_Fees" targetRef="MS_Join"/>

    <sequenceFlow id="MS_Flow_End" sourceRef="MS_Join" targetRef="MS_End"/>
  </process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">

      <bpmndi:BPMNShape id="Participant_Board_di" bpmnElement="Participant_Board" isHorizontal="true">
        <omgdc:Bounds x="100" y="50" width="1400" height="150"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_AI_Office_di" bpmnElement="Participant_AI_Office" isHorizontal="true">
        <omgdc:Bounds x="100" y="250" width="1400" height="500"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_MS_di" bpmnElement="Participant_MS" isHorizontal="true">
        <omgdc:Bounds x="100" y="800" width="1400" height="850"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Board_Start_di" bpmnElement="Board_Start">
        <omgdc:Bounds x="150" y="100" width="30" height="30"/>
      </bpmndi:BPMNShape>
