      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="AIO_Task_Evaluate_Convergence_di" bpmnElement="AIO_Task_Evaluate_Convergence">
        <omgdc:Bounds x="350" y="640" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="AIO_Task_Promote_Convergence_di" bpmnElement="AIO_Task_Promote_Convergence">
        <omgdc:Bounds x="500" y="640" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="AIO_Join_di" bpmnElement="AIO_Join">
