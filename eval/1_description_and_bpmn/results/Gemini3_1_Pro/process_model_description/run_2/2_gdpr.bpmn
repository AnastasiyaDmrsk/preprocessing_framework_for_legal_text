<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             exporter="BPMN Modeler" exporterVersion="1.0"
             id="Definitions_1"
             targetNamespace="http://bpmn.io/schema/bpmn"
             xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd">
  <collaboration id="Collaboration_1">
    <participant id="Participant_Processor" name="Processor" processRef="Process_Processor" />
    <participant id="Participant_Controller" name="Controller" processRef="Process_Controller" />
    <participant id="Participant_SA" name="Supervisory authority" processRef="Process_SA" />
    <messageFlow id="MessageFlow_1" sourceRef="Task_Proc_Notify" targetRef="StartEvent_Cont" />
    <messageFlow id="MessageFlow_2" sourceRef="Task_Cont_NotifySA" targetRef="StartEvent_SA" />
    <messageFlow id="MessageFlow_3" sourceRef="Task_SA_RequireComm" targetRef="Task_Cont_CommReq" />
  </collaboration>

  <process id="Process_Processor" isExecutable="false">
    <startEvent id="StartEvent_Proc" name="Personal data breach">
      <outgoing>Flow_P1</outgoing>
    </startEvent>
    <task id="Task_Proc_Notify" name="Notify the controller without undue delay">
      <incoming>Flow_P1</incoming>
      <outgoing>Flow_P2</outgoing>
    </task>
    <endEvent id="EndEvent_Proc" name="Notification sent end event">
      <incoming>Flow_P2</incoming>
    </endEvent>
    <sequenceFlow id="Flow_P1" sourceRef="StartEvent_Proc" targetRef="Task_Proc_Notify" />
    <sequenceFlow id="Flow_P2" sourceRef="Task_Proc_Notify" targetRef="EndEvent_Proc" />
  </process>

  <process id="Process_Controller" isExecutable="false">
    <startEvent id="StartEvent_Cont" name="Receive notification or become aware">
      <outgoing>Flow_C1</outgoing>
      <messageEventDefinition id="MessageEventDefinition_1" />
    </startEvent>
    <task id="Task_Cont_AssessRisk" name="Assess whether the personal data breach is unlikely to result in a risk">
      <incoming>Flow_C1</incoming>
      <outgoing>Flow_C2</outgoing>
    </task>
    <exclusiveGateway id="Gateway_Cont_Risk" name="Likely to result in a risk?">
      <incoming>Flow_C2</incoming>
      <outgoing>Flow_C3_Yes</outgoing>
      <outgoing>Flow_C3_No</outgoing>
    </exclusiveGateway>
    <task id="Task_Cont_NotifySA" name="Notify the personal data breach to the supervisory authority">
      <incoming>Flow_C3_Yes</incoming>
      <outgoing>Flow_C4</outgoing>
    </task>
    <exclusiveGateway id="Gateway_Cont_Risk_Join">
      <incoming>Flow_C4</incoming>
      <incoming>Flow_C3_No</incoming>
      <outgoing>Flow_C5</outgoing>
    </exclusiveGateway>
    <task id="Task_Cont_Assess72h" name="Assess whether the notification is made within 72 hours">
      <incoming>Flow_C5</incoming>
      <outgoing>Flow_C6</outgoing>
    </task>
    <exclusiveGateway id="Gateway_Cont_72h" name="Not made within 72h?">
      <incoming>Flow_C6</incoming>
      <outgoing>Flow_C7_Yes</outgoing>
      <outgoing>Flow_C7_No</outgoing>
    </exclusiveGateway>
    <task id="Task_Cont_ProvideReasons" name="Provide reasons for the delay">
      <incoming>Flow_C7_Yes</incoming>
      <outgoing>Flow_C8</outgoing>
    </task>
    <exclusiveGateway id="Gateway_Cont_72h_Join">
      <incoming>Flow_C8</incoming>
      <incoming>Flow_C7_No</incoming>
      <outgoing>Flow_C9</outgoing>
    </exclusiveGateway>
    <task id="Task_Cont_AssessSameTime" name="Assess whether it is possible to provide info at the same time">
      <incoming>Flow_C9</incoming>
      <outgoing>Flow_C10</outgoing>
    </task>
    <exclusiveGateway id="Gateway_Cont_SameTime" name="Not possible?">
      <incoming>Flow_C10</incoming>
      <outgoing>Flow_C11_Yes</outgoing>
      <outgoing>Flow_C11_No</outgoing>
    </exclusiveGateway>
    <task id="Task_Cont_ProvidePhases" name="Provide the information in phases">
      <incoming>Flow_C11_Yes</incoming>
      <outgoing>Flow_C12</outgoing>
    </task>
    <exclusiveGateway id="Gateway_Cont_SameTime_Join">
      <incoming>Flow_C12</incoming>
      <incoming>Flow_C11_No</incoming>
      <outgoing>Flow_C13</outgoing>
    </exclusiveGateway>
    <parallelGateway id="Gateway_Cont_Parallel_Split" name="Carry out 4 activities in parallel">
      <incoming>Flow_C13</incoming>
      <outgoing>Flow_C14_1</outgoing>
      <outgoing>Flow_C14_2</outgoing>
      <outgoing>Flow_C14_3</outgoing>
      <outgoing>Flow_C14_4</outgoing>
    </parallelGateway>
    <task id="Task_Cont_DescNature" name="Describe the nature of the personal data breach">
      <incoming>Flow_C14_1</incoming>
      <outgoing>Flow_C15_1</outgoing>
    </task>
    <task id="Task_Cont_CommDPO" name="Communicate name and contact details of DPO">
      <incoming>Flow_C14_2</incoming>
      <outgoing>Flow_C15_2</outgoing>
    </task>
    <task id="Task_Cont_DescCons" name="Describe the likely consequences">
      <incoming>Flow_C14_3</incoming>
      <outgoing>Flow_C15_3</outgoing>
    </task>
    <task id="Task_Cont_DescMeasures" name="Describe the measures taken or proposed">
      <incoming>Flow_C14_4</incoming>
      <outgoing>Flow_C15_4</outgoing>
    </task>
    <parallelGateway id="Gateway_Cont_Parallel_Join" name="All 4 activities completed">
      <incoming>Flow_C15_1</incoming>
      <incoming>Flow_C15_2</incoming>
      <incoming>Flow_C15_3</incoming>
      <incoming>Flow_C15_4</incoming>
      <outgoing>Flow_C16</outgoing>
    </parallelGateway>
    <task id="Task_Cont_Document" name="Document any personal data breaches">
      <incoming>Flow_C16</incoming>
      <outgoing>Flow_C17</outgoing>
    </task>
    <task id="Task_Cont_IncludeFacts" name="Include the facts, effects and remedial action">
      <incoming>Flow_C17</incoming>
      <outgoing>Flow_C18</outgoing>
    </task>
    <task id="Task_Cont_AssessHighRisk" name="Assess whether the breach is likely to result in a high risk">
      <incoming>Flow_C18</incoming>
      <outgoing>Flow_C19</outgoing>
    </task>
    <exclusiveGateway id="Gateway_Cont_HighRisk" name="High risk likely?">
      <incoming>Flow_C19</incoming>
      <outgoing>Flow_C20_Yes</outgoing>
      <outgoing>Flow_C20_No</outgoing>
    </exclusiveGateway>
    <task id="Task_Cont_CommDataSubject" name="Communicate the personal data breach to the data subject">
      <incoming>Flow_C20_Yes</incoming>
      <outgoing>Flow_C21</outgoing>
    </task>
    <task id="Task_Cont_DescLanguage" name="Describe in clear and plain language the nature">
      <incoming>Flow_C21</incoming>
      <outgoing>Flow_C22</outgoing>
    </task>
    <task id="Task_Cont_IncludeInfo" name="Include at least the information and measures">
      <incoming>Flow_C22</incoming>
      <outgoing>Flow_C23</outgoing>
    </task>
    <exclusiveGateway id="Gateway_Cont_HighRisk_Join">
      <incoming>Flow_C23</incoming>
      <incoming>Flow_C20_No</incoming>
      <outgoing>Flow_C24</outgoing>
    </exclusiveGateway>
    <task id="Task_Cont_AssessEffort" name="Assess whether communication involves disproportionate effort">
      <incoming>Flow_C24</incoming>
      <outgoing>Flow_C25</outgoing>
    </task>
    <exclusiveGateway id="Gateway_Cont_Effort" name="Disproportionate effort?">
      <incoming>Flow_C25</incoming>
      <outgoing>Flow_C26_Yes</outgoing>
      <outgoing>Flow_C26_No</outgoing>
    </exclusiveGateway>
    <task id="Task_Cont_PublicComm" name="Make a public communication">
      <incoming>Flow_C26_Yes</incoming>
      <outgoing>Flow_C27</outgoing>
    </task>
    <exclusiveGateway id="Gateway_Cont_Effort_Join">
      <incoming>Flow_C27</incoming>
      <incoming>Flow_C26_No</incoming>
      <outgoing>Flow_C28</outgoing>
    </exclusiveGateway>
    <task id="Task_Cont_CommReq" name="Communicate the personal data breach to the data subject">
      <incoming>Flow_C28</incoming>
      <outgoing>Flow_C29</outgoing>
    </task>
    <endEvent id="EndEvent_Cont" name="Documentation and communication completed end event">
      <incoming>Flow_C29</incoming>
    </endEvent>

    <sequenceFlow id="Flow_C1" sourceRef="StartEvent_Cont" targetRef="Task_Cont_AssessRisk" />
    <sequenceFlow id="Flow_C2" sourceRef="Task_Cont_AssessRisk" targetRef="Gateway_Cont_Risk" />
    <sequenceFlow id="Flow_C3_Yes" name="Yes" sourceRef="Gateway_Cont_Risk" targetRef="Task_Cont_NotifySA" />
    <sequenceFlow id="Flow_C3_No" name="No" sourceRef="Gateway_Cont_Risk" targetRef="Gateway_Cont_Risk_Join" />
    <sequenceFlow id="Flow_C4" sourceRef="Task_Cont_NotifySA" targetRef="Gateway_Cont_Risk_Join" />
    <sequenceFlow id="Flow_C5" sourceRef="Gateway_Cont_Risk_Join" targetRef="Task_Cont_Assess72h" />
    <sequenceFlow id="Flow_C6" sourceRef="Task_Cont_Assess72h" targetRef="Gateway_Cont_72h" />
    <sequenceFlow id="Flow_C7_Yes" name="Yes" sourceRef="Gateway_Cont_72h" targetRef="Task_Cont_ProvideReasons" />
    <sequenceFlow id="Flow_C7_No" name="No" sourceRef="Gateway_Cont_72h" targetRef="Gateway_Cont_72h_Join" />
    <sequenceFlow id="Flow_C8" sourceRef="Task_Cont_ProvideReasons" targetRef="Gateway_Cont_72h_Join" />
    <sequenceFlow id="Flow_C9" sourceRef="Gateway_Cont_72h_Join" targetRef="Task_Cont_AssessSameTime" />
    <sequenceFlow id="Flow_C10" sourceRef="Task_Cont_AssessSameTime" targetRef="Gateway_Cont_SameTime" />
    <sequenceFlow id="Flow_C11_Yes" name="Yes" sourceRef="Gateway_Cont_SameTime" targetRef="Task_Cont_ProvidePhases" />
    <sequenceFlow id="Flow_C11_No" name="No" sourceRef="Gateway_Cont_SameTime" targetRef="Gateway_Cont_SameTime_Join" />
    <sequenceFlow id="Flow_C12" sourceRef="Task_Cont_ProvidePhases" targetRef="Gateway_Cont_SameTime_Join" />
    <sequenceFlow id="Flow_C13" sourceRef="Gateway_Cont_SameTime_Join" targetRef="Gateway_Cont_Parallel_Split" />
    <sequenceFlow id="Flow_C14_1" sourceRef="Gateway_Cont_Parallel_Split" targetRef="Task_Cont_DescNature" />
    <sequenceFlow id="Flow_C14_2" sourceRef="Gateway_Cont_Parallel_Split" targetRef="Task_Cont_CommDPO" />
    <sequenceFlow id="Flow_C14_3" sourceRef="Gateway_Cont_Parallel_Split" targetRef="Task_Cont_DescCons" />
    <sequenceFlow id="Flow_C14_4" sourceRef="Gateway_Cont_Parallel_Split" targetRef="Task_Cont_DescMeasures" />
    <sequenceFlow id="Flow_C15_1" sourceRef="Task_Cont_DescNature" targetRef="Gateway_Cont_Parallel_Join" />
    <sequenceFlow id="Flow_C15_2" sourceRef="Task_Cont_CommDPO" targetRef="Gateway_Cont_Parallel_Join" />
    <sequenceFlow id="Flow_C15_3" sourceRef="Task_Cont_DescCons" targetRef="Gateway_Cont_Parallel_Join" />
    <sequenceFlow id="Flow_C15_4" sourceRef="Task_Cont_DescMeasures" targetRef="Gateway_Cont_Parallel_Join" />
    <sequenceFlow id="Flow_C16" sourceRef="Gateway_Cont_Parallel_Join" targetRef="Task_Cont_Document" />
    <sequenceFlow id="Flow_C17" sourceRef="Task_Cont_Document" targetRef="Task_Cont_IncludeFacts" />
    <sequenceFlow id="Flow_C18" sourceRef="Task_Cont_IncludeFacts" targetRef="Task_Cont_AssessHighRisk" />
    <sequenceFlow id="Flow_C19" sourceRef="Task_Cont_AssessHighRisk" targetRef="Gateway_Cont_HighRisk" />
    <sequenceFlow id="Flow_C20_Yes" name="Yes" sourceRef="Gateway_Cont_HighRisk" targetRef="Task_Cont_CommDataSubject" />
    <sequenceFlow id="Flow_C20_No" name="No" sourceRef="Gateway_Cont_HighRisk" targetRef="Gateway_Cont_HighRisk_Join" />
    <sequenceFlow id="Flow_C21" sourceRef="Task_Cont_CommDataSubject" targetRef="Task_Cont_DescLanguage" />
    <sequenceFlow id="Flow_C22" sourceRef="Task_Cont_DescLanguage" targetRef="Task_Cont_IncludeInfo" />
    <sequenceFlow id="Flow_C23" sourceRef="Task_Cont_IncludeInfo" targetRef="Gateway_Cont_HighRisk_Join" />
    <sequenceFlow id="Flow_C24" sourceRef="Gateway_Cont_HighRisk_Join" targetRef="Task_Cont_AssessEffort" />
    <sequenceFlow id="Flow_C25" sourceRef="Task_Cont_AssessEffort" targetRef="Gateway_Cont_Effort" />
    <sequenceFlow id="Flow_C26_Yes" name="Yes" sourceRef="Gateway_Cont_Effort" targetRef="Task_Cont_PublicComm" />
    <sequenceFlow id="Flow_C26_No" name="No" sourceRef="Gateway_Cont_Effort" targetRef="Gateway_Cont_Effort_Join" />
    <sequenceFlow id="Flow_C27" sourceRef="Task_Cont_PublicComm" targetRef="Gateway_Cont_Effort_Join" />
    <sequenceFlow id="Flow_C28" sourceRef="Gateway_Cont_Effort_Join" targetRef="Task_Cont_CommReq" />
    <sequenceFlow id="Flow_C29" sourceRef="Task_Cont_CommReq" targetRef="EndEvent_Cont" />
  </process>

  <process id="Process_SA" isExecutable="false">
    <startEvent id="StartEvent_SA" name="Receive notification">
      <outgoing>Flow_S1</outgoing>
      <messageEventDefinition id="MessageEventDefinition_2" />
    </startEvent>
    <task id="Task_SA_Verify" name="Verify compliance with this Article using the documentation">
      <incoming>Flow_S1</incoming>
      <outgoing>Flow_S2</outgoing>
    </task>
    <task id="Task_SA_AssessComm" name="Assess whether controller has not already communicated to data subject">
      <incoming>Flow_S2</incoming>
      <outgoing>Flow_S3</outgoing>
    </task>
    <exclusiveGateway id="Gateway_SA_NotComm" name="Not already communicated?">
      <incoming>Flow_S3</incoming>
      <outgoing>Flow_S4_Yes</outgoing>
      <outgoing>Flow_S4_No</outgoing>
    </exclusiveGateway>
    <task id="Task_SA_ConsiderRisk" name="Consider the likelihood of high risk">
      <incoming>Flow_S4_Yes</incoming>
      <outgoing>Flow_S5</outgoing>
    </task>
    <task id="Task_SA_RequireComm" name="Require the controller to communicate to data subject">
      <incoming>Flow_S5</incoming>
      <outgoing>Flow_S6</outgoing>
    </task>
    <task id="Task_SA_Decide" name="Decide that conditions are met">
      <incoming>Flow_S6</incoming>
      <outgoing>Flow_S7</outgoing>
    </task>
    <exclusiveGateway id="Gateway_SA_NotComm_Join">
      <incoming>Flow_S7</incoming>
      <incoming>Flow_S4_No</incoming>
      <outgoing>Flow_S8</outgoing>
    </exclusiveGateway>
    <endEvent id="EndEvent_SA" name="Verification and assessment completed end event">
      <incoming>Flow_S8</incoming>
    </endEvent>

    <sequenceFlow id="Flow_S1" sourceRef="StartEvent_SA" targetRef="Task_SA_Verify" />
    <sequenceFlow id="Flow_S2" sourceRef="Task_SA_Verify" targetRef="Task_SA_AssessComm" />
    <sequenceFlow id="Flow_S3" sourceRef="Task_SA_AssessComm" targetRef="Gateway_SA_NotComm" />
    <sequenceFlow id="Flow_S4_Yes" name="Yes" sourceRef="Gateway_SA_NotComm" targetRef="Task_SA_ConsiderRisk" />
    <sequenceFlow id="Flow_S4_No" name="No" sourceRef="Gateway_SA_NotComm" targetRef="Gateway_SA_NotComm_Join" />
    <sequenceFlow id="Flow_S5" sourceRef="Task_SA_ConsiderRisk" targetRef="Task_SA_RequireComm" />
    <sequenceFlow id="Flow_S6" sourceRef="Task_SA_RequireComm" targetRef="Task_SA_Decide" />
    <sequenceFlow id="Flow_S7" sourceRef="Task_SA_Decide" targetRef="Gateway_SA_NotComm_Join" />
    <sequenceFlow id="Flow_S8" sourceRef="Gateway_SA_NotComm_Join" targetRef="EndEvent_SA" />
  </process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">

      <bpmndi:BPMNShape id="Participant_Processor_di" bpmnElement="Participant_Processor" isHorizontal="true">
        <omgdc:Bounds x="50" y="50" width="600" height="150" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_Proc_di" bpmnElement="StartEvent_Proc">
        <omgdc:Bounds x="120" y="100" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Proc_Notify_di" bpmnElement="Task_Proc_Notify">
        <omgdc:Bounds x="210" y="78" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Proc_di" bpmnElement="EndEvent_Proc">
        <omgdc:Bounds x="370" y="100" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_P1_di" bpmnElement="Flow_P1">
        <omgdi:waypoint x="156" y="118" />
        <omgdi:waypoint x="210" y="118" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_P2_di" bpmnElement="Flow_P2">
        <omgdi:waypoint x="310" y="118" />
        <omgdi:waypoint x="370" y="118" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNShape id="Participant_Controller_di" bpmnElement="Participant_Controller" isHorizontal="true">
        <omgdc:Bounds x="50" y="250" width="4050" height="550" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_Cont_di" bpmnElement="StartEvent_Cont">
        <omgdc:Bounds x="120" y="482" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Cont_AssessRisk_di" bpmnElement="Task_Cont_AssessRisk">
        <omgdc:Bounds x="210" y="460" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Cont_Risk_di" bpmnElement="Gateway_Cont_Risk" isMarkerVisible="true">
        <omgdc:Bounds x="360" y="475" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Cont_NotifySA_di" bpmnElement="Task_Cont_NotifySA">
        <omgdc:Bounds x="460" y="370" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Cont_Risk_Join_di" bpmnElement="Gateway_Cont_Risk_Join" isMarkerVisible="true">
        <omgdc:Bounds x="610" y="475" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Cont_Assess72h_di" bpmnElement="Task_Cont_Assess72h">
        <omgdc:Bounds x="710" y="460" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Cont_72h_di" bpmnElement="Gateway_Cont_72h" isMarkerVisible="true">
        <omgdc:Bounds x="860" y="475" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Cont_ProvideReasons_di" bpmnElement="Task_Cont_ProvideReasons">
        <omgdc:Bounds x="960" y="370" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Cont_72h_Join_di" bpmnElement="Gateway_Cont_72h_Join" isMarkerVisible="true">
        <omgdc:Bounds x="1110" y="475" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Cont_AssessSameTime_di" bpmnElement="Task_Cont_AssessSameTime">
        <omgdc:Bounds x="1210" y="460" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Cont_SameTime_di" bpmnElement="Gateway_Cont_SameTime" isMarkerVisible="true">
        <omgdc:Bounds x="1360" y="475" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Cont_ProvidePhases_di" bpmnElement="Task_Cont_ProvidePhases">
        <omgdc:Bounds x="1460" y="370" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Cont_SameTime_Join_di" bpmnElement="Gateway_Cont_SameTime_Join" isMarkerVisible="true">
        <omgdc:Bounds x="1610" y="475" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Cont_Parallel_Split_di" bpmnElement="Gateway_Cont_Parallel_Split">
        <omgdc:Bounds x="1710" y="475" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Cont_DescNature_di" bpmnElement="Task_Cont_DescNature">
        <omgdc:Bounds x="1810" y="270" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Cont_CommDPO_di" bpmnElement="Task_Cont_CommDPO">
        <omgdc:Bounds x="1810" y="370" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Cont_DescCons_di" bpmnElement="Task_Cont_DescCons">
        <omgdc:Bounds x="1810" y="470" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Cont_DescMeasures_di" bpmnElement="Task_Cont_DescMeasures">
        <omgdc:Bounds x="1810" y="570" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Cont_Parallel_Join_di" bpmnElement="Gateway_Cont_Parallel_Join">
        <omgdc:Bounds x="1960" y="475" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Cont_Document_di" bpmnElement="Task_Cont_Document">
        <omgdc:Bounds x="2060" y="460" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Cont_IncludeFacts_di" bpmnElement="Task_Cont_IncludeFacts">
        <omgdc:Bounds x="2210" y="460" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Cont_AssessHighRisk_di" bpmnElement="Task_Cont_AssessHighRisk">
        <omgdc:Bounds x="2360" y="460" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Cont_HighRisk_di" bpmnElement="Gateway_Cont_HighRisk" isMarkerVisible="true">
        <omgdc:Bounds x="2510" y="475" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Cont_CommDataSubject_di" bpmnElement="Task_Cont_CommDataSubject">
        <omgdc:Bounds x="2610" y="370" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Cont_DescLanguage_di" bpmnElement="Task_Cont_DescLanguage">
        <omgdc:Bounds x="2760" y="370" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Cont_IncludeInfo_di" bpmnElement="Task_Cont_IncludeInfo">
