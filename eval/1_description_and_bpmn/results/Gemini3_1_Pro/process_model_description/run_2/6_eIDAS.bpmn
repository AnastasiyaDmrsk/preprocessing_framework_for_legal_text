            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape bpmnElement="COM_T2" id="Shape_COM_T2">
                <omgdc:Bounds x="300" y="355" width="100" height="80" />
            </bpmndi:BPMNShape>

            <bpmndi:BPMNShape bpmnElement="ASB_Start" id="Shape_ASB_Start">
