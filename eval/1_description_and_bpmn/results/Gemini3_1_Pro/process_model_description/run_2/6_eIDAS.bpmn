            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape bpmnElement="Participant_TSP" id="Shape_Participant_TSP" isHorizontal="true">
                <omgdc:Bounds x="50" y="750" width="2000" height="250" />
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape bpmnElement="Participant_SB" id="Shape_Participant_SB" isHorizontal="true">
                <omgdc:Bounds x="50" y="1050" width="2000" height="500" />
            </bpmndi:BPMNShape>

