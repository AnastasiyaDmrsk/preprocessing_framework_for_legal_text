<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             targetNamespace="http://bpmn.io/schema/bpmn"
             exporter="BPMN Modeler"
             exporterVersion="1.0"
             id="Definitions_1">
  <collaboration id="Collaboration_1">
    <participant id="Participant_MS" name="Member States" processRef="Process_MS" />
    <participant id="Participant_APP" name="Applicants or holders" processRef="Process_APP" />
    <participant id="Participant_COM" name="Commission" processRef="Process_COM" />
    <messageFlow id="MessageFlow_1" sourceRef="MS_T10" targetRef="APP_Start2_Msg" />
    <messageFlow id="MessageFlow_2" sourceRef="MS_T21" targetRef="COM_Start1_Msg" />
    <messageFlow id="MessageFlow_3" sourceRef="MS_T23" targetRef="COM_Start2_Msg" />
  </collaboration>

  <process id="Process_MS" isExecutable="true">
    <startEvent id="MS_Start" name="Application for issuance/renewal">
      <outgoing>Flow_MS_S_T1</outgoing>
    </startEvent>
    <task id="MS_T1" name="Set stricter standards">
      <incoming>Flow_MS_S_T1</incoming>
      <outgoing>Flow_MS_T1_T2</outgoing>
    </task>
    <task id="MS_T2" name="Ensure medical examination">
      <incoming>Flow_MS_T1_T2</incoming>
      <outgoing>Flow_MS_T2_T3</outgoing>
    </task>
    <task id="MS_T3" name="Apply minimum standards">
      <incoming>Flow_MS_T2_T3</incoming>
      <outgoing>Flow_MS_T3_T4</outgoing>
    </task>
    <task id="MS_T4" name="Assess whether in category AM">
      <incoming>Flow_MS_T3_T4</incoming>
      <outgoing>Flow_MS_T4_GW1</outgoing>
    </task>

    <exclusiveGateway id="MS_GW1">
      <incoming>Flow_MS_T4_GW1</incoming>
      <outgoing>Flow_MS_GW1_T5</outgoing>
      <outgoing>Flow_MS_GW1_GW1J</outgoing>
    </exclusiveGateway>
    <task id="MS_T5" name="Apply medical examination to AM">
      <incoming>Flow_MS_GW1_T5</incoming>
      <outgoing>Flow_MS_T5_GW1J</outgoing>
    </task>
    <exclusiveGateway id="MS_GW1_J">
      <incoming>Flow_MS_GW1_GW1J</incoming>
      <incoming>Flow_MS_T5_GW1J</incoming>
      <outgoing>Flow_MS_GW1J_T6</outgoing>
    </exclusiveGateway>

    <task id="MS_T6" name="Assess categories C, CE, C1, C1E, D, D1, DE, D1E">
      <incoming>Flow_MS_GW1J_T6</incoming>
      <outgoing>Flow_MS_T6_GW2</outgoing>
    </task>
    <exclusiveGateway id="MS_GW2">
      <incoming>Flow_MS_T6_GW2</incoming>
      <outgoing>Flow_MS_GW2_T7</outgoing>
      <outgoing>Flow_MS_GW2_GW2J</outgoing>
    </exclusiveGateway>
    <task id="MS_T7" name="Require medical examination">
      <incoming>Flow_MS_GW2_T7</incoming>
      <outgoing>Flow_MS_T7_GW2J</outgoing>
    </task>
    <exclusiveGateway id="MS_GW2_J">
      <incoming>Flow_MS_GW2_GW2J</incoming>
      <incoming>Flow_MS_T7_GW2J</incoming>
      <outgoing>Flow_MS_GW2J_T8</outgoing>
    </exclusiveGateway>

    <task id="MS_T8" name="Assess categories AM, A, A1, A2, B, B1, BE">
      <incoming>Flow_MS_GW2J_T8</incoming>
      <outgoing>Flow_MS_T8_GW3</outgoing>
    </task>
    <exclusiveGateway id="MS_GW3">
      <incoming>Flow_MS_T8_GW3</incoming>
      <outgoing>Flow_MS_GW3_T9</outgoing>
      <outgoing>Flow_MS_GW3_GW3J</outgoing>
    </exclusiveGateway>
    <task id="MS_T9" name="Apply alternative measures">
      <incoming>Flow_MS_GW3_T9</incoming>
      <outgoing>Flow_MS_T9_T10</outgoing>
    </task>
    <task id="MS_T10" name="Send requirement for self-assessment">
      <incoming>Flow_MS_T9_T10</incoming>
      <outgoing>Flow_MS_T10_T11</outgoing>
    </task>
    <task id="MS_T11" name="Establish national system of assessment">
      <incoming>Flow_MS_T10_T11</incoming>
      <outgoing>Flow_MS_T11_T12</outgoing>
    </task>
    <task id="MS_T12" name="Address non-compliance, incorrect info, failures">
      <incoming>Flow_MS_T11_T12</incoming>
      <outgoing>Flow_MS_T12_T13</outgoing>
    </task>
    <task id="MS_T13" name="Monitor fitness during validity">
      <incoming>Flow_MS_T12_T13</incoming>
      <outgoing>Flow_MS_T13_GW3J</outgoing>
    </task>
    <exclusiveGateway id="MS_GW3_J">
      <incoming>Flow_MS_GW3_GW3J</incoming>
      <incoming>Flow_MS_T13_GW3J</incoming>
      <outgoing>Flow_MS_GW3J_T16</outgoing>
    </exclusiveGateway>

    <task id="MS_T16" name="Assess likelihood of medical conditions">
      <incoming>Flow_MS_GW3J_T16</incoming>
      <outgoing>Flow_MS_T16_GW4</outgoing>
    </task>
    <exclusiveGateway id="MS_GW4">
      <incoming>Flow_MS_T16_GW4</incoming>
      <outgoing>Flow_MS_GW4_T17</outgoing>
      <outgoing>Flow_MS_GW4_GW4J</outgoing>
    </exclusiveGateway>
    <task id="MS_T17" name="Ensure medical exam prior to issue/renew">
      <incoming>Flow_MS_GW4_T17</incoming>
      <outgoing>Flow_MS_T17_GW4J</outgoing>
    </task>
    <exclusiveGateway id="MS_GW4_J">
      <incoming>Flow_MS_GW4_GW4J</incoming>
      <incoming>Flow_MS_T17_GW4J</incoming>
      <outgoing>Flow_MS_GW4J_T18</outgoing>
    </exclusiveGateway>

    <task id="MS_T18" name="Take measures to raise awareness &amp; improve knowledge">
      <incoming>Flow_MS_GW4J_T18</incoming>
      <outgoing>Flow_MS_T18_T20</outgoing>
    </task>
    <task id="MS_T20" name="Assess guidelines adoption">
      <incoming>Flow_MS_T18_T20</incoming>
      <outgoing>Flow_MS_T20_GW5</outgoing>
    </task>
    <exclusiveGateway id="MS_GW5">
      <incoming>Flow_MS_T20_GW5</incoming>
      <outgoing>Flow_MS_GW5_T21</outgoing>
      <outgoing>Flow_MS_GW5_GW5J</outgoing>
    </exclusiveGateway>
    <task id="MS_T21" name="Notify adopted guidelines">
      <incoming>Flow_MS_GW5_T21</incoming>
      <outgoing>Flow_MS_T21_GW5J</outgoing>
    </task>
    <exclusiveGateway id="MS_GW5_J">
      <incoming>Flow_MS_GW5_GW5J</incoming>
      <incoming>Flow_MS_T21_GW5J</incoming>
      <outgoing>Flow_MS_GW5J_T22</outgoing>
    </exclusiveGateway>

    <task id="MS_T22" name="Assess public awareness campaigns">
      <incoming>Flow_MS_GW5J_T22</incoming>
      <outgoing>Flow_MS_T22_GW6</outgoing>
    </task>
    <exclusiveGateway id="MS_GW6">
      <incoming>Flow_MS_T22_GW6</incoming>
      <outgoing>Flow_MS_GW6_T23</outgoing>
      <outgoing>Flow_MS_GW6_GW6J</outgoing>
    </exclusiveGateway>
    <task id="MS_T23" name="Notify campaigns information">
      <incoming>Flow_MS_GW6_T23</incoming>
      <outgoing>Flow_MS_T23_GW6J</outgoing>
    </task>
    <exclusiveGateway id="MS_GW6_J">
      <incoming>Flow_MS_GW6_GW6J</incoming>
      <incoming>Flow_MS_T23_GW6J</incoming>
      <outgoing>Flow_MS_GW6J_End</outgoing>
    </exclusiveGateway>

    <endEvent id="MS_End" name="Fitness assessment measures completed">
      <incoming>Flow_MS_GW6J_End</incoming>
    </endEvent>

    <sequenceFlow id="Flow_MS_S_T1" sourceRef="MS_Start" targetRef="MS_T1" />
    <sequenceFlow id="Flow_MS_T1_T2" sourceRef="MS_T1" targetRef="MS_T2" />
    <sequenceFlow id="Flow_MS_T2_T3" sourceRef="MS_T2" targetRef="MS_T3" />
    <sequenceFlow id="Flow_MS_T3_T4" sourceRef="MS_T3" targetRef="MS_T4" />
    <sequenceFlow id="Flow_MS_T4_GW1" sourceRef="MS_T4" targetRef="MS_GW1" />
    <sequenceFlow id="Flow_MS_GW1_T5" sourceRef="MS_GW1" targetRef="MS_T5" />
    <sequenceFlow id="Flow_MS_GW1_GW1J" sourceRef="MS_GW1" targetRef="MS_GW1_J" />
    <sequenceFlow id="Flow_MS_T5_GW1J" sourceRef="MS_T5" targetRef="MS_GW1_J" />
    <sequenceFlow id="Flow_MS_GW1J_T6" sourceRef="MS_GW1_J" targetRef="MS_T6" />
    <sequenceFlow id="Flow_MS_T6_GW2" sourceRef="MS_T6" targetRef="MS_GW2" />
    <sequenceFlow id="Flow_MS_GW2_T7" sourceRef="MS_GW2" targetRef="MS_T7" />
    <sequenceFlow id="Flow_MS_GW2_GW2J" sourceRef="MS_GW2" targetRef="MS_GW2_J" />
    <sequenceFlow id="Flow_MS_T7_GW2J" sourceRef="MS_T7" targetRef="MS_GW2_J" />
    <sequenceFlow id="Flow_MS_GW2J_T8" sourceRef="MS_GW2_J" targetRef="MS_T8" />
    <sequenceFlow id="Flow_MS_T8_GW3" sourceRef="MS_T8" targetRef="MS_GW3" />
    <sequenceFlow id="Flow_MS_GW3_T9" sourceRef="MS_GW3" targetRef="MS_T9" />
    <sequenceFlow id="Flow_MS_T9_T10" sourceRef="MS_T9" targetRef="MS_T10" />
    <sequenceFlow id="Flow_MS_T10_T11" sourceRef="MS_T10" targetRef="MS_T11" />
    <sequenceFlow id="Flow_MS_T11_T12" sourceRef="MS_T11" targetRef="MS_T12" />
    <sequenceFlow id="Flow_MS_T12_T13" sourceRef="MS_T12" targetRef="MS_T13" />
    <sequenceFlow id="Flow_MS_GW3_GW3J" sourceRef="MS_GW3" targetRef="MS_GW3_J" />
    <sequenceFlow id="Flow_MS_T13_GW3J" sourceRef="MS_T13" targetRef="MS_GW3_J" />
    <sequenceFlow id="Flow_MS_GW3J_T16" sourceRef="MS_GW3_J" targetRef="MS_T16" />
    <sequenceFlow id="Flow_MS_T16_GW4" sourceRef="MS_T16" targetRef="MS_GW4" />
    <sequenceFlow id="Flow_MS_GW4_T17" sourceRef="MS_GW4" targetRef="MS_T17" />
    <sequenceFlow id="Flow_MS_GW4_GW4J" sourceRef="MS_GW4" targetRef="MS_GW4_J" />
    <sequenceFlow id="Flow_MS_T17_GW4J" sourceRef="MS_T17" targetRef="MS_GW4_J" />
    <sequenceFlow id="Flow_MS_GW4J_T18" sourceRef="MS_GW4_J" targetRef="MS_T18" />
    <sequenceFlow id="Flow_MS_T18_T20" sourceRef="MS_T18" targetRef="MS_T20" />
    <sequenceFlow id="Flow_MS_T20_GW5" sourceRef="MS_T20" targetRef="MS_GW5" />
    <sequenceFlow id="Flow_MS_GW5_T21" sourceRef="MS_GW5" targetRef="MS_T21" />
    <sequenceFlow id="Flow_MS_GW5_GW5J" sourceRef="MS_GW5" targetRef="MS_GW5_J" />
    <sequenceFlow id="Flow_MS_T21_GW5J" sourceRef="MS_T21" targetRef="MS_GW5_J" />
    <sequenceFlow id="Flow_MS_GW5J_T22" sourceRef="MS_GW5_J" targetRef="MS_T22" />
    <sequenceFlow id="Flow_MS_T22_GW6" sourceRef="MS_T22" targetRef="MS_GW6" />
    <sequenceFlow id="Flow_MS_GW6_T23" sourceRef="MS_GW6" targetRef="MS_T23" />
    <sequenceFlow id="Flow_MS_GW6_GW6J" sourceRef="MS_GW6" targetRef="MS_GW6_J" />
    <sequenceFlow id="Flow_MS_T23_GW6J" sourceRef="MS_T23" targetRef="MS_GW6_J" />
    <sequenceFlow id="Flow_MS_GW6J_End" sourceRef="MS_GW6_J" targetRef="MS_End" />
  </process>

  <process id="Process_APP" isExecutable="true">
    <startEvent id="APP_Start1" name="Process starts">
      <outgoing>Flow_APP_S1_T1</outgoing>
    </startEvent>
    <task id="APP_T1" name="Undergo medical examination">
      <incoming>Flow_APP_S1_T1</incoming>
      <outgoing>Flow_APP_T1_T2</outgoing>
    </task>
    <task id="APP_T2" name="Assess whether renewal is for category AM">
      <incoming>Flow_APP_T1_T2</incoming>
      <outgoing>Flow_APP_T2_GW1</outgoing>
    </task>
    <exclusiveGateway id="APP_GW1">
      <incoming>Flow_APP_T2_GW1</incoming>
      <outgoing>Flow_APP_GW1_T3</outgoing>
      <outgoing>Flow_APP_GW1_GW1J</outgoing>
    </exclusiveGateway>
    <task id="APP_T3" name="Undergo medical exam only if required">
      <incoming>Flow_APP_GW1_T3</incoming>
      <outgoing>Flow_APP_T3_GW1J</outgoing>
    </task>
    <exclusiveGateway id="APP_GW1_J">
      <incoming>Flow_APP_GW1_GW1J</incoming>
      <incoming>Flow_APP_T3_GW1J</incoming>
      <outgoing>Flow_APP_GW1J_End1</outgoing>
    </exclusiveGateway>
    <endEvent id="APP_End1" name="Application requirements fulfilled">
      <incoming>Flow_APP_GW1J_End1</incoming>
    </endEvent>

    <startEvent id="APP_Start2_Msg" name="Receive requirement to fill in form">
      <outgoing>Flow_APP_S2_T4</outgoing>
      <messageEventDefinition id="MsgDef_1"/>
    </startEvent>
    <task id="APP_T4" name="Fill in self-assessment form">
      <incoming>Flow_APP_S2_T4</incoming>
      <outgoing>Flow_APP_T4_End2</outgoing>
    </task>
    <endEvent id="APP_End2" name="Application requirements fulfilled">
      <incoming>Flow_APP_T4_End2</incoming>
    </endEvent>

    <sequenceFlow id="Flow_APP_S1_T1" sourceRef="APP_Start1" targetRef="APP_T1" />
    <sequenceFlow id="Flow_APP_T1_T2" sourceRef="APP_T1" targetRef="APP_T2" />
    <sequenceFlow id="Flow_APP_T2_GW1" sourceRef="APP_T2" targetRef="APP_GW1" />
    <sequenceFlow id="Flow_APP_GW1_T3" sourceRef="APP_GW1" targetRef="APP_T3" />
    <sequenceFlow id="Flow_APP_T3_GW1J" sourceRef="APP_T3" targetRef="APP_GW1_J" />
    <sequenceFlow id="Flow_APP_GW1_GW1J" sourceRef="APP_GW1" targetRef="APP_GW1_J" />
    <sequenceFlow id="Flow_APP_GW1J_End1" sourceRef="APP_GW1_J" targetRef="APP_End1" />
    <sequenceFlow id="Flow_APP_S2_T4" sourceRef="APP_Start2_Msg" targetRef="APP_T4" />
    <sequenceFlow id="Flow_APP_T4_End2" sourceRef="APP_T4" targetRef="APP_End2" />
  </process>

  <process id="Process_COM" isExecutable="true">
    <startEvent id="COM_Start1_Msg" name="Receive adopted guidelines">
      <outgoing>Flow_COM_S1_T1</outgoing>
      <messageEventDefinition id="MsgDef_2"/>
    </startEvent>
    <task id="COM_T1" name="Make guidelines available">
      <incoming>Flow_COM_S1_T1</incoming>
      <outgoing>Flow_COM_T1_End1</outgoing>
    </task>
    <endEvent id="COM_End1" name="Information distributed">
      <incoming>Flow_COM_T1_End1</incoming>
    </endEvent>

    <startEvent id="COM_Start2_Msg" name="Receive campaigns info">
      <outgoing>Flow_COM_S2_T2</outgoing>
      <messageEventDefinition id="MsgDef_3"/>
    </startEvent>
    <task id="COM_T2" name="Make information available">
      <incoming>Flow_COM_S2_T2</incoming>
      <outgoing>Flow_COM_T2_End2</outgoing>
    </task>
    <endEvent id="COM_End2" name="Information distributed">
      <incoming>Flow_COM_T2_End2</incoming>
    </endEvent>

    <sequenceFlow id="Flow_COM_S1_T1" sourceRef="COM_Start1_Msg" targetRef="COM_T1" />
    <sequenceFlow id="Flow_COM_T1_End1" sourceRef="COM_T1" targetRef="COM_End1" />
    <sequenceFlow id="Flow_COM_S2_T2" sourceRef="COM_Start2_Msg" targetRef="COM_T2" />
    <sequenceFlow id="Flow_COM_T2_End2" sourceRef="COM_T2" targetRef="COM_End2" />
  </process>

