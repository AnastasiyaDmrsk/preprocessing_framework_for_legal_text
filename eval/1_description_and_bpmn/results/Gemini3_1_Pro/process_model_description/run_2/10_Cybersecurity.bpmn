        <omgdc:Bounds x="1000" y="398" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="E_GW2_di" bpmnElement="E_GW2" isMarkerVisible="true">
        <omgdc:Bounds x="1150" y="413" width="50" height="50" />
      </bpmndi:BPMNShape>
