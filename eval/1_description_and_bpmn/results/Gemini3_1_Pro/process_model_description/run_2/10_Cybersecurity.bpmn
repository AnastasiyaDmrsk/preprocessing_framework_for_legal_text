      <bpmndi:BPMNShape id="C_T7_di" bpmnElement="C_T7">
        <omgdc:Bounds x="1350" y="128" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="C_T8_di" bpmnElement="C_T8">
        <omgdc:Bounds x="1500" y="128" width="100" height="80" />
