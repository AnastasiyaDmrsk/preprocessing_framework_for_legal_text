<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             id="sid-cybersecurity-scheme"
             targetNamespace="http://bpmn.io/schema/bpmn"
             exporter="BPMN-AI" exporterVersion="1.0">

  <collaboration id="Collaboration_1">
    <participant id="Participant_Commission" name="Commission" processRef="Process_Commission" />
    <participant id="Participant_ECCG" name="ECCG" processRef="Process_ECCG" />
    <participant id="Participant_ENISA" name="ENISA" processRef="Process_ENISA" />
    <messageFlow id="Flow_Comm_ENISA_Req" sourceRef="C_T2" targetRef="N_Start" />
    <messageFlow id="Flow_ECCG_ENISA_Req" sourceRef="E_T2" targetRef="N_Start" />
    <messageFlow id="Flow_ECCG_ENISA_Op" sourceRef="E_T5" targetRef="N_Rcv1" />
    <messageFlow id="Flow_ENISA_Comm_Scheme" sourceRef="N_T11" targetRef="C_Rcv1" />
    <messageFlow id="Flow_Comm_ENISA_Rev" sourceRef="C_T9" targetRef="N_Rcv2" />
    <messageFlow id="Flow_ECCG_ENISA_Rev" sourceRef="E_T7" targetRef="N_Rcv2" />
  </collaboration>

  <process id="Process_Commission" isExecutable="false">
    <startEvent id="C_Start" name="Need for cybersecurity scheme">
      <outgoing>Flow_C1</outgoing>
    </startEvent>
    <task id="C_T1" name="Assess if scheme is on basis of Union rolling work programme">
      <incoming>Flow_C1</incoming>
      <outgoing>Flow_C2</outgoing>
    </task>
    <exclusiveGateway id="C_GW1" name="On basis of programme?">
      <incoming>Flow_C2</incoming>
      <outgoing>Flow_C3</outgoing>
      <outgoing>Flow_C4</outgoing>
    </exclusiveGateway>
    <task id="C_T2" name="Send request to prepare/review scheme to ENISA">
      <incoming>Flow_C3</incoming>
      <outgoing>Flow_C5</outgoing>
    </task>
    <task id="C_T3" name="Assess duly justified case not included in programme">
      <incoming>Flow_C4</incoming>
      <incoming>Flow_C5</incoming>
      <outgoing>Flow_C6</outgoing>
    </task>
    <exclusiveGateway id="C_GW2" name="Duly justified case?">
      <incoming>Flow_C6</incoming>
      <outgoing>Flow_C7</outgoing>
      <outgoing>Flow_C8</outgoing>
    </exclusiveGateway>
    <task id="C_T4" name="Send request to prepare/review scheme to ENISA">
      <incoming>Flow_C7</incoming>
      <outgoing>Flow_C9</outgoing>
    </task>
    <task id="C_T5" name="Update Union rolling work programme accordingly">
      <incoming>Flow_C9</incoming>
      <outgoing>Flow_C10</outgoing>
    </task>
    <intermediateCatchEvent id="C_Rcv1" name="Receive candidate scheme">
      <incoming>Flow_C8</incoming>
      <incoming>Flow_C10</incoming>
      <outgoing>Flow_C11</outgoing>
      <messageEventDefinition id="MessageEventDefinition_1"/>
    </intermediateCatchEvent>
    <task id="C_T6" name="Adopt implementing acts for certification scheme">
      <incoming>Flow_C11</incoming>
      <outgoing>Flow_C12</outgoing>
    </task>
    <task id="C_T7" name="Adopt implementing acts in accordance with examination procedure">
      <incoming>Flow_C12</incoming>
      <outgoing>Flow_C13</outgoing>
    </task>
    <task id="C_T8" name="Assess if necessary to start developing revised scheme (5 years)">
      <incoming>Flow_C13</incoming>
      <outgoing>Flow_C14</outgoing>
    </task>
    <exclusiveGateway id="C_GW3" name="Necessary?">
      <incoming>Flow_C14</incoming>
      <outgoing>Flow_C15</outgoing>
      <outgoing>Flow_C16</outgoing>
    </exclusiveGateway>
    <task id="C_T9" name="Send request to start revised scheme to ENISA">
      <incoming>Flow_C15</incoming>
      <outgoing>Flow_C17</outgoing>
    </task>
    <endEvent id="C_End" name="Scheme adopted">
      <incoming>Flow_C16</incoming>
      <incoming>Flow_C17</incoming>
    </endEvent>

    <sequenceFlow id="Flow_C1" sourceRef="C_Start" targetRef="C_T1" />
    <sequenceFlow id="Flow_C2" sourceRef="C_T1" targetRef="C_GW1" />
    <sequenceFlow id="Flow_C3" sourceRef="C_GW1" targetRef="C_T2" name="Yes"/>
    <sequenceFlow id="Flow_C4" sourceRef="C_GW1" targetRef="C_T3" name="No"/>
    <sequenceFlow id="Flow_C5" sourceRef="C_T2" targetRef="C_T3" />
    <sequenceFlow id="Flow_C6" sourceRef="C_T3" targetRef="C_GW2" />
    <sequenceFlow id="Flow_C7" sourceRef="C_GW2" targetRef="C_T4" name="Yes"/>
    <sequenceFlow id="Flow_C8" sourceRef="C_GW2" targetRef="C_Rcv1" name="No"/>
    <sequenceFlow id="Flow_C9" sourceRef="C_T4" targetRef="C_T5" />
    <sequenceFlow id="Flow_C10" sourceRef="C_T5" targetRef="C_Rcv1" />
    <sequenceFlow id="Flow_C11" sourceRef="C_Rcv1" targetRef="C_T6" />
    <sequenceFlow id="Flow_C12" sourceRef="C_T6" targetRef="C_T7" />
    <sequenceFlow id="Flow_C13" sourceRef="C_T7" targetRef="C_T8" />
    <sequenceFlow id="Flow_C14" sourceRef="C_T8" targetRef="C_GW3" />
    <sequenceFlow id="Flow_C15" sourceRef="C_GW3" targetRef="C_T9" name="Yes"/>
    <sequenceFlow id="Flow_C16" sourceRef="C_GW3" targetRef="C_End" name="No"/>
    <sequenceFlow id="Flow_C17" sourceRef="C_T9" targetRef="C_End" />
  </process>

  <process id="Process_ECCG" isExecutable="false">
    <startEvent id="E_Start" name="Need for cybersecurity scheme">
      <outgoing>Flow_E1</outgoing>
    </startEvent>
    <task id="E_T1" name="Assess duly justified case not included in programme">
      <incoming>Flow_E1</incoming>
      <outgoing>Flow_E2</outgoing>
    </task>
    <exclusiveGateway id="E_GW1" name="Duly justified case?">
      <incoming>Flow_E2</incoming>
      <outgoing>Flow_E3</outgoing>
      <outgoing>Flow_E4</outgoing>
    </exclusiveGateway>
    <task id="E_T2" name="Send request to prepare/review scheme to ENISA">
      <incoming>Flow_E3</incoming>
      <outgoing>Flow_E5</outgoing>
    </task>
    <task id="E_T3" name="Provide ENISA with assistance and expert advice">
      <incoming>Flow_E4</incoming>
      <incoming>Flow_E5</incoming>
      <outgoing>Flow_E6</outgoing>
    </task>
    <task id="E_T4" name="Adopt an opinion on the candidate scheme">
      <incoming>Flow_E6</incoming>
      <outgoing>Flow_E7</outgoing>
    </task>
    <task id="E_T5" name="Send opinion on candidate scheme to ENISA">
      <incoming>Flow_E7</incoming>
      <outgoing>Flow_E8</outgoing>
    </task>
    <task id="E_T6" name="Assess if necessary to start developing revised scheme (5 years)">
      <incoming>Flow_E8</incoming>
      <outgoing>Flow_E9</outgoing>
    </task>
    <exclusiveGateway id="E_GW2" name="Necessary?">
      <incoming>Flow_E9</incoming>
      <outgoing>Flow_E10</outgoing>
      <outgoing>Flow_E11</outgoing>
    </exclusiveGateway>
    <task id="E_T7" name="Send request to start revised scheme to ENISA">
      <incoming>Flow_E10</incoming>
      <outgoing>Flow_E12</outgoing>
    </task>
    <endEvent id="E_End" name="ECCG participation completed">
      <incoming>Flow_E11</incoming>
      <incoming>Flow_E12</incoming>
    </endEvent>

    <sequenceFlow id="Flow_E1" sourceRef="E_Start" targetRef="E_T1" />
    <sequenceFlow id="Flow_E2" sourceRef="E_T1" targetRef="E_GW1" />
    <sequenceFlow id="Flow_E3" sourceRef="E_GW1" targetRef="E_T2" name="Yes"/>
    <sequenceFlow id="Flow_E4" sourceRef="E_GW1" targetRef="E_T3" name="No"/>
    <sequenceFlow id="Flow_E5" sourceRef="E_T2" targetRef="E_T3" />
    <sequenceFlow id="Flow_E6" sourceRef="E_T3" targetRef="E_T4" />
    <sequenceFlow id="Flow_E7" sourceRef="E_T4" targetRef="E_T5" />
    <sequenceFlow id="Flow_E8" sourceRef="E_T5" targetRef="E_T6" />
    <sequenceFlow id="Flow_E9" sourceRef="E_T6" targetRef="E_GW2" />
    <sequenceFlow id="Flow_E10" sourceRef="E_GW2" targetRef="E_T7" name="Yes"/>
    <sequenceFlow id="Flow_E11" sourceRef="E_GW2" targetRef="E_End" name="No"/>
    <sequenceFlow id="Flow_E12" sourceRef="E_T7" targetRef="E_End" />
  </process>

  <process id="Process_ENISA" isExecutable="false">
    <laneSet id="LaneSet_ENISA">
      <lane id="Lane_ENISA_Normal" name="ENISA">
        <flowNodeRef>N_Start</flowNodeRef>
        <flowNodeRef>N_T1</flowNodeRef>
        <flowNodeRef>N_GW1</flowNodeRef>
        <flowNodeRef>N_T2</flowNodeRef>
        <flowNodeRef>N_T3</flowNodeRef>
        <flowNodeRef>N_GW2</flowNodeRef>
        <flowNodeRef>N_T5</flowNodeRef>
        <flowNodeRef>N_T6</flowNodeRef>
        <flowNodeRef>N_GW_Split</flowNodeRef>
        <flowNodeRef>N_T7</flowNodeRef>
        <flowNodeRef>N_T8</flowNodeRef>
        <flowNodeRef>N_T9</flowNodeRef>
        <flowNodeRef>N_GW_Join</flowNodeRef>
        <flowNodeRef>N_Rcv1</flowNodeRef>
        <flowNodeRef>N_T10</flowNodeRef>
        <flowNodeRef>N_T11</flowNodeRef>
        <flowNodeRef>N_T12</flowNodeRef>
        <flowNodeRef>N_T13</flowNodeRef>
        <flowNodeRef>N_Rcv2</flowNodeRef>
        <flowNodeRef>N_T14</flowNodeRef>
        <flowNodeRef>N_End1</flowNodeRef>
        <flowNodeRef>N_End2</flowNodeRef>
      </lane>
      <lane id="Lane_Management_Board" name="Management Board">
        <flowNodeRef>N_T4</flowNodeRef>
      </lane>
    </laneSet>

    <startEvent id="N_Start" name="Receive request to prepare/review scheme">
      <outgoing>Flow_N1</outgoing>
      <messageEventDefinition id="MessageEventDefinition_N1"/>
    </startEvent>
    <task id="N_T1" name="Assess if request is from Commission">
      <incoming>Flow_N1</incoming>
      <outgoing>Flow_N2</outgoing>
    </task>
    <exclusiveGateway id="N_GW1" name="From Commission?">
      <incoming>Flow_N2</incoming>
      <outgoing>Flow_N3</outgoing>
      <outgoing>Flow_N4</outgoing>
    </exclusiveGateway>
    <task id="N_T2" name="Prepare a candidate scheme">
      <incoming>Flow_N3</incoming>
      <outgoing>Flow_N5</outgoing>
    </task>
    <task id="N_T3" name="Assess whether to refuse request from ECCG">
      <incoming>Flow_N4</incoming>
      <outgoing>Flow_N6</outgoing>
    </task>
    <exclusiveGateway id="N_GW2" name="Refuse request?">
      <incoming>Flow_N6</incoming>
      <outgoing>Flow_N7</outgoing>
      <outgoing>Flow_N8</outgoing>
    </exclusiveGateway>
    <task id="N_T4" name="Take decision to refuse request">
      <incoming>Flow_N7</incoming>
      <outgoing>Flow_N9</outgoing>
    </task>
    <task id="N_T5" name="Give reasons for refusal">
      <incoming>Flow_N9</incoming>
      <outgoing>Flow_N10</outgoing>
    </task>
    <endEvent id="N_End2" name="Request refused">
      <incoming>Flow_N10</incoming>
    </endEvent>
    <task id="N_T6" name="Prepare a candidate scheme">
      <incoming>Flow_N8</incoming>
      <outgoing>Flow_N11</outgoing>
    </task>
    <parallelGateway id="N_GW_Split">
      <incoming>Flow_N5</incoming>
      <incoming>Flow_N11</incoming>
      <outgoing>Flow_N12</outgoing>
      <outgoing>Flow_N13</outgoing>
      <outgoing>Flow_N14</outgoing>
    </parallelGateway>
    <task id="N_T7" name="Consult all relevant stakeholders">
      <incoming>Flow_N12</incoming>
      <outgoing>Flow_N15</outgoing>
    </task>
    <task id="N_T8" name="Establish an ad hoc working group">
      <incoming>Flow_N13</incoming>
      <outgoing>Flow_N16</outgoing>
    </task>
    <task id="N_T9" name="Closely cooperate with the ECCG">
      <incoming>Flow_N14</incoming>
      <outgoing>Flow_N17</outgoing>
    </task>
    <parallelGateway id="N_GW_Join">
      <incoming>Flow_N15</incoming>
      <incoming>Flow_N16</incoming>
      <incoming>Flow_N17</incoming>
      <outgoing>Flow_N18</outgoing>
    </parallelGateway>
    <intermediateCatchEvent id="N_Rcv1" name="Receive opinion from ECCG">
      <incoming>Flow_N18</incoming>
      <outgoing>Flow_N19</outgoing>
      <messageEventDefinition id="MessageEventDefinition_N2"/>
    </intermediateCatchEvent>
    <task id="N_T10" name="Take utmost account of opinion of ECCG">
      <incoming>Flow_N19</incoming>
      <outgoing>Flow_N20</outgoing>
    </task>
    <task id="N_T11" name="Send candidate scheme to Commission">
      <incoming>Flow_N20</incoming>
      <outgoing>Flow_N21</outgoing>
    </task>
    <task id="N_T12" name="Evaluate adopted schemes (5 years)">
      <incoming>Flow_N21</incoming>
      <outgoing>Flow_N22</outgoing>
    </task>
    <task id="N_T13" name="Take into account feedback from interested parties">
      <incoming>Flow_N22</incoming>
      <outgoing>Flow_N23</outgoing>
    </task>
    <intermediateCatchEvent id="N_Rcv2" name="Receive request to start revised scheme">
      <incoming>Flow_N23</incoming>
      <outgoing>Flow_N24</outgoing>
      <messageEventDefinition id="MessageEventDefinition_N3"/>
    </intermediateCatchEvent>
    <task id="N_T14" name="Start process of developing revised scheme">
      <incoming>Flow_N24</incoming>
      <outgoing>Flow_N25</outgoing>
    </task>
    <endEvent id="N_End1" name="Scheme evaluated">
      <incoming>Flow_N25</incoming>
    </endEvent>

    <sequenceFlow id="Flow_N1" sourceRef="N_Start" targetRef="N_T1" />
    <sequenceFlow id="Flow_N2" sourceRef="N_T1" targetRef="N_GW1" />
    <sequenceFlow id="Flow_N3" sourceRef="N_GW1" targetRef="N_T2" name="Yes"/>
    <sequenceFlow id="Flow_N4" sourceRef="N_GW1" targetRef="N_T3" name="No"/>
    <sequenceFlow id="Flow_N5" sourceRef="N_T2" targetRef="N_GW_Split" />
    <sequenceFlow id="Flow_N6" sourceRef="N_T3" targetRef="N_GW2" />
    <sequenceFlow id="Flow_N7" sourceRef="N_GW2" targetRef="N_T4" name="Yes"/>
    <sequenceFlow id="Flow_N8" sourceRef="N_GW2" targetRef="N_T6" name="No"/>
    <sequenceFlow id="Flow_N9" sourceRef="N_T4" targetRef="N_T5" />
    <sequenceFlow id="Flow_N10" sourceRef="N_T5" targetRef="N_End2" />
    <sequenceFlow id="Flow_N11" sourceRef="N_T6" targetRef="N_GW_Split" />
    <sequenceFlow id="Flow_N12" sourceRef="N_GW_Split" targetRef="N_T7" />
    <sequenceFlow id="Flow_N13" sourceRef="N_GW_Split" targetRef="N_T8" />
    <sequenceFlow id="Flow_N14" sourceRef="N_GW_Split" targetRef="N_T9" />
    <sequenceFlow id="Flow_N15" sourceRef="N_T7" targetRef="N_GW_Join" />
    <sequenceFlow id="Flow_N16" sourceRef="N_T8" targetRef="N_GW_Join" />
    <sequenceFlow id="Flow_N17" sourceRef="N_T9" targetRef="N_GW_Join" />
    <sequenceFlow id="Flow_N18" sourceRef="N_GW_Join" targetRef="N_Rcv1" />
    <sequenceFlow id="Flow_N19" sourceRef="N_Rcv1" targetRef="N_T10" />
    <sequenceFlow id="Flow_N20" sourceRef="N_T10" targetRef="N_T11" />
    <sequenceFlow id="Flow_N21" sourceRef="N_T11" targetRef="N_T12" />
    <sequenceFlow id="Flow_N22" sourceRef="N_T12" targetRef="N_T13" />
    <sequenceFlow id="Flow_N23" sourceRef="N_T13" targetRef="N_Rcv2" />
    <sequenceFlow id="Flow_N24" sourceRef="N_Rcv2" targetRef="N_T14" />
    <sequenceFlow id="Flow_N25" sourceRef="N_T14" targetRef="N_End1" />
  </process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">

      <bpmndi:BPMNShape id="Participant_Commission_di" bpmnElement="Participant_Commission" isHorizontal="true">
