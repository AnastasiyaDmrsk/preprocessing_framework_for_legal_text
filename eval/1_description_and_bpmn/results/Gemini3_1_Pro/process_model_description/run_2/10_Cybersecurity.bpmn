      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="E_End_di" bpmnElement="E_End">
        <omgdc:Bounds x="1400" y="420" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Participant_ENISA_di" bpmnElement="Participant_ENISA" isHorizontal="true">
        <omgdc:Bounds x="50" y="600" width="2200" height="450" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_ENISA_Normal_di" bpmnElement="Lane_ENISA_Normal" isHorizontal="true">
        <omgdc:Bounds x="80" y="600" width="2170" height="300" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Management_Board_di" bpmnElement="Lane_Management_Board" isHorizontal="true">
        <omgdc:Bounds x="80" y="900" width="2170" height="150" />
