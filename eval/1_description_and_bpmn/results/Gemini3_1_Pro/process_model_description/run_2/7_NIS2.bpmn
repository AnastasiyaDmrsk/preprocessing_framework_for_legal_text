  <process id="proc_sp" isExecutable="false">
    <startEvent id="sp_s" name="Process for the Single point of contact starts"/>
    <task id="sp_1" name="Assess whether the significant incident concerns two or more Member States or it is otherwise appropriate to inform others"/>
    <exclusiveGateway id="sp_gw1" name="Appropriate to inform?"/>
    <parallelGateway id="sp_gw2"/>
    <task id="sp_2" name="Inform the other affected Member States of the significant incident without undue delay"/>
    <task id="sp_3" name="Inform ENISA of the significant incident without undue delay"/>
    <parallelGateway id="sp_gw3"/>
    <exclusiveGateway id="sp_j1"/>
    <task id="sp_4" name="Include the type of information received in accordance with paragraph 4 in the information"/>
    <task id="sp_5" name="Preserve the entity’s security and commercial interests as well as the confidentiality of the information provided"/>
    <task id="sp_6" name="Forward notifications received to the single points of contact of other affected Member States"/>
    <task id="sp_7" name="Send a summary report to ENISA"/>
    <task id="sp_8" name="Include anonymised and aggregated data on significant incidents, incidents, cyber threats and near misses in the summary report"/>
    <endEvent id="sp_e" name="Reporting completed"/>

    <sequenceFlow id="sf_sp_s_1" sourceRef="sp_s" targetRef="sp_1"/>
    <sequenceFlow id="sf_sp_1_gw1" sourceRef="sp_1" targetRef="sp_gw1"/>
