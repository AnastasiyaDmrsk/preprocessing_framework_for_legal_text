  </process>

  <process id="proc_cm" isExecutable="false">
    <startEvent id="cm_s" name="Process for the Commission starts"/>
    <task id="cm_1" name="Adopt implementing acts further specifying the type of information, the format and the procedure of a notification and of a communication"/>
    <task id="cm_2" name="Adopt implementing acts further specifying the cases in which an incident shall be considered to be significant..."/>
    <task id="cm_3" name="Adopt such implementing acts with regard to other essential and important entities"/>
    <parallelGateway id="cm_gw1"/>
    <task id="cm_4" name="Exchange advice with the Cooperation Group on the draft implementing acts"/>
    <task id="cm_5" name="Cooperate with the Cooperation Group on the draft implementing acts"/>
    <parallelGateway id="cm_gw2"/>
    <task id="cm_6" name="Adopt those implementing acts in accordance with the examination procedure referred to in Article 39(2)"/>
    <endEvent id="cm_e" name="Implementing acts adopted"/>

