  </process>

  <process id="proc_en" isExecutable="false">
    <startEvent id="en_s" name="Process for ENISA starts"/>
    <task id="en_1" name="Adopt technical guidance on the parameters of the information to be included in the summary report"/>
    <parallelGateway id="en_gw1"/>
    <task id="en_2" name="Inform the Cooperation Group about its findings on notifications received"/>
    <task id="en_3" name="Inform the CSIRTs network about its findings on notifications received"/>
    <parallelGateway id="en_gw2"/>
    <endEvent id="en_e" name="Findings shared"/>

    <sequenceFlow id="sf_en_s_1" sourceRef="en_s" targetRef="en_1"/>
