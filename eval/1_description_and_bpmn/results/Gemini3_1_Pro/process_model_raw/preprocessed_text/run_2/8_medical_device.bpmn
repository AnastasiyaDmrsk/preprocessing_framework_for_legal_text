<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             id="sid-definitions"
             targetNamespace="http://www.signavio.com">
    <collaboration id="collab_1">
        <participant id="p_manufacturer" name="Manufacturer" processRef="proc_manufacturer"/>
        <participant id="p_competent_authority" name="Competent Authority" processRef="proc_ca"/>
        <messageFlow id="mf1" sourceRef="t14" targetRef="p_competent_authority"/>
    </collaboration>

    <process id="proc_manufacturer" isExecutable="true" name="Manufacturer">
        <startEvent id="start" name="Start Obligations">
            <outgoing>sf_start_t1</outgoing>
        </startEvent>

        <task id="t1" name="Ensure design and manufacture IAW requirements">
            <incoming>sf_start_t1</incoming>
            <outgoing>sf_t1_t2</outgoing>
        </task>
        <task id="t2" name="Establish risk management system">
            <incoming>sf_t1_t2</incoming>
            <outgoing>sf_t2_t3</outgoing>
        </task>
        <task id="t3" name="Conduct clinical evaluation">
            <incoming>sf_t2_t3</incoming>
            <outgoing>sf_t3_t4</outgoing>
        </task>
        <task id="t4" name="Draw up technical documentation">
            <incoming>sf_t3_t4</incoming>
            <outgoing>sf_t4_t5</outgoing>
        </task>
        <task id="t5" name="Draw up EU declaration and affix CE marking">
            <incoming>sf_t4_t5</incoming>
            <outgoing>sf_t5_t6</outgoing>
        </task>
        <task id="t6" name="Comply with UDI and registration obligations">
            <incoming>sf_t5_t6</incoming>
            <outgoing>sf_t6_t7</outgoing>
        </task>
        <task id="t7" name="Keep documentation available">
            <incoming>sf_t6_t7</incoming>
            <outgoing>sf_t7_t8</outgoing>
        </task>
        <task id="t8" name="Ensure authorised rep has documentation">
            <incoming>sf_t7_t8</incoming>
            <outgoing>sf_t8_gw1</outgoing>
        </task>

        <parallelGateway id="gw1" name="Start QMS Parallel Tasks">
            <incoming>sf_t8_gw1</incoming>
            <outgoing>sf_gw1_t9a</outgoing>
            <outgoing>sf_gw1_t9b</outgoing>
            <outgoing>sf_gw1_t9c</outgoing>
            <outgoing>sf_gw1_t9d</outgoing>
            <outgoing>sf_gw1_t9e</outgoing>
            <outgoing>sf_gw1_t9f</outgoing>
            <outgoing>sf_gw1_t9g</outgoing>
            <outgoing>sf_gw1_t9h</outgoing>
            <outgoing>sf_gw1_t9i</outgoing>
            <outgoing>sf_gw1_t9j</outgoing>
            <outgoing>sf_gw1_t9k</outgoing>
            <outgoing>sf_gw1_t9l</outgoing>
            <outgoing>sf_gw1_t9m</outgoing>
        </parallelGateway>

        <task id="t9a" name="QMS: Strategy for regulatory compliance">
            <incoming>sf_gw1_t9a</incoming>
            <outgoing>sf_t9a_gw2</outgoing>
        </task>
        <task id="t9b" name="QMS: General safety &amp; performance requirements">
            <incoming>sf_gw1_t9b</incoming>
            <outgoing>sf_t9b_gw2</outgoing>
        </task>
        <task id="t9c" name="QMS: Responsibility of the management">
            <incoming>sf_gw1_t9c</incoming>
            <outgoing>sf_t9c_gw2</outgoing>
        </task>
        <task id="t9d" name="QMS: Resource management">
            <incoming>sf_gw1_t9d</incoming>
            <outgoing>sf_t9d_gw2</outgoing>
        </task>
        <task id="t9e" name="QMS: Risk management">
            <incoming>sf_gw1_t9e</incoming>
            <outgoing>sf_t9e_gw2</outgoing>
        </task>
        <task id="t9f" name="QMS: Clinical evaluation">
            <incoming>sf_gw1_t9f</incoming>
            <outgoing>sf_t9f_gw2</outgoing>
        </task>
        <task id="t9g" name="QMS: Product realisation">
            <incoming>sf_gw1_t9g</incoming>
            <outgoing>sf_t9g_gw2</outgoing>
        </task>
        <task id="t9h" name="QMS: Verification of UDI assignments">
            <incoming>sf_gw1_t9h</incoming>
            <outgoing>sf_t9h_gw2</outgoing>
        </task>
        <task id="t9i" name="QMS: Post-market surveillance system">
            <incoming>sf_gw1_t9i</incoming>
            <outgoing>sf_t9i_gw2</outgoing>
        </task>
        <task id="t9j" name="QMS: Handling communication">
            <incoming>sf_gw1_t9j</incoming>
            <outgoing>sf_t9j_gw2</outgoing>
        </task>
        <task id="t9k" name="QMS: Reporting of serious incidents">
            <incoming>sf_gw1_t9k</incoming>
            <outgoing>sf_t9k_gw2</outgoing>
        </task>
        <task id="t9l" name="QMS: Corrective and preventive actions">
            <incoming>sf_gw1_t9l</incoming>
            <outgoing>sf_t9l_gw2</outgoing>
        </task>
        <task id="t9m" name="QMS: Monitoring and product improvement">
            <incoming>sf_gw1_t9m</incoming>
            <outgoing>sf_t9m_gw2</outgoing>
        </task>

        <parallelGateway id="gw2" name="End QMS Parallel Tasks">
            <incoming>sf_t9a_gw2</incoming>
            <incoming>sf_t9b_gw2</incoming>
            <incoming>sf_t9c_gw2</incoming>
            <incoming>sf_t9d_gw2</incoming>
            <incoming>sf_t9e_gw2</incoming>
            <incoming>sf_t9f_gw2</incoming>
            <incoming>sf_t9g_gw2</incoming>
            <incoming>sf_t9h_gw2</incoming>
            <incoming>sf_t9i_gw2</incoming>
            <incoming>sf_t9j_gw2</incoming>
            <incoming>sf_t9k_gw2</incoming>
            <incoming>sf_t9l_gw2</incoming>
            <incoming>sf_t9m_gw2</incoming>
            <outgoing>sf_gw2_t10</outgoing>
        </parallelGateway>

        <task id="t10" name="Implement post-market surveillance system">
            <incoming>sf_gw2_t10</incoming>
            <outgoing>sf_t10_t11</outgoing>
        </task>
        <task id="t11" name="Ensure device accompanied by information">
            <incoming>sf_t10_t11</incoming>
            <outgoing>sf_t11_t12</outgoing>
        </task>
        <task id="t12" name="Take corrective action">
            <incoming>sf_t11_t12</incoming>
            <outgoing>sf_t12_t13</outgoing>
        </task>
        <task id="t13" name="Record and report incidents">
            <incoming>sf_t12_t13</incoming>
            <outgoing>sf_t13_t14</outgoing>
        </task>
        <task id="t14" name="Cooperate with competent authority">
            <incoming>sf_t13_t14</incoming>
            <outgoing>sf_t14_t15</outgoing>
        </task>
        <task id="t15" name="Submit identity of other designers">
            <incoming>sf_t14_t15</incoming>
            <outgoing>sf_t15_t16</outgoing>
        </task>
        <task id="t16" name="Provide financial coverage">
            <incoming>sf_t15_t16</incoming>
            <outgoing>sf_t16_end</outgoing>
        </task>

        <endEvent id="end" name="End Obligations">
            <incoming>sf_t16_end</incoming>
        </endEvent>

        <!-- Sequence Flows -->
        <sequenceFlow id="sf_start_t1" sourceRef="start" targetRef="t1"/>
        <sequenceFlow id="sf_t1_t2" sourceRef="t1" targetRef="t2"/>
