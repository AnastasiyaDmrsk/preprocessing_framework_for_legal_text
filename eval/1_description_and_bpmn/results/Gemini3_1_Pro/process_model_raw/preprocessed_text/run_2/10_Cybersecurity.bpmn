         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape id="task-eccg-upd_gui" bpmnElement="task-eccg-upd">
            <omgdc:Bounds x="400" y="310" width="100" height="80"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape id="task-eccg-adv_gui" bpmnElement="task-eccg-adv">
            <omgdc:Bounds x="550" y="310" width="100" height="80"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape id="task-eccg-opi_gui" bpmnElement="task-eccg-opi">
            <omgdc:Bounds x="700" y="310" width="100" height="80"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape id="task-eccg-req-rev_gui" bpmnElement="task-eccg-req-rev">
            <omgdc:Bounds x="850" y="310" width="100" height="80"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape id="end-eccg_gui" bpmnElement="end-eccg">
            <omgdc:Bounds x="1000" y="335" width="30" height="30"/>
         </bpmndi:BPMNShape>

         <!-- ENISA Pool -->
         <bpmndi:BPMNShape id="part-enisa_gui" bpmnElement="part-enisa" isHorizontal="true">
            <omgdc:Bounds x="100" y="450" width="1300" height="200"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape id="lane-enisa_gui" bpmnElement="lane-enisa" isHorizontal="true">
            <omgdc:Bounds x="130" y="450" width="1270" height="200"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape id="start-enisa_gui" bpmnElement="start-enisa">
            <omgdc:Bounds x="150" y="535" width="30" height="30"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape id="task-enisa-prep_gui" bpmnElement="task-enisa-prep">
            <omgdc:Bounds x="250" y="510" width="100" height="80"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape id="task-enisa-refuse_gui" bpmnElement="task-enisa-refuse">
            <omgdc:Bounds x="400" y="510" width="100" height="80"/>
