         <bpmndi:BPMNShape id="task-enisa-consult_gui" bpmnElement="task-enisa-consult">
            <omgdc:Bounds x="550" y="510" width="100" height="80"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape id="task-enisa-wg_gui" bpmnElement="task-enisa-wg">
            <omgdc:Bounds x="700" y="510" width="100" height="80"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape id="task-enisa-coop_gui" bpmnElement="task-enisa-coop">
            <omgdc:Bounds x="850" y="510" width="100" height="80"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape id="task-enisa-trans_gui" bpmnElement="task-enisa-trans">
            <omgdc:Bounds x="1000" y="510" width="100" height="80"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape id="task-enisa-eval_gui" bpmnElement="task-enisa-eval">
            <omgdc:Bounds x="1150" y="510" width="100" height="80"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape id="end-enisa_gui" bpmnElement="end-enisa">
            <omgdc:Bounds x="1300" y="535" width="30" height="30"/>
         </bpmndi:BPMNShape>

         <!-- Management Board Pool -->
         <bpmndi:BPMNShape id="part-mb_gui" bpmnElement="part-mb" isHorizontal="true">
            <omgdc:Bounds x="100" y="650" width="1300" height="200"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape id="lane-mb_gui" bpmnElement="lane-mb" isHorizontal="true">
            <omgdc:Bounds x="130" y="650" width="1270" height="200"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape id="start-mb_gui" bpmnElement="start-mb">
            <omgdc:Bounds x="300" y="735" width="30" height="30"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape id="task-mb-decide_gui" bpmnElement="task-mb-decide">
            <omgdc:Bounds x="400" y="710" width="100" height="80"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape id="end-mb_gui" bpmnElement="end-mb">
            <omgdc:Bounds x="550" y="735" width="30" height="30"/>
         </bpmndi:BPMNShape>

         <!-- Commission Flows -->
         <bpmndi:BPMNEdge id="sf-c1_gui" bpmnElement="sf-c1">
            <omgdi:waypoint x="180" y="150"/>
            <omgdi:waypoint x="250" y="150"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge id="sf-c2_gui" bpmnElement="sf-c2">
            <omgdi:waypoint x="350" y="150"/>
            <omgdi:waypoint x="400" y="150"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge id="sf-c3_gui" bpmnElement="sf-c3">
            <omgdi:waypoint x="500" y="150"/>
            <omgdi:waypoint x="550" y="150"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge id="sf-c4_gui" bpmnElement="sf-c4">
            <omgdi:waypoint x="650" y="150"/>
            <omgdi:waypoint x="700" y="150"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge id="sf-c5_gui" bpmnElement="sf-c5">
            <omgdi:waypoint x="800" y="150"/>
            <omgdi:waypoint x="850" y="150"/>
         </bpmndi:BPMNEdge>

         <!-- ECCG Flows -->
         <bpmndi:BPMNEdge id="sf-e1_gui" bpmnElement="sf-e1">
            <omgdi:waypoint x="180" y="350"/>
            <omgdi:waypoint x="250" y="350"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge id="sf-e2_gui" bpmnElement="sf-e2">
            <omgdi:waypoint x="350" y="350"/>
            <omgdi:waypoint x="400" y="350"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge id="sf-e3_gui" bpmnElement="sf-e3">
            <omgdi:waypoint x="500" y="350"/>
            <omgdi:waypoint x="550" y="350"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge id="sf-e4_gui" bpmnElement="sf-e4">
            <omgdi:waypoint x="650" y="350"/>
            <omgdi:waypoint x="700" y="350"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge id="sf-e5_gui" bpmnElement="sf-e5">
            <omgdi:waypoint x="800" y="350"/>
            <omgdi:waypoint x="850" y="350"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge id="sf-e6_gui" bpmnElement="sf-e6">
            <omgdi:waypoint x="950" y="350"/>
            <omgdi:waypoint x="1000" y="350"/>
         </bpmndi:BPMNEdge>

         <!-- ENISA Flows -->
         <bpmndi:BPMNEdge id="sf-en1_gui" bpmnElement="sf-en1">
            <omgdi:waypoint x="180" y="550"/>
            <omgdi:waypoint x="250" y="550"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge id="sf-en2_gui" bpmnElement="sf-en2">
            <omgdi:waypoint x="350" y="550"/>
