            <omgdi:waypoint x="300" y="510"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge id="mf2_gui" bpmnElement="mf2">
            <omgdi:waypoint x="300" y="390"/>
            <omgdi:waypoint x="300" y="510"/>
