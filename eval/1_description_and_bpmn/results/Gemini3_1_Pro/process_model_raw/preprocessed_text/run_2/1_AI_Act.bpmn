         <bpmndi:BPMNEdge bpmnElement="Flow_AI_3d_Join" id="Edge_Flow_AI_3d_Join">
            <omgdi:waypoint x="500.0" y="920.0" />
            <omgdi:waypoint x="575.0" y="920.0" />
            <omgdi:waypoint x="575.0" y="825.0" />
