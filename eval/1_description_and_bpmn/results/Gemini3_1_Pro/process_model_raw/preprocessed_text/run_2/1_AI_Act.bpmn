            <omgdi:waypoint x="345.0" y="210.0" />
            <omgdi:waypoint x="380.0" y="210.0" />
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="Flow_MS_Split_1c" id="Edge_Flow_MS_Split_1c">
            <omgdi:waypoint x="310.0" y="290.0" />
            <omgdi:waypoint x="345.0" y="290.0" />
            <omgdi:waypoint x="345.0" y="310.0" />
            <omgdi:waypoint x="380.0" y="310.0" />
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="Flow_MS_Split_1d" id="Edge_Flow_MS_Split_1d">
            <omgdi:waypoint x="285.0" y="315.0" />
            <omgdi:waypoint x="285.0" y="410.0" />
            <omgdi:waypoint x="380.0" y="410.0" />
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="Flow_MS_1a_Join" id="Edge_Flow_MS_1a_Join">
            <omgdi:waypoint x="500.0" y="110.0" />
            <omgdi:waypoint x="575.0" y="110.0" />
            <omgdi:waypoint x="575.0" y="265.0" />
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="Flow_MS_1b_Join" id="Edge_Flow_MS_1b_Join">
            <omgdi:waypoint x="500.0" y="210.0" />
            <omgdi:waypoint x="525.0" y="210.0" />
            <omgdi:waypoint x="525.0" y="290.0" />
            <omgdi:waypoint x="550.0" y="290.0" />
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="Flow_MS_1c_Join" id="Edge_Flow_MS_1c_Join">
            <omgdi:waypoint x="500.0" y="310.0" />
            <omgdi:waypoint x="525.0" y="310.0" />
            <omgdi:waypoint x="525.0" y="290.0" />
            <omgdi:waypoint x="550.0" y="290.0" />
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="Flow_MS_1d_Join" id="Edge_Flow_MS_1d_Join">
            <omgdi:waypoint x="500.0" y="410.0" />
            <omgdi:waypoint x="575.0" y="410.0" />
            <omgdi:waypoint x="575.0" y="315.0" />
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="Flow_MS_Join_2" id="Edge_Flow_MS_Join_2">
            <omgdi:waypoint x="600.0" y="290.0" />
            <omgdi:waypoint x="660.0" y="290.0" />
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="Flow_MS_2_End" id="Edge_Flow_MS_2_End">
            <omgdi:waypoint x="780.0" y="290.0" />
            <omgdi:waypoint x="840.0" y="290.0" />
         </bpmndi:BPMNEdge>

         <!-- The AI Office Pool & Lane -->
         <bpmndi:BPMNShape bpmnElement="Participant_AIOffice" id="Shape_Participant_AI" isHorizontal="true">
            <omgdc:Bounds height="480.0" width="1050.0" x="100.0" y="560.0" />
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="Lane_AI" id="Shape_Lane_AI" isHorizontal="true">
            <omgdc:Bounds height="480.0" width="1020.0" x="130.0" y="560.0" />
         </bpmndi:BPMNShape>

         <bpmndi:BPMNShape bpmnElement="Start_AI" id="Shape_Start_AI">
            <omgdc:Bounds height="36.0" width="36.0" x="180.0" y="782.0" />
         </bpmndi:BPMNShape>

         <bpmndi:BPMNShape bpmnElement="Split_AI" id="Shape_Split_AI">
            <omgdc:Bounds height="50.0" width="50.0" x="260.0" y="775.0" />
         </bpmndi:BPMNShape>

         <bpmndi:BPMNShape bpmnElement="Task_AI_3a" id="Shape_Task_AI_3a">
            <omgdc:Bounds height="80.0" width="120.0" x="380.0" y="580.0" />
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="Task_AI_3b" id="Shape_Task_AI_3b">
            <omgdc:Bounds height="80.0" width="120.0" x="380.0" y="680.0" />
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="Task_AI_3c" id="Shape_Task_AI_3c">
            <omgdc:Bounds height="80.0" width="120.0" x="380.0" y="780.0" />
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="Task_AI_3d" id="Shape_Task_AI_3d">
            <omgdc:Bounds height="80.0" width="120.0" x="380.0" y="880.0" />
         </bpmndi:BPMNShape>

         <bpmndi:BPMNShape bpmnElement="Join_AI" id="Shape_Join_AI">
            <omgdc:Bounds height="50.0" width="50.0" x="550.0" y="775.0" />
         </bpmndi:BPMNShape>

         <bpmndi:BPMNShape bpmnElement="End_AI" id="Shape_End_AI">
            <omgdc:Bounds height="36.0" width="36.0" x="660.0" y="782.0" />
         </bpmndi:BPMNShape>

         <bpmndi:BPMNEdge bpmnElement="Flow_AI_Start_Split" id="Edge_Flow_AI_Start_Split">
            <omgdi:waypoint x="216.0" y="800.0" />
            <omgdi:waypoint x="260.0" y="800.0" />
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="Flow_AI_Split_3a" id="Edge_Flow_AI_Split_3a">
            <omgdi:waypoint x="285.0" y="775.0" />
            <omgdi:waypoint x="285.0" y="620.0" />
            <omgdi:waypoint x="380.0" y="620.0" />
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="Flow_AI_Split_3b" id="Edge_Flow_AI_Split_3b">
            <omgdi:waypoint x="310.0" y="800.0" />
            <omgdi:waypoint x="345.0" y="800.0" />
            <omgdi:waypoint x="345.0" y="720.0" />
            <omgdi:waypoint x="380.0" y="720.0" />
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="Flow_AI_Split_3c" id="Edge_Flow_AI_Split_3c">
            <omgdi:waypoint x="310.0" y="800.0" />
            <omgdi:waypoint x="345.0" y="800.0" />
            <omgdi:waypoint x="345.0" y="820.0" />
