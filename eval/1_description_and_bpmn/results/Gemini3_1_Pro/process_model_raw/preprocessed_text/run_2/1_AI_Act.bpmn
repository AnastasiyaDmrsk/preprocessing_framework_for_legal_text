            <omgdi:waypoint x="380.0" y="920.0" />
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="Flow_AI_3a_Join" id="Edge_Flow_AI_3a_Join">
            <omgdi:waypoint x="500.0" y="620.0" />
            <omgdi:waypoint x="575.0" y="620.0" />
            <omgdi:waypoint x="575.0" y="775.0" />
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="Flow_AI_3b_Join" id="Edge_Flow_AI_3b_Join">
