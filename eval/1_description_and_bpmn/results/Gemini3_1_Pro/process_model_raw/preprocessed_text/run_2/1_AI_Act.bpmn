         <bpmndi:BPMNEdge bpmnElement="Flow_AI_Join_End" id="Edge_Flow_AI_Join_End">
            <omgdi:waypoint x="600.0" y="800.0" />
            <omgdi:waypoint x="660.0" y="800.0" />
         </bpmndi:BPMNEdge>

      </bpmndi:BPMNPlane>
   </bpmndi:BPMNDiagram>
</definitions>
