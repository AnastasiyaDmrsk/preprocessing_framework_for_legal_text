            <omgdi:waypoint x="1675" y="700" />
            <omgdi:waypoint x="1675" y="900" />
            <omgdi:waypoint x="1700" y="900" />
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge id="edge_sf12" bpmnElement="sf12">
            <omgdi:waypoint x="1800" y="900" />
            <omgdi:waypoint x="1850" y="900" />
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge id="edge_sf13" bpmnElement="sf13">
            <omgdi:waypoint x="1950" y="900" />
            <omgdi:waypoint x="1975" y="900" />
            <omgdi:waypoint x="1975" y="100" />
            <omgdi:waypoint x="2000" y="100" />
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge id="edge_sf14" bpmnElement="sf14">
