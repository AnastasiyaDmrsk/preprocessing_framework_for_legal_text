         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge id="edge_sf15" bpmnElement="sf15">
            <omgdi:waypoint x="2250" y="100" />
            <omgdi:waypoint x="2300" y="100" />
         </bpmndi:BPMNEdge>
      </bpmndi:BPMNPlane>
   </bpmndi:BPMNDiagram>
</definitions>
