         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape id="shape_t1" bpmnElement="t1">
            <omgdc:Bounds x="200" y="60" width="100" height="80" />
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape id="shape_t2" bpmnElement="t2">
            <omgdc:Bounds x="350" y="60" width="100" height="80" />
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape id="shape_t3" bpmnElement="t3">
            <omgdc:Bounds x="500" y="60" width="100" height="80" />
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape id="shape_t4" bpmnElement="t4">
            <omgdc:Bounds x="650" y="60" width="100" height="80" />
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape id="shape_t7" bpmnElement="t7">
            <omgdc:Bounds x="800" y="260" width="100" height="80" />
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape id="shape_t8" bpmnElement="t8">
            <omgdc:Bounds x="950" y="260" width="100" height="80" />
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape id="shape_t9" bpmnElement="t9">
            <omgdc:Bounds x="1100" y="460" width="100" height="80" />
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape id="shape_t10" bpmnElement="t10">
            <omgdc:Bounds x="1250" y="460" width="100" height="80" />
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape id="shape_t11" bpmnElement="t11">
            <omgdc:Bounds x="1400" y="660" width="100" height="80" />
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape id="shape_t12" bpmnElement="t12">
            <omgdc:Bounds x="1550" y="660" width="100" height="80" />
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape id="shape_t13" bpmnElement="t13">
            <omgdc:Bounds x="1700" y="860" width="100" height="80" />
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape id="shape_t14" bpmnElement="t14">
            <omgdc:Bounds x="1850" y="860" width="100" height="80" />
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape id="shape_t5" bpmnElement="t5">
            <omgdc:Bounds x="2000" y="60" width="100" height="80" />
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape id="shape_t6" bpmnElement="t6">
            <omgdc:Bounds x="2150" y="60" width="100" height="80" />
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape id="shape_end" bpmnElement="end">
            <omgdc:Bounds x="2300" y="85" width="30" height="30" />
         </bpmndi:BPMNShape>

         <bpmndi:BPMNEdge id="edge_sf1" bpmnElement="sf1">
            <omgdi:waypoint x="130" y="100" />
            <omgdi:waypoint x="200" y="100" />
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge id="edge_sf2" bpmnElement="sf2">
            <omgdi:waypoint x="300" y="100" />
            <omgdi:waypoint x="350" y="100" />
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge id="edge_sf3" bpmnElement="sf3">
            <omgdi:waypoint x="450" y="100" />
            <omgdi:waypoint x="500" y="100" />
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge id="edge_sf4" bpmnElement="sf4">
            <omgdi:waypoint x="600" y="100" />
            <omgdi:waypoint x="650" y="100" />
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge id="edge_sf5" bpmnElement="sf5">
            <omgdi:waypoint x="750" y="100" />
            <omgdi:waypoint x="775" y="100" />
            <omgdi:waypoint x="775" y="300" />
            <omgdi:waypoint x="800" y="300" />
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge id="edge_sf6" bpmnElement="sf6">
            <omgdi:waypoint x="900" y="300" />
            <omgdi:waypoint x="950" y="300" />
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge id="edge_sf7" bpmnElement="sf7">
            <omgdi:waypoint x="1050" y="300" />
            <omgdi:waypoint x="1075" y="300" />
            <omgdi:waypoint x="1075" y="500" />
            <omgdi:waypoint x="1100" y="500" />
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge id="edge_sf8" bpmnElement="sf8">
            <omgdi:waypoint x="1200" y="500" />
            <omgdi:waypoint x="1250" y="500" />
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge id="edge_sf9" bpmnElement="sf9">
            <omgdi:waypoint x="1350" y="500" />
            <omgdi:waypoint x="1375" y="500" />
            <omgdi:waypoint x="1375" y="700" />
            <omgdi:waypoint x="1400" y="700" />
         </bpmndi:BPMNEdge>
