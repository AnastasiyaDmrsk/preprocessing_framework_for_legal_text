<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             id="sid-regulation-process"
             targetNamespace="http://www.signavio.com"
             xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd">

   <collaboration id="Collaboration_1">
      <participant id="Participant_Regulation" name="Trust Services Regulation Process" processRef="Process_Regulation" />
   </collaboration>

   <process id="Process_Regulation" isClosed="false" isExecutable="true" name="Regulation Process" processType="None">
      <laneSet id="LaneSet_1">
         <lane id="Lane_MS" name="Member States">
            <flowNodeRef>StartEvent_1</flowNodeRef>
            <flowNodeRef>Task_MS_1</flowNodeRef>
            <flowNodeRef>Task_MS_2</flowNodeRef>
            <flowNodeRef>GW_Split_3</flowNodeRef>
         </lane>
         <lane id="Lane_SB" name="Supervisory Body">
            <flowNodeRef>Task_SB_3a</flowNodeRef>
            <flowNodeRef>Task_SB_3b</flowNodeRef>
            <flowNodeRef>GW_Join_3</flowNodeRef>
            <flowNodeRef>GW_Split_4</flowNodeRef>
            <flowNodeRef>Task_SB_4a</flowNodeRef>
            <flowNodeRef>Task_SB_4b</flowNodeRef>
            <flowNodeRef>Task_SB_4c</flowNodeRef>
            <flowNodeRef>Task_SB_4d</flowNodeRef>
            <flowNodeRef>Task_SB_4e</flowNodeRef>
            <flowNodeRef>Task_SB_4f</flowNodeRef>
            <flowNodeRef>Task_SB_4g</flowNodeRef>
            <flowNodeRef>Task_SB_4h</flowNodeRef>
            <flowNodeRef>Task_SB_4i</flowNodeRef>
            <flowNodeRef>Task_SB_4j</flowNodeRef>
            <flowNodeRef>GW_Join_4</flowNodeRef>
            <flowNodeRef>GW_Split_18</flowNodeRef>
            <flowNodeRef>Task_SB_18a</flowNodeRef>
            <flowNodeRef>Task_SB_18b</flowNodeRef>
            <flowNodeRef>Task_SB_18c</flowNodeRef>
            <flowNodeRef>GW_Join_18</flowNodeRef>
            <flowNodeRef>Task_SB_17_6</flowNodeRef>
            <flowNodeRef>Task_SB_19_3</flowNodeRef>
         </lane>
         <lane id="Lane_Com" name="Commission">
            <flowNodeRef>Task_Com_17_7</flowNodeRef>
            <flowNodeRef>GW_Split_19</flowNodeRef>
            <flowNodeRef>Task_Com_19_4a</flowNodeRef>
            <flowNodeRef>Task_Com_19_4b</flowNodeRef>
            <flowNodeRef>GW_Join_19</flowNodeRef>
            <flowNodeRef>EndEvent_1</flowNodeRef>
         </lane>
         <lane id="Lane_TSP" name="Trust Service Providers">
            <flowNodeRef>Task_TSP_19_1</flowNodeRef>
            <flowNodeRef>Task_TSP_19_2</flowNodeRef>
         </lane>
      </laneSet>

      <!-- Member States Elements -->
      <startEvent id="StartEvent_1" name="Regulation Active">
         <outgoing>Flow_S_T1</outgoing>
      </startEvent>
      <task id="Task_MS_1" name="Designate supervisory body">
         <incoming>Flow_S_T1</incoming>
         <outgoing>Flow_T1_T2</outgoing>
      </task>
      <task id="Task_MS_2" name="Notify to Commission names and addresses">
         <incoming>Flow_T1_T2</incoming>
         <outgoing>Flow_T2_G1</outgoing>
      </task>
      <parallelGateway id="GW_Split_3" name="Split 3">
         <incoming>Flow_T2_G1</incoming>
         <outgoing>Flow_G1_3a</outgoing>
         <outgoing>Flow_G1_3b</outgoing>
      </parallelGateway>

      <!-- Supervisory Body Elements -->
      <task id="Task_SB_3a" name="Supervise qualified trust service providers">
         <incoming>Flow_G1_3a</incoming>
         <outgoing>Flow_3a_G2</outgoing>
      </task>
      <task id="Task_SB_3b" name="Take action on non-qualified trust service providers">
         <incoming>Flow_G1_3b</incoming>
         <outgoing>Flow_3b_G2</outgoing>
      </task>
      <parallelGateway id="GW_Join_3" name="Join 3">
         <incoming>Flow_3a_G2</incoming>
         <incoming>Flow_3b_G2</incoming>
         <outgoing>Flow_G2_G3</outgoing>
      </parallelGateway>

      <parallelGateway id="GW_Split_4" name="Split 4">
         <incoming>Flow_G2_G3</incoming>
         <outgoing>Flow_G3_4a</outgoing>
         <outgoing>Flow_G3_4b</outgoing>
         <outgoing>Flow_G3_4c</outgoing>
         <outgoing>Flow_G3_4d</outgoing>
         <outgoing>Flow_G3_4e</outgoing>
         <outgoing>Flow_G3_4f</outgoing>
         <outgoing>Flow_G3_4g</outgoing>
         <outgoing>Flow_G3_4h</outgoing>
         <outgoing>Flow_G3_4i</outgoing>
         <outgoing>Flow_G3_4j</outgoing>
      </parallelGateway>

      <task id="Task_SB_4a" name="Cooperate with other supervisory bodies"><incoming>Flow_G3_4a</incoming><outgoing>Flow_4a_G4</outgoing></task>
      <task id="Task_SB_4b" name="Analyse conformity assessment reports"><incoming>Flow_G3_4b</incoming><outgoing>Flow_4b_G4</outgoing></task>
      <task id="Task_SB_4c" name="Inform about breaches of security"><incoming>Flow_G3_4c</incoming><outgoing>Flow_4c_G4</outgoing></task>
      <task id="Task_SB_4d" name="Report to the Commission"><incoming>Flow_G3_4d</incoming><outgoing>Flow_4d_G4</outgoing></task>
      <task id="Task_SB_4e" name="Carry out audits"><incoming>Flow_G3_4e</incoming><outgoing>Flow_4e_G4</outgoing></task>
      <task id="Task_SB_4f" name="Cooperate with data protection authorities"><incoming>Flow_G3_4f</incoming><outgoing>Flow_4f_G4</outgoing></task>
      <task id="Task_SB_4g" name="Grant and withdraw qualified status"><incoming>Flow_G3_4g</incoming><outgoing>Flow_4g_G4</outgoing></task>
      <task id="Task_SB_4h" name="Inform body responsible for national trusted list"><incoming>Flow_G3_4h</incoming><outgoing>Flow_4h_G4</outgoing></task>
      <task id="Task_SB_4i" name="Verify termination plans"><incoming>Flow_G3_4i</incoming><outgoing>Flow_4i_G4</outgoing></task>
      <task id="Task_SB_4j" name="Require remedy of failure"><incoming>Flow_G3_4j</incoming><outgoing>Flow_4j_G4</outgoing></task>

      <parallelGateway id="GW_Join_4" name="Join 4">
         <incoming>Flow_4a_G4</incoming><incoming>Flow_4b_G4</incoming><incoming>Flow_4c_G4</incoming><incoming>Flow_4d_G4</incoming><incoming>Flow_4e_G4</incoming>
         <incoming>Flow_4f_G4</incoming><incoming>Flow_4g_G4</incoming><incoming>Flow_4h_G4</incoming><incoming>Flow_4i_G4</incoming><incoming>Flow_4j_G4</incoming>
         <outgoing>Flow_G4_G5</outgoing>
      </parallelGateway>

      <parallelGateway id="GW_Split_18" name="Split 18">
         <incoming>Flow_G4_G5</incoming>
         <outgoing>Flow_G5_18a</outgoing>
         <outgoing>Flow_G5_18b</outgoing>
         <outgoing>Flow_G5_18c</outgoing>
      </parallelGateway>

      <task id="Task_SB_18a" name="Refuse request: not competent"><incoming>Flow_G5_18a</incoming><outgoing>Flow_18a_G6</outgoing></task>
      <task id="Task_SB_18b" name="Refuse request: not proportionate"><incoming>Flow_G5_18b</incoming><outgoing>Flow_18b_G6</outgoing></task>
      <task id="Task_SB_18c" name="Refuse request: incompatible"><incoming>Flow_G5_18c</incoming><outgoing>Flow_18c_G6</outgoing></task>

      <parallelGateway id="GW_Join_18" name="Join 18">
         <incoming>Flow_18a_G6</incoming><incoming>Flow_18b_G6</incoming><incoming>Flow_18c_G6</incoming>
         <outgoing>Flow_G6_176</outgoing>
      </parallelGateway>

      <task id="Task_SB_17_6" name="Submit report to Commission">
         <incoming>Flow_G6_176</incoming>
         <outgoing>Flow_176_177</outgoing>
      </task>

      <!-- Commission Elements -->
      <task id="Task_Com_17_7" name="Make annual report available">
         <incoming>Flow_176_177</incoming>
         <outgoing>Flow_177_191</outgoing>
      </task>

      <!-- TSP Elements -->
      <task id="Task_TSP_19_1" name="Take technical and organisational measures">
         <incoming>Flow_177_191</incoming>
         <outgoing>Flow_191_192</outgoing>
      </task>
      <task id="Task_TSP_19_2" name="Notify breach of security">
         <incoming>Flow_191_192</incoming>
         <outgoing>Flow_192_193</outgoing>
      </task>

      <!-- Back to SB Elements -->
      <task id="Task_SB_19_3" name="Provide ENISA with summary of notifications">
         <incoming>Flow_192_193</incoming>
         <outgoing>Flow_193_G7</outgoing>
      </task>

      <!-- Back to Commission Elements -->
      <parallelGateway id="GW_Split_19" name="Split 19">
         <incoming>Flow_193_G7</incoming>
         <outgoing>Flow_G7_194a</outgoing>
         <outgoing>Flow_G7_194b</outgoing>
      </parallelGateway>

      <task id="Task_Com_19_4a" name="Specify measures"><incoming>Flow_G7_194a</incoming><outgoing>Flow_194a_G8</outgoing></task>
      <task id="Task_Com_19_4b" name="Define formats and procedures"><incoming>Flow_G7_194b</incoming><outgoing>Flow_194b_G8</outgoing></task>

      <parallelGateway id="GW_Join_19" name="Join 19">
         <incoming>Flow_194a_G8</incoming>
         <incoming>Flow_194b_G8</incoming>
         <outgoing>Flow_G8_End</outgoing>
      </parallelGateway>

      <endEvent id="EndEvent_1" name="Process Complete">
         <incoming>Flow_G8_End</incoming>
      </endEvent>

      <!-- Sequence Flows -->
      <sequenceFlow id="Flow_S_T1" sourceRef="StartEvent_1" targetRef="Task_MS_1" />
      <sequenceFlow id="Flow_T1_T2" sourceRef="Task_MS_1" targetRef="Task_MS_2" />
      <sequenceFlow id="Flow_T2_G1" sourceRef="Task_MS_2" targetRef="GW_Split_3" />
      <sequenceFlow id="Flow_G1_3a" sourceRef="GW_Split_3" targetRef="Task_SB_3a" />
      <sequenceFlow id="Flow_G1_3b" sourceRef="GW_Split_3" targetRef="Task_SB_3b" />
      <sequenceFlow id="Flow_3a_G2" sourceRef="Task_SB_3a" targetRef="GW_Join_3" />
      <sequenceFlow id="Flow_3b_G2" sourceRef="Task_SB_3b" targetRef="GW_Join_3" />
      <sequenceFlow id="Flow_G2_G3" sourceRef="GW_Join_3" targetRef="GW_Split_4" />
      <sequenceFlow id="Flow_G3_4a" sourceRef="GW_Split_4" targetRef="Task_SB_4a" />
