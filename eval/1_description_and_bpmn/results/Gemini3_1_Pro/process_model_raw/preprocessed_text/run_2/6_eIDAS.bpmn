      <sequenceFlow id="Flow_G3_4g" sourceRef="GW_Split_4" targetRef="Task_SB_4g" />
      <sequenceFlow id="Flow_G3_4h" sourceRef="GW_Split_4" targetRef="Task_SB_4h" />
      <sequenceFlow id="Flow_G3_4i" sourceRef="GW_Split_4" targetRef="Task_SB_4i" />
      <sequenceFlow id="Flow_G3_4j" sourceRef="GW_Split_4" targetRef="Task_SB_4j" />
      <sequenceFlow id="Flow_4a_G4" sourceRef="Task_SB_4a" targetRef="GW_Join_4" />
      <sequenceFlow id="Flow_4b_G4" sourceRef="Task_SB_4b" targetRef="GW_Join_4" />
      <sequenceFlow id="Flow_4c_G4" sourceRef="Task_SB_4c" targetRef="GW_Join_4" />
      <sequenceFlow id="Flow_4d_G4" sourceRef="Task_SB_4d" targetRef="GW_Join_4" />
      <sequenceFlow id="Flow_4e_G4" sourceRef="Task_SB_4e" targetRef="GW_Join_4" />
      <sequenceFlow id="Flow_4f_G4" sourceRef="Task_SB_4f" targetRef="GW_Join_4" />
      <sequenceFlow id="Flow_4g_G4" sourceRef="Task_SB_4g" targetRef="GW_Join_4" />
      <sequenceFlow id="Flow_4h_G4" sourceRef="Task_SB_4h" targetRef="GW_Join_4" />
      <sequenceFlow id="Flow_4i_G4" sourceRef="Task_SB_4i" targetRef="GW_Join_4" />
      <sequenceFlow id="Flow_4j_G4" sourceRef="Task_SB_4j" targetRef="GW_Join_4" />
      <sequenceFlow id="Flow_G4_G5" sourceRef="GW_Join_4" targetRef="GW_Split_18" />
      <sequenceFlow id="Flow_G5_18a" sourceRef="GW_Split_18" targetRef="Task_SB_18a" />
      <sequenceFlow id="Flow_G5_18b" sourceRef="GW_Split_18" targetRef="Task_SB_18b" />
      <sequenceFlow id="Flow_G5_18c" sourceRef="GW_Split_18" targetRef="Task_SB_18c" />
      <sequenceFlow id="Flow_18a_G6" sourceRef="Task_SB_18a" targetRef="GW_Join_18" />
      <sequenceFlow id="Flow_18b_G6" sourceRef="Task_SB_18b" targetRef="GW_Join_18" />
      <sequenceFlow id="Flow_18c_G6" sourceRef="Task_SB_18c" targetRef="GW_Join_18" />
      <sequenceFlow id="Flow_G6_176" sourceRef="GW_Join_18" targetRef="Task_SB_17_6" />
      <sequenceFlow id="Flow_176_177" sourceRef="Task_SB_17_6" targetRef="Task_Com_17_7" />
      <sequenceFlow id="Flow_177_191" sourceRef="Task_Com_17_7" targetRef="Task_TSP_19_1" />
      <sequenceFlow id="Flow_191_192" sourceRef="Task_TSP_19_1" targetRef="Task_TSP_19_2" />
      <sequenceFlow id="Flow_192_193" sourceRef="Task_TSP_19_2" targetRef="Task_SB_19_3" />
      <sequenceFlow id="Flow_193_G7" sourceRef="Task_SB_19_3" targetRef="GW_Split_19" />
      <sequenceFlow id="Flow_G7_194a" sourceRef="GW_Split_19" targetRef="Task_Com_19_4a" />
      <sequenceFlow id="Flow_G7_194b" sourceRef="GW_Split_19" targetRef="Task_Com_19_4b" />
      <sequenceFlow id="Flow_194a_G8" sourceRef="Task_Com_19_4a" targetRef="GW_Join_19" />
      <sequenceFlow id="Flow_194b_G8" sourceRef="Task_Com_19_4b" targetRef="GW_Join_19" />
      <sequenceFlow id="Flow_G8_End" sourceRef="GW_Join_19" targetRef="EndEvent_1" />

   </process>

