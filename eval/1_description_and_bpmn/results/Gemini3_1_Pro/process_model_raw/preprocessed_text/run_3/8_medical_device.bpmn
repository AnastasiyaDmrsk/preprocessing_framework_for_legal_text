      <!-- Nodes -->
      <startEvent id="StartEvent_1" name="Start">
         <outgoing>Flow_Start_T1</outgoing>
      </startEvent>
      <task id="Task_1" name="Ensure devices designed and manufactured">
         <incoming>Flow_Start_T1</incoming>
         <outgoing>Flow_T1_T2</outgoing>
      </task>
      <task id="Task_2" name="Establish risk management system">
