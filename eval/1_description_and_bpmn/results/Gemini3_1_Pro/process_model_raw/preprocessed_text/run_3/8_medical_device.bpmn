         <outgoing>Flow_T3_T4</outgoing>
      </task>
      <task id="Task_4" name="Draw up technical documentation">
         <incoming>Flow_T3_T4</incoming>
         <outgoing>Flow_T4_T5</outgoing>
      </task>
