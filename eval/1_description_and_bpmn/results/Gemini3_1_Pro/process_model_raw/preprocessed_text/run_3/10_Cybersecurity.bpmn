            <omgdc:Bounds x="760.0" y="525.0" width="30.0" height="30.0" />
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape id="Task_5_di" bpmnElement="Task_5">
            <omgdc:Bounds x="500.0" y="400.0" width="100.0" height="80.0" />
