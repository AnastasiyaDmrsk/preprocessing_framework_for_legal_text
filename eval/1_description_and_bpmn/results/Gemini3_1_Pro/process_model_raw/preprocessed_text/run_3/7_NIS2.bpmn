         <bpmndi:BPMNEdge bpmnElement="seq_spoc2_enisa" id="seq_spoc2_enisa_gui">
            <omgdi:waypoint x="1450.0" y="1075.0"/>
            <omgdi:waypoint x="1470.0" y="1075.0"/>
            <omgdi:waypoint x="1470.0" y="1225.0"/>
            <omgdi:waypoint x="1500.0" y="1225.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="seq_enisa_comm" id="seq_enisa_comm_gui">
            <omgdi:waypoint x="1600.0" y="1225.0"/>
            <omgdi:waypoint x="1620.0" y="1225.0"/>
            <omgdi:waypoint x="1620.0" y="1400.0"/>
            <omgdi:waypoint x="1650.0" y="1400.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="seq_comm_end" id="seq_comm_end_gui">
            <omgdi:waypoint x="1750.0" y="1400.0"/>
            <omgdi:waypoint x="1800.0" y="1400.0"/>
         </bpmndi:BPMNEdge>
      </bpmndi:BPMNPlane>
   </bpmndi:BPMNDiagram>
</definitions>
