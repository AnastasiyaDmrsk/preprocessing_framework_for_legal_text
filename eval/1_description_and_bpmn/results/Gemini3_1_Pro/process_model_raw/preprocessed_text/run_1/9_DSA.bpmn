         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape id="Shape_End_Com" bpmnElement="End_Com">
            <omgdc:Bounds x="1000" y="1150" width="30" height="30"/>
         </bpmndi:BPMNShape>

         <!-- Sequence Flows (Abstracted straight lines) -->
         <bpmndi:BPMNEdge id="Edge_Seq_App_1" bpmnElement="Seq_App_1">
            <omgdi:waypoint x="180" y="115"/>
            <omgdi:waypoint x="250" y="115"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge id="Edge_Seq_App_2" bpmnElement="Seq_App_2">
