         <!-- Message Flows -->
         <bpmndi:BPMNEdge id="Edge_MF_Apply" bpmnElement="MF_Apply">
            <omgdi:waypoint x="300" y="165"/>
            <omgdi:waypoint x="165" y="370"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge id="Edge_MF_Notices" bpmnElement="MF_Notices">
            <omgdi:waypoint x="300" y="765"/>
            <omgdi:waypoint x="165" y="950"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge id="Edge_MF_Reports" bpmnElement="MF_Reports">
            <omgdi:waypoint x="800" y="765"/>
            <omgdi:waypoint x="165" y="1150"/>
