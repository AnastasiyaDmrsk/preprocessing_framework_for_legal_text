            <omgdc:Bounds height="150.0" width="1970.0" x="130.0" y="100.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="Lane_Cust" id="Lane_Cust_di" isHorizontal="true">
