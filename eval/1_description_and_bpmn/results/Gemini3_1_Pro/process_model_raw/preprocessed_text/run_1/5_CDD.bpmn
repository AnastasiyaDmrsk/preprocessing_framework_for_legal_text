      <bpmndi:BPMNPlane bpmnElement="Collaboration_1" id="BPMNPlane_1">
         <bpmndi:BPMNShape bpmnElement="Participant_1" id="Participant_1_di" isHorizontal="true">
            <omgdc:Bounds height="600.0" width="2000.0" x="100.0" y="100.0"/>
