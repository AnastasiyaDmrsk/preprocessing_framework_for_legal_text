         <outgoing>Seq_38</outgoing>
      </task>
      <task id="T28" name="adopt implementing acts">
         <incoming>Seq_38</incoming>
         <outgoing>Seq_39</outgoing>
      </task>
      <task id="T29" name="adopt implementing acts specifying significant incident cases">
         <incoming>Seq_39</incoming>
         <outgoing>Seq_40</outgoing>
      </task>
      <task id="T30" name="adopt implementing acts for other entities">
         <incoming>Seq_40</incoming>
         <outgoing>Seq_41</outgoing>
      </task>
      <task id="T31" name="exchange advice AND cooperate with Cooperation Group">
         <incoming>Seq_41</incoming>
         <outgoing>Seq_42</outgoing>
      </task>
      <task id="T32" name="adopt those implementing acts">
         <incoming>Seq_42</incoming>
         <outgoing>Seq_43</outgoing>
      </task>
      <endEvent id="E_End" name="End Process">
         <incoming>Seq_43</incoming>
      </endEvent>

