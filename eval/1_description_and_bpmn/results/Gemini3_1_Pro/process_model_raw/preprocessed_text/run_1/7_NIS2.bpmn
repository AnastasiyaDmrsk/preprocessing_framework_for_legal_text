      <startEvent id="E_Start" name="Start Process">
         <outgoing>Seq_1</outgoing>
      </startEvent>
      <task id="T1" name="notify CSIRT or competent authority">
         <incoming>Seq_1</incoming>
         <outgoing>Seq_2</outgoing>
      </task>
      <task id="T2" name="notify recipients of significant incidents">
         <incoming>Seq_2</incoming>
         <outgoing>Seq_3</outgoing>
      </task>
      <task id="T3" name="report information to determine cross-border impact">
         <incoming>Seq_3</incoming>
         <outgoing>Seq_4</outgoing>
      </task>
      <task id="T4" name="forward notification to CSIRT">
         <incoming>Seq_4</incoming>
         <outgoing>Seq_5</outgoing>
      </task>
      <task id="T5" name="provide single points of contact with relevant information">
         <incoming>Seq_5</incoming>
         <outgoing>Seq_6</outgoing>
      </task>
      <task id="T6" name="communicate measures or remedies to recipients">
         <incoming>Seq_6</incoming>
         <outgoing>Seq_7</outgoing>
      </task>
      <task id="T7" name="inform recipients of significant cyber threat itself">
         <incoming>Seq_7</incoming>
         <outgoing>Seq_8</outgoing>
      </task>

      <parallelGateway id="GW_S1">
         <incoming>Seq_8</incoming>
         <outgoing>Seq_9</outgoing>
         <outgoing>Seq_10</outgoing>
      </parallelGateway>
      <task id="T8" name="consider incident significant (operational disruption / financial loss)">
         <incoming>Seq_9</incoming>
         <outgoing>Seq_11</outgoing>
      </task>
      <task id="T9" name="consider incident significant (material / non-material damage)">
