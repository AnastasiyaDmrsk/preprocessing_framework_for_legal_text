            <omgdi:waypoint x="300.0" y="210.0"/>
         </bpmndi:BPMNEdge>

         <bpmndi:BPMNEdge bpmnElement="seq_gw_t1c" id="seq_gw_t1c_gui">
            <omgdi:waypoint x="225.0" y="300.0"/>
            <omgdi:waypoint x="225.0" y="310.0"/>
            <omgdi:waypoint x="300.0" y="310.0"/>
         </bpmndi:BPMNEdge>

         <bpmndi:BPMNEdge bpmnElement="seq_gw_t1d" id="seq_gw_t1d_gui">
            <omgdi:waypoint x="225.0" y="300.0"/>
            <omgdi:waypoint x="225.0" y="410.0"/>
            <omgdi:waypoint x="300.0" y="410.0"/>
         </bpmndi:BPMNEdge>

         <bpmndi:BPMNEdge bpmnElement="seq_t1a_gwj" id="seq_t1a_gwj_gui">
            <omgdi:waypoint x="400.0" y="110.0"/>
            <omgdi:waypoint x="475.0" y="110.0"/>
            <omgdi:waypoint x="475.0" y="250.0"/>
         </bpmndi:BPMNEdge>

         <bpmndi:BPMNEdge bpmnElement="seq_t1b_gwj" id="seq_t1b_gwj_gui">
            <omgdi:waypoint x="400.0" y="210.0"/>
            <omgdi:waypoint x="475.0" y="210.0"/>
            <omgdi:waypoint x="475.0" y="250.0"/>
         </bpmndi:BPMNEdge>

         <bpmndi:BPMNEdge bpmnElement="seq_t1c_gwj" id="seq_t1c_gwj_gui">
            <omgdi:waypoint x="400.0" y="310.0"/>
            <omgdi:waypoint x="475.0" y="310.0"/>
            <omgdi:waypoint x="475.0" y="300.0"/>
         </bpmndi:BPMNEdge>

         <bpmndi:BPMNEdge bpmnElement="seq_t1d_gwj" id="seq_t1d_gwj_gui">
            <omgdi:waypoint x="400.0" y="410.0"/>
            <omgdi:waypoint x="475.0" y="410.0"/>
            <omgdi:waypoint x="475.0" y="300.0"/>
         </bpmndi:BPMNEdge>

         <bpmndi:BPMNEdge bpmnElement="seq_gwj_t2" id="seq_gwj_t2_gui">
            <omgdi:waypoint x="500.0" y="275.0"/>
            <omgdi:waypoint x="550.0" y="275.0"/>
         </bpmndi:BPMNEdge>

         <bpmndi:BPMNEdge bpmnElement="seq_t2_end" id="seq_t2_end_gui">
            <omgdi:waypoint x="650.0" y="275.0"/>
            <omgdi:waypoint x="700.0" y="275.0"/>
         </bpmndi:BPMNEdge>

         <!-- Sequence Flows: AI Office -->
         <bpmndi:BPMNEdge bpmnElement="seq_ai_start_gw" id="seq_ai_start_gw_gui">
            <omgdi:waypoint x="150.0" y="755.0"/>
            <omgdi:waypoint x="200.0" y="755.0"/>
         </bpmndi:BPMNEdge>

         <bpmndi:BPMNEdge bpmnElement="seq_gw_t3a" id="seq_gw_t3a_gui">
            <omgdi:waypoint x="225.0" y="730.0"/>
            <omgdi:waypoint x="225.0" y="590.0"/>
            <omgdi:waypoint x="300.0" y="590.0"/>
         </bpmndi:BPMNEdge>

         <bpmndi:BPMNEdge bpmnElement="seq_gw_t3b" id="seq_gw_t3b_gui">
            <omgdi:waypoint x="225.0" y="730.0"/>
            <omgdi:waypoint x="225.0" y="690.0"/>
            <omgdi:waypoint x="300.0" y="690.0"/>
         </bpmndi:BPMNEdge>

