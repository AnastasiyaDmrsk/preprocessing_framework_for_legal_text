            <omgdi:waypoint x="300.0" y="790.0"/>
         </bpmndi:BPMNEdge>

         <bpmndi:BPMNEdge bpmnElement="seq_gw_t3d" id="seq_gw_t3d_gui">
            <omgdi:waypoint x="225.0" y="780.0"/>
