            <omgdc:Bounds height="80.0" width="100.0" x="300.0" y="270.0"/>
         </bpmndi:BPMNShape>

         <bpmndi:BPMNShape bpmnElement="task_ms_1d" id="task_ms_1d_gui">
            <omgdc:Bounds height="80.0" width="100.0" x="300.0" y="370.0"/>
         </bpmndi:BPMNShape>

         <bpmndi:BPMNShape bpmnElement="gw_ms_join" id="gw_ms_join_gui">
            <omgdc:Bounds height="50.0" width="50.0" x="450.0" y="250.0"/>
         </bpmndi:BPMNShape>

         <bpmndi:BPMNShape bpmnElement="task_ms_2" id="task_ms_2_gui">
            <omgdc:Bounds height="80.0" width="100.0" x="550.0" y="235.0"/>
         </bpmndi:BPMNShape>

         <bpmndi:BPMNShape bpmnElement="end_ms" id="end_ms_gui">
            <omgdc:Bounds height="30.0" width="30.0" x="700.0" y="260.0"/>
         </bpmndi:BPMNShape>

         <!-- AI Office Elements -->
         <bpmndi:BPMNShape bpmnElement="start_ai" id="start_ai_gui">
            <omgdc:Bounds height="30.0" width="30.0" x="120.0" y="740.0"/>
         </bpmndi:BPMNShape>

         <bpmndi:BPMNShape bpmnElement="gw_ai_split" id="gw_ai_split_gui">
            <omgdc:Bounds height="50.0" width="50.0" x="200.0" y="730.0"/>
         </bpmndi:BPMNShape>

         <bpmndi:BPMNShape bpmnElement="task_ai_3a" id="task_ai_3a_gui">
            <omgdc:Bounds height="80.0" width="100.0" x="300.0" y="550.0"/>
         </bpmndi:BPMNShape>

         <bpmndi:BPMNShape bpmnElement="task_ai_3b" id="task_ai_3b_gui">
            <omgdc:Bounds height="80.0" width="100.0" x="300.0" y="650.0"/>
         </bpmndi:BPMNShape>

         <bpmndi:BPMNShape bpmnElement="task_ai_3c" id="task_ai_3c_gui">
            <omgdc:Bounds height="80.0" width="100.0" x="300.0" y="750.0"/>
         </bpmndi:BPMNShape>

         <bpmndi:BPMNShape bpmnElement="task_ai_3d" id="task_ai_3d_gui">
            <omgdc:Bounds height="80.0" width="100.0" x="300.0" y="850.0"/>
         </bpmndi:BPMNShape>

         <bpmndi:BPMNShape bpmnElement="gw_ai_join" id="gw_ai_join_gui">
            <omgdc:Bounds height="50.0" width="50.0" x="450.0" y="730.0"/>
         </bpmndi:BPMNShape>

         <bpmndi:BPMNShape bpmnElement="end_ai" id="end_ai_gui">
            <omgdc:Bounds height="30.0" width="30.0" x="550.0" y="740.0"/>
         </bpmndi:BPMNShape>

         <!-- Sequence Flows: Member States -->
         <bpmndi:BPMNEdge bpmnElement="seq_ms_start_gw" id="seq_ms_start_gw_gui">
            <omgdi:waypoint x="150.0" y="275.0"/>
            <omgdi:waypoint x="200.0" y="275.0"/>
         </bpmndi:BPMNEdge>

         <bpmndi:BPMNEdge bpmnElement="seq_gw_t1a" id="seq_gw_t1a_gui">
            <omgdi:waypoint x="225.0" y="250.0"/>
            <omgdi:waypoint x="225.0" y="110.0"/>
            <omgdi:waypoint x="300.0" y="110.0"/>
         </bpmndi:BPMNEdge>

         <bpmndi:BPMNEdge bpmnElement="seq_gw_t1b" id="seq_gw_t1b_gui">
            <omgdi:waypoint x="225.0" y="250.0"/>
