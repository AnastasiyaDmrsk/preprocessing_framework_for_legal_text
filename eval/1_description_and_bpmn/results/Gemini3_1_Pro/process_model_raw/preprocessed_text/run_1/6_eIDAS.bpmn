   <collaboration id="Collaboration_1">
      <participant id="Participant_Main" name="Regulation Process" processRef="Process_Main" />
   </collaboration>

   <process id="Process_Main" isExecutable="true" name="Main Process">
      <laneSet id="LaneSet_1">
