      <sequenceFlow id="Flow_SB_5" sourceRef="Task_SB_5" targetRef="Task_SB_6" />
      <sequenceFlow id="Flow_SB_6" sourceRef="Task_SB_6" targetRef="Task_SB_7" />
      <sequenceFlow id="Flow_SB_7" sourceRef="Task_SB_7" targetRef="Task_SB_8" />
      <sequenceFlow id="Flow_SB_8" sourceRef="Task_SB_8" targetRef="Task_SB_9" />
      <sequenceFlow id="Flow_SB_9" sourceRef="Task_SB_9" targetRef="Task_SB_10" />
      <sequenceFlow id="Flow_SB_10" sourceRef="Task_SB_10" targetRef="Task_SB_11" />
      <sequenceFlow id="Flow_SB_11" sourceRef="Task_SB_11" targetRef="Task_SB_12" />
      <sequenceFlow id="Flow_SB_12" sourceRef="Task_SB_12" targetRef="Task_SB_13" />
      <sequenceFlow id="Flow_SB_13" sourceRef="Task_SB_13" targetRef="Task_SB_14" />
      <sequenceFlow id="Flow_SB_14" sourceRef="Task_SB_14" targetRef="Task_SB_15" />
      <sequenceFlow id="Flow_SB_15" sourceRef="Task_SB_15" targetRef="Task_SB_16" />
      <sequenceFlow id="Flow_SB_16" sourceRef="Task_SB_16" targetRef="Task_SB_17" />
      <sequenceFlow id="Flow_SB_17" sourceRef="Task_SB_17" targetRef="Task_SB_18" />
      <sequenceFlow id="Flow_SB_18" sourceRef="Task_SB_18" targetRef="End_SB" />
   </process>

   <process id="Process_COM" isExecutable="false">
      <startEvent id="Start_COM" name="Start" />
      <task id="Task_COM_1" name="make annual report available" />
      <task id="Task_COM_2" name="define formats and procedures for report" />
      <task id="Task_COM_3" name="specify measures" />
      <endEvent id="End_COM" name="End" />
      <sequenceFlow id="Flow_COM_0" sourceRef="Start_COM" targetRef="Task_COM_1" />
      <sequenceFlow id="Flow_COM_1" sourceRef="Task_COM_1" targetRef="Task_COM_2" />
      <sequenceFlow id="Flow_COM_2" sourceRef="Task_COM_2" targetRef="Task_COM_3" />
      <sequenceFlow id="Flow_COM_3" sourceRef="Task_COM_3" targetRef="End_COM" />
   </process>

   <process id="Process_TSP" isExecutable="false">
      <startEvent id="Start_TSP" name="Start" />
      <task id="Task_TSP_1" name="take technical and organisational measures" />
      <task id="Task_TSP_2" name="notify supervisory body of breach" />
      <task id="Task_TSP_3" name="notify natural or legal person of breach" />
      <endEvent id="End_TSP" name="End" />
      <sequenceFlow id="Flow_TSP_0" sourceRef="Start_TSP" targetRef="Task_TSP_1" />
      <sequenceFlow id="Flow_TSP_1" sourceRef="Task_TSP_1" targetRef="Task_TSP_2" />
      <sequenceFlow id="Flow_TSP_2" sourceRef="Task_TSP_2" targetRef="Task_TSP_3" />
      <sequenceFlow id="Flow_TSP_3" sourceRef="Task_TSP_3" targetRef="End_TSP" />
   </process>

