         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape id="shape_T10_suspend" bpmnElement="T10_suspend">
            <omgdc:Bounds x="1550.0" y="360.0" width="100.0" height="80.0" />
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape id="shape_T11_investigate" bpmnElement="T11_investigate">
            <omgdc:Bounds x="1700.0" y="360.0" width="100.0" height="80.0" />
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape id="shape_T12_afford_react" bpmnElement="T12_afford_react">
            <omgdc:Bounds x="1850.0" y="360.0" width="100.0" height="80.0" />
