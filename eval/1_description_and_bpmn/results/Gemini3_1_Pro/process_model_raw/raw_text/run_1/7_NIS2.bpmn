  <collaboration id="Collaboration_1">
    <participant id="Part_1" name="Entities (Essential/Important)" processRef="Proc_1" />
    <participant id="Part_2" name="Trust Service Provider" processRef="Proc_2" />
    <participant id="Part_3" name="CSIRT / Competent Authority" processRef="Proc_3" />
    <participant id="Part_4" name="Single Point of Contact" processRef="Proc_4" />
    <participant id="Part_5" name="ENISA" processRef="Proc_5" />
    <participant id="Part_6" name="Commission" processRef="Proc_6" />
  </collaboration>

  <process id="Proc_1" isExecutable="false">
    <startEvent id="E_S1" name="Start">
      <outgoing>SF_1_0</outgoing>
    </startEvent>
    <task id="T_1_1" name="Notify CSIRT or competent authority">
      <incoming>SF_1_0</incoming>
      <outgoing>SF_1_1</outgoing>
    </task>
    <task id="T_1_2" name="Notify recipients of services">
      <incoming>SF_1_1</incoming>
      <outgoing>SF_1_2</outgoing>
    </task>
    <task id="T_1_3" name="Submit early warning">
      <incoming>SF_1_2</incoming>
      <outgoing>SF_1_3</outgoing>
    </task>
    <task id="T_1_4" name="Submit incident notification">
      <incoming>SF_1_3</incoming>
      <outgoing>SF_1_4</outgoing>
    </task>
    <task id="T_1_5" name="Submit intermediate report">
      <incoming>SF_1_4</incoming>
      <outgoing>SF_1_5</outgoing>
    </task>
    <task id="T_1_6" name="Submit final report">
      <incoming>SF_1_5</incoming>
      <outgoing>SF_1_6</outgoing>
    </task>
    <task id="T_1_7" name="Provide progress report">
      <incoming>SF_1_6</incoming>
      <outgoing>SF_1_7</outgoing>
    </task>
    <endEvent id="E_E1" name="End">
      <incoming>SF_1_7</incoming>
    </endEvent>
    <sequenceFlow id="SF_1_0" sourceRef="E_S1" targetRef="T_1_1" />
    <sequenceFlow id="SF_1_1" sourceRef="T_1_1" targetRef="T_1_2" />
    <sequenceFlow id="SF_1_2" sourceRef="T_1_2" targetRef="T_1_3" />
