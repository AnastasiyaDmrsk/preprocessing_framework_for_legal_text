         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_ms_5" id="task_ms_5_gui">
            <omgdc:Bounds height="80.0" width="100.0" x="840.0" y="160.0" />
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="end_ms" id="end_ms_gui">
