            <omgdi:waypoint x="720.0" y="570.0"/>
            <omgdi:waypoint x="720.0" y="690.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf_aio_t2_join" id="sf_aio_t2_join_gui">
