         <bpmndi:BPMNEdge bpmnElement="sf_ms_t3_join" id="sf_ms_t3_join_gui">
            <omgdi:waypoint x="600.0" y="320.0"/>
            <omgdi:waypoint x="650.0" y="320.0"/>
            <omgdi:waypoint x="650.0" y="260.0"/>
            <omgdi:waypoint x="700.0" y="260.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf_ms_t4_join" id="sf_ms_t4_join_gui">
            <omgdi:waypoint x="600.0" y="420.0"/>
