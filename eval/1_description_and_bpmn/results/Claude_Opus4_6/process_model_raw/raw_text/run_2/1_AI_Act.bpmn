            <omgdi:waypoint x="720.0" y="280.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf_ms_join_end" id="sf_ms_join_end_gui">
            <omgdi:waypoint x="740.0" y="260.0"/>
            <omgdi:waypoint x="830.0" y="260.0"/>
         </bpmndi:BPMNEdge>

         <!-- AI Office Pool -->
         <bpmndi:BPMNShape bpmnElement="participant_aio" id="participant_aio_gui" isHorizontal="true">
            <omgdc:Bounds height="400.0" width="900.0" x="120.0" y="510.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="lane_aio" id="lane_aio_gui" isHorizontal="true">
            <omgdc:Bounds height="400.0" width="870.0" x="150.0" y="510.0"/>
         </bpmndi:BPMNShape>

         <!-- AIO Start -->
         <bpmndi:BPMNShape bpmnElement="start_aio" id="start_aio_gui">
            <omgdc:Bounds height="30.0" width="30.0" x="190.0" y="695.0"/>
         </bpmndi:BPMNShape>

         <!-- AIO Fork Gateway -->
         <bpmndi:BPMNShape bpmnElement="fork_aio" id="fork_aio_gui" isMarkerVisible="true">
            <omgdc:Bounds height="40.0" width="40.0" x="270.0" y="690.0"/>
         </bpmndi:BPMNShape>

         <!-- AIO Tasks -->
         <bpmndi:BPMNShape bpmnElement="task_aio_1" id="task_aio_1_gui">
