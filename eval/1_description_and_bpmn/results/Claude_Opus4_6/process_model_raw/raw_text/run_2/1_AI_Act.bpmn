         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_aio_2" id="task_aio_2_gui">
            <omgdc:Bounds height="80.0" width="200.0" x="400.0" y="630.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_aio_3" id="task_aio_3_gui">
            <omgdc:Bounds height="80.0" width="200.0" x="400.0" y="730.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_aio_4" id="task_aio_4_gui">
            <omgdc:Bounds height="80.0" width="200.0" x="400.0" y="830.0"/>
         </bpmndi:BPMNShape>

         <!-- AIO Join Gateway -->
         <bpmndi:BPMNShape bpmnElement="join_aio" id="join_aio_gui" isMarkerVisible="true">
            <omgdc:Bounds height="40.0" width="40.0" x="700.0" y="690.0"/>
         </bpmndi:BPMNShape>

         <!-- AIO End -->
         <bpmndi:BPMNShape bpmnElement="end_aio" id="end_aio_gui">
            <omgdc:Bounds height="28.0" width="28.0" x="830.0" y="696.0"/>
         </bpmndi:BPMNShape>

         <!-- AIO Sequence Flows -->
         <bpmndi:BPMNEdge bpmnElement="sf_aio_start_fork" id="sf_aio_start_fork_gui">
            <omgdi:waypoint x="220.0" y="710.0"/>
            <omgdi:waypoint x="270.0" y="710.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf_aio_fork_t1" id="sf_aio_fork_t1_gui">
