         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_ms_2" id="task_ms_2_gui">
            <omgdc:Bounds height="80.0" width="200.0" x="400.0" y="180.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_ms_3" id="task_ms_3_gui">
            <omgdc:Bounds height="80.0" width="200.0" x="400.0" y="280.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_ms_4" id="task_ms_4_gui">
            <omgdc:Bounds height="80.0" width="200.0" x="400.0" y="380.0"/>
         </bpmndi:BPMNShape>

         <!-- MS Join Gateway -->
         <bpmndi:BPMNShape bpmnElement="join_ms" id="join_ms_gui" isMarkerVisible="true">
            <omgdc:Bounds height="40.0" width="40.0" x="700.0" y="240.0"/>
         </bpmndi:BPMNShape>

         <!-- MS End -->
         <bpmndi:BPMNShape bpmnElement="end_ms" id="end_ms_gui">
            <omgdc:Bounds height="28.0" width="28.0" x="830.0" y="246.0"/>
         </bpmndi:BPMNShape>

         <!-- MS Sequence Flows -->
         <bpmndi:BPMNEdge bpmnElement="sf_ms_start_fork" id="sf_ms_start_fork_gui">
