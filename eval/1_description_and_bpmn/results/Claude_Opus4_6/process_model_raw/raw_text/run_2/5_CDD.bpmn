<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:signavio="http://www.signavio.com"
             exporter="Signavio Process Editor, http://www.signavio.com"
             exporterVersion="19.2.2"
             expressionLanguage="http://www.w3.org/TR/XPath"
             id="sid-def-001"
             targetNamespace="http://www.signavio.com"
             typeLanguage="http://www.w3.org/2001/XMLSchema"
             xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd">

   <collaboration id="collab-001">
      <participant id="part-obliged" name="Obliged Entity" processRef="proc-obliged">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffff"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
      </participant>
      <participant id="part-fiu" name="FIU" processRef="proc-fiu">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffff"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
      </participant>
      <messageFlow id="mf-str" name="" sourceRef="task-consider-str" targetRef="start-fiu">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
      </messageFlow>
   </collaboration>

   <!-- ============================================================ -->
   <!-- Obliged Entity Process                                        -->
   <!-- ============================================================ -->
   <process id="proc-obliged" isClosed="false" isExecutable="false" name="Obliged Entity" processType="None">
      <laneSet id="ls-obliged">
         <lane id="lane-obliged">
            <extensionElements>
               <signavio:signavioMetaData metaKey="bgcolor" metaValue=""/>
               <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            </extensionElements>
            <flowNodeRef>start-obliged</flowNodeRef>
            <flowNodeRef>task-verify-identity</flowNodeRef>
            <flowNodeRef>gw-cdd-comply</flowNodeRef>
            <flowNodeRef>task-establish-relationship</flowNodeRef>
            <flowNodeRef>task-apply-cdd</flowNodeRef>
            <flowNodeRef>end-obliged-ok</flowNodeRef>
            <flowNodeRef>task-refrain-transaction</flowNodeRef>
            <flowNodeRef>task-terminate-relationship</flowNodeRef>
            <flowNodeRef>task-consider-str</flowNodeRef>
            <flowNodeRef>end-obliged-fail</flowNodeRef>
         </lane>
      </laneSet>

      <startEvent id="start-obliged" name="Customer contact initiated">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffff"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <outgoing>sf-start-to-verify</outgoing>
      </startEvent>

      <task completionQuantity="1" id="task-verify-identity" isForCompensation="false" name="Verify identity of customer and beneficial owner" startQuantity="1">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffcc"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <incoming>sf-start-to-verify</incoming>
         <outgoing>sf-verify-to-gw</outgoing>
      </task>

      <exclusiveGateway id="gw-cdd-comply" name="Able to comply with CDD requirements?" gatewayDirection="Diverging">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffff"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <incoming>sf-verify-to-gw</incoming>
         <outgoing>sf-gw-to-establish</outgoing>
         <outgoing>sf-gw-to-refrain</outgoing>
      </exclusiveGateway>

      <!-- Upper path: CDD requirements met -->
      <task completionQuantity="1" id="task-establish-relationship" isForCompensation="false" name="Establish business relationship or carry out transaction" startQuantity="1">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffcc"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <incoming>sf-gw-to-establish</incoming>
         <outgoing>sf-establish-to-cdd</outgoing>
      </task>

      <task completionQuantity="1" id="task-apply-cdd" isForCompensation="false" name="Apply CDD measures to existing customers on risk-sensitive basis" startQuantity="1">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffcc"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <incoming>sf-establish-to-cdd</incoming>
         <outgoing>sf-cdd-to-end-ok</outgoing>
      </task>

      <endEvent id="end-obliged-ok" name="Relationship established">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffff"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <incoming>sf-cdd-to-end-ok</incoming>
      </endEvent>

      <!-- Lower path: Unable to comply with CDD -->
      <task completionQuantity="1" id="task-refrain-transaction" isForCompensation="false" name="Refrain from carrying out transaction or establishing business relationship" startQuantity="1">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffcc"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <incoming>sf-gw-to-refrain</incoming>
         <outgoing>sf-refrain-to-terminate</outgoing>
      </task>

      <task completionQuantity="1" id="task-terminate-relationship" isForCompensation="false" name="Terminate business relationship" startQuantity="1">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffcc"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <incoming>sf-refrain-to-terminate</incoming>
         <outgoing>sf-terminate-to-str</outgoing>
      </task>

      <task completionQuantity="1" id="task-consider-str" isForCompensation="false" name="Consider making suspicious transaction report to FIU" startQuantity="1">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffcc"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <incoming>sf-terminate-to-str</incoming>
         <outgoing>sf-str-to-end-fail</outgoing>
      </task>

      <endEvent id="end-obliged-fail" name="Relationship terminated">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffff"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <incoming>sf-str-to-end-fail</incoming>
      </endEvent>

      <!-- Sequence Flows -->
      <sequenceFlow id="sf-start-to-verify" name="" sourceRef="start-obliged" targetRef="task-verify-identity"/>
      <sequenceFlow id="sf-verify-to-gw" name="" sourceRef="task-verify-identity" targetRef="gw-cdd-comply"/>
      <sequenceFlow id="sf-gw-to-establish" name="CDD requirements met" sourceRef="gw-cdd-comply" targetRef="task-establish-relationship"/>
      <sequenceFlow id="sf-gw-to-refrain" name="Unable to comply with CDD" sourceRef="gw-cdd-comply" targetRef="task-refrain-transaction"/>
      <sequenceFlow id="sf-establish-to-cdd" name="" sourceRef="task-establish-relationship" targetRef="task-apply-cdd"/>
      <sequenceFlow id="sf-cdd-to-end-ok" name="" sourceRef="task-apply-cdd" targetRef="end-obliged-ok"/>
      <sequenceFlow id="sf-refrain-to-terminate" name="" sourceRef="task-refrain-transaction" targetRef="task-terminate-relationship"/>
      <sequenceFlow id="sf-terminate-to-str" name="" sourceRef="task-terminate-relationship" targetRef="task-consider-str"/>
      <sequenceFlow id="sf-str-to-end-fail" name="" sourceRef="task-consider-str" targetRef="end-obliged-fail"/>
   </process>

   <!-- ============================================================ -->
   <!-- FIU Process (collapsed pool, receives STR)                    -->
   <!-- ============================================================ -->
   <process id="proc-fiu" isClosed="false" isExecutable="false" name="FIU" processType="None">
      <startEvent id="start-fiu" name="Receive suspicious transaction report">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffff"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <messageEventDefinition id="med-fiu-start"/>
      </startEvent>
   </process>

   <!-- ============================================================ -->
   <!-- Diagram (DI) Layout                                           -->
   <!-- ============================================================ -->
   <bpmndi:BPMNDiagram id="diagram-001">
      <bpmndi:BPMNPlane bpmnElement="collab-001" id="plane-001">

         <!-- Obliged Entity Pool -->
         <bpmndi:BPMNShape bpmnElement="part-obliged" id="shape-part-obliged" isHorizontal="true">
            <omgdc:Bounds height="330.0" width="1100.0" x="60.0" y="60.0"/>
            <bpmndi:BPMNLabel>
               <omgdc:Bounds height="80.0" width="12.0" x="65.0" y="185.0"/>
            </bpmndi:BPMNLabel>
         </bpmndi:BPMNShape>

         <!-- Lane inside Obliged Entity -->
         <bpmndi:BPMNShape bpmnElement="lane-obliged" id="shape-lane-obliged" isHorizontal="true">
            <omgdc:Bounds height="330.0" width="1070.0" x="90.0" y="60.0"/>
         </bpmndi:BPMNShape>

         <!-- FIU Pool (collapsed) -->
         <bpmndi:BPMNShape bpmnElement="part-fiu" id="shape-part-fiu" isHorizontal="true">
            <omgdc:Bounds height="60.0" width="1100.0" x="60.0" y="430.0"/>
            <bpmndi:BPMNLabel>
               <omgdc:Bounds height="20.0" width="12.0" x="65.0" y="450.0"/>
            </bpmndi:BPMNLabel>
         </bpmndi:BPMNShape>

         <!-- Start Event -->
         <bpmndi:BPMNShape bpmnElement="start-obliged" id="shape-start-obliged">
            <omgdc:Bounds height="30.0" width="30.0" x="130.0" y="210.0"/>
            <bpmndi:BPMNLabel>
               <omgdc:Bounds height="11.0" width="100.0" x="95.0" y="245.0"/>
            </bpmndi:BPMNLabel>
         </bpmndi:BPMNShape>

         <!-- Task: Verify identity -->
         <bpmndi:BPMNShape bpmnElement="task-verify-identity" id="shape-task-verify-identity">
            <omgdc:Bounds height="80.0" width="140.0" x="210.0" y="185.0"/>
         </bpmndi:BPMNShape>

         <!-- Gateway: CDD comply -->
         <bpmndi:BPMNShape bpmnElement="gw-cdd-comply" id="shape-gw-cdd-comply" isMarkerVisible="true">
            <omgdc:Bounds height="40.0" width="40.0" x="400.0" y="205.0"/>
            <bpmndi:BPMNLabel>
               <omgdc:Bounds height="22.0" width="120.0" x="360.0" y="250.0"/>
            </bpmndi:BPMNLabel>
         </bpmndi:BPMNShape>

         <!-- Upper path: Establish relationship -->
         <bpmndi:BPMNShape bpmnElement="task-establish-relationship" id="shape-task-establish">
            <omgdc:Bounds height="80.0" width="140.0" x="500.0" y="90.0"/>
         </bpmndi:BPMNShape>

         <!-- Upper path: Apply CDD -->
         <bpmndi:BPMNShape bpmnElement="task-apply-cdd" id="shape-task-apply-cdd">
            <omgdc:Bounds height="80.0" width="140.0" x="700.0" y="90.0"/>
         </bpmndi:BPMNShape>

         <!-- Upper path: End OK -->
         <bpmndi:BPMNShape bpmnElement="end-obliged-ok" id="shape-end-obliged-ok">
            <omgdc:Bounds height="28.0" width="28.0" x="896.0" y="116.0"/>
            <bpmndi:BPMNLabel>
               <omgdc:Bounds height="11.0" width="100.0" x="860.0" y="149.0"/>
            </bpmndi:BPMNLabel>
         </bpmndi:BPMNShape>

         <!-- Lower path: Refrain from transaction -->
         <bpmndi:BPMNShape bpmnElement="task-refrain-transaction" id="shape-task-refrain">
            <omgdc:Bounds height="80.0" width="140.0" x="500.0" y="290.0"/>
         </bpmndi:BPMNShape>

         <!-- Lower path: Terminate relationship -->
         <bpmndi:BPMNShape bpmnElement="task-terminate-relationship" id="shape-task-terminate">
            <omgdc:Bounds height="80.0" width="140.0" x="700.0" y="290.0"/>
         </bpmndi:BPMNShape>

         <!-- Lower path: Consider STR -->
         <bpmndi:BPMNShape bpmnElement="task-consider-str" id="shape-task-str">
            <omgdc:Bounds height="80.0" width="140.0" x="900.0" y="290.0"/>
         </bpmndi:BPMNShape>

         <!-- Lower path: End Fail -->
         <bpmndi:BPMNShape bpmnElement="end-obliged-fail" id="shape-end-obliged-fail">
            <omgdc:Bounds height="28.0" width="28.0" x="1090.0" y="316.0"/>
            <bpmndi:BPMNLabel>
               <omgdc:Bounds height="11.0" width="100.0" x="1054.0" y="349.0"/>
            </bpmndi:BPMNLabel>
         </bpmndi:BPMNShape>

         <!-- FIU Start Event (message) -->
         <bpmndi:BPMNShape bpmnElement="start-fiu" id="shape-start-fiu">
            <omgdc:Bounds height="30.0" width="30.0" x="955.0" y="445.0"/>
         </bpmndi:BPMNShape>

         <!-- ========== EDGES ========== -->

         <!-- sf-start-to-verify -->
         <bpmndi:BPMNEdge bpmnElement="sf-start-to-verify" id="edge-sf-start-to-verify">
            <omgdi:waypoint x="160.0" y="225.0"/>
            <omgdi:waypoint x="210.0" y="225.0"/>
         </bpmndi:BPMNEdge>

         <!-- sf-verify-to-gw -->
         <bpmndi:BPMNEdge bpmnElement="sf-verify-to-gw" id="edge-sf-verify-to-gw">
            <omgdi:waypoint x="350.0" y="225.0"/>
            <omgdi:waypoint x="400.0" y="225.0"/>
         </bpmndi:BPMNEdge>

         <!-- sf-gw-to-establish (upper path) -->
         <bpmndi:BPMNEdge bpmnElement="sf-gw-to-establish" id="edge-sf-gw-to-establish">
            <omgdi:waypoint x="420.0" y="205.0"/>
            <omgdi:waypoint x="420.0" y="130.0"/>
            <omgdi:waypoint x="500.0" y="130.0"/>
            <bpmndi:BPMNLabel>
               <omgdc:Bounds height="11.0" width="100.0" x="425.0" y="115.0"/>
            </bpmndi:BPMNLabel>
         </bpmndi:BPMNEdge>

         <!-- sf-gw-to-refrain (lower path) -->
         <bpmndi:BPMNEdge bpmnElement="sf-gw-to-refrain" id="edge-sf-gw-to-refrain">
            <omgdi:waypoint x="420.0" y="245.0"/>
            <omgdi:waypoint x="420.0" y="330.0"/>
            <omgdi:waypoint x="500.0" y="330.0"/>
            <bpmndi:BPMNLabel>
               <omgdc:Bounds height="11.0" width="120.0" x="425.0" y="335.0"/>
            </bpmndi:BPMNLabel>
         </bpmndi:BPMNEdge>

         <!-- sf-establish-to-cdd -->
         <bpmndi:BPMNEdge bpmnElement="sf-establish-to-cdd" id="edge-sf-establish-to-cdd">
            <omgdi:waypoint x="640.0" y="130.0"/>
            <omgdi:waypoint x="700.0" y="130.0"/>
         </bpmndi:BPMNEdge>

         <!-- sf-cdd-to-end-ok -->
         <bpmndi:BPMNEdge bpmnElement="sf-cdd-to-end-ok" id="edge-sf-cdd-to-end-ok">
            <omgdi:waypoint x="840.0" y="130.0"/>
            <omgdi:waypoint x="896.0" y="130.0"/>
         </bpmndi:BPMNEdge>

         <!-- sf-refrain-to-terminate -->
         <bpmndi:BPMNEdge bpmnElement="sf-refrain-to-terminate" id="edge-sf-refrain-to-terminate">
            <omgdi:waypoint x="640.0" y="330.0"/>
            <omgdi:waypoint x="700.0" y="330.0"/>
         </bpmndi:BPMNEdge>

         <!-- sf-terminate-to-str -->
         <bpmndi:BPMNEdge bpmnElement="sf-terminate-to-str" id="edge-sf-terminate-to-str">
            <omgdi:waypoint x="840.0" y="330.0"/>
            <omgdi:waypoint x="900.0" y="330.0"/>
         </bpmndi:BPMNEdge>

         <!-- sf-str-to-end-fail -->
         <bpmndi:BPMNEdge bpmnElement="sf-str-to-end-fail" id="edge-sf-str-to-end-fail">
            <omgdi:waypoint x="1040.0" y="330.0"/>
            <omgdi:waypoint x="1090.0" y="330.0"/>
         </bpmndi:BPMNEdge>

         <!-- Message flow: Consider STR -> FIU -->
         <bpmndi:BPMNEdge bpmnElement="mf-str" id="edge-mf-str">
            <omgdi:waypoint x="970.0" y="370.0"/>
            <omgdi:waypoint x="970.0" y="445.0"/>
         </bpmndi:BPMNEdge>

      </bpmndi:BPMNPlane>

      <bpmndi:BPMNLabelStyle id="labelstyle-small">
         <omgdc:Font isBold="false" isItalic="false" isStrikeThrough="false" isUnderline="false" name="Arial" size="11.0"/>
      </bpmndi:BPMNLabelStyle>
      <bpmndi:BPMNLabelStyle id="labelstyle-normal">
         <omgdc:Font isBold="false" isItalic="false" isStrikeThrough="false" isUnderline="false" name="Arial" size="12.0"/>
      </bpmndi:BPMNLabelStyle>
   </bpmndi:BPMNDiagram>
</definitions>
