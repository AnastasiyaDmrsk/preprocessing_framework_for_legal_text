<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             id="definitions_1"
             targetNamespace="http://www.signavio.com"
             expressionLanguage="http://www.w3.org/TR/XPath"
             typeLanguage="http://www.w3.org/2001/XMLSchema"
             xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd">

   <!-- ============================================================ -->
   <!-- COLLABORATION                                                 -->
   <!-- ============================================================ -->
   <collaboration id="collab_1">
      <participant id="part_processor" name="Processor" processRef="proc_processor"/>
      <participant id="part_controller" name="Controller" processRef="proc_controller"/>
      <participant id="part_sa" name="Supervisory Authority" processRef="proc_sa"/>

      <!-- Processor notifies Controller -->
      <messageFlow id="mf_proc_to_ctrl" name="Breach notification" sourceRef="task_proc_notify_controller" targetRef="start_ctrl_receive"/>
      <!-- Controller notifies Supervisory Authority -->
      <messageFlow id="mf_ctrl_to_sa" name="Breach notification to SA" sourceRef="task_ctrl_notify_sa" targetRef="start_sa_receive"/>
      <!-- SA may require Controller to communicate to data subject -->
      <messageFlow id="mf_sa_to_ctrl" name="Require communication" sourceRef="task_sa_require_comm" targetRef="event_ctrl_receive_sa_request"/>
   </collaboration>

   <!-- ============================================================ -->
   <!-- PROCESSOR PROCESS                                             -->
   <!-- ============================================================ -->
   <process id="proc_processor" name="Processor" isExecutable="false" isClosed="false" processType="None">
      <laneSet id="ls_processor">
         <lane id="lane_processor">
            <flowNodeRef>start_proc</flowNodeRef>
            <flowNodeRef>task_proc_become_aware</flowNodeRef>
            <flowNodeRef>task_proc_notify_controller</flowNodeRef>
            <flowNodeRef>end_proc</flowNodeRef>
         </lane>
      </laneSet>

      <startEvent id="start_proc" name="Personal data breach occurs">
         <outgoing>sf_proc_1</outgoing>
      </startEvent>
      <task id="task_proc_become_aware" name="Become aware of personal data breach">
         <incoming>sf_proc_1</incoming>
         <outgoing>sf_proc_2</outgoing>
      </task>
      <task id="task_proc_notify_controller" name="Notify controller without undue delay">
         <incoming>sf_proc_2</incoming>
         <outgoing>sf_proc_3</outgoing>
      </task>
      <endEvent id="end_proc" name="End">
         <incoming>sf_proc_3</incoming>
      </endEvent>

      <sequenceFlow id="sf_proc_1" sourceRef="start_proc" targetRef="task_proc_become_aware"/>
      <sequenceFlow id="sf_proc_2" sourceRef="task_proc_become_aware" targetRef="task_proc_notify_controller"/>
      <sequenceFlow id="sf_proc_3" sourceRef="task_proc_notify_controller" targetRef="end_proc"/>
   </process>

   <!-- ============================================================ -->
   <!-- CONTROLLER PROCESS                                            -->
   <!-- ============================================================ -->
   <process id="proc_controller" name="Controller" isExecutable="false" isClosed="false" processType="None">
      <laneSet id="ls_controller">
         <lane id="lane_controller">
            <flowNodeRef>start_ctrl_receive</flowNodeRef>
            <flowNodeRef>task_ctrl_assess_risk</flowNodeRef>
            <flowNodeRef>gw_risk_split</flowNodeRef>
            <flowNodeRef>task_ctrl_notify_sa</flowNodeRef>
            <flowNodeRef>gw_risk_merge</flowNodeRef>
            <flowNodeRef>task_ctrl_document</flowNodeRef>
            <flowNodeRef>task_ctrl_assess_high_risk</flowNodeRef>
            <flowNodeRef>gw_high_risk</flowNodeRef>
            <flowNodeRef>task_ctrl_check_exemption</flowNodeRef>
            <flowNodeRef>gw_exemption</flowNodeRef>
            <flowNodeRef>task_ctrl_communicate_ds</flowNodeRef>
            <flowNodeRef>gw_merge_final</flowNodeRef>
            <flowNodeRef>end_ctrl</flowNodeRef>
            <flowNodeRef>event_ctrl_receive_sa_request</flowNodeRef>
         </lane>
      </laneSet>

      <startEvent id="start_ctrl_receive" name="Receive breach notification from processor" isInterrupting="true">
         <outgoing>sf_ctrl_1</outgoing>
         <messageEventDefinition id="med_ctrl_start"/>
      </startEvent>

      <task id="task_ctrl_assess_risk" name="Assess risk to rights and freedoms of natural persons">
         <incoming>sf_ctrl_1</incoming>
         <outgoing>sf_ctrl_2</outgoing>
      </task>

      <exclusiveGateway id="gw_risk_split" name="Breach likely to result in risk?" gatewayDirection="Diverging">
         <incoming>sf_ctrl_2</incoming>
         <outgoing>sf_ctrl_3_yes</outgoing>
         <outgoing>sf_ctrl_3_no</outgoing>
      </exclusiveGateway>

      <task id="task_ctrl_notify_sa" name="Notify personal data breach to supervisory authority within 72 hours">
         <incoming>sf_ctrl_3_yes</incoming>
         <outgoing>sf_ctrl_4</outgoing>
      </task>

      <exclusiveGateway id="gw_risk_merge" name="" gatewayDirection="Converging">
         <incoming>sf_ctrl_4</incoming>
         <incoming>sf_ctrl_3_no</incoming>
         <outgoing>sf_ctrl_5</outgoing>
      </exclusiveGateway>

      <task id="task_ctrl_document" name="Document personal data breach, effects and remedial action">
         <incoming>sf_ctrl_5</incoming>
         <outgoing>sf_ctrl_6</outgoing>
      </task>

      <task id="task_ctrl_assess_high_risk" name="Assess if breach likely to result in high risk to data subjects">
         <incoming>sf_ctrl_6</incoming>
         <outgoing>sf_ctrl_7</outgoing>
      </task>

      <exclusiveGateway id="gw_high_risk" name="High risk to data subjects?" gatewayDirection="Diverging">
         <incoming>sf_ctrl_7</incoming>
         <outgoing>sf_ctrl_8_yes</outgoing>
         <outgoing>sf_ctrl_8_no</outgoing>
      </exclusiveGateway>

      <task id="task_ctrl_check_exemption" name="Check if exemption conditions are met (Art. 34(3))">
         <incoming>sf_ctrl_8_yes</incoming>
         <outgoing>sf_ctrl_9</outgoing>
      </task>

      <exclusiveGateway id="gw_exemption" name="Exemption conditions met?" gatewayDirection="Diverging">
         <incoming>sf_ctrl_9</incoming>
         <outgoing>sf_ctrl_10_yes</outgoing>
         <outgoing>sf_ctrl_10_no</outgoing>
      </exclusiveGateway>

      <task id="task_ctrl_communicate_ds" name="Communicate personal data breach to data subject without undue delay">
         <incoming>sf_ctrl_10_no</incoming>
         <incoming>sf_ctrl_sa_request</incoming>
         <outgoing>sf_ctrl_11</outgoing>
      </task>

      <intermediateCatchEvent id="event_ctrl_receive_sa_request" name="SA requires communication to data subject">
         <outgoing>sf_ctrl_sa_request</outgoing>
         <messageEventDefinition id="med_ctrl_sa_req"/>
      </intermediateCatchEvent>

      <exclusiveGateway id="gw_merge_final" name="" gatewayDirection="Converging">
         <incoming>sf_ctrl_8_no</incoming>
         <incoming>sf_ctrl_10_yes</incoming>
         <incoming>sf_ctrl_11</incoming>
         <outgoing>sf_ctrl_end</outgoing>
      </exclusiveGateway>

      <endEvent id="end_ctrl" name="End">
         <incoming>sf_ctrl_end</incoming>
      </endEvent>

      <sequenceFlow id="sf_ctrl_1" sourceRef="start_ctrl_receive" targetRef="task_ctrl_assess_risk"/>
      <sequenceFlow id="sf_ctrl_2" sourceRef="task_ctrl_assess_risk" targetRef="gw_risk_split"/>
      <sequenceFlow id="sf_ctrl_3_yes" name="Yes" sourceRef="gw_risk_split" targetRef="task_ctrl_notify_sa"/>
      <sequenceFlow id="sf_ctrl_3_no" name="No" sourceRef="gw_risk_split" targetRef="gw_risk_merge"/>
      <sequenceFlow id="sf_ctrl_4" sourceRef="task_ctrl_notify_sa" targetRef="gw_risk_merge"/>
      <sequenceFlow id="sf_ctrl_5" sourceRef="gw_risk_merge" targetRef="task_ctrl_document"/>
      <sequenceFlow id="sf_ctrl_6" sourceRef="task_ctrl_document" targetRef="task_ctrl_assess_high_risk"/>
      <sequenceFlow id="sf_ctrl_7" sourceRef="task_ctrl_assess_high_risk" targetRef="gw_high_risk"/>
      <sequenceFlow id="sf_ctrl_8_yes" name="Yes" sourceRef="gw_high_risk" targetRef="task_ctrl_check_exemption"/>
      <sequenceFlow id="sf_ctrl_8_no" name="No" sourceRef="gw_high_risk" targetRef="gw_merge_final"/>
      <sequenceFlow id="sf_ctrl_9" sourceRef="task_ctrl_check_exemption" targetRef="gw_exemption"/>
      <sequenceFlow id="sf_ctrl_10_yes" name="Yes" sourceRef="gw_exemption" targetRef="gw_merge_final"/>
      <sequenceFlow id="sf_ctrl_10_no" name="No" sourceRef="gw_exemption" targetRef="task_ctrl_communicate_ds"/>
      <sequenceFlow id="sf_ctrl_11" sourceRef="task_ctrl_communicate_ds" targetRef="gw_merge_final"/>
      <sequenceFlow id="sf_ctrl_sa_request" sourceRef="event_ctrl_receive_sa_request" targetRef="task_ctrl_communicate_ds"/>
      <sequenceFlow id="sf_ctrl_end" sourceRef="gw_merge_final" targetRef="end_ctrl"/>
   </process>

   <!-- ============================================================ -->
   <!-- SUPERVISORY AUTHORITY PROCESS                                 -->
   <!-- ============================================================ -->
   <process id="proc_sa" name="Supervisory Authority" isExecutable="false" isClosed="false" processType="None">
      <laneSet id="ls_sa">
         <lane id="lane_sa">
            <flowNodeRef>start_sa_receive</flowNodeRef>
            <flowNodeRef>task_sa_verify</flowNodeRef>
            <flowNodeRef>gw_sa_require</flowNodeRef>
            <flowNodeRef>task_sa_require_comm</flowNodeRef>
            <flowNodeRef>gw_sa_merge</flowNodeRef>
            <flowNodeRef>end_sa</flowNodeRef>
         </lane>
      </laneSet>

      <startEvent id="start_sa_receive" name="Receive breach notification" isInterrupting="true">
         <outgoing>sf_sa_1</outgoing>
         <messageEventDefinition id="med_sa_start"/>
      </startEvent>

      <task id="task_sa_verify" name="Verify compliance with Art. 33">
         <incoming>sf_sa_1</incoming>
         <outgoing>sf_sa_2</outgoing>
      </task>

      <exclusiveGateway id="gw_sa_require" name="Controller has not communicated to data subject and high risk exists?" gatewayDirection="Diverging">
         <incoming>sf_sa_2</incoming>
         <outgoing>sf_sa_3_yes</outgoing>
         <outgoing>sf_sa_3_no</outgoing>
      </exclusiveGateway>

      <task id="task_sa_require_comm" name="Require controller to communicate breach to data subject">
         <incoming>sf_sa_3_yes</incoming>
         <outgoing>sf_sa_4</outgoing>
      </task>

      <exclusiveGateway id="gw_sa_merge" name="" gatewayDirection="Converging">
         <incoming>sf_sa_3_no</incoming>
         <incoming>sf_sa_4</incoming>
         <outgoing>sf_sa_end</outgoing>
      </exclusiveGateway>

      <endEvent id="end_sa" name="End">
         <incoming>sf_sa_end</incoming>
      </endEvent>

      <sequenceFlow id="sf_sa_1" sourceRef="start_sa_receive" targetRef="task_sa_verify"/>
      <sequenceFlow id="sf_sa_2" sourceRef="task_sa_verify" targetRef="gw_sa_require"/>
      <sequenceFlow id="sf_sa_3_yes" name="Yes" sourceRef="gw_sa_require" targetRef="task_sa_require_comm"/>
      <sequenceFlow id="sf_sa_3_no" name="No" sourceRef="gw_sa_require" targetRef="gw_sa_merge"/>
      <sequenceFlow id="sf_sa_4" sourceRef="task_sa_require_comm" targetRef="gw_sa_merge"/>
      <sequenceFlow id="sf_sa_end" sourceRef="gw_sa_merge" targetRef="end_sa"/>
   </process>

   <!-- ============================================================ -->
   <!-- DIAGRAM (DI)                                                  -->
   <!-- ============================================================ -->
   <bpmndi:BPMNDiagram id="diagram_1">
      <bpmndi:BPMNPlane bpmnElement="collab_1" id="plane_1">

         <!-- ======= PROCESSOR POOL (top, y=60) ======= -->
         <bpmndi:BPMNShape bpmnElement="part_processor" id="shape_part_processor" isHorizontal="true">
            <omgdc:Bounds x="120" y="60" width="620" height="130"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="lane_processor" id="shape_lane_processor" isHorizontal="true">
            <omgdc:Bounds x="150" y="60" width="590" height="130"/>
         </bpmndi:BPMNShape>

         <bpmndi:BPMNShape bpmnElement="start_proc" id="shape_start_proc">
            <omgdc:Bounds x="195" y="107" width="36" height="36"/>
            <bpmndi:BPMNLabel><omgdc:Bounds x="170" y="148" width="86" height="28"/></bpmndi:BPMNLabel>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_proc_become_aware" id="shape_task_proc_become_aware">
            <omgdc:Bounds x="290" y="85" width="140" height="80"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_proc_notify_controller" id="shape_task_proc_notify_controller">
            <omgdc:Bounds x="490" y="85" width="140" height="80"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="end_proc" id="shape_end_proc">
            <omgdc:Bounds x="680" y="111" width="28" height="28"/>
            <bpmndi:BPMNLabel><omgdc:Bounds x="685" y="143" width="18" height="14"/></bpmndi:BPMNLabel>
         </bpmndi:BPMNShape>

         <bpmndi:BPMNEdge bpmnElement="sf_proc_1" id="edge_sf_proc_1">
            <omgdi:waypoint x="231" y="125"/>
            <omgdi:waypoint x="290" y="125"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf_proc_2" id="edge_sf_proc_2">
            <omgdi:waypoint x="430" y="125"/>
            <omgdi:waypoint x="490" y="125"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf_proc_3" id="edge_sf_proc_3">
            <omgdi:waypoint x="630" y="125"/>
            <omgdi:waypoint x="680" y="125"/>
         </bpmndi:BPMNEdge>

         <!-- ======= CONTROLLER POOL (middle, y=230) ======= -->
         <bpmndi:BPMNShape bpmnElement="part_controller" id="shape_part_controller" isHorizontal="true">
            <omgdc:Bounds x="120" y="230" width="1380" height="350"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="lane_controller" id="shape_lane_controller" isHorizontal="true">
            <omgdc:Bounds x="150" y="230" width="1350" height="350"/>
         </bpmndi:BPMNShape>

         <bpmndi:BPMNShape bpmnElement="start_ctrl_receive" id="shape_start_ctrl_receive">
            <omgdc:Bounds x="195" y="347" width="36" height="36"/>
            <bpmndi:BPMNLabel><omgdc:Bounds x="168" y="388" width="90" height="28"/></bpmndi:BPMNLabel>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_ctrl_assess_risk" id="shape_task_ctrl_assess_risk">
            <omgdc:Bounds x="280" y="325" width="140" height="80"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="gw_risk_split" id="shape_gw_risk_split" isMarkerVisible="true">
            <omgdc:Bounds x="465" y="345" width="40" height="40"/>
            <bpmndi:BPMNLabel><omgdc:Bounds x="445" y="390" width="80" height="28"/></bpmndi:BPMNLabel>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_ctrl_notify_sa" id="shape_task_ctrl_notify_sa">
            <omgdc:Bounds x="555" y="265" width="140" height="80"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="gw_risk_merge" id="shape_gw_risk_merge" isMarkerVisible="true">
            <omgdc:Bounds x="735" y="345" width="40" height="40"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_ctrl_document" id="shape_task_ctrl_document">
            <omgdc:Bounds x="820" y="325" width="140" height="80"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_ctrl_assess_high_risk" id="shape_task_ctrl_assess_high_risk">
            <omgdc:Bounds x="1000" y="325" width="140" height="80"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="gw_high_risk" id="shape_gw_high_risk" isMarkerVisible="true">
            <omgdc:Bounds x="1180" y="345" width="40" height="40"/>
            <bpmndi:BPMNLabel><omgdc:Bounds x="1160" y="390" width="80" height="28"/></bpmndi:BPMNLabel>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_ctrl_check_exemption" id="shape_task_ctrl_check_exemption">
            <omgdc:Bounds x="1160" y="245" width="140" height="80"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="gw_exemption" id="shape_gw_exemption" isMarkerVisible="true">
            <omgdc:Bounds x="1340" y="265" width="40" height="40"/>
            <bpmndi:BPMNLabel><omgdc:Bounds x="1385" y="272" width="80" height="28"/></bpmndi:BPMNLabel>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_ctrl_communicate_ds" id="shape_task_ctrl_communicate_ds">
            <omgdc:Bounds x="1290" y="460" width="160" height="80"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="event_ctrl_receive_sa_request" id="shape_event_ctrl_receive_sa_request">
            <omgdc:Bounds x="1195" y="482" width="36" height="36"/>
            <bpmndi:BPMNLabel><omgdc:Bounds x="1160" y="522" width="106" height="28"/></bpmndi:BPMNLabel>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="gw_merge_final" id="shape_gw_merge_final" isMarkerVisible="true">
            <omgdc:Bounds x="1420" y="345" width="40" height="40"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="end_ctrl" id="shape_end_ctrl">
            <omgdc:Bounds x="1476" y="351" width="28" height="28"/>
            <bpmndi:BPMNLabel><omgdc:Bounds x="1481" y="383" width="18" height="14"/></bpmndi:BPMNLabel>
         </bpmndi:BPMNShape>

         <!-- Controller sequence flow edges -->
         <bpmndi:BPMNEdge bpmnElement="sf_ctrl_1" id="edge_sf_ctrl_1">
            <omgdi:waypoint x="231" y="365"/>
            <omgdi:waypoint x="280" y="365"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf_ctrl_2" id="edge_sf_ctrl_2">
            <omgdi:waypoint x="420" y="365"/>
            <omgdi:waypoint x="465" y="365"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf_ctrl_3_yes" id="edge_sf_ctrl_3_yes">
            <omgdi:waypoint x="485" y="345"/>
            <omgdi:waypoint x="485" y="305"/>
            <omgdi:waypoint x="555" y="305"/>
            <bpmndi:BPMNLabel><omgdc:Bounds x="490" y="320" width="20" height="14"/></bpmndi:BPMNLabel>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf_ctrl_3_no" id="edge_sf_ctrl_3_no">
            <omgdi:waypoint x="505" y="365"/>
            <omgdi:waypoint x="735" y="365"/>
            <bpmndi:BPMNLabel><omgdc:Bounds x="600" y="348" width="20" height="14"/></bpmndi:BPMNLabel>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf_ctrl_4" id="edge_sf_ctrl_4">
            <omgdi:waypoint x="695" y="305"/>
            <omgdi:waypoint x="755" y="305"/>
            <omgdi:waypoint x="755" y="345"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf_ctrl_5" id="edge_sf_ctrl_5">
            <omgdi:waypoint x="775" y="365"/>
            <omgdi:waypoint x="820" y="365"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf_ctrl_6" id="edge_sf_ctrl_6">
            <omgdi:waypoint x="960" y="365"/>
            <omgdi:waypoint x="1000" y="365"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf_ctrl_7" id="edge_sf_ctrl_7">
            <omgdi:waypoint x="1140" y="365"/>
            <omgdi:waypoint x="1180" y="365"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf_ctrl_8_yes" id="edge_sf_ctrl_8_yes">
            <omgdi:waypoint x="1200" y="345"/>
            <omgdi:waypoint x="1200" y="325"/>
            <bpmndi:BPMNLabel><omgdc:Bounds x="1205" y="330" width="20" height="14"/></bpmndi:BPMNLabel>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf_ctrl_8_no" id="edge_sf_ctrl_8_no">
            <omgdi:waypoint x="1220" y="365"/>
            <omgdi:waypoint x="1420" y="365"/>
            <bpmndi:BPMNLabel><omgdc:Bounds x="1310" y="348" width="20" height="14"/></bpmndi:BPMNLabel>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf_ctrl_9" id="edge_sf_ctrl_9">
            <omgdi:waypoint x="1300" y="285"/>
            <omgdi:waypoint x="1340" y="285"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf_ctrl_10_yes" id="edge_sf_ctrl_10_yes">
            <omgdi:waypoint x="1360" y="265"/>
            <omgdi:waypoint x="1360" y="240"/>
            <omgdi:waypoint x="1440" y="240"/>
            <omgdi:waypoint x="1440" y="345"/>
            <bpmndi:BPMNLabel><omgdc:Bounds x="1365" y="243" width="20" height="14"/></bpmndi:BPMNLabel>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf_ctrl_10_no" id="edge_sf_ctrl_10_no">
            <omgdi:waypoint x="1360" y="305"/>
            <omgdi:waypoint x="1360" y="460"/>
            <bpmndi:BPMNLabel><omgdc:Bounds x="1365" y="380" width="20" height="14"/></bpmndi:BPMNLabel>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf_ctrl_11" id="edge_sf_ctrl_11">
            <omgdi:waypoint x="1450" y="500"/>
            <omgdi:waypoint x="1470" y="500"/>
            <omgdi:waypoint x="1470" y="365"/>
            <omgdi:waypoint x="1460" y="365"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf_ctrl_sa_request" id="edge_sf_ctrl_sa_request">
            <omgdi:waypoint x="1231" y="500"/>
            <omgdi:waypoint x="1290" y="500"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf_ctrl_end" id="edge_sf_ctrl_end">
            <omgdi:waypoint x="1460" y="365"/>
            <omgdi:waypoint x="1476" y="365"/>
         </bpmndi:BPMNEdge>

         <!-- ======= SUPERVISORY AUTHORITY POOL (bottom, y=620) ======= -->
         <bpmndi:BPMNShape bpmnElement="part_sa" id="shape_part_sa" isHorizontal="true">
            <omgdc:Bounds x="120" y="620" width="1100" height="140"/>
         </bpmndi:BPMNShape>
