<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             id="definitions_1"
             targetNamespace="http://www.omg.org/spec/BPMN/20100524/MODEL"
             exporter="Claude"
             exporterVersion="1.0"
             typeLanguage="http://www.w3.org/2001/XMLSchema"
             expressionLanguage="http://www.w3.org/TR/XPath"
             xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd">

   <!-- ============================================================ -->
   <!-- COLLABORATION                                                 -->
   <!-- ============================================================ -->
   <collaboration id="collab_1">
      <participant id="pool_MS" name="Member States" processRef="proc_MS"/>
      <participant id="pool_SB" name="Supervisory Body" processRef="proc_SB"/>
      <participant id="pool_TSP" name="Trust Service Providers" processRef="proc_TSP"/>
      <participant id="pool_COM" name="Commission" processRef="proc_COM"/>

      <!-- Message flows between pools -->
      <messageFlow id="mf_MS_notify_COM" name="Notify names and addresses" sourceRef="task_MS_notify" targetRef="start_COM_receive"/>
      <messageFlow id="mf_TSP_notify_SB" name="Breach notification" sourceRef="task_TSP_notify_SB" targetRef="event_SB_receive_breach"/>
      <messageFlow id="mf_SB_report_COM" name="Annual report" sourceRef="task_SB_submit_report" targetRef="event_COM_receive_report"/>
      <messageFlow id="mf_MS_designate_SB" name="Designation" sourceRef="task_MS_designate" targetRef="start_SB_designated"/>
      <messageFlow id="mf_SB_require_TSP" name="Require remedy" sourceRef="task_SB_require_remedy" targetRef="event_TSP_receive_requirement"/>
   </collaboration>

   <!-- ============================================================ -->
   <!-- PROCESS: Member States                                        -->
   <!-- ============================================================ -->
   <process id="proc_MS" name="Member States" isExecutable="false" isClosed="false" processType="None">
      <laneSet id="ls_MS">
         <lane id="lane_MS" name="">
            <flowNodeRef>start_MS</flowNodeRef>
            <flowNodeRef>task_MS_designate</flowNodeRef>
            <flowNodeRef>task_MS_notify</flowNodeRef>
            <flowNodeRef>end_MS</flowNodeRef>
         </lane>
      </laneSet>
      <startEvent id="start_MS" name="Start">
         <outgoing>sf_MS_1</outgoing>
      </startEvent>
      <task id="task_MS_designate" name="Designate supervisory body">
         <incoming>sf_MS_1</incoming>
         <outgoing>sf_MS_2</outgoing>
      </task>
      <task id="task_MS_notify" name="Notify Commission of names and addresses">
         <incoming>sf_MS_2</incoming>
         <outgoing>sf_MS_3</outgoing>
      </task>
      <endEvent id="end_MS" name="End">
         <incoming>sf_MS_3</incoming>
      </endEvent>
      <sequenceFlow id="sf_MS_1" sourceRef="start_MS" targetRef="task_MS_designate"/>
      <sequenceFlow id="sf_MS_2" sourceRef="task_MS_designate" targetRef="task_MS_notify"/>
      <sequenceFlow id="sf_MS_3" sourceRef="task_MS_notify" targetRef="end_MS"/>
   </process>

   <!-- ============================================================ -->
   <!-- PROCESS: Supervisory Body                                     -->
   <!-- ============================================================ -->
   <process id="proc_SB" name="Supervisory Body" isExecutable="false" isClosed="false" processType="None">
      <laneSet id="ls_SB">
         <lane id="lane_SB_supervision" name="Ongoing Supervision">
            <flowNodeRef>start_SB_designated</flowNodeRef>
            <flowNodeRef>task_SB_supervise_qualified</flowNodeRef>
            <flowNodeRef>task_SB_take_action_nonqualified</flowNodeRef>
            <flowNodeRef>task_SB_analyse_reports</flowNodeRef>
            <flowNodeRef>task_SB_carry_out_audits</flowNodeRef>
            <flowNodeRef>task_SB_grant_status</flowNodeRef>
            <flowNodeRef>task_SB_cooperate_DPA</flowNodeRef>
            <flowNodeRef>task_SB_verify_termination</flowNodeRef>
            <flowNodeRef>task_SB_require_remedy</flowNodeRef>
            <flowNodeRef>task_SB_submit_report</flowNodeRef>
            <flowNodeRef>end_SB_supervision</flowNodeRef>
         </lane>
         <lane id="lane_SB_breach" name="Breach Handling">
            <flowNodeRef>event_SB_receive_breach</flowNodeRef>
            <flowNodeRef>task_SB_inform_other_SBs</flowNodeRef>
            <flowNodeRef>task_SB_inform_public</flowNodeRef>
            <flowNodeRef>task_SB_provide_ENISA_summary</flowNodeRef>
            <flowNodeRef>end_SB_breach</flowNodeRef>
         </lane>
      </laneSet>

      <!-- Supervision lane -->
      <startEvent id="start_SB_designated" name="Designated by Member State">
         <outgoing>sf_SB_1</outgoing>
         <messageEventDefinition id="med_SB_designated"/>
      </startEvent>
      <task id="task_SB_supervise_qualified" name="Supervise qualified trust service providers">
         <incoming>sf_SB_1</incoming>
         <outgoing>sf_SB_2</outgoing>
      </task>
      <task id="task_SB_take_action_nonqualified" name="Take action on non-qualified trust service providers">
         <incoming>sf_SB_2</incoming>
         <outgoing>sf_SB_3</outgoing>
      </task>
      <task id="task_SB_analyse_reports" name="Analyse conformity assessment reports">
         <incoming>sf_SB_3</incoming>
         <outgoing>sf_SB_4</outgoing>
      </task>
      <task id="task_SB_carry_out_audits" name="Carry out audits or request conformity assessment">
         <incoming>sf_SB_4</incoming>
         <outgoing>sf_SB_5</outgoing>
      </task>
      <task id="task_SB_grant_status" name="Grant or withdraw qualified status">
         <incoming>sf_SB_5</incoming>
         <outgoing>sf_SB_6</outgoing>
      </task>
      <task id="task_SB_cooperate_DPA" name="Cooperate with data protection authorities">
         <incoming>sf_SB_6</incoming>
         <outgoing>sf_SB_7</outgoing>
      </task>
      <task id="task_SB_verify_termination" name="Verify termination plans">
         <incoming>sf_SB_7</incoming>
         <outgoing>sf_SB_8</outgoing>
      </task>
      <task id="task_SB_require_remedy" name="Require trust service providers to remedy failures">
         <incoming>sf_SB_8</incoming>
         <outgoing>sf_SB_9</outgoing>
      </task>
      <task id="task_SB_submit_report" name="Submit annual report to Commission">
         <incoming>sf_SB_9</incoming>
         <outgoing>sf_SB_10</outgoing>
      </task>
      <endEvent id="end_SB_supervision" name="End">
         <incoming>sf_SB_10</incoming>
      </endEvent>

      <!-- Breach handling lane -->
      <startEvent id="event_SB_receive_breach" name="Receive breach notification">
         <outgoing>sf_SB_B1</outgoing>
         <messageEventDefinition id="med_SB_breach"/>
      </startEvent>
      <task id="task_SB_inform_other_SBs" name="Inform other supervisory bodies and ENISA">
         <incoming>sf_SB_B1</incoming>
         <outgoing>sf_SB_B2</outgoing>
      </task>
      <task id="task_SB_inform_public" name="Inform the public or require provider to do so">
         <incoming>sf_SB_B2</incoming>
         <outgoing>sf_SB_B3</outgoing>
      </task>
      <task id="task_SB_provide_ENISA_summary" name="Provide ENISA yearly summary of breach notifications">
         <incoming>sf_SB_B3</incoming>
         <outgoing>sf_SB_B4</outgoing>
      </task>
      <endEvent id="end_SB_breach" name="End">
         <incoming>sf_SB_B4</incoming>
      </endEvent>

      <!-- Supervision sequence flows -->
      <sequenceFlow id="sf_SB_1" sourceRef="start_SB_designated" targetRef="task_SB_supervise_qualified"/>
      <sequenceFlow id="sf_SB_2" sourceRef="task_SB_supervise_qualified" targetRef="task_SB_take_action_nonqualified"/>
      <sequenceFlow id="sf_SB_3" sourceRef="task_SB_take_action_nonqualified" targetRef="task_SB_analyse_reports"/>
      <sequenceFlow id="sf_SB_4" sourceRef="task_SB_analyse_reports" targetRef="task_SB_carry_out_audits"/>
      <sequenceFlow id="sf_SB_5" sourceRef="task_SB_carry_out_audits" targetRef="task_SB_grant_status"/>
      <sequenceFlow id="sf_SB_6" sourceRef="task_SB_grant_status" targetRef="task_SB_cooperate_DPA"/>
      <sequenceFlow id="sf_SB_7" sourceRef="task_SB_cooperate_DPA" targetRef="task_SB_verify_termination"/>
      <sequenceFlow id="sf_SB_8" sourceRef="task_SB_verify_termination" targetRef="task_SB_require_remedy"/>
      <sequenceFlow id="sf_SB_9" sourceRef="task_SB_require_remedy" targetRef="task_SB_submit_report"/>
      <sequenceFlow id="sf_SB_10" sourceRef="task_SB_submit_report" targetRef="end_SB_supervision"/>

      <!-- Breach sequence flows -->
      <sequenceFlow id="sf_SB_B1" sourceRef="event_SB_receive_breach" targetRef="task_SB_inform_other_SBs"/>
      <sequenceFlow id="sf_SB_B2" sourceRef="task_SB_inform_other_SBs" targetRef="task_SB_inform_public"/>
      <sequenceFlow id="sf_SB_B3" sourceRef="task_SB_inform_public" targetRef="task_SB_provide_ENISA_summary"/>
      <sequenceFlow id="sf_SB_B4" sourceRef="task_SB_provide_ENISA_summary" targetRef="end_SB_breach"/>
   </process>

   <!-- ============================================================ -->
   <!-- PROCESS: Trust Service Providers                              -->
   <!-- ============================================================ -->
   <process id="proc_TSP" name="Trust Service Providers" isExecutable="false" isClosed="false" processType="None">
      <laneSet id="ls_TSP">
         <lane id="lane_TSP" name="">
            <flowNodeRef>start_TSP</flowNodeRef>
            <flowNodeRef>task_TSP_take_measures</flowNodeRef>
            <flowNodeRef>gw_TSP_breach</flowNodeRef>
            <flowNodeRef>task_TSP_notify_SB</flowNodeRef>
            <flowNodeRef>task_TSP_notify_person</flowNodeRef>
            <flowNodeRef>end_TSP_breach</flowNodeRef>
            <flowNodeRef>event_TSP_receive_requirement</flowNodeRef>
            <flowNodeRef>task_TSP_remedy_failures</flowNodeRef>
            <flowNodeRef>gw_TSP_merge</flowNodeRef>
            <flowNodeRef>end_TSP</flowNodeRef>
         </lane>
      </laneSet>
      <startEvent id="start_TSP" name="Start">
         <outgoing>sf_TSP_1</outgoing>
      </startEvent>
      <task id="task_TSP_take_measures" name="Take appropriate technical and organisational measures">
         <incoming>sf_TSP_1</incoming>
         <outgoing>sf_TSP_2</outgoing>
      </task>
      <exclusiveGateway id="gw_TSP_breach" name="Breach of security occurred?" gatewayDirection="Diverging">
         <incoming>sf_TSP_2</incoming>
         <outgoing>sf_TSP_3</outgoing>
         <outgoing>sf_TSP_no_breach</outgoing>
      </exclusiveGateway>
      <task id="task_TSP_notify_SB" name="Notify supervisory body of breach within 24 hours">
         <incoming>sf_TSP_3</incoming>
         <outgoing>sf_TSP_4</outgoing>
      </task>
      <task id="task_TSP_notify_person" name="Notify affected natural or legal person of breach">
         <incoming>sf_TSP_4</incoming>
         <outgoing>sf_TSP_5</outgoing>
      </task>
      <endEvent id="end_TSP_breach" name="End">
         <incoming>sf_TSP_5</incoming>
      </endEvent>
      <startEvent id="event_TSP_receive_requirement" name="Receive requirement to remedy">
         <outgoing>sf_TSP_R1</outgoing>
         <messageEventDefinition id="med_TSP_requirement"/>
      </startEvent>
      <task id="task_TSP_remedy_failures" name="Remedy failures to fulfil requirements">
         <incoming>sf_TSP_R1</incoming>
         <outgoing>sf_TSP_R2</outgoing>
      </task>
      <endEvent id="end_TSP" name="End">
         <incoming>sf_TSP_no_breach</incoming>
         <incoming>sf_TSP_R2</incoming>
      </endEvent>

      <sequenceFlow id="sf_TSP_1" sourceRef="start_TSP" targetRef="task_TSP_take_measures"/>
      <sequenceFlow id="sf_TSP_2" sourceRef="task_TSP_take_measures" targetRef="gw_TSP_breach"/>
      <sequenceFlow id="sf_TSP_3" name="Yes" sourceRef="gw_TSP_breach" targetRef="task_TSP_notify_SB"/>
      <sequenceFlow id="sf_TSP_no_breach" name="No" sourceRef="gw_TSP_breach" targetRef="end_TSP"/>
      <sequenceFlow id="sf_TSP_4" sourceRef="task_TSP_notify_SB" targetRef="task_TSP_notify_person"/>
      <sequenceFlow id="sf_TSP_5" sourceRef="task_TSP_notify_person" targetRef="end_TSP_breach"/>
      <sequenceFlow id="sf_TSP_R1" sourceRef="event_TSP_receive_requirement" targetRef="task_TSP_remedy_failures"/>
      <sequenceFlow id="sf_TSP_R2" sourceRef="task_TSP_remedy_failures" targetRef="end_TSP"/>
   </process>

   <!-- ============================================================ -->
   <!-- PROCESS: Commission                                           -->
   <!-- ============================================================ -->
   <process id="proc_COM" name="Commission" isExecutable="false" isClosed="false" processType="None">
      <laneSet id="ls_COM">
         <lane id="lane_COM" name="">
            <flowNodeRef>start_COM_receive</flowNodeRef>
            <flowNodeRef>end_COM_notified</flowNodeRef>
            <flowNodeRef>event_COM_receive_report</flowNodeRef>
            <flowNodeRef>task_COM_make_available</flowNodeRef>
            <flowNodeRef>task_COM_define_formats</flowNodeRef>
            <flowNodeRef>end_COM</flowNodeRef>
         </lane>
      </laneSet>
      <startEvent id="start_COM_receive" name="Receive notification from Member States">
         <outgoing>sf_COM_0</outgoing>
         <messageEventDefinition id="med_COM_receive"/>
      </startEvent>
      <endEvent id="end_COM_notified" name="End">
         <incoming>sf_COM_0</incoming>
      </endEvent>
      <startEvent id="event_COM_receive_report" name="Receive annual report">
         <outgoing>sf_COM_1</outgoing>
         <messageEventDefinition id="med_COM_report"/>
      </startEvent>
      <task id="task_COM_make_available" name="Make annual report available to Member States">
         <incoming>sf_COM_1</incoming>
         <outgoing>sf_COM_2</outgoing>
      </task>
      <task id="task_COM_define_formats" name="Define formats and procedures by implementing acts">
         <incoming>sf_COM_2</incoming>
         <outgoing>sf_COM_3</outgoing>
      </task>
      <endEvent id="end_COM" name="End">
         <incoming>sf_COM_3</incoming>
      </endEvent>

      <sequenceFlow id="sf_COM_0" sourceRef="start_COM_receive" targetRef="end_COM_notified"/>
      <sequenceFlow id="sf_COM_1" sourceRef="event_COM_receive_report" targetRef="task_COM_make_available"/>
      <sequenceFlow id="sf_COM_2" sourceRef="task_COM_make_available" targetRef="task_COM_define_formats"/>
      <sequenceFlow id="sf_COM_3" sourceRef="task_COM_define_formats" targetRef="end_COM"/>
   </process>

   <!-- ============================================================ -->
   <!-- DIAGRAM (DI)                                                  -->
   <!-- ============================================================ -->
   <bpmndi:BPMNDiagram id="diagram_1">
      <bpmndi:BPMNPlane bpmnElement="collab_1" id="plane_1">

         <!-- ======= POOL: Member States (y=60, h=130) ======= -->
         <bpmndi:BPMNShape bpmnElement="pool_MS" id="pool_MS_gui" isHorizontal="true">
            <omgdc:Bounds height="130.0" width="750.0" x="60.0" y="60.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="lane_MS" id="lane_MS_gui" isHorizontal="true">
            <omgdc:Bounds height="130.0" width="720.0" x="90.0" y="60.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="start_MS" id="start_MS_gui">
            <omgdc:Bounds height="30.0" width="30.0" x="140.0" y="110.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_MS_designate" id="task_MS_designate_gui">
            <omgdc:Bounds height="80.0" width="100.0" x="230.0" y="85.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_MS_notify" id="task_MS_notify_gui">
            <omgdc:Bounds height="80.0" width="100.0" x="400.0" y="85.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="end_MS" id="end_MS_gui">
            <omgdc:Bounds height="28.0" width="28.0" x="570.0" y="111.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNEdge bpmnElement="sf_MS_1" id="sf_MS_1_gui">
            <omgdi:waypoint x="170.0" y="125.0"/>
            <omgdi:waypoint x="230.0" y="125.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf_MS_2" id="sf_MS_2_gui">
            <omgdi:waypoint x="330.0" y="125.0"/>
            <omgdi:waypoint x="400.0" y="125.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf_MS_3" id="sf_MS_3_gui">
            <omgdi:waypoint x="500.0" y="125.0"/>
            <omgdi:waypoint x="570.0" y="125.0"/>
         </bpmndi:BPMNEdge>

         <!-- ======= POOL: Supervisory Body (y=210, h=350) ======= -->
         <bpmndi:BPMNShape bpmnElement="pool_SB" id="pool_SB_gui" isHorizontal="true">
            <omgdc:Bounds height="350.0" width="1400.0" x="60.0" y="210.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="lane_SB_supervision" id="lane_SB_supervision_gui" isHorizontal="true">
            <omgdc:Bounds height="200.0" width="1370.0" x="90.0" y="210.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="lane_SB_breach" id="lane_SB_breach_gui" isHorizontal="true">
            <omgdc:Bounds height="150.0" width="1370.0" x="90.0" y="410.0"/>
         </bpmndi:BPMNShape>

         <!-- Supervision lane elements -->
         <bpmndi:BPMNShape bpmnElement="start_SB_designated" id="start_SB_designated_gui">
            <omgdc:Bounds height="30.0" width="30.0" x="140.0" y="290.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_SB_supervise_qualified" id="task_SB_supervise_qualified_gui">
            <omgdc:Bounds height="80.0" width="100.0" x="220.0" y="265.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_SB_take_action_nonqualified" id="task_SB_take_action_nonqualified_gui">
            <omgdc:Bounds height="80.0" width="100.0" x="360.0" y="265.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_SB_analyse_reports" id="task_SB_analyse_reports_gui">
            <omgdc:Bounds height="80.0" width="100.0" x="500.0" y="265.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_SB_carry_out_audits" id="task_SB_carry_out_audits_gui">
            <omgdc:Bounds height="80.0" width="100.0" x="640.0" y="265.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_SB_grant_status" id="task_SB_grant_status_gui">
            <omgdc:Bounds height="80.0" width="100.0" x="780.0" y="265.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_SB_cooperate_DPA" id="task_SB_cooperate_DPA_gui">
            <omgdc:Bounds height="80.0" width="100.0" x="920.0" y="265.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_SB_verify_termination" id="task_SB_verify_termination_gui">
            <omgdc:Bounds height="80.0" width="100.0" x="1060.0" y="265.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_SB_require_remedy" id="task_SB_require_remedy_gui">
            <omgdc:Bounds height="80.0" width="100.0" x="1200.0" y="225.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_SB_submit_report" id="task_SB_submit_report_gui">
            <omgdc:Bounds height="80.0" width="100.0" x="1200.0" y="325.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="end_SB_supervision" id="end_SB_supervision_gui">
            <omgdc:Bounds height="28.0" width="28.0" x="1370.0" y="351.0"/>
         </bpmndi:BPMNShape>

         <!-- Breach lane elements -->
         <bpmndi:BPMNShape bpmnElement="event_SB_receive_breach" id="event_SB_receive_breach_gui">
            <omgdc:Bounds height="30.0" width="30.0" x="140.0" y="470.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_SB_inform_other_SBs" id="task_SB_inform_other_SBs_gui">
            <omgdc:Bounds height="80.0" width="100.0" x="360.0" y="445.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_SB_inform_public" id="task_SB_inform_public_gui">
            <omgdc:Bounds height="80.0" width="100.0" x="560.0" y="445.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_SB_provide_ENISA_summary" id="task_SB_provide_ENISA_summary_gui">
            <omgdc:Bounds height="80.0" width="100.0" x="760.0" y="445.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="end_SB_breach" id="end_SB_breach_gui">
            <omgdc:Bounds height="28.0" width="28.0" x="920.0" y="471.0"/>
         </bpmndi:BPMNShape>

         <!-- Supervision lane edges -->
         <bpmndi:BPMNEdge bpmnElement="sf_SB_1" id="sf_SB_1_gui">
            <omgdi:waypoint x="170.0" y="305.0"/>
            <omgdi:waypoint x="220.0" y="305.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf_SB_2" id="sf_SB_2_gui">
            <omgdi:waypoint x="320.0" y="305.0"/>
            <omgdi:waypoint x="360.0" y="305.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf_SB_3" id="sf_SB_3_gui">
            <omgdi:waypoint x="460.0" y="305.0"/>
            <omgdi:waypoint x="500.0" y="305.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf_SB_4" id="sf_SB_4_gui">
            <omgdi:waypoint x="600.0" y="305.0"/>
            <omgdi:waypoint x="640.0" y="305.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf_SB_5" id="sf_SB_5_gui">
            <omgdi:waypoint x="740.0" y="305.0"/>
            <omgdi:waypoint x="780.0" y="305.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf_SB_6" id="sf_SB_6_gui">
            <omgdi:waypoint x="880.0" y="305.0"/>
