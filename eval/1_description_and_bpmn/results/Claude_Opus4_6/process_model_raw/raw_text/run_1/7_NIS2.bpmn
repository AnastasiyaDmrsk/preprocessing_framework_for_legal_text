            <omgdi:waypoint x="540" y="650"/>
            <omgdi:waypoint x="610" y="650"/>
         </bpmndi:BPMNEdge>

         <!-- ===== ENISA Pool ===== -->
         <bpmndi:BPMNShape bpmnElement="part_enisa" id="shape_part_enisa" isHorizontal="true">
            <omgdc:Bounds x="60" y="770" width="1520" height="150"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="lane_enisa" id="shape_lane_enisa" isHorizontal="true">
            <omgdc:Bounds x="90" y="770" width="1490" height="150"/>
