         <bpmndi:BPMNShape bpmnElement="end_enisa" id="shape_end_enisa">
            <omgdc:Bounds x="420" y="831" width="28" height="28"/>
            <bpmndi:BPMNLabel><omgdc:Bounds x="420" y="864" width="28" height="14"/></bpmndi:BPMNLabel>
         </bpmndi:BPMNShape>

         <!-- ENISA sequence flow edges -->
         <bpmndi:BPMNEdge bpmnElement="sf_n1" id="edge_sf_n1">
            <omgdi:waypoint x="150" y="845"/>
            <omgdi:waypoint x="230" y="845"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf_n2" id="edge_sf_n2">
            <omgdi:waypoint x="350" y="845"/>
            <omgdi:waypoint x="420" y="845"/>
         </bpmndi:BPMNEdge>

         <!-- ===== Message Flow Edges ===== -->
         <bpmndi:BPMNEdge bpmnElement="mf_earlywarning" id="edge_mf_ew">
            <omgdi:waypoint x="250" y="207"/>
            <omgdi:waypoint x="135" y="415"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="mf_incnotif" id="edge_mf_in">
            <omgdi:waypoint x="550" y="207"/>
