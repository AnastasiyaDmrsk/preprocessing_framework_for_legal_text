<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             id="definitions_1"
             targetNamespace="http://www.signavio.com"
             expressionLanguage="http://www.w3.org/TR/XPath"
             typeLanguage="http://www.w3.org/2001/XMLSchema"
             xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd">

   <!-- ============================================================ -->
   <!-- COLLABORATION                                                 -->
   <!-- ============================================================ -->
   <collaboration id="collab_1">
      <participant id="pool_ms" name="Member States" processRef="proc_ms"/>
      <participant id="pool_sb" name="Supervisory Body" processRef="proc_sb"/>
      <participant id="pool_tsp" name="Trust Service Provider" processRef="proc_tsp"/>
      <participant id="pool_comm" name="Commission" processRef="proc_comm"/>

      <!-- Message flows -->
      <messageFlow id="mf_ms_sb_designate" name="" sourceRef="task_ms_designate" targetRef="start_sb_designated"/>
      <messageFlow id="mf_ms_sb_notify" name="" sourceRef="task_ms_notify" targetRef="task_sb_receive_notification"/>
      <messageFlow id="mf_tsp_sb_breach" name="" sourceRef="task_tsp_notify_sb" targetRef="start_sb_breach"/>
      <messageFlow id="mf_sb_comm_report" name="" sourceRef="task_sb_submit_report" targetRef="start_comm_report"/>
      <messageFlow id="mf_comm_ms_publish" name="" sourceRef="task_comm_publish" targetRef="task_ms_receive_report"/>
      <messageFlow id="mf_sb_tsp_require" name="" sourceRef="task_sb_require_remedy" targetRef="task_tsp_remedy"/>
      <messageFlow id="mf_sb_public_inform" name="" sourceRef="task_sb_inform_public" targetRef="end_sb_breach"/>
   </collaboration>

   <!-- ============================================================ -->
   <!-- PROCESS: Member States                                        -->
   <!-- ============================================================ -->
   <process id="proc_ms" name="Member States" isExecutable="false" isClosed="false" processType="None">
      <laneSet id="ls_ms">
         <lane id="lane_ms">
            <flowNodeRef>start_ms</flowNodeRef>
            <flowNodeRef>task_ms_designate</flowNodeRef>
            <flowNodeRef>task_ms_notify</flowNodeRef>
            <flowNodeRef>task_ms_receive_report</flowNodeRef>
            <flowNodeRef>end_ms</flowNodeRef>
         </lane>
      </laneSet>

      <startEvent id="start_ms" name="Start">
         <outgoing>sf_ms_1</outgoing>
      </startEvent>
      <task id="task_ms_designate" name="designate supervisory body">
         <incoming>sf_ms_1</incoming>
         <outgoing>sf_ms_2</outgoing>
      </task>
      <task id="task_ms_notify" name="notify Commission of names and addresses">
         <incoming>sf_ms_2</incoming>
         <outgoing>sf_ms_3</outgoing>
      </task>
      <task id="task_ms_receive_report" name="receive annual report">
         <incoming>sf_ms_3</incoming>
         <outgoing>sf_ms_4</outgoing>
      </task>
      <endEvent id="end_ms" name="End">
         <incoming>sf_ms_4</incoming>
      </endEvent>

      <sequenceFlow id="sf_ms_1" sourceRef="start_ms" targetRef="task_ms_designate"/>
      <sequenceFlow id="sf_ms_2" sourceRef="task_ms_designate" targetRef="task_ms_notify"/>
      <sequenceFlow id="sf_ms_3" sourceRef="task_ms_notify" targetRef="task_ms_receive_report"/>
      <sequenceFlow id="sf_ms_4" sourceRef="task_ms_receive_report" targetRef="end_ms"/>
   </process>

   <!-- ============================================================ -->
   <!-- PROCESS: Supervisory Body                                     -->
   <!-- ============================================================ -->
   <process id="proc_sb" name="Supervisory Body" isExecutable="false" isClosed="false" processType="None">
      <laneSet id="ls_sb">
         <lane id="lane_sb">
            <flowNodeRef>start_sb_designated</flowNodeRef>
            <flowNodeRef>task_sb_receive_notification</flowNodeRef>
            <flowNodeRef>task_sb_supervise</flowNodeRef>
            <flowNodeRef>task_sb_analyse_reports</flowNodeRef>
            <flowNodeRef>task_sb_carry_out_audits</flowNodeRef>
            <flowNodeRef>task_sb_grant_status</flowNodeRef>
            <flowNodeRef>task_sb_cooperate</flowNodeRef>
            <flowNodeRef>task_sb_cooperate_dpa</flowNodeRef>
            <flowNodeRef>task_sb_verify_termination</flowNodeRef>
            <flowNodeRef>task_sb_require_remedy</flowNodeRef>
            <flowNodeRef>task_sb_submit_report</flowNodeRef>
            <flowNodeRef>end_sb_supervision</flowNodeRef>
            <flowNodeRef>start_sb_breach</flowNodeRef>
            <flowNodeRef>task_sb_inform_other_sb</flowNodeRef>
            <flowNodeRef>task_sb_inform_public</flowNodeRef>
            <flowNodeRef>task_sb_provide_enisa_summary</flowNodeRef>
            <flowNodeRef>end_sb_breach</flowNodeRef>
            <flowNodeRef>gw_sb_parallel_split</flowNodeRef>
            <flowNodeRef>gw_sb_parallel_join</flowNodeRef>
         </lane>
      </laneSet>

      <!-- Supervision sub-process -->
      <startEvent id="start_sb_designated" name="Designated by Member State">
         <outgoing>sf_sb_1</outgoing>
         <messageEventDefinition id="med_sb_designated"/>
      </startEvent>
      <task id="task_sb_receive_notification" name="receive notification from Member State">
         <incoming>sf_sb_1</incoming>
         <outgoing>sf_sb_2</outgoing>
      </task>
      <task id="task_sb_supervise" name="supervise qualified trust service providers">
         <incoming>sf_sb_2</incoming>
         <outgoing>sf_sb_3</outgoing>
      </task>
      <parallelGateway id="gw_sb_parallel_split" name="" gatewayDirection="Diverging">
         <incoming>sf_sb_3</incoming>
         <outgoing>sf_sb_4a</outgoing>
         <outgoing>sf_sb_4b</outgoing>
         <outgoing>sf_sb_4c</outgoing>
         <outgoing>sf_sb_4d</outgoing>
         <outgoing>sf_sb_4e</outgoing>
         <outgoing>sf_sb_4f</outgoing>
      </parallelGateway>
      <task id="task_sb_analyse_reports" name="analyse conformity assessment reports">
         <incoming>sf_sb_4a</incoming>
         <outgoing>sf_sb_5a</outgoing>
      </task>
      <task id="task_sb_carry_out_audits" name="carry out audits">
         <incoming>sf_sb_4b</incoming>
         <outgoing>sf_sb_5b</outgoing>
      </task>
      <task id="task_sb_grant_status" name="grant or withdraw qualified status">
         <incoming>sf_sb_4c</incoming>
         <outgoing>sf_sb_5c</outgoing>
      </task>
      <task id="task_sb_cooperate" name="cooperate with other supervisory bodies">
         <incoming>sf_sb_4d</incoming>
         <outgoing>sf_sb_5d</outgoing>
      </task>
      <task id="task_sb_cooperate_dpa" name="cooperate with data protection authorities">
         <incoming>sf_sb_4e</incoming>
         <outgoing>sf_sb_5e</outgoing>
      </task>
      <task id="task_sb_verify_termination" name="verify termination plans">
         <incoming>sf_sb_4f</incoming>
         <outgoing>sf_sb_5f</outgoing>
      </task>
      <parallelGateway id="gw_sb_parallel_join" name="" gatewayDirection="Converging">
         <incoming>sf_sb_5a</incoming>
         <incoming>sf_sb_5b</incoming>
         <incoming>sf_sb_5c</incoming>
         <incoming>sf_sb_5d</incoming>
         <incoming>sf_sb_5e</incoming>
         <incoming>sf_sb_5f</incoming>
         <outgoing>sf_sb_6</outgoing>
      </parallelGateway>
      <task id="task_sb_require_remedy" name="require trust service providers to remedy failures">
         <incoming>sf_sb_6</incoming>
         <outgoing>sf_sb_7</outgoing>
      </task>
      <task id="task_sb_submit_report" name="submit annual report to Commission">
         <incoming>sf_sb_7</incoming>
         <outgoing>sf_sb_8</outgoing>
      </task>
      <endEvent id="end_sb_supervision" name="End">
         <incoming>sf_sb_8</incoming>
      </endEvent>

      <!-- Breach notification sub-process -->
      <startEvent id="start_sb_breach" name="Receive breach notification from TSP">
         <outgoing>sf_sb_b1</outgoing>
         <messageEventDefinition id="med_sb_breach"/>
      </startEvent>
      <task id="task_sb_inform_other_sb" name="inform supervisory bodies in other Member States">
         <incoming>sf_sb_b1</incoming>
         <outgoing>sf_sb_b2</outgoing>
      </task>
      <task id="task_sb_inform_public" name="inform the public about breach">
         <incoming>sf_sb_b2</incoming>
         <outgoing>sf_sb_b3</outgoing>
      </task>
      <task id="task_sb_provide_enisa_summary" name="provide ENISA yearly summary of breach notifications">
         <incoming>sf_sb_b3</incoming>
         <outgoing>sf_sb_b4</outgoing>
      </task>
      <endEvent id="end_sb_breach" name="End">
         <incoming>sf_sb_b4</incoming>
      </endEvent>

      <!-- Sequence flows - supervision -->
      <sequenceFlow id="sf_sb_1" sourceRef="start_sb_designated" targetRef="task_sb_receive_notification"/>
      <sequenceFlow id="sf_sb_2" sourceRef="task_sb_receive_notification" targetRef="task_sb_supervise"/>
      <sequenceFlow id="sf_sb_3" sourceRef="task_sb_supervise" targetRef="gw_sb_parallel_split"/>
      <sequenceFlow id="sf_sb_4a" sourceRef="gw_sb_parallel_split" targetRef="task_sb_analyse_reports"/>
      <sequenceFlow id="sf_sb_4b" sourceRef="gw_sb_parallel_split" targetRef="task_sb_carry_out_audits"/>
      <sequenceFlow id="sf_sb_4c" sourceRef="gw_sb_parallel_split" targetRef="task_sb_grant_status"/>
      <sequenceFlow id="sf_sb_4d" sourceRef="gw_sb_parallel_split" targetRef="task_sb_cooperate"/>
      <sequenceFlow id="sf_sb_4e" sourceRef="gw_sb_parallel_split" targetRef="task_sb_cooperate_dpa"/>
      <sequenceFlow id="sf_sb_4f" sourceRef="gw_sb_parallel_split" targetRef="task_sb_verify_termination"/>
      <sequenceFlow id="sf_sb_5a" sourceRef="task_sb_analyse_reports" targetRef="gw_sb_parallel_join"/>
      <sequenceFlow id="sf_sb_5b" sourceRef="task_sb_carry_out_audits" targetRef="gw_sb_parallel_join"/>
      <sequenceFlow id="sf_sb_5c" sourceRef="task_sb_grant_status" targetRef="gw_sb_parallel_join"/>
      <sequenceFlow id="sf_sb_5d" sourceRef="task_sb_cooperate" targetRef="gw_sb_parallel_join"/>
      <sequenceFlow id="sf_sb_5e" sourceRef="task_sb_cooperate_dpa" targetRef="gw_sb_parallel_join"/>
      <sequenceFlow id="sf_sb_5f" sourceRef="task_sb_verify_termination" targetRef="gw_sb_parallel_join"/>
      <sequenceFlow id="sf_sb_6" sourceRef="gw_sb_parallel_join" targetRef="task_sb_require_remedy"/>
      <sequenceFlow id="sf_sb_7" sourceRef="task_sb_require_remedy" targetRef="task_sb_submit_report"/>
      <sequenceFlow id="sf_sb_8" sourceRef="task_sb_submit_report" targetRef="end_sb_supervision"/>

      <!-- Sequence flows - breach -->
      <sequenceFlow id="sf_sb_b1" sourceRef="start_sb_breach" targetRef="task_sb_inform_other_sb"/>
      <sequenceFlow id="sf_sb_b2" sourceRef="task_sb_inform_other_sb" targetRef="task_sb_inform_public"/>
      <sequenceFlow id="sf_sb_b3" sourceRef="task_sb_inform_public" targetRef="task_sb_provide_enisa_summary"/>
      <sequenceFlow id="sf_sb_b4" sourceRef="task_sb_provide_enisa_summary" targetRef="end_sb_breach"/>
   </process>

   <!-- ============================================================ -->
   <!-- PROCESS: Trust Service Provider                               -->
   <!-- ============================================================ -->
   <process id="proc_tsp" name="Trust Service Provider" isExecutable="false" isClosed="false" processType="None">
      <laneSet id="ls_tsp">
         <lane id="lane_tsp">
            <flowNodeRef>start_tsp</flowNodeRef>
            <flowNodeRef>task_tsp_take_measures</flowNodeRef>
            <flowNodeRef>task_tsp_notify_sb</flowNodeRef>
            <flowNodeRef>task_tsp_notify_person</flowNodeRef>
            <flowNodeRef>task_tsp_remedy</flowNodeRef>
            <flowNodeRef>end_tsp</flowNodeRef>
         </lane>
      </laneSet>

      <startEvent id="start_tsp" name="Breach of security detected">
         <outgoing>sf_tsp_1</outgoing>
      </startEvent>
      <task id="task_tsp_take_measures" name="take appropriate technical and organisational measures">
         <incoming>sf_tsp_1</incoming>
         <outgoing>sf_tsp_2</outgoing>
      </task>
      <task id="task_tsp_notify_sb" name="notify supervisory body of breach within 24 hours">
         <incoming>sf_tsp_2</incoming>
         <outgoing>sf_tsp_3</outgoing>
      </task>
      <task id="task_tsp_notify_person" name="notify affected natural or legal person of breach">
         <incoming>sf_tsp_3</incoming>
         <outgoing>sf_tsp_4</outgoing>
      </task>
      <task id="task_tsp_remedy" name="remedy failure to fulfil requirements">
         <incoming>sf_tsp_4</incoming>
         <outgoing>sf_tsp_5</outgoing>
      </task>
      <endEvent id="end_tsp" name="End">
         <incoming>sf_tsp_5</incoming>
      </endEvent>

      <sequenceFlow id="sf_tsp_1" sourceRef="start_tsp" targetRef="task_tsp_take_measures"/>
      <sequenceFlow id="sf_tsp_2" sourceRef="task_tsp_take_measures" targetRef="task_tsp_notify_sb"/>
      <sequenceFlow id="sf_tsp_3" sourceRef="task_tsp_notify_sb" targetRef="task_tsp_notify_person"/>
      <sequenceFlow id="sf_tsp_4" sourceRef="task_tsp_notify_person" targetRef="task_tsp_remedy"/>
      <sequenceFlow id="sf_tsp_5" sourceRef="task_tsp_remedy" targetRef="end_tsp"/>
   </process>

   <!-- ============================================================ -->
   <!-- PROCESS: Commission                                           -->
   <!-- ============================================================ -->
   <process id="proc_comm" name="Commission" isExecutable="false" isClosed="false" processType="None">
      <laneSet id="ls_comm">
         <lane id="lane_comm">
            <flowNodeRef>start_comm_report</flowNodeRef>
            <flowNodeRef>task_comm_publish</flowNodeRef>
            <flowNodeRef>task_comm_define_formats</flowNodeRef>
            <flowNodeRef>end_comm</flowNodeRef>
         </lane>
      </laneSet>

      <startEvent id="start_comm_report" name="Receive annual report">
         <outgoing>sf_comm_1</outgoing>
         <messageEventDefinition id="med_comm_report"/>
      </startEvent>
      <task id="task_comm_publish" name="make annual report available to Member States">
         <incoming>sf_comm_1</incoming>
         <outgoing>sf_comm_2</outgoing>
      </task>
      <task id="task_comm_define_formats" name="define formats and procedures by implementing acts">
         <incoming>sf_comm_2</incoming>
         <outgoing>sf_comm_3</outgoing>
      </task>
      <endEvent id="end_comm" name="End">
         <incoming>sf_comm_3</incoming>
      </endEvent>

      <sequenceFlow id="sf_comm_1" sourceRef="start_comm_report" targetRef="task_comm_publish"/>
      <sequenceFlow id="sf_comm_2" sourceRef="task_comm_publish" targetRef="task_comm_define_formats"/>
      <sequenceFlow id="sf_comm_3" sourceRef="task_comm_define_formats" targetRef="end_comm"/>
   </process>

   <!-- ============================================================ -->
   <!-- DIAGRAM (DI)                                                  -->
   <!-- ============================================================ -->
   <bpmndi:BPMNDiagram id="diagram_1">
      <bpmndi:BPMNPlane bpmnElement="collab_1" id="plane_1">

         <!-- ===== POOL: Member States (y=60) ===== -->
         <bpmndi:BPMNShape bpmnElement="pool_ms" id="pool_ms_gui" isHorizontal="true">
            <omgdc:Bounds height="140.0" width="750.0" x="60.0" y="60.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="lane_ms" id="lane_ms_gui" isHorizontal="true">
            <omgdc:Bounds height="140.0" width="720.0" x="90.0" y="60.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="start_ms" id="start_ms_gui">
            <omgdc:Bounds height="30.0" width="30.0" x="130.0" y="115.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_ms_designate" id="task_ms_designate_gui">
            <omgdc:Bounds height="80.0" width="100.0" x="210.0" y="90.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_ms_notify" id="task_ms_notify_gui">
            <omgdc:Bounds height="80.0" width="100.0" x="370.0" y="90.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_ms_receive_report" id="task_ms_receive_report_gui">
            <omgdc:Bounds height="80.0" width="100.0" x="540.0" y="90.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="end_ms" id="end_ms_gui">
            <omgdc:Bounds height="28.0" width="28.0" x="710.0" y="116.0"/>
         </bpmndi:BPMNShape>

         <!-- Edges: Member States -->
         <bpmndi:BPMNEdge bpmnElement="sf_ms_1" id="sf_ms_1_gui">
            <omgdi:waypoint x="160.0" y="130.0"/>
            <omgdi:waypoint x="210.0" y="130.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf_ms_2" id="sf_ms_2_gui">
            <omgdi:waypoint x="310.0" y="130.0"/>
            <omgdi:waypoint x="370.0" y="130.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf_ms_3" id="sf_ms_3_gui">
            <omgdi:waypoint x="470.0" y="130.0"/>
            <omgdi:waypoint x="540.0" y="130.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf_ms_4" id="sf_ms_4_gui">
            <omgdi:waypoint x="640.0" y="130.0"/>
            <omgdi:waypoint x="710.0" y="130.0"/>
         </bpmndi:BPMNEdge>

         <!-- ===== POOL: Supervisory Body (y=240) ===== -->
         <bpmndi:BPMNShape bpmnElement="pool_sb" id="pool_sb_gui" isHorizontal="true">
            <omgdc:Bounds height="540.0" width="1350.0" x="60.0" y="240.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="lane_sb" id="lane_sb_gui" isHorizontal="true">
            <omgdc:Bounds height="540.0" width="1320.0" x="90.0" y="240.0"/>
         </bpmndi:BPMNShape>

         <!-- Supervision flow -->
         <bpmndi:BPMNShape bpmnElement="start_sb_designated" id="start_sb_designated_gui">
            <omgdc:Bounds height="30.0" width="30.0" x="130.0" y="345.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_sb_receive_notification" id="task_sb_receive_notification_gui">
            <omgdc:Bounds height="80.0" width="100.0" x="210.0" y="320.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_sb_supervise" id="task_sb_supervise_gui">
            <omgdc:Bounds height="80.0" width="100.0" x="370.0" y="320.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="gw_sb_parallel_split" id="gw_sb_parallel_split_gui" isMarkerVisible="true">
            <omgdc:Bounds height="40.0" width="40.0" x="520.0" y="340.0"/>
         </bpmndi:BPMNShape>

         <!-- Parallel tasks (3 rows x 2 cols) -->
         <bpmndi:BPMNShape bpmnElement="task_sb_analyse_reports" id="task_sb_analyse_reports_gui">
            <omgdc:Bounds height="60.0" width="140.0" x="610.0" y="260.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_sb_carry_out_audits" id="task_sb_carry_out_audits_gui">
            <omgdc:Bounds height="60.0" width="140.0" x="610.0" y="330.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_sb_grant_status" id="task_sb_grant_status_gui">
            <omgdc:Bounds height="60.0" width="140.0" x="610.0" y="400.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_sb_cooperate" id="task_sb_cooperate_gui">
            <omgdc:Bounds height="60.0" width="140.0" x="780.0" y="260.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_sb_cooperate_dpa" id="task_sb_cooperate_dpa_gui">
            <omgdc:Bounds height="60.0" width="140.0" x="780.0" y="330.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_sb_verify_termination" id="task_sb_verify_termination_gui">
            <omgdc:Bounds height="60.0" width="140.0" x="780.0" y="400.0"/>
         </bpmndi:BPMNShape>

         <bpmndi:BPMNShape bpmnElement="gw_sb_parallel_join" id="gw_sb_parallel_join_gui" isMarkerVisible="true">
            <omgdc:Bounds height="40.0" width="40.0" x="960.0" y="340.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_sb_require_remedy" id="task_sb_require_remedy_gui">
            <omgdc:Bounds height="80.0" width="120.0" x="1040.0" y="320.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_sb_submit_report" id="task_sb_submit_report_gui">
            <omgdc:Bounds height="80.0" width="120.0" x="1200.0" y="320.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="end_sb_supervision" id="end_sb_supervision_gui">
            <omgdc:Bounds height="28.0" width="28.0" x="1356.0" y="346.0"/>
         </bpmndi:BPMNShape>

         <!-- Breach notification flow (below supervision) -->
         <bpmndi:BPMNShape bpmnElement="start_sb_breach" id="start_sb_breach_gui">
            <omgdc:Bounds height="30.0" width="30.0" x="130.0" y="615.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_sb_inform_other_sb" id="task_sb_inform_other_sb_gui">
            <omgdc:Bounds height="80.0" width="140.0" x="220.0" y="590.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_sb_inform_public" id="task_sb_inform_public_gui">
            <omgdc:Bounds height="80.0" width="140.0" x="420.0" y="590.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_sb_provide_enisa_summary" id="task_sb_provide_enisa_summary_gui">
            <omgdc:Bounds height="80.0" width="140.0" x="620.0" y="590.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="end_sb_breach" id="end_sb_breach_gui">
            <omgdc:Bounds height="28.0" width="28.0" x="810.0" y="616.0"/>
         </bpmndi:BPMNShape>

         <!-- Edges: Supervisory Body - supervision -->
