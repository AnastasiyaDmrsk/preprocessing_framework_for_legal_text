<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             id="Definitions_1"
             targetNamespace="http://bpmn.io/schema/bpmn"
             expressionLanguage="http://www.w3.org/TR/XPath"
             typeLanguage="http://www.w3.org/2001/XMLSchema"
             xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd">

   <collaboration id="Collaboration_1">
      <participant id="Participant_MS" name="Member States" processRef="Process_MS"/>
      <participant id="Participant_OE" name="Obliged Entities" processRef="Process_OE"/>
      <messageFlow id="MsgFlow_1" name="require CDD application" sourceRef="Task_EstablishBR" targetRef="Task_ApplyCDD"/>
   </collaboration>

   <!-- ============================================================ -->
   <!-- MEMBER STATES PROCESS                                        -->
   <!-- ============================================================ -->
   <process id="Process_MS" name="Member States" isExecutable="false" isClosed="false" processType="None">
      <laneSet id="LaneSet_MS">
         <lane id="Lane_MS" name="">
            <flowNodeRef>StartEvent_MS</flowNodeRef>
            <flowNodeRef>Task_VerifyIdentity</flowNodeRef>
            <flowNodeRef>GW_VerificationTiming</flowNodeRef>
            <flowNodeRef>Task_EstablishBR</flowNodeRef>
            <flowNodeRef>Task_CompleteVerifDuring</flowNodeRef>
            <flowNodeRef>Task_CompleteProcedures</flowNodeRef>
            <flowNodeRef>Task_AllowAccountOpening</flowNodeRef>
            <flowNodeRef>Task_EnsureNoTx</flowNodeRef>
            <flowNodeRef>GW_MergeDerogation</flowNodeRef>
            <flowNodeRef>GW_CompliancePossible</flowNodeRef>
            <flowNodeRef>Task_NotCarryOutTx</flowNodeRef>
            <flowNodeRef>Task_TerminateBR</flowNodeRef>
            <flowNodeRef>Task_ConsiderSTR</flowNodeRef>
            <flowNodeRef>GW_MergeEnd</flowNodeRef>
            <flowNodeRef>EndEvent_MS</flowNodeRef>
         </lane>
      </laneSet>

      <startEvent id="StartEvent_MS" name="Start">
         <outgoing>Flow_1</outgoing>
      </startEvent>

      <task id="Task_VerifyIdentity" name="Verify identity of customer and beneficial owner">
         <incoming>Flow_1</incoming>
         <outgoing>Flow_2</outgoing>
      </task>

      <exclusiveGateway id="GW_VerificationTiming" name="Verification before establishment possible?">
         <incoming>Flow_2</incoming>
         <outgoing>Flow_3</outgoing>
         <outgoing>Flow_4</outgoing>
         <outgoing>Flow_5</outgoing>
      </exclusiveGateway>

      <!-- Normal path (paragraph 1) -->
      <task id="Task_EstablishBR" name="Establish business relationship or carry out transaction">
         <incoming>Flow_3</incoming>
         <outgoing>Flow_6</outgoing>
      </task>

      <!-- Derogation path paragraph 2 -->
      <task id="Task_CompleteVerifDuring" name="Complete verification during establishment of business relationship">
         <incoming>Flow_4</incoming>
         <outgoing>Flow_7</outgoing>
      </task>

      <task id="Task_CompleteProcedures" name="Complete procedures as soon as practicable after initial contact">
         <incoming>Flow_7</incoming>
         <outgoing>Flow_8</outgoing>
      </task>

      <!-- Derogation path paragraph 3 -->
      <task id="Task_AllowAccountOpening" name="Allow opening of account with credit institution or financial institution">
         <incoming>Flow_5</incoming>
         <outgoing>Flow_9</outgoing>
      </task>

      <task id="Task_EnsureNoTx" name="Ensure no transactions until full CDD compliance obtained">
         <incoming>Flow_9</incoming>
         <outgoing>Flow_10</outgoing>
      </task>

      <!-- Merge derogation paths -->
      <exclusiveGateway id="GW_MergeDerogation" name="">
         <incoming>Flow_6</incoming>
         <incoming>Flow_8</incoming>
         <incoming>Flow_10</incoming>
         <outgoing>Flow_11</outgoing>
      </exclusiveGateway>

      <!-- Paragraph 4 decision -->
      <exclusiveGateway id="GW_CompliancePossible" name="Obliged entity able to comply with CDD?">
         <incoming>Flow_11</incoming>
         <outgoing>Flow_12</outgoing>
         <outgoing>Flow_13</outgoing>
      </exclusiveGateway>

      <!-- Non-compliance path (paragraph 4) -->
      <task id="Task_NotCarryOutTx" name="Not carry out transaction through bank account and not establish business relationship">
         <incoming>Flow_13</incoming>
         <outgoing>Flow_14</outgoing>
      </task>

      <task id="Task_TerminateBR" name="Terminate business relationship">
         <incoming>Flow_14</incoming>
         <outgoing>Flow_15</outgoing>
      </task>

      <task id="Task_ConsiderSTR" name="Consider making suspicious transaction report to FIU">
         <incoming>Flow_15</incoming>
         <outgoing>Flow_16</outgoing>
      </task>

      <!-- Merge to end -->
      <exclusiveGateway id="GW_MergeEnd" name="">
         <incoming>Flow_12</incoming>
         <incoming>Flow_16</incoming>
         <outgoing>Flow_17</outgoing>
      </exclusiveGateway>

      <endEvent id="EndEvent_MS" name="End">
         <incoming>Flow_17</incoming>
      </endEvent>

      <!-- Sequence Flows -->
      <sequenceFlow id="Flow_1" sourceRef="StartEvent_MS" targetRef="Task_VerifyIdentity"/>
      <sequenceFlow id="Flow_2" sourceRef="Task_VerifyIdentity" targetRef="GW_VerificationTiming"/>
      <sequenceFlow id="Flow_3" name="Yes - before establishment" sourceRef="GW_VerificationTiming" targetRef="Task_EstablishBR"/>
      <sequenceFlow id="Flow_4" name="Derogation para 2 - during establishment" sourceRef="GW_VerificationTiming" targetRef="Task_CompleteVerifDuring"/>
      <sequenceFlow id="Flow_5" name="Derogation para 3 - account opening" sourceRef="GW_VerificationTiming" targetRef="Task_AllowAccountOpening"/>
      <sequenceFlow id="Flow_6" sourceRef="Task_EstablishBR" targetRef="GW_MergeDerogation"/>
      <sequenceFlow id="Flow_7" sourceRef="Task_CompleteVerifDuring" targetRef="Task_CompleteProcedures"/>
      <sequenceFlow id="Flow_8" sourceRef="Task_CompleteProcedures" targetRef="GW_MergeDerogation"/>
      <sequenceFlow id="Flow_9" sourceRef="Task_AllowAccountOpening" targetRef="Task_EnsureNoTx"/>
      <sequenceFlow id="Flow_10" sourceRef="Task_EnsureNoTx" targetRef="GW_MergeDerogation"/>
      <sequenceFlow id="Flow_11" sourceRef="GW_MergeDerogation" targetRef="GW_CompliancePossible"/>
      <sequenceFlow id="Flow_12" name="Yes" sourceRef="GW_CompliancePossible" targetRef="GW_MergeEnd"/>
      <sequenceFlow id="Flow_13" name="No - unable to comply" sourceRef="GW_CompliancePossible" targetRef="Task_NotCarryOutTx"/>
      <sequenceFlow id="Flow_14" sourceRef="Task_NotCarryOutTx" targetRef="Task_TerminateBR"/>
      <sequenceFlow id="Flow_15" sourceRef="Task_TerminateBR" targetRef="Task_ConsiderSTR"/>
      <sequenceFlow id="Flow_16" sourceRef="Task_ConsiderSTR" targetRef="GW_MergeEnd"/>
      <sequenceFlow id="Flow_17" sourceRef="GW_MergeEnd" targetRef="EndEvent_MS"/>
   </process>

   <!-- ============================================================ -->
   <!-- OBLIGED ENTITIES PROCESS                                     -->
   <!-- ============================================================ -->
   <process id="Process_OE" name="Obliged Entities" isExecutable="false" isClosed="false" processType="None">
      <laneSet id="LaneSet_OE">
         <lane id="Lane_OE" name="">
            <flowNodeRef>StartEvent_OE</flowNodeRef>
            <flowNodeRef>Task_ApplyCDD</flowNodeRef>
            <flowNodeRef>EndEvent_OE</flowNodeRef>
         </lane>
      </laneSet>

      <startEvent id="StartEvent_OE" name="Start">
         <outgoing>Flow_OE1</outgoing>
      </startEvent>

      <task id="Task_ApplyCDD" name="Apply customer due diligence measures to new and existing customers on risk-sensitive basis">
         <incoming>Flow_OE1</incoming>
         <outgoing>Flow_OE2</outgoing>
      </task>

      <endEvent id="EndEvent_OE" name="End">
         <incoming>Flow_OE2</incoming>
      </endEvent>

      <sequenceFlow id="Flow_OE1" sourceRef="StartEvent_OE" targetRef="Task_ApplyCDD"/>
      <sequenceFlow id="Flow_OE2" sourceRef="Task_ApplyCDD" targetRef="EndEvent_OE"/>
   </process>

   <!-- ============================================================ -->
   <!-- BPMN DIAGRAM (DI)                                            -->
   <!-- ============================================================ -->
   <bpmndi:BPMNDiagram id="BPMNDiagram_1">
      <bpmndi:BPMNPlane bpmnElement="Collaboration_1" id="BPMNPlane_1">

         <!-- Member States Pool -->
         <bpmndi:BPMNShape bpmnElement="Participant_MS" id="Participant_MS_di" isHorizontal="true">
            <omgdc:Bounds x="120" y="60" width="1560" height="520"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="Lane_MS" id="Lane_MS_di" isHorizontal="true">
            <omgdc:Bounds x="150" y="60" width="1530" height="520"/>
         </bpmndi:BPMNShape>

         <!-- Obliged Entities Pool -->
         <bpmndi:BPMNShape bpmnElement="Participant_OE" id="Participant_OE_di" isHorizontal="true">
            <omgdc:Bounds x="120" y="620" width="1560" height="150"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="Lane_OE" id="Lane_OE_di" isHorizontal="true">
            <omgdc:Bounds x="150" y="620" width="1530" height="150"/>
         </bpmndi:BPMNShape>

         <!-- MS Start Event -->
         <bpmndi:BPMNShape bpmnElement="StartEvent_MS" id="StartEvent_MS_di">
            <omgdc:Bounds x="192" y="282" width="36" height="36"/>
         </bpmndi:BPMNShape>

         <!-- Task: Verify Identity -->
         <bpmndi:BPMNShape bpmnElement="Task_VerifyIdentity" id="Task_VerifyIdentity_di">
            <omgdc:Bounds x="270" y="260" width="100" height="80"/>
         </bpmndi:BPMNShape>

         <!-- GW: Verification Timing -->
         <bpmndi:BPMNShape bpmnElement="GW_VerificationTiming" id="GW_VerificationTiming_di" isMarkerVisible="true">
            <omgdc:Bounds x="415" y="275" width="50" height="50"/>
         </bpmndi:BPMNShape>

         <!-- Task: Establish BR (top path) -->
         <bpmndi:BPMNShape bpmnElement="Task_EstablishBR" id="Task_EstablishBR_di">
            <omgdc:Bounds x="530" y="100" width="100" height="80"/>
         </bpmndi:BPMNShape>

         <!-- Task: Complete Verification During (middle path) -->
         <bpmndi:BPMNShape bpmnElement="Task_CompleteVerifDuring" id="Task_CompleteVerifDuring_di">
            <omgdc:Bounds x="530" y="260" width="100" height="80"/>
         </bpmndi:BPMNShape>

         <!-- Task: Complete Procedures -->
         <bpmndi:BPMNShape bpmnElement="Task_CompleteProcedures" id="Task_CompleteProcedures_di">
            <omgdc:Bounds x="680" y="260" width="100" height="80"/>
         </bpmndi:BPMNShape>

         <!-- Task: Allow Account Opening (bottom path) -->
         <bpmndi:BPMNShape bpmnElement="Task_AllowAccountOpening" id="Task_AllowAccountOpening_di">
            <omgdc:Bounds x="530" y="420" width="100" height="80"/>
         </bpmndi:BPMNShape>

         <!-- Task: Ensure No Tx -->
         <bpmndi:BPMNShape bpmnElement="Task_EnsureNoTx" id="Task_EnsureNoTx_di">
            <omgdc:Bounds x="680" y="420" width="100" height="80"/>
         </bpmndi:BPMNShape>

         <!-- GW: Merge Derogation -->
         <bpmndi:BPMNShape bpmnElement="GW_MergeDerogation" id="GW_MergeDerogation_di" isMarkerVisible="true">
            <omgdc:Bounds x="835" y="275" width="50" height="50"/>
         </bpmndi:BPMNShape>

         <!-- GW: Compliance Possible -->
         <bpmndi:BPMNShape bpmnElement="GW_CompliancePossible" id="GW_CompliancePossible_di" isMarkerVisible="true">
            <omgdc:Bounds x="935" y="275" width="50" height="50"/>
         </bpmndi:BPMNShape>

         <!-- Task: Not Carry Out Tx -->
         <bpmndi:BPMNShape bpmnElement="Task_NotCarryOutTx" id="Task_NotCarryOutTx_di">
            <omgdc:Bounds x="1050" y="380" width="100" height="80"/>
         </bpmndi:BPMNShape>

         <!-- Task: Terminate BR -->
         <bpmndi:BPMNShape bpmnElement="Task_TerminateBR" id="Task_TerminateBR_di">
            <omgdc:Bounds x="1200" y="380" width="100" height="80"/>
         </bpmndi:BPMNShape>

         <!-- Task: Consider STR -->
         <bpmndi:BPMNShape bpmnElement="Task_ConsiderSTR" id="Task_ConsiderSTR_di">
            <omgdc:Bounds x="1350" y="380" width="100" height="80"/>
         </bpmndi:BPMNShape>

         <!-- GW: Merge End -->
         <bpmndi:BPMNShape bpmnElement="GW_MergeEnd" id="GW_MergeEnd_di" isMarkerVisible="true">
            <omgdc:Bounds x="1505" y="275" width="50" height="50"/>
         </bpmndi:BPMNShape>

         <!-- MS End Event -->
         <bpmndi:BPMNShape bpmnElement="EndEvent_MS" id="EndEvent_MS_di">
            <omgdc:Bounds x="1602" y="282" width="36" height="36"/>
         </bpmndi:BPMNShape>

         <!-- OE Start Event -->
         <bpmndi:BPMNShape bpmnElement="StartEvent_OE" id="StartEvent_OE_di">
            <omgdc:Bounds x="192" y="682" width="36" height="36"/>
         </bpmndi:BPMNShape>

         <!-- Task: Apply CDD -->
         <bpmndi:BPMNShape bpmnElement="Task_ApplyCDD" id="Task_ApplyCDD_di">
            <omgdc:Bounds x="530" y="660" width="100" height="80"/>
         </bpmndi:BPMNShape>

         <!-- OE End Event -->
         <bpmndi:BPMNShape bpmnElement="EndEvent_OE" id="EndEvent_OE_di">
            <omgdc:Bounds x="692" y="682" width="36" height="36"/>
         </bpmndi:BPMNShape>

         <!-- ====== SEQUENCE FLOW EDGES (MS) ====== -->

         <!-- Flow_1: Start -> Verify Identity -->
         <bpmndi:BPMNEdge bpmnElement="Flow_1" id="Flow_1_di">
            <omgdi:waypoint x="228" y="300"/>
            <omgdi:waypoint x="270" y="300"/>
         </bpmndi:BPMNEdge>

         <!-- Flow_2: Verify Identity -> GW Timing -->
         <bpmndi:BPMNEdge bpmnElement="Flow_2" id="Flow_2_di">
            <omgdi:waypoint x="370" y="300"/>
            <omgdi:waypoint x="415" y="300"/>
         </bpmndi:BPMNEdge>

         <!-- Flow_3: GW Timing -> Establish BR (top) -->
         <bpmndi:BPMNEdge bpmnElement="Flow_3" id="Flow_3_di">
            <omgdi:waypoint x="440" y="275"/>
            <omgdi:waypoint x="440" y="140"/>
            <omgdi:waypoint x="530" y="140"/>
         </bpmndi:BPMNEdge>

         <!-- Flow_4: GW Timing -> Complete Verif During (middle) -->
         <bpmndi:BPMNEdge bpmnElement="Flow_4" id="Flow_4_di">
            <omgdi:waypoint x="465" y="300"/>
            <omgdi:waypoint x="530" y="300"/>
         </bpmndi:BPMNEdge>

         <!-- Flow_5: GW Timing -> Allow Account Opening (bottom) -->
         <bpmndi:BPMNEdge bpmnElement="Flow_5" id="Flow_5_di">
            <omgdi:waypoint x="440" y="325"/>
            <omgdi:waypoint x="440" y="460"/>
            <omgdi:waypoint x="530" y="460"/>
         </bpmndi:BPMNEdge>

         <!-- Flow_6: Establish BR -> GW Merge Derogation -->
         <bpmndi:BPMNEdge bpmnElement="Flow_6" id="Flow_6_di">
            <omgdi:waypoint x="630" y="140"/>
            <omgdi:waypoint x="860" y="140"/>
            <omgdi:waypoint x="860" y="275"/>
         </bpmndi:BPMNEdge>

         <!-- Flow_7: Complete Verif During -> Complete Procedures -->
         <bpmndi:BPMNEdge bpmnElement="Flow_7" id="Flow_7_di">
            <omgdi:waypoint x="630" y="300"/>
            <omgdi:waypoint x="680" y="300"/>
         </bpmndi:BPMNEdge>

         <!-- Flow_8: Complete Procedures -> GW Merge Derogation -->
         <bpmndi:BPMNEdge bpmnElement="Flow_8" id="Flow_8_di">
            <omgdi:waypoint x="780" y="300"/>
            <omgdi:waypoint x="835" y="300"/>
         </bpmndi:BPMNEdge>

         <!-- Flow_9: Allow Account Opening -> Ensure No Tx -->
         <bpmndi:BPMNEdge bpmnElement="Flow_9" id="Flow_9_di">
            <omgdi:waypoint x="630" y="460"/>
            <omgdi:waypoint x="680" y="460"/>
         </bpmndi:BPMNEdge>

         <!-- Flow_10: Ensure No Tx -> GW Merge Derogation -->
         <bpmndi:BPMNEdge bpmnElement="Flow_10" id="Flow_10_di">
            <omgdi:waypoint x="780" y="460"/>
            <omgdi:waypoint x="860" y="460"/>
            <omgdi:waypoint x="860" y="325"/>
         </bpmndi:BPMNEdge>

         <!-- Flow_11: GW Merge Derogation -> GW Compliance -->
         <bpmndi:BPMNEdge bpmnElement="Flow_11" id="Flow_11_di">
            <omgdi:waypoint x="885" y="300"/>
            <omgdi:waypoint x="935" y="300"/>
         </bpmndi:BPMNEdge>

         <!-- Flow_12: GW Compliance -> GW Merge End (Yes) -->
         <bpmndi:BPMNEdge bpmnElement="Flow_12" id="Flow_12_di">
            <omgdi:waypoint x="985" y="300"/>
            <omgdi:waypoint x="1505" y="300"/>
         </bpmndi:BPMNEdge>

         <!-- Flow_13: GW Compliance -> Not Carry Out Tx (No) -->
         <bpmndi:BPMNEdge bpmnElement="Flow_13" id="Flow_13_di">
            <omgdi:waypoint x="960" y="325"/>
            <omgdi:waypoint x="960" y="420"/>
            <omgdi:waypoint x="1050" y="420"/>
         </bpmndi:BPMNEdge>

         <!-- Flow_14: Not Carry Out Tx -> Terminate BR -->
         <bpmndi:BPMNEdge bpmnElement="Flow_14" id="Flow_14_di">
            <omgdi:waypoint x="1150" y="420"/>
            <omgdi:waypoint x="1200" y="420"/>
         </bpmndi:BPMNEdge>

         <!-- Flow_15: Terminate BR -> Consider STR -->
         <bpmndi:BPMNEdge bpmnElement="Flow_15" id="Flow_15_di">
            <omgdi:waypoint x="1300" y="420"/>
            <omgdi:waypoint x="1350" y="420"/>
         </bpmndi:BPMNEdge>

         <!-- Flow_16: Consider STR -> GW Merge End -->
         <bpmndi:BPMNEdge bpmnElement="Flow_16" id="Flow_16_di">
            <omgdi:waypoint x="1450" y="420"/>
            <omgdi:waypoint x="1530" y="420"/>
            <omgdi:waypoint x="1530" y="325"/>
         </bpmndi:BPMNEdge>

         <!-- Flow_17: GW Merge End -> End -->
         <bpmndi:BPMNEdge bpmnElement="Flow_17" id="Flow_17_di">
            <omgdi:waypoint x="1555" y="300"/>
            <omgdi:waypoint x="1602" y="300"/>
         </bpmndi:BPMNEdge>

         <!-- ====== SEQUENCE FLOW EDGES (OE) ====== -->

         <!-- Flow_OE1: Start -> Apply CDD -->
         <bpmndi:BPMNEdge bpmnElement="Flow_OE1" id="Flow_OE1_di">
            <omgdi:waypoint x="228" y="700"/>
            <omgdi:waypoint x="530" y="700"/>
         </bpmndi:BPMNEdge>

         <!-- Flow_OE2: Apply CDD -> End -->
         <bpmndi:BPMNEdge bpmnElement="Flow_OE2" id="Flow_OE2_di">
            <omgdi:waypoint x="630" y="700"/>
            <omgdi:waypoint x="692" y="700"/>
         </bpmndi:BPMNEdge>

         <!-- ====== MESSAGE FLOW ====== -->
         <bpmndi:BPMNEdge bpmnElement="MsgFlow_1" id="MsgFlow_1_di">
            <omgdi:waypoint x="580" y="180"/>
            <omgdi:waypoint x="580" y="660"/>
         </bpmndi:BPMNEdge>

      </bpmndi:BPMNPlane>
   </bpmndi:BPMNDiagram>
</definitions>
