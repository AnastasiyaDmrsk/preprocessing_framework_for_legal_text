<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             id="definitions_1"
             targetNamespace="http://bpmn.io/schema/bpmn"
             expressionLanguage="http://www.w3.org/TR/XPath"
             typeLanguage="http://www.w3.org/2001/XMLSchema"
             xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd">

  <!-- ======== COLLABORATION ======== -->
  <collaboration id="collab_1">
    <participant id="part_processor" name="Processor" processRef="proc_processor"/>
    <participant id="part_controller" name="Controller" processRef="proc_controller"/>
    <participant id="part_sa" name="Supervisory Authority" processRef="proc_sa"/>
    <messageFlow id="mf_1" name="Breach notification" sourceRef="task_p1" targetRef="startEvent_c"/>
    <messageFlow id="mf_2" name="Breach notification to SA" sourceRef="task_notifySA" targetRef="startEvent_sa"/>
  </collaboration>

  <!-- ======== PROCESSOR PROCESS ======== -->
  <process id="proc_processor" name="Processor" isExecutable="false" isClosed="false" processType="None">
    <laneSet id="ls_processor">
      <lane id="lane_processor">
        <flowNodeRef>startEvent_p</flowNodeRef>
        <flowNodeRef>task_p1</flowNodeRef>
        <flowNodeRef>endEvent_p</flowNodeRef>
      </lane>
    </laneSet>
    <startEvent id="startEvent_p" name="Become aware of breach">
      <outgoing>sf_p1</outgoing>
    </startEvent>
    <task id="task_p1" name="Notify controller of personal data breach">
      <incoming>sf_p1</incoming>
      <outgoing>sf_p2</outgoing>
    </task>
    <endEvent id="endEvent_p" name="End">
      <incoming>sf_p2</incoming>
    </endEvent>
    <sequenceFlow id="sf_p1" sourceRef="startEvent_p" targetRef="task_p1"/>
    <sequenceFlow id="sf_p2" sourceRef="task_p1" targetRef="endEvent_p"/>
  </process>

  <!-- ======== CONTROLLER PROCESS ======== -->
  <process id="proc_controller" name="Controller" isExecutable="false" isClosed="false" processType="None">
    <laneSet id="ls_controller">
      <lane id="lane_controller">
        <flowNodeRef>startEvent_c</flowNodeRef>
        <flowNodeRef>xorGw_risk</flowNodeRef>
        <flowNodeRef>task_notifySA</flowNodeRef>
        <flowNodeRef>task_docOnly</flowNodeRef>
        <flowNodeRef>endEvent_c1</flowNodeRef>
        <flowNodeRef>xorGw_72h</flowNodeRef>
        <flowNodeRef>task_delayReasons</flowNodeRef>
        <flowNodeRef>xorGw_72h_merge</flowNodeRef>
        <flowNodeRef>parGw_33_fork</flowNodeRef>
        <flowNodeRef>task_33a</flowNodeRef>
        <flowNodeRef>task_33b</flowNodeRef>
        <flowNodeRef>task_33c</flowNodeRef>
        <flowNodeRef>task_33d</flowNodeRef>
        <flowNodeRef>parGw_33_join</flowNodeRef>
        <flowNodeRef>xorGw_phased</flowNodeRef>
        <flowNodeRef>task_phases</flowNodeRef>
        <flowNodeRef>xorGw_phased_merge</flowNodeRef>
        <flowNodeRef>task_document</flowNodeRef>
        <flowNodeRef>xorGw_highRisk</flowNodeRef>
        <flowNodeRef>endEvent_c2</flowNodeRef>
        <flowNodeRef>parGw_34_fork</flowNodeRef>
        <flowNodeRef>task_34a</flowNodeRef>
        <flowNodeRef>task_34b</flowNodeRef>
        <flowNodeRef>task_34c</flowNodeRef>
        <flowNodeRef>parGw_34_join</flowNodeRef>
        <flowNodeRef>xorGw_exempt</flowNodeRef>
        <flowNodeRef>endEvent_c3</flowNodeRef>
        <flowNodeRef>task_communicate</flowNodeRef>
        <flowNodeRef>endEvent_c4</flowNodeRef>
      </lane>
    </laneSet>

    <startEvent id="startEvent_c" name="Receive breach notification">
      <outgoing>sf_c1</outgoing>
      <messageEventDefinition id="msgEvtDef_c"/>
    </startEvent>

    <exclusiveGateway id="xorGw_risk" name="Breach likely to result in risk?" gatewayDirection="Diverging">
      <incoming>sf_c1</incoming>
      <outgoing>sf_c2</outgoing>
      <outgoing>sf_c3</outgoing>
    </exclusiveGateway>

    <task id="task_notifySA" name="Notify personal data breach to supervisory authority">
      <incoming>sf_c2</incoming>
      <outgoing>sf_c5</outgoing>
    </task>

    <task id="task_docOnly" name="Document breach (no risk to rights and freedoms)">
      <incoming>sf_c3</incoming>
      <outgoing>sf_c4</outgoing>
    </task>

    <endEvent id="endEvent_c1" name="End (no risk)">
      <incoming>sf_c4</incoming>
    </endEvent>

    <exclusiveGateway id="xorGw_72h" name="Notification within 72 hours?" gatewayDirection="Diverging">
      <incoming>sf_c5</incoming>
      <outgoing>sf_c6</outgoing>
      <outgoing>sf_c7</outgoing>
    </exclusiveGateway>

    <task id="task_delayReasons" name="Accompany notification with reasons for delay">
      <incoming>sf_c6</incoming>
      <outgoing>sf_c8</outgoing>
    </task>

    <exclusiveGateway id="xorGw_72h_merge" name="" gatewayDirection="Converging">
      <incoming>sf_c7</incoming>
      <incoming>sf_c8</incoming>
      <outgoing>sf_c9</outgoing>
    </exclusiveGateway>

    <parallelGateway id="parGw_33_fork" name="" gatewayDirection="Diverging">
      <incoming>sf_c9</incoming>
      <outgoing>sf_c10</outgoing>
      <outgoing>sf_c11</outgoing>
      <outgoing>sf_c12</outgoing>
      <outgoing>sf_c13</outgoing>
    </parallelGateway>

    <task id="task_33a" name="Describe nature of breach, categories and number of data subjects and records">
      <incoming>sf_c10</incoming>
      <outgoing>sf_c14</outgoing>
    </task>

    <task id="task_33b" name="Communicate name and contact details of DPO">
      <incoming>sf_c11</incoming>
      <outgoing>sf_c15</outgoing>
    </task>

    <task id="task_33c" name="Describe likely consequences of breach">
      <incoming>sf_c12</incoming>
      <outgoing>sf_c16</outgoing>
    </task>

    <task id="task_33d" name="Describe measures taken or proposed to address breach">
      <incoming>sf_c13</incoming>
      <outgoing>sf_c17</outgoing>
    </task>

    <parallelGateway id="parGw_33_join" name="" gatewayDirection="Converging">
      <incoming>sf_c14</incoming>
      <incoming>sf_c15</incoming>
      <incoming>sf_c16</incoming>
      <incoming>sf_c17</incoming>
      <outgoing>sf_c18</outgoing>
    </parallelGateway>

    <exclusiveGateway id="xorGw_phased" name="All information available at same time?" gatewayDirection="Diverging">
      <incoming>sf_c18</incoming>
      <outgoing>sf_c19</outgoing>
      <outgoing>sf_c20</outgoing>
    </exclusiveGateway>

    <task id="task_phases" name="Provide information in phases without undue further delay">
      <incoming>sf_c19</incoming>
      <outgoing>sf_c21</outgoing>
    </task>

    <exclusiveGateway id="xorGw_phased_merge" name="" gatewayDirection="Converging">
      <incoming>sf_c20</incoming>
      <incoming>sf_c21</incoming>
      <outgoing>sf_c22</outgoing>
    </exclusiveGateway>

    <task id="task_document" name="Document personal data breach, effects and remedial action">
      <incoming>sf_c22</incoming>
      <outgoing>sf_c23</outgoing>
    </task>

    <exclusiveGateway id="xorGw_highRisk" name="High risk to rights and freedoms?" gatewayDirection="Diverging">
      <incoming>sf_c23</incoming>
      <outgoing>sf_c24</outgoing>
      <outgoing>sf_c25</outgoing>
    </exclusiveGateway>

    <endEvent id="endEvent_c2" name="End (no high risk)">
      <incoming>sf_c24</incoming>
    </endEvent>

    <parallelGateway id="parGw_34_fork" name="" gatewayDirection="Diverging">
      <incoming>sf_c25</incoming>
      <outgoing>sf_c26</outgoing>
      <outgoing>sf_c27</outgoing>
      <outgoing>sf_c28</outgoing>
    </parallelGateway>

    <task id="task_34a" name="Check if appropriate technical and organisational protection measures were applied">
      <incoming>sf_c26</incoming>
      <outgoing>sf_c29</outgoing>
    </task>

    <task id="task_34b" name="Check if subsequent measures ensure high risk no longer likely to materialise">
      <incoming>sf_c27</incoming>
      <outgoing>sf_c30</outgoing>
    </task>

    <task id="task_34c" name="Assess if communication would involve disproportionate effort">
      <incoming>sf_c28</incoming>
      <outgoing>sf_c31</outgoing>
    </task>

    <parallelGateway id="parGw_34_join" name="" gatewayDirection="Converging">
      <incoming>sf_c29</incoming>
      <incoming>sf_c30</incoming>
      <incoming>sf_c31</incoming>
      <outgoing>sf_c32</outgoing>
    </parallelGateway>

    <exclusiveGateway id="xorGw_exempt" name="Any exemption condition met?" gatewayDirection="Diverging">
      <incoming>sf_c32</incoming>
      <outgoing>sf_c33</outgoing>
      <outgoing>sf_c34</outgoing>
    </exclusiveGateway>

    <endEvent id="endEvent_c3" name="End (exemption applies)">
      <incoming>sf_c33</incoming>
    </endEvent>

    <task id="task_communicate" name="Communicate personal data breach to data subject">
      <incoming>sf_c34</incoming>
      <outgoing>sf_c35</outgoing>
    </task>

    <endEvent id="endEvent_c4" name="End">
      <incoming>sf_c35</incoming>
    </endEvent>

    <sequenceFlow id="sf_c1" sourceRef="startEvent_c" targetRef="xorGw_risk"/>
    <sequenceFlow id="sf_c2" name="Yes" sourceRef="xorGw_risk" targetRef="task_notifySA"/>
    <sequenceFlow id="sf_c3" name="No (unlikely risk)" sourceRef="xorGw_risk" targetRef="task_docOnly"/>
    <sequenceFlow id="sf_c4" sourceRef="task_docOnly" targetRef="endEvent_c1"/>
    <sequenceFlow id="sf_c5" sourceRef="task_notifySA" targetRef="xorGw_72h"/>
    <sequenceFlow id="sf_c6" name="No (after 72h)" sourceRef="xorGw_72h" targetRef="task_delayReasons"/>
    <sequenceFlow id="sf_c7" name="Yes" sourceRef="xorGw_72h" targetRef="xorGw_72h_merge"/>
    <sequenceFlow id="sf_c8" sourceRef="task_delayReasons" targetRef="xorGw_72h_merge"/>
    <sequenceFlow id="sf_c9" sourceRef="xorGw_72h_merge" targetRef="parGw_33_fork"/>
    <sequenceFlow id="sf_c10" sourceRef="parGw_33_fork" targetRef="task_33a"/>
    <sequenceFlow id="sf_c11" sourceRef="parGw_33_fork" targetRef="task_33b"/>
    <sequenceFlow id="sf_c12" sourceRef="parGw_33_fork" targetRef="task_33c"/>
    <sequenceFlow id="sf_c13" sourceRef="parGw_33_fork" targetRef="task_33d"/>
    <sequenceFlow id="sf_c14" sourceRef="task_33a" targetRef="parGw_33_join"/>
    <sequenceFlow id="sf_c15" sourceRef="task_33b" targetRef="parGw_33_join"/>
    <sequenceFlow id="sf_c16" sourceRef="task_33c" targetRef="parGw_33_join"/>
    <sequenceFlow id="sf_c17" sourceRef="task_33d" targetRef="parGw_33_join"/>
    <sequenceFlow id="sf_c18" sourceRef="parGw_33_join" targetRef="xorGw_phased"/>
    <sequenceFlow id="sf_c19" name="No" sourceRef="xorGw_phased" targetRef="task_phases"/>
    <sequenceFlow id="sf_c20" name="Yes" sourceRef="xorGw_phased" targetRef="xorGw_phased_merge"/>
    <sequenceFlow id="sf_c21" sourceRef="task_phases" targetRef="xorGw_phased_merge"/>
    <sequenceFlow id="sf_c22" sourceRef="xorGw_phased_merge" targetRef="task_document"/>
    <sequenceFlow id="sf_c23" sourceRef="task_document" targetRef="xorGw_highRisk"/>
    <sequenceFlow id="sf_c24" name="No" sourceRef="xorGw_highRisk" targetRef="endEvent_c2"/>
    <sequenceFlow id="sf_c25" name="Yes" sourceRef="xorGw_highRisk" targetRef="parGw_34_fork"/>
    <sequenceFlow id="sf_c26" sourceRef="parGw_34_fork" targetRef="task_34a"/>
    <sequenceFlow id="sf_c27" sourceRef="parGw_34_fork" targetRef="task_34b"/>
    <sequenceFlow id="sf_c28" sourceRef="parGw_34_fork" targetRef="task_34c"/>
    <sequenceFlow id="sf_c29" sourceRef="task_34a" targetRef="parGw_34_join"/>
    <sequenceFlow id="sf_c30" sourceRef="task_34b" targetRef="parGw_34_join"/>
    <sequenceFlow id="sf_c31" sourceRef="task_34c" targetRef="parGw_34_join"/>
    <sequenceFlow id="sf_c32" sourceRef="parGw_34_join" targetRef="xorGw_exempt"/>
    <sequenceFlow id="sf_c33" name="Yes (exempt)" sourceRef="xorGw_exempt" targetRef="endEvent_c3"/>
    <sequenceFlow id="sf_c34" name="No" sourceRef="xorGw_exempt" targetRef="task_communicate"/>
    <sequenceFlow id="sf_c35" sourceRef="task_communicate" targetRef="endEvent_c4"/>
  </process>

  <!-- ======== SUPERVISORY AUTHORITY PROCESS ======== -->
  <process id="proc_sa" name="Supervisory Authority" isExecutable="false" isClosed="false" processType="None">
    <laneSet id="ls_sa">
      <lane id="lane_sa">
        <flowNodeRef>startEvent_sa</flowNodeRef>
        <flowNodeRef>task_verify</flowNodeRef>
        <flowNodeRef>xorGw_communicated</flowNodeRef>
        <flowNodeRef>task_require</flowNodeRef>
        <flowNodeRef>endEvent_sa1</flowNodeRef>
        <flowNodeRef>endEvent_sa2</flowNodeRef>
      </lane>
    </laneSet>

    <startEvent id="startEvent_sa" name="Receive breach notification">
      <outgoing>sf_sa1</outgoing>
      <messageEventDefinition id="msgEvtDef_sa"/>
    </startEvent>

    <task id="task_verify" name="Verify compliance with Article 33">
      <incoming>sf_sa1</incoming>
      <outgoing>sf_sa2</outgoing>
    </task>

    <exclusiveGateway id="xorGw_communicated" name="Controller communicated to data subject?" gatewayDirection="Diverging">
      <incoming>sf_sa2</incoming>
      <outgoing>sf_sa3</outgoing>
      <outgoing>sf_sa4</outgoing>
    </exclusiveGateway>

    <endEvent id="endEvent_sa1" name="End">
      <incoming>sf_sa3</incoming>
    </endEvent>

    <task id="task_require" name="Require controller to communicate breach to data subject or decide exemption conditions are met">
      <incoming>sf_sa4</incoming>
      <outgoing>sf_sa5</outgoing>
    </task>

    <endEvent id="endEvent_sa2" name="End">
      <incoming>sf_sa5</incoming>
    </endEvent>

    <sequenceFlow id="sf_sa1" sourceRef="startEvent_sa" targetRef="task_verify"/>
    <sequenceFlow id="sf_sa2" sourceRef="task_verify" targetRef="xorGw_communicated"/>
    <sequenceFlow id="sf_sa3" name="Yes" sourceRef="xorGw_communicated" targetRef="endEvent_sa1"/>
    <sequenceFlow id="sf_sa4" name="No" sourceRef="xorGw_communicated" targetRef="task_require"/>
    <sequenceFlow id="sf_sa5" sourceRef="task_require" targetRef="endEvent_sa2"/>
  </process>

  <!-- ======== DIAGRAM (DI) ======== -->
  <bpmndi:BPMNDiagram id="diagram_1">
    <bpmndi:BPMNPlane bpmnElement="collab_1" id="plane_1">

      <!-- ===== Processor Pool ===== -->
      <bpmndi:BPMNShape bpmnElement="part_processor" id="shape_part_processor" isHorizontal="true">
        <omgdc:Bounds x="60" y="60" width="600" height="120"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="lane_processor" id="shape_lane_processor" isHorizontal="true">
        <omgdc:Bounds x="90" y="60" width="570" height="120"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="startEvent_p" id="shape_startEvent_p">
        <omgdc:Bounds x="150" y="102" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="task_p1" id="shape_task_p1">
        <omgdc:Bounds x="240" y="80" width="200" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="endEvent_p" id="shape_endEvent_p">
        <omgdc:Bounds x="500" y="106" width="28" height="28"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge bpmnElement="sf_p1" id="edge_sf_p1">
        <omgdi:waypoint x="186" y="120"/>
        <omgdi:waypoint x="240" y="120"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="sf_p2" id="edge_sf_p2">
        <omgdi:waypoint x="440" y="120"/>
        <omgdi:waypoint x="500" y="120"/>
      </bpmndi:BPMNEdge>

      <!-- ===== Controller Pool ===== -->
      <bpmndi:BPMNShape bpmnElement="part_controller" id="shape_part_controller" isHorizontal="true">
        <omgdc:Bounds x="60" y="220" width="2480" height="560"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="lane_controller" id="shape_lane_controller" isHorizontal="true">
        <omgdc:Bounds x="90" y="220" width="2450" height="560"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape bpmnElement="startEvent_c" id="shape_startEvent_c">
        <omgdc:Bounds x="150" y="382" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="xorGw_risk" id="shape_xorGw_risk" isMarkerVisible="true">
        <omgdc:Bounds x="235" y="375" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="task_notifySA" id="shape_task_notifySA">
        <omgdc:Bounds x="330" y="360" width="180" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="task_docOnly" id="shape_task_docOnly">
        <omgdc:Bounds x="330" y="600" width="180" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="endEvent_c1" id="shape_endEvent_c1">
        <omgdc:Bounds x="570" y="626" width="28" height="28"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="xorGw_72h" id="shape_xorGw_72h" isMarkerVisible="true">
        <omgdc:Bounds x="555" y="375" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="task_delayReasons" id="shape_task_delayReasons">
        <omgdc:Bounds x="620" y="260" width="180" height="70"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="xorGw_72h_merge" id="shape_xorGw_72h_merge" isMarkerVisible="true">
        <omgdc:Bounds x="770" y="375" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="parGw_33_fork" id="shape_parGw_33_fork">
        <omgdc:Bounds x="855" y="375" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="task_33a" id="shape_task_33a">
        <omgdc:Bounds x="940" y="250" width="200" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="task_33b" id="shape_task_33b">
        <omgdc:Bounds x="940" y="330" width="200" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="task_33c" id="shape_task_33c">
        <omgdc:Bounds x="940" y="410" width="200" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="task_33d" id="shape_task_33d">
        <omgdc:Bounds x="940" y="490" width="200" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="parGw_33_join" id="shape_parGw_33_join">
        <omgdc:Bounds x="1175" y="375" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="xorGw_phased" id="shape_xorGw_phased" isMarkerVisible="true">
        <omgdc:Bounds x="1260" y="375" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="task_phases" id="shape_task_phases">
        <omgdc:Bounds x="1330" y="260" width="180" height="70"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="xorGw_phased_merge" id="shape_xorGw_phased_merge" isMarkerVisible="true">
        <omgdc:Bounds x="1475" y="375" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="task_document" id="shape_task_document">
        <omgdc:Bounds x="1560" y="360" width="180" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="xorGw_highRisk" id="shape_xorGw_highRisk" isMarkerVisible="true">
        <omgdc:Bounds x="1775" y="375" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="endEvent_c2" id="shape_endEvent_c2">
        <omgdc:Bounds x="1786" y="626" width="28" height="28"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="parGw_34_fork" id="shape_parGw_34_fork">
        <omgdc:Bounds x="1860" y="375" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="task_34a" id="shape_task_34a">
        <omgdc:Bounds x="1945" y="270" width="200" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="task_34b" id="shape_task_34b">
        <omgdc:Bounds x="1945" y="370" width="200" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="task_34c" id="shape_task_34c">
        <omgdc:Bounds x="1945" y="460" width="200" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="parGw_34_join" id="shape_parGw_34_join">
        <omgdc:Bounds x="2180" y="375" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="xorGw_exempt" id="shape_xorGw_exempt" isMarkerVisible="true">
        <omgdc:Bounds x="2265" y="375" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="endEvent_c3" id="shape_endEvent_c3">
        <omgdc:Bounds x="2276" y="276" width="28" height="28"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="task_communicate" id="shape_task_communicate">
        <omgdc:Bounds x="2350" y="360" width="180" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="endEvent_c4" id="shape_endEvent_c4">
        <omgdc:Bounds x="2426" y="626" width="28" height="28"/>
      </bpmndi:BPMNShape>

      <!-- Controller sequence flow edges -->
