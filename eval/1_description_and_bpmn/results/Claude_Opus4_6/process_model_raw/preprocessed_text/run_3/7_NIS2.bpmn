<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             id="definitions_1"
             targetNamespace="http://www.signavio.com"
             expressionLanguage="http://www.w3.org/TR/XPath"
             typeLanguage="http://www.w3.org/2001/XMLSchema"
             xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd">

   <!-- ============ COLLABORATION ============ -->
   <collaboration id="collab_1">
      <participant id="pool_entities" name="Essential and Important Entities" processRef="proc_entities"/>
      <participant id="pool_csirt" name="CSIRT / Competent Authority" processRef="proc_csirt"/>
      <participant id="pool_spoc" name="Single Point of Contact" processRef="proc_spoc"/>
      <participant id="pool_enisa" name="ENISA" processRef="proc_enisa"/>
      <participant id="pool_commission" name="Commission" processRef="proc_commission"/>

      <!-- Message flows between pools -->
      <messageFlow id="mf_notify_csirt" name="Significant incident notification" sourceRef="task_notify_csirt" targetRef="start_csirt_receive"/>
      <messageFlow id="mf_early_warning" name="Early warning" sourceRef="task_submit_early_warning" targetRef="task_provide_response"/>
      <messageFlow id="mf_forward_to_csirt" name="Forward notification" sourceRef="task_forward_to_csirt" targetRef="task_provide_response"/>
      <messageFlow id="mf_inform_ms_enisa" name="Inform ENISA" sourceRef="task_inform_other_ms" targetRef="start_enisa"/>
      <messageFlow id="mf_forward_spoc" name="Forward to other SPOCs" sourceRef="task_csirt_to_spoc" targetRef="start_spoc_forward"/>
      <messageFlow id="mf_summary_enisa" name="Summary report" sourceRef="task_submit_summary" targetRef="task_enisa_receive_summary"/>
   </collaboration>

   <!-- ============ PROCESS: Essential and Important Entities ============ -->
   <process id="proc_entities" name="Essential and Important Entities" isExecutable="false" isClosed="false" processType="None">
      <laneSet id="ls_entities">
         <lane id="lane_entities" name="Entities">
            <flowNodeRef>start_entities</flowNodeRef>
            <flowNodeRef>task_notify_csirt</flowNodeRef>
            <flowNodeRef>task_notify_recipients</flowNodeRef>
            <flowNodeRef>task_report_crossborder</flowNodeRef>
            <flowNodeRef>task_communicate_measures</flowNodeRef>
            <flowNodeRef>gw_par_split_significance</flowNodeRef>
            <flowNodeRef>task_assess_operational</flowNodeRef>
            <flowNodeRef>task_assess_damage</flowNodeRef>
            <flowNodeRef>gw_par_join_significance</flowNodeRef>
            <flowNodeRef>gw_par_split_reports</flowNodeRef>
            <flowNodeRef>task_submit_early_warning</flowNodeRef>
            <flowNodeRef>task_submit_incident_notif</flowNodeRef>
            <flowNodeRef>task_submit_intermediate</flowNodeRef>
            <flowNodeRef>task_submit_final_report</flowNodeRef>
            <flowNodeRef>task_submit_progress</flowNodeRef>
            <flowNodeRef>gw_par_join_reports</flowNodeRef>
            <flowNodeRef>end_entities</flowNodeRef>
         </lane>
      </laneSet>

      <startEvent id="start_entities" name="Significant incident detected">
         <outgoing>sf_e1</outgoing>
      </startEvent>
      <task completionQuantity="1" id="task_notify_csirt" isForCompensation="false" name="Notify CSIRT or competent authority of significant incident" startQuantity="1">
         <incoming>sf_e1</incoming>
         <outgoing>sf_e2</outgoing>
      </task>
      <task completionQuantity="1" id="task_notify_recipients" isForCompensation="false" name="Notify recipients of services of significant incidents" startQuantity="1">
         <incoming>sf_e2</incoming>
         <outgoing>sf_e3</outgoing>
      </task>
      <task completionQuantity="1" id="task_report_crossborder" isForCompensation="false" name="Report information on cross-border impact of incident" startQuantity="1">
         <incoming>sf_e3</incoming>
         <outgoing>sf_e4</outgoing>
      </task>
      <task completionQuantity="1" id="task_communicate_measures" isForCompensation="false" name="Communicate measures or remedies to affected recipients" startQuantity="1">
         <incoming>sf_e4</incoming>
         <outgoing>sf_e5</outgoing>
      </task>

      <parallelGateway id="gw_par_split_significance" name="" gatewayDirection="Diverging">
         <incoming>sf_e5</incoming>
         <outgoing>sf_e6a</outgoing>
         <outgoing>sf_e6b</outgoing>
      </parallelGateway>
      <task completionQuantity="1" id="task_assess_operational" isForCompensation="false" name="Assess if incident caused severe operational disruption or financial loss" startQuantity="1">
         <incoming>sf_e6a</incoming>
         <outgoing>sf_e7a</outgoing>
      </task>
      <task completionQuantity="1" id="task_assess_damage" isForCompensation="false" name="Assess if incident affected persons causing material or non-material damage" startQuantity="1">
         <incoming>sf_e6b</incoming>
         <outgoing>sf_e7b</outgoing>
      </task>
      <parallelGateway id="gw_par_join_significance" name="" gatewayDirection="Converging">
         <incoming>sf_e7a</incoming>
         <incoming>sf_e7b</incoming>
         <outgoing>sf_e8</outgoing>
      </parallelGateway>

      <parallelGateway id="gw_par_split_reports" name="" gatewayDirection="Diverging">
         <incoming>sf_e8</incoming>
         <outgoing>sf_e9a</outgoing>
         <outgoing>sf_e9b</outgoing>
         <outgoing>sf_e9c</outgoing>
         <outgoing>sf_e9d</outgoing>
         <outgoing>sf_e9e</outgoing>
      </parallelGateway>
      <task completionQuantity="1" id="task_submit_early_warning" isForCompensation="false" name="Submit early warning within 24 hours" startQuantity="1">
         <incoming>sf_e9a</incoming>
         <outgoing>sf_e10a</outgoing>
      </task>
      <task completionQuantity="1" id="task_submit_incident_notif" isForCompensation="false" name="Submit incident notification within 72 hours" startQuantity="1">
         <incoming>sf_e9b</incoming>
         <outgoing>sf_e10b</outgoing>
      </task>
      <task completionQuantity="1" id="task_submit_intermediate" isForCompensation="false" name="Submit intermediate report on relevant status updates" startQuantity="1">
         <incoming>sf_e9c</incoming>
         <outgoing>sf_e10c</outgoing>
      </task>
      <task completionQuantity="1" id="task_submit_final_report" isForCompensation="false" name="Submit final report within one month" startQuantity="1">
         <incoming>sf_e9d</incoming>
         <outgoing>sf_e10d</outgoing>
      </task>
      <task completionQuantity="1" id="task_submit_progress" isForCompensation="false" name="Submit progress report if incident ongoing" startQuantity="1">
         <incoming>sf_e9e</incoming>
         <outgoing>sf_e10e</outgoing>
      </task>
      <parallelGateway id="gw_par_join_reports" name="" gatewayDirection="Converging">
         <incoming>sf_e10a</incoming>
         <incoming>sf_e10b</incoming>
         <incoming>sf_e10c</incoming>
         <incoming>sf_e10d</incoming>
         <incoming>sf_e10e</incoming>
         <outgoing>sf_e11</outgoing>
      </parallelGateway>
      <endEvent id="end_entities" name="End">
         <incoming>sf_e11</incoming>
      </endEvent>

      <sequenceFlow id="sf_e1" sourceRef="start_entities" targetRef="task_notify_csirt"/>
      <sequenceFlow id="sf_e2" sourceRef="task_notify_csirt" targetRef="task_notify_recipients"/>
      <sequenceFlow id="sf_e3" sourceRef="task_notify_recipients" targetRef="task_report_crossborder"/>
      <sequenceFlow id="sf_e4" sourceRef="task_report_crossborder" targetRef="task_communicate_measures"/>
      <sequenceFlow id="sf_e5" sourceRef="task_communicate_measures" targetRef="gw_par_split_significance"/>
      <sequenceFlow id="sf_e6a" sourceRef="gw_par_split_significance" targetRef="task_assess_operational"/>
      <sequenceFlow id="sf_e6b" sourceRef="gw_par_split_significance" targetRef="task_assess_damage"/>
      <sequenceFlow id="sf_e7a" sourceRef="task_assess_operational" targetRef="gw_par_join_significance"/>
      <sequenceFlow id="sf_e7b" sourceRef="task_assess_damage" targetRef="gw_par_join_significance"/>
      <sequenceFlow id="sf_e8" sourceRef="gw_par_join_significance" targetRef="gw_par_split_reports"/>
      <sequenceFlow id="sf_e9a" sourceRef="gw_par_split_reports" targetRef="task_submit_early_warning"/>
      <sequenceFlow id="sf_e9b" sourceRef="gw_par_split_reports" targetRef="task_submit_incident_notif"/>
      <sequenceFlow id="sf_e9c" sourceRef="gw_par_split_reports" targetRef="task_submit_intermediate"/>
      <sequenceFlow id="sf_e9d" sourceRef="gw_par_split_reports" targetRef="task_submit_final_report"/>
      <sequenceFlow id="sf_e9e" sourceRef="gw_par_split_reports" targetRef="task_submit_progress"/>
      <sequenceFlow id="sf_e10a" sourceRef="task_submit_early_warning" targetRef="gw_par_join_reports"/>
      <sequenceFlow id="sf_e10b" sourceRef="task_submit_incident_notif" targetRef="gw_par_join_reports"/>
      <sequenceFlow id="sf_e10c" sourceRef="task_submit_intermediate" targetRef="gw_par_join_reports"/>
      <sequenceFlow id="sf_e10d" sourceRef="task_submit_final_report" targetRef="gw_par_join_reports"/>
      <sequenceFlow id="sf_e10e" sourceRef="task_submit_progress" targetRef="gw_par_join_reports"/>
      <sequenceFlow id="sf_e11" sourceRef="gw_par_join_reports" targetRef="end_entities"/>
   </process>

   <!-- ============ PROCESS: CSIRT / Competent Authority ============ -->
   <process id="proc_csirt" name="CSIRT / Competent Authority" isExecutable="false" isClosed="false" processType="None">
      <laneSet id="ls_csirt">
         <lane id="lane_csirt" name="CSIRT / Competent Authority">
            <flowNodeRef>start_csirt_receive</flowNodeRef>
            <flowNodeRef>task_forward_to_csirt</flowNodeRef>
            <flowNodeRef>task_provide_response</flowNodeRef>
            <flowNodeRef>task_provide_tech_support</flowNodeRef>
            <flowNodeRef>task_guidance_law_enforcement</flowNodeRef>
            <flowNodeRef>task_inform_other_ms</flowNodeRef>
            <flowNodeRef>task_inform_public</flowNodeRef>
            <flowNodeRef>task_provide_info_competent</flowNodeRef>
            <flowNodeRef>task_csirt_to_spoc</flowNodeRef>
            <flowNodeRef>end_csirt</flowNodeRef>
         </lane>
      </laneSet>

      <startEvent id="start_csirt_receive" name="Receive significant incident notification">
         <outgoing>sf_c1</outgoing>
         <messageEventDefinition id="msg_def_csirt"/>
      </startEvent>
      <task completionQuantity="1" id="task_forward_to_csirt" isForCompensation="false" name="Forward notification to CSIRT upon receipt" startQuantity="1">
         <incoming>sf_c1</incoming>
         <outgoing>sf_c2</outgoing>
      </task>
      <task completionQuantity="1" id="task_provide_response" isForCompensation="false" name="Provide response and initial feedback within 24 hours" startQuantity="1">
         <incoming>sf_c2</incoming>
         <outgoing>sf_c3</outgoing>
      </task>
      <task completionQuantity="1" id="task_provide_tech_support" isForCompensation="false" name="Provide additional technical support upon request" startQuantity="1">
         <incoming>sf_c3</incoming>
         <outgoing>sf_c4</outgoing>
      </task>
      <task completionQuantity="1" id="task_guidance_law_enforcement" isForCompensation="false" name="Provide guidance on reporting to law enforcement authorities" startQuantity="1">
         <incoming>sf_c4</incoming>
         <outgoing>sf_c5</outgoing>
      </task>
      <task completionQuantity="1" id="task_inform_other_ms" isForCompensation="false" name="Inform other affected Member States and ENISA of significant incident" startQuantity="1">
         <incoming>sf_c5</incoming>
         <outgoing>sf_c6</outgoing>
      </task>
      <task completionQuantity="1" id="task_inform_public" isForCompensation="false" name="Inform public about significant incident or require entity to do so" startQuantity="1">
         <incoming>sf_c6</incoming>
         <outgoing>sf_c7</outgoing>
      </task>
      <task completionQuantity="1" id="task_provide_info_competent" isForCompensation="false" name="Provide information on significant incidents to competent authorities" startQuantity="1">
         <incoming>sf_c7</incoming>
         <outgoing>sf_c8</outgoing>
      </task>
      <task completionQuantity="1" id="task_csirt_to_spoc" isForCompensation="false" name="Request single point of contact to forward notifications" startQuantity="1">
         <incoming>sf_c8</incoming>
         <outgoing>sf_c9</outgoing>
      </task>
      <endEvent id="end_csirt" name="End">
         <incoming>sf_c9</incoming>
      </endEvent>

      <sequenceFlow id="sf_c1" sourceRef="start_csirt_receive" targetRef="task_forward_to_csirt"/>
      <sequenceFlow id="sf_c2" sourceRef="task_forward_to_csirt" targetRef="task_provide_response"/>
      <sequenceFlow id="sf_c3" sourceRef="task_provide_response" targetRef="task_provide_tech_support"/>
      <sequenceFlow id="sf_c4" sourceRef="task_provide_tech_support" targetRef="task_guidance_law_enforcement"/>
      <sequenceFlow id="sf_c5" sourceRef="task_guidance_law_enforcement" targetRef="task_inform_other_ms"/>
      <sequenceFlow id="sf_c6" sourceRef="task_inform_other_ms" targetRef="task_inform_public"/>
      <sequenceFlow id="sf_c7" sourceRef="task_inform_public" targetRef="task_provide_info_competent"/>
      <sequenceFlow id="sf_c8" sourceRef="task_provide_info_competent" targetRef="task_csirt_to_spoc"/>
      <sequenceFlow id="sf_c9" sourceRef="task_csirt_to_spoc" targetRef="end_csirt"/>
   </process>

   <!-- ============ PROCESS: Single Point of Contact ============ -->
   <process id="proc_spoc" name="Single Point of Contact" isExecutable="false" isClosed="false" processType="None">
      <laneSet id="ls_spoc">
         <lane id="lane_spoc" name="Single Point of Contact">
            <flowNodeRef>start_spoc_forward</flowNodeRef>
            <flowNodeRef>task_forward_notifications</flowNodeRef>
            <flowNodeRef>task_submit_summary</flowNodeRef>
            <flowNodeRef>end_spoc</flowNodeRef>
         </lane>
      </laneSet>

      <startEvent id="start_spoc_forward" name="Receive forwarding request">
         <outgoing>sf_s1</outgoing>
         <messageEventDefinition id="msg_def_spoc"/>
      </startEvent>
      <task completionQuantity="1" id="task_forward_notifications" isForCompensation="false" name="Forward notifications to single points of contact of other affected Member States" startQuantity="1">
         <incoming>sf_s1</incoming>
         <outgoing>sf_s2</outgoing>
      </task>
      <task completionQuantity="1" id="task_submit_summary" isForCompensation="false" name="Submit summary report to ENISA every three months" startQuantity="1">
         <incoming>sf_s2</incoming>
         <outgoing>sf_s3</outgoing>
      </task>
      <endEvent id="end_spoc" name="End">
         <incoming>sf_s3</incoming>
      </endEvent>

      <sequenceFlow id="sf_s1" sourceRef="start_spoc_forward" targetRef="task_forward_notifications"/>
      <sequenceFlow id="sf_s2" sourceRef="task_forward_notifications" targetRef="task_submit_summary"/>
      <sequenceFlow id="sf_s3" sourceRef="task_submit_summary" targetRef="end_spoc"/>
   </process>

   <!-- ============ PROCESS: ENISA ============ -->
   <process id="proc_enisa" name="ENISA" isExecutable="false" isClosed="false" processType="None">
      <laneSet id="ls_enisa">
         <lane id="lane_enisa" name="ENISA">
            <flowNodeRef>start_enisa</flowNodeRef>
            <flowNodeRef>task_enisa_receive_summary</flowNodeRef>
            <flowNodeRef>task_adopt_technical_guidance</flowNodeRef>
            <flowNodeRef>task_inform_coop_group</flowNodeRef>
            <flowNodeRef>end_enisa</flowNodeRef>
         </lane>
      </laneSet>

      <startEvent id="start_enisa" name="Receive information on significant incident">
         <outgoing>sf_n1</outgoing>
         <messageEventDefinition id="msg_def_enisa"/>
      </startEvent>
      <task completionQuantity="1" id="task_enisa_receive_summary" isForCompensation="false" name="Receive summary report from single point of contact" startQuantity="1">
         <incoming>sf_n1</incoming>
         <outgoing>sf_n2</outgoing>
      </task>
      <task completionQuantity="1" id="task_adopt_technical_guidance" isForCompensation="false" name="Adopt technical guidance on information parameters" startQuantity="1">
         <incoming>sf_n2</incoming>
         <outgoing>sf_n3</outgoing>
      </task>
      <task completionQuantity="1" id="task_inform_coop_group" isForCompensation="false" name="Inform Cooperation Group and CSIRTs network every six months" startQuantity="1">
         <incoming>sf_n3</incoming>
         <outgoing>sf_n4</outgoing>
      </task>
      <endEvent id="end_enisa" name="End">
         <incoming>sf_n4</incoming>
      </endEvent>

      <sequenceFlow id="sf_n1" sourceRef="start_enisa" targetRef="task_enisa_receive_summary"/>
      <sequenceFlow id="sf_n2" sourceRef="task_enisa_receive_summary" targetRef="task_adopt_technical_guidance"/>
      <sequenceFlow id="sf_n3" sourceRef="task_adopt_technical_guidance" targetRef="task_inform_coop_group"/>
      <sequenceFlow id="sf_n4" sourceRef="task_inform_coop_group" targetRef="end_enisa"/>
   </process>

   <!-- ============ PROCESS: Commission ============ -->
   <process id="proc_commission" name="Commission" isExecutable="false" isClosed="false" processType="None">
      <laneSet id="ls_commission">
         <lane id="lane_commission" name="Commission">
            <flowNodeRef>start_commission</flowNodeRef>
            <flowNodeRef>task_adopt_implementing_acts</flowNodeRef>
            <flowNodeRef>task_adopt_specific_acts</flowNodeRef>
            <flowNodeRef>task_cooperate_coop_group</flowNodeRef>
            <flowNodeRef>end_commission</flowNodeRef>
         </lane>
      </laneSet>

      <startEvent id="start_commission" name="Start">
         <outgoing>sf_m1</outgoing>
      </startEvent>
      <task completionQuantity="1" id="task_adopt_implementing_acts" isForCompensation="false" name="Adopt implementing acts specifying information type, format, and procedure" startQuantity="1">
         <incoming>sf_m1</incoming>
         <outgoing>sf_m2</outgoing>
      </task>
      <task completionQuantity="1" id="task_adopt_specific_acts" isForCompensation="false" name="Adopt implementing acts for specific service providers by 17 October 2024" startQuantity="1">
         <incoming>sf_m2</incoming>
         <outgoing>sf_m3</outgoing>
      </task>
      <task completionQuantity="1" id="task_cooperate_coop_group" isForCompensation="false" name="Exchange advice and cooperate with Cooperation Group on draft implementing acts" startQuantity="1">
         <incoming>sf_m3</incoming>
         <outgoing>sf_m4</outgoing>
      </task>
      <endEvent id="end_commission" name="End">
         <incoming>sf_m4</incoming>
      </endEvent>

      <sequenceFlow id="sf_m1" sourceRef="start_commission" targetRef="task_adopt_implementing_acts"/>
      <sequenceFlow id="sf_m2" sourceRef="task_adopt_implementing_acts" targetRef="task_adopt_specific_acts"/>
      <sequenceFlow id="sf_m3" sourceRef="task_adopt_specific_acts" targetRef="task_cooperate_coop_group"/>
      <sequenceFlow id="sf_m4" sourceRef="task_cooperate_coop_group" targetRef="end_commission"/>
   </process>

   <!-- ============ DIAGRAM (DI) ============ -->
   <bpmndi:BPMNDiagram id="diagram_1">
      <bpmndi:BPMNPlane bpmnElement="collab_1" id="plane_1">

         <!-- ===== POOL: Entities ===== -->
         <bpmndi:BPMNShape bpmnElement="pool_entities" id="pool_entities_gui" isHorizontal="true">
            <omgdc:Bounds height="420.0" width="1900.0" x="60.0" y="60.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="lane_entities" id="lane_entities_gui" isHorizontal="true">
            <omgdc:Bounds height="420.0" width="1870.0" x="90.0" y="60.0"/>
         </bpmndi:BPMNShape>

         <bpmndi:BPMNShape bpmnElement="start_entities" id="start_entities_gui">
            <omgdc:Bounds height="30.0" width="30.0" x="120.0" y="175.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_notify_csirt" id="task_notify_csirt_gui">
            <omgdc:Bounds height="80.0" width="120.0" x="185.0" y="150.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_notify_recipients" id="task_notify_recipients_gui">
            <omgdc:Bounds height="80.0" width="120.0" x="340.0" y="150.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_report_crossborder" id="task_report_crossborder_gui">
            <omgdc:Bounds height="80.0" width="120.0" x="495.0" y="150.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_communicate_measures" id="task_communicate_measures_gui">
            <omgdc:Bounds height="80.0" width="120.0" x="650.0" y="150.0"/>
         </bpmndi:BPMNShape>

         <bpmndi:BPMNShape bpmnElement="gw_par_split_significance" id="gw_par_split_significance_gui" isMarkerVisible="true">
            <omgdc:Bounds height="40.0" width="40.0" x="810.0" y="170.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_assess_operational" id="task_assess_operational_gui">
            <omgdc:Bounds height="80.0" width="140.0" x="885.0" y="100.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_assess_damage" id="task_assess_damage_gui">
            <omgdc:Bounds height="80.0" width="140.0" x="885.0" y="220.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="gw_par_join_significance" id="gw_par_join_significance_gui" isMarkerVisible="true">
            <omgdc:Bounds height="40.0" width="40.0" x="1060.0" y="170.0"/>
         </bpmndi:BPMNShape>

         <bpmndi:BPMNShape bpmnElement="gw_par_split_reports" id="gw_par_split_reports_gui" isMarkerVisible="true">
            <omgdc:Bounds height="40.0" width="40.0" x="1140.0" y="170.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_submit_early_warning" id="task_submit_early_warning_gui">
            <omgdc:Bounds height="60.0" width="150.0" x="1230.0" y="80.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_submit_incident_notif" id="task_submit_incident_notif_gui">
            <omgdc:Bounds height="60.0" width="150.0" x="1230.0" y="160.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_submit_intermediate" id="task_submit_intermediate_gui">
            <omgdc:Bounds height="60.0" width="150.0" x="1230.0" y="240.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_submit_final_report" id="task_submit_final_report_gui">
            <omgdc:Bounds height="60.0" width="150.0" x="1230.0" y="320.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_submit_progress" id="task_submit_progress_gui">
            <omgdc:Bounds height="60.0" width="150.0" x="1230.0" y="400.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="gw_par_join_reports" id="gw_par_join_reports_gui" isMarkerVisible="true">
            <omgdc:Bounds height="40.0" width="40.0" x="1430.0" y="170.0"/>
