<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             id="definitions_1"
             targetNamespace="http://www.signavio.com"
             expressionLanguage="http://www.w3.org/TR/XPath"
             typeLanguage="http://www.w3.org/2001/XMLSchema"
             xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd">

   <!-- ==================== COLLABORATION ==================== -->
   <collaboration id="collab_1">
      <participant id="pool_commission" name="Commission" processRef="proc_commission"/>
      <participant id="pool_transferring_ms" name="Transferring Member State" processRef="proc_transferring_ms"/>
      <participant id="pool_responsible_ms" name="Member State Responsible" processRef="proc_responsible_ms"/>
      <participant id="pool_health_prof" name="Health Professional" processRef="proc_health_prof"/>

      <!-- Message flows between pools -->
      <messageFlow id="mf_1" name="health certificate and documents" sourceRef="task_transfer_info_cert" targetRef="start_responsible_ms"/>
      <messageFlow id="mf_2" name="common health certificate" sourceRef="task_draw_up_cert" targetRef="start_transferring_ms"/>
      <messageFlow id="mf_3" name="health data" sourceRef="task_ensure_needs" targetRef="start_health_prof"/>
      <messageFlow id="mf_4" name="uniform conditions" sourceRef="task_adopt_uniform" targetRef="task_exchange_info"/>
   </collaboration>

   <!-- ==================== PROCESS: COMMISSION ==================== -->
   <process id="proc_commission" name="Commission" isExecutable="false" isClosed="false" processType="None">
      <laneSet id="ls_commission">
         <lane id="lane_commission">
            <flowNodeRef>start_commission</flowNodeRef>
            <flowNodeRef>task_draw_up_cert</flowNodeRef>
            <flowNodeRef>task_adopt_impl_acts_1</flowNodeRef>
            <flowNodeRef>task_use_info</flowNodeRef>
            <flowNodeRef>task_adopt_uniform</flowNodeRef>
            <flowNodeRef>task_adopt_impl_acts_2</flowNodeRef>
            <flowNodeRef>end_commission</flowNodeRef>
         </lane>
      </laneSet>
      <startEvent id="start_commission" name="Start">
         <outgoing>sf_c1</outgoing>
      </startEvent>
      <task id="task_draw_up_cert" name="draw up common health certificate">
         <incoming>sf_c1</incoming>
         <outgoing>sf_c2</outgoing>
      </task>
      <task id="task_adopt_impl_acts_1" name="adopt implementing acts">
         <incoming>sf_c2</incoming>
         <outgoing>sf_c3</outgoing>
      </task>
      <task id="task_use_info" name="use exchanged information">
         <incoming>sf_c3</incoming>
         <outgoing>sf_c4</outgoing>
      </task>
      <task id="task_adopt_uniform" name="adopt uniform conditions and practical arrangements">
         <incoming>sf_c4</incoming>
         <outgoing>sf_c5</outgoing>
      </task>
      <task id="task_adopt_impl_acts_2" name="adopt implementing acts">
         <incoming>sf_c5</incoming>
         <outgoing>sf_c6</outgoing>
      </task>
      <endEvent id="end_commission" name="End">
         <incoming>sf_c6</incoming>
      </endEvent>
      <sequenceFlow id="sf_c1" sourceRef="start_commission" targetRef="task_draw_up_cert"/>
      <sequenceFlow id="sf_c2" sourceRef="task_draw_up_cert" targetRef="task_adopt_impl_acts_1"/>
      <sequenceFlow id="sf_c3" sourceRef="task_adopt_impl_acts_1" targetRef="task_use_info"/>
      <sequenceFlow id="sf_c4" sourceRef="task_use_info" targetRef="task_adopt_uniform"/>
      <sequenceFlow id="sf_c5" sourceRef="task_adopt_uniform" targetRef="task_adopt_impl_acts_2"/>
      <sequenceFlow id="sf_c6" sourceRef="task_adopt_impl_acts_2" targetRef="end_commission"/>
   </process>

   <!-- ==================== PROCESS: TRANSFERRING MEMBER STATE ==================== -->
   <process id="proc_transferring_ms" name="Transferring Member State" isExecutable="false" isClosed="false" processType="None">
      <laneSet id="ls_transferring_ms">
         <lane id="lane_transferring_ms">
            <flowNodeRef>start_transferring_ms</flowNodeRef>
            <flowNodeRef>task_obtain_consent</flowNodeRef>
            <flowNodeRef>task_transmit_info</flowNodeRef>
            <flowNodeRef>task_transfer_info_cert</flowNodeRef>
            <flowNodeRef>end_transferring_ms</flowNodeRef>
         </lane>
      </laneSet>
      <startEvent id="start_transferring_ms" name="Receive common health certificate">
         <outgoing>sf_t1</outgoing>
         <messageEventDefinition id="med_start_transferring"/>
      </startEvent>
      <task id="task_obtain_consent" name="obtain explicit consent of applicant">
         <incoming>sf_t1</incoming>
         <outgoing>sf_t2</outgoing>
      </task>
      <task id="task_transmit_info" name="transmit information on special needs">
         <incoming>sf_t2</incoming>
         <outgoing>sf_t3</outgoing>
      </task>
      <task id="task_transfer_info_cert" name="transfer information in common health certificate">
         <incoming>sf_t3</incoming>
         <outgoing>sf_t4</outgoing>
      </task>
      <endEvent id="end_transferring_ms" name="End">
         <incoming>sf_t4</incoming>
      </endEvent>
      <sequenceFlow id="sf_t1" sourceRef="start_transferring_ms" targetRef="task_obtain_consent"/>
      <sequenceFlow id="sf_t2" sourceRef="task_obtain_consent" targetRef="task_transmit_info"/>
      <sequenceFlow id="sf_t3" sourceRef="task_transmit_info" targetRef="task_transfer_info_cert"/>
      <sequenceFlow id="sf_t4" sourceRef="task_transfer_info_cert" targetRef="end_transferring_ms"/>
   </process>

   <!-- ==================== PROCESS: MEMBER STATE RESPONSIBLE ==================== -->
   <process id="proc_responsible_ms" name="Member State Responsible" isExecutable="false" isClosed="false" processType="None">
      <laneSet id="ls_responsible_ms">
         <lane id="lane_responsible_ms">
            <flowNodeRef>start_responsible_ms</flowNodeRef>
            <flowNodeRef>task_ensure_needs</flowNodeRef>
            <flowNodeRef>end_responsible_ms</flowNodeRef>
         </lane>
      </laneSet>
      <startEvent id="start_responsible_ms" name="Receive health certificate and documents">
         <outgoing>sf_r1</outgoing>
         <messageEventDefinition id="med_start_responsible"/>
      </startEvent>
      <task id="task_ensure_needs" name="ensure special needs are adequately addressed">
         <incoming>sf_r1</incoming>
         <outgoing>sf_r2</outgoing>
      </task>
      <endEvent id="end_responsible_ms" name="End">
         <incoming>sf_r2</incoming>
      </endEvent>
      <sequenceFlow id="sf_r1" sourceRef="start_responsible_ms" targetRef="task_ensure_needs"/>
      <sequenceFlow id="sf_r2" sourceRef="task_ensure_needs" targetRef="end_responsible_ms"/>
   </process>

   <!-- ==================== PROCESS: HEALTH PROFESSIONAL ==================== -->
   <process id="proc_health_prof" name="Health Professional" isExecutable="false" isClosed="false" processType="None">
      <laneSet id="ls_health_prof">
         <lane id="lane_health_prof">
            <flowNodeRef>start_health_prof</flowNodeRef>
            <flowNodeRef>task_process_data</flowNodeRef>
            <flowNodeRef>task_exchange_info</flowNodeRef>
            <flowNodeRef>end_health_prof</flowNodeRef>
         </lane>
      </laneSet>
      <startEvent id="start_health_prof" name="Receive health data">
         <outgoing>sf_h1</outgoing>
         <messageEventDefinition id="med_start_health"/>
      </startEvent>
      <task id="task_process_data" name="process personal health data">
         <incoming>sf_h1</incoming>
         <outgoing>sf_h2</outgoing>
      </task>
      <task id="task_exchange_info" name="exchange information">
         <incoming>sf_h2</incoming>
         <outgoing>sf_h3</outgoing>
      </task>
      <endEvent id="end_health_prof" name="End">
         <incoming>sf_h3</incoming>
      </endEvent>
      <sequenceFlow id="sf_h1" sourceRef="start_health_prof" targetRef="task_process_data"/>
      <sequenceFlow id="sf_h2" sourceRef="task_process_data" targetRef="task_exchange_info"/>
      <sequenceFlow id="sf_h3" sourceRef="task_exchange_info" targetRef="end_health_prof"/>
   </process>

   <!-- ==================== DIAGRAM ==================== -->
   <bpmndi:BPMNDiagram id="diagram_1">
      <bpmndi:BPMNPlane bpmnElement="collab_1" id="plane_1">

         <!-- Pool: Commission -->
         <bpmndi:BPMNShape bpmnElement="pool_commission" id="pool_commission_gui" isHorizontal="true">
            <omgdc:Bounds height="160.0" width="1050.0" x="120.0" y="60.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="lane_commission" id="lane_commission_gui" isHorizontal="true">
            <omgdc:Bounds height="160.0" width="1020.0" x="150.0" y="60.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="start_commission" id="start_commission_gui">
            <omgdc:Bounds height="30.0" width="30.0" x="190.0" y="125.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_draw_up_cert" id="task_draw_up_cert_gui">
            <omgdc:Bounds height="80.0" width="120.0" x="270.0" y="100.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_adopt_impl_acts_1" id="task_adopt_impl_acts_1_gui">
            <omgdc:Bounds height="80.0" width="120.0" x="430.0" y="100.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_use_info" id="task_use_info_gui">
            <omgdc:Bounds height="80.0" width="120.0" x="590.0" y="100.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_adopt_uniform" id="task_adopt_uniform_gui">
            <omgdc:Bounds height="80.0" width="120.0" x="750.0" y="100.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_adopt_impl_acts_2" id="task_adopt_impl_acts_2_gui">
            <omgdc:Bounds height="80.0" width="120.0" x="910.0" y="100.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="end_commission" id="end_commission_gui">
            <omgdc:Bounds height="28.0" width="28.0" x="1080.0" y="126.0"/>
         </bpmndi:BPMNShape>

         <!-- Pool: Transferring Member State -->
         <bpmndi:BPMNShape bpmnElement="pool_transferring_ms" id="pool_transferring_ms_gui" isHorizontal="true">
            <omgdc:Bounds height="160.0" width="1050.0" x="120.0" y="260.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="lane_transferring_ms" id="lane_transferring_ms_gui" isHorizontal="true">
            <omgdc:Bounds height="160.0" width="1020.0" x="150.0" y="260.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="start_transferring_ms" id="start_transferring_ms_gui">
            <omgdc:Bounds height="30.0" width="30.0" x="190.0" y="325.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_obtain_consent" id="task_obtain_consent_gui">
            <omgdc:Bounds height="80.0" width="120.0" x="270.0" y="300.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_transmit_info" id="task_transmit_info_gui">
            <omgdc:Bounds height="80.0" width="120.0" x="430.0" y="300.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_transfer_info_cert" id="task_transfer_info_cert_gui">
            <omgdc:Bounds height="80.0" width="120.0" x="590.0" y="300.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="end_transferring_ms" id="end_transferring_ms_gui">
            <omgdc:Bounds height="28.0" width="28.0" x="760.0" y="326.0"/>
         </bpmndi:BPMNShape>

         <!-- Pool: Member State Responsible -->
         <bpmndi:BPMNShape bpmnElement="pool_responsible_ms" id="pool_responsible_ms_gui" isHorizontal="true">
            <omgdc:Bounds height="160.0" width="1050.0" x="120.0" y="460.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="lane_responsible_ms" id="lane_responsible_ms_gui" isHorizontal="true">
            <omgdc:Bounds height="160.0" width="1020.0" x="150.0" y="460.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="start_responsible_ms" id="start_responsible_ms_gui">
            <omgdc:Bounds height="30.0" width="30.0" x="190.0" y="525.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_ensure_needs" id="task_ensure_needs_gui">
            <omgdc:Bounds height="80.0" width="120.0" x="270.0" y="500.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="end_responsible_ms" id="end_responsible_ms_gui">
            <omgdc:Bounds height="28.0" width="28.0" x="440.0" y="526.0"/>
         </bpmndi:BPMNShape>

         <!-- Pool: Health Professional -->
         <bpmndi:BPMNShape bpmnElement="pool_health_prof" id="pool_health_prof_gui" isHorizontal="true">
            <omgdc:Bounds height="160.0" width="1050.0" x="120.0" y="660.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="lane_health_prof" id="lane_health_prof_gui" isHorizontal="true">
            <omgdc:Bounds height="160.0" width="1020.0" x="150.0" y="660.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="start_health_prof" id="start_health_prof_gui">
            <omgdc:Bounds height="30.0" width="30.0" x="190.0" y="725.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_process_data" id="task_process_data_gui">
            <omgdc:Bounds height="80.0" width="120.0" x="270.0" y="700.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_exchange_info" id="task_exchange_info_gui">
            <omgdc:Bounds height="80.0" width="120.0" x="430.0" y="700.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="end_health_prof" id="end_health_prof_gui">
            <omgdc:Bounds height="28.0" width="28.0" x="600.0" y="726.0"/>
         </bpmndi:BPMNShape>

         <!-- Sequence Flows: Commission -->
         <bpmndi:BPMNEdge bpmnElement="sf_c1" id="sf_c1_gui">
            <omgdi:waypoint x="220.0" y="140.0"/>
            <omgdi:waypoint x="270.0" y="140.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf_c2" id="sf_c2_gui">
            <omgdi:waypoint x="390.0" y="140.0"/>
            <omgdi:waypoint x="430.0" y="140.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf_c3" id="sf_c3_gui">
            <omgdi:waypoint x="550.0" y="140.0"/>
            <omgdi:waypoint x="590.0" y="140.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf_c4" id="sf_c4_gui">
            <omgdi:waypoint x="710.0" y="140.0"/>
            <omgdi:waypoint x="750.0" y="140.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf_c5" id="sf_c5_gui">
            <omgdi:waypoint x="870.0" y="140.0"/>
            <omgdi:waypoint x="910.0" y="140.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf_c6" id="sf_c6_gui">
            <omgdi:waypoint x="1030.0" y="140.0"/>
            <omgdi:waypoint x="1080.0" y="140.0"/>
         </bpmndi:BPMNEdge>

         <!-- Sequence Flows: Transferring MS -->
         <bpmndi:BPMNEdge bpmnElement="sf_t1" id="sf_t1_gui">
            <omgdi:waypoint x="220.0" y="340.0"/>
            <omgdi:waypoint x="270.0" y="340.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf_t2" id="sf_t2_gui">
            <omgdi:waypoint x="390.0" y="340.0"/>
            <omgdi:waypoint x="430.0" y="340.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf_t3" id="sf_t3_gui">
            <omgdi:waypoint x="550.0" y="340.0"/>
            <omgdi:waypoint x="590.0" y="340.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf_t4" id="sf_t4_gui">
            <omgdi:waypoint x="710.0" y="340.0"/>
            <omgdi:waypoint x="760.0" y="340.0"/>
         </bpmndi:BPMNEdge>

         <!-- Sequence Flows: Responsible MS -->
         <bpmndi:BPMNEdge bpmnElement="sf_r1" id="sf_r1_gui">
            <omgdi:waypoint x="220.0" y="540.0"/>
            <omgdi:waypoint x="270.0" y="540.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf_r2" id="sf_r2_gui">
            <omgdi:waypoint x="390.0" y="540.0"/>
            <omgdi:waypoint x="440.0" y="540.0"/>
         </bpmndi:BPMNEdge>

         <!-- Sequence Flows: Health Professional -->
         <bpmndi:BPMNEdge bpmnElement="sf_h1" id="sf_h1_gui">
            <omgdi:waypoint x="220.0" y="740.0"/>
            <omgdi:waypoint x="270.0" y="740.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf_h2" id="sf_h2_gui">
            <omgdi:waypoint x="390.0" y="740.0"/>
            <omgdi:waypoint x="430.0" y="740.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf_h3" id="sf_h3_gui">
            <omgdi:waypoint x="550.0" y="740.0"/>
            <omgdi:waypoint x="600.0" y="740.0"/>
         </bpmndi:BPMNEdge>

         <!-- Message Flows -->
         <bpmndi:BPMNEdge bpmnElement="mf_1" id="mf_1_gui">
            <omgdi:waypoint x="650.0" y="380.0"/>
            <omgdi:waypoint x="650.0" y="440.0"/>
            <omgdi:waypoint x="205.0" y="440.0"/>
            <omgdi:waypoint x="205.0" y="525.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="mf_2" id="mf_2_gui">
            <omgdi:waypoint x="330.0" y="180.0"/>
            <omgdi:waypoint x="330.0" y="240.0"/>
            <omgdi:waypoint x="205.0" y="240.0"/>
            <omgdi:waypoint x="205.0" y="325.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="mf_3" id="mf_3_gui">
            <omgdi:waypoint x="330.0" y="580.0"/>
            <omgdi:waypoint x="330.0" y="640.0"/>
            <omgdi:waypoint x="205.0" y="640.0"/>
            <omgdi:waypoint x="205.0" y="725.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="mf_4" id="mf_4_gui">
            <omgdi:waypoint x="810.0" y="180.0"/>
            <omgdi:waypoint x="810.0" y="440.0"/>
            <omgdi:waypoint x="490.0" y="440.0"/>
            <omgdi:waypoint x="490.0" y="700.0"/>
         </bpmndi:BPMNEdge>

      </bpmndi:BPMNPlane>
   </bpmndi:BPMNDiagram>
</definitions>
