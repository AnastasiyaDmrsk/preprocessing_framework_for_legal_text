<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             id="definitions_1"
             targetNamespace="http://www.omg.org/spec/BPMN/20100524/MODEL"
             expressionLanguage="http://www.w3.org/TR/XPath"
             typeLanguage="http://www.w3.org/2001/XMLSchema"
             xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd">

   <!-- ============================================================ -->
   <!-- COLLABORATION                                                 -->
   <!-- ============================================================ -->
   <collaboration id="collab_1">
      <participant id="part_ms" name="Member States" processRef="proc_ms"/>
      <participant id="part_oe" name="Obliged Entity" processRef="proc_oe"/>
      <messageFlow id="mf_1" name="CDD requirement" sourceRef="task_require_cdd" targetRef="task_apply_cdd"/>
   </collaboration>

   <!-- ============================================================ -->
   <!-- PROCESS: Member States                                        -->
   <!-- ============================================================ -->
   <process id="proc_ms" name="Member States" isExecutable="false" isClosed="false" processType="None">
      <laneSet id="ls_ms">
         <lane id="lane_ms" name="Member States">
            <flowNodeRef>start_ms</flowNodeRef>
            <flowNodeRef>task_verify_identity</flowNodeRef>
            <flowNodeRef>gw_derogation</flowNodeRef>
            <flowNodeRef>task_establish_relationship</flowNodeRef>
            <flowNodeRef>task_complete_verification_during</flowNodeRef>
            <flowNodeRef>task_complete_asap</flowNodeRef>
            <flowNodeRef>gw_merge_derogation</flowNodeRef>
            <flowNodeRef>gw_cdd_met</flowNodeRef>
            <flowNodeRef>task_open_account</flowNodeRef>
            <flowNodeRef>task_ensure_no_transactions</flowNodeRef>
            <flowNodeRef>task_require_cdd</flowNodeRef>
            <flowNodeRef>end_ms_ok</flowNodeRef>
            <flowNodeRef>task_refuse_transaction</flowNodeRef>
            <flowNodeRef>task_terminate_relationship</flowNodeRef>
            <flowNodeRef>task_consider_str</flowNodeRef>
            <flowNodeRef>end_ms_fail</flowNodeRef>
         </lane>
      </laneSet>

      <startEvent id="start_ms" name="Start">
         <outgoing>sf_1</outgoing>
      </startEvent>

      <task id="task_verify_identity" name="Verify identity of customer and beneficial owner">
         <incoming>sf_1</incoming>
         <outgoing>sf_2</outgoing>
      </task>

      <exclusiveGateway id="gw_derogation" name="Verification before establishment possible?" gatewayDirection="Diverging">
         <incoming>sf_2</incoming>
         <outgoing>sf_3</outgoing>
         <outgoing>sf_4</outgoing>
      </exclusiveGateway>

      <task id="task_establish_relationship" name="Establish business relationship or carry out transaction">
         <incoming>sf_3</incoming>
         <outgoing>sf_5</outgoing>
      </task>

      <task id="task_complete_verification_during" name="Complete verification during establishment of business relationship">
         <incoming>sf_4</incoming>
         <outgoing>sf_6</outgoing>
      </task>

      <task id="task_complete_asap" name="Complete procedures as soon as practicable after initial contact">
         <incoming>sf_6</incoming>
         <outgoing>sf_7</outgoing>
      </task>

      <exclusiveGateway id="gw_merge_derogation" name="" gatewayDirection="Converging">
         <incoming>sf_5</incoming>
         <incoming>sf_7</incoming>
         <outgoing>sf_8</outgoing>
      </exclusiveGateway>

      <exclusiveGateway id="gw_cdd_met" name="CDD requirements met?" gatewayDirection="Diverging">
         <incoming>sf_8</incoming>
         <outgoing>sf_9</outgoing>
         <outgoing>sf_13</outgoing>
      </exclusiveGateway>

      <task id="task_open_account" name="Open account with adequate safeguards">
         <incoming>sf_9</incoming>
         <outgoing>sf_10</outgoing>
      </task>

      <task id="task_ensure_no_transactions" name="Ensure no transactions until full CDD compliance">
         <incoming>sf_10</incoming>
         <outgoing>sf_11</outgoing>
      </task>

      <task id="task_require_cdd" name="Require application of CDD measures to new and existing customers">
         <incoming>sf_11</incoming>
         <outgoing>sf_12</outgoing>
      </task>

      <endEvent id="end_ms_ok" name="End (compliant)">
         <incoming>sf_12</incoming>
      </endEvent>

      <task id="task_refuse_transaction" name="Do not carry out transaction or establish business relationship">
         <incoming>sf_13</incoming>
         <outgoing>sf_14</outgoing>
      </task>

      <task id="task_terminate_relationship" name="Terminate business relationship">
         <incoming>sf_14</incoming>
         <outgoing>sf_15</outgoing>
      </task>

      <task id="task_consider_str" name="Consider making suspicious transaction report to FIU">
         <incoming>sf_15</incoming>
         <outgoing>sf_16</outgoing>
      </task>

      <endEvent id="end_ms_fail" name="End (non-compliant)">
         <incoming>sf_16</incoming>
      </endEvent>

      <sequenceFlow id="sf_1"  sourceRef="start_ms"                       targetRef="task_verify_identity"/>
      <sequenceFlow id="sf_2"  sourceRef="task_verify_identity"            targetRef="gw_derogation"/>
      <sequenceFlow id="sf_3"  name="Yes"  sourceRef="gw_derogation"      targetRef="task_establish_relationship"/>
      <sequenceFlow id="sf_4"  name="No (derogation)" sourceRef="gw_derogation" targetRef="task_complete_verification_during"/>
      <sequenceFlow id="sf_5"  sourceRef="task_establish_relationship"     targetRef="gw_merge_derogation"/>
      <sequenceFlow id="sf_6"  sourceRef="task_complete_verification_during" targetRef="task_complete_asap"/>
      <sequenceFlow id="sf_7"  sourceRef="task_complete_asap"              targetRef="gw_merge_derogation"/>
      <sequenceFlow id="sf_8"  sourceRef="gw_merge_derogation"            targetRef="gw_cdd_met"/>
      <sequenceFlow id="sf_9"  name="Yes"  sourceRef="gw_cdd_met"         targetRef="task_open_account"/>
      <sequenceFlow id="sf_10" sourceRef="task_open_account"               targetRef="task_ensure_no_transactions"/>
      <sequenceFlow id="sf_11" sourceRef="task_ensure_no_transactions"     targetRef="task_require_cdd"/>
      <sequenceFlow id="sf_12" sourceRef="task_require_cdd"                targetRef="end_ms_ok"/>
      <sequenceFlow id="sf_13" name="No"   sourceRef="gw_cdd_met"         targetRef="task_refuse_transaction"/>
      <sequenceFlow id="sf_14" sourceRef="task_refuse_transaction"         targetRef="task_terminate_relationship"/>
      <sequenceFlow id="sf_15" sourceRef="task_terminate_relationship"     targetRef="task_consider_str"/>
      <sequenceFlow id="sf_16" sourceRef="task_consider_str"               targetRef="end_ms_fail"/>
   </process>

   <!-- ============================================================ -->
   <!-- PROCESS: Obliged Entity                                       -->
   <!-- ============================================================ -->
   <process id="proc_oe" name="Obliged Entity" isExecutable="false" isClosed="false" processType="None">
      <laneSet id="ls_oe">
         <lane id="lane_oe" name="Obliged Entity">
            <flowNodeRef>start_oe</flowNodeRef>
            <flowNodeRef>task_apply_cdd</flowNodeRef>
            <flowNodeRef>end_oe</flowNodeRef>
         </lane>
      </laneSet>

      <startEvent id="start_oe" name="CDD requirement received">
         <outgoing>sf_oe_1</outgoing>
         <messageEventDefinition id="msg_evt_oe"/>
      </startEvent>

      <task id="task_apply_cdd" name="Apply customer due diligence measures to new and existing customers">
         <incoming>sf_oe_1</incoming>
         <outgoing>sf_oe_2</outgoing>
      </task>

      <endEvent id="end_oe" name="End">
         <incoming>sf_oe_2</incoming>
      </endEvent>

      <sequenceFlow id="sf_oe_1" sourceRef="start_oe"      targetRef="task_apply_cdd"/>
      <sequenceFlow id="sf_oe_2" sourceRef="task_apply_cdd" targetRef="end_oe"/>
   </process>

   <!-- ============================================================ -->
   <!-- DIAGRAM                                                       -->
   <!-- ============================================================ -->
   <bpmndi:BPMNDiagram id="diagram_1">
      <bpmndi:BPMNPlane bpmnElement="collab_1" id="plane_1">

         <!-- Pool: Member States -->
         <bpmndi:BPMNShape bpmnElement="part_ms" id="shape_part_ms" isHorizontal="true">
            <omgdc:Bounds height="460.0" width="1520.0" x="60.0" y="30.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="lane_ms" id="shape_lane_ms" isHorizontal="true">
            <omgdc:Bounds height="460.0" width="1490.0" x="90.0" y="30.0"/>
         </bpmndi:BPMNShape>

         <!-- Pool: Obliged Entity -->
         <bpmndi:BPMNShape bpmnElement="part_oe" id="shape_part_oe" isHorizontal="true">
            <omgdc:Bounds height="160.0" width="1520.0" x="60.0" y="540.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="lane_oe" id="shape_lane_oe" isHorizontal="true">
            <omgdc:Bounds height="160.0" width="1490.0" x="90.0" y="540.0"/>
         </bpmndi:BPMNShape>

         <!-- Start MS -->
         <bpmndi:BPMNShape bpmnElement="start_ms" id="shape_start_ms">
            <omgdc:Bounds height="30.0" width="30.0" x="130.0" y="195.0"/>
         </bpmndi:BPMNShape>

         <!-- Task: Verify identity -->
         <bpmndi:BPMNShape bpmnElement="task_verify_identity" id="shape_task_verify_identity">
            <omgdc:Bounds height="80.0" width="140.0" x="200.0" y="170.0"/>
         </bpmndi:BPMNShape>

         <!-- Gateway: Derogation -->
         <bpmndi:BPMNShape bpmnElement="gw_derogation" id="shape_gw_derogation" isMarkerVisible="true">
            <omgdc:Bounds height="40.0" width="40.0" x="380.0" y="190.0"/>
         </bpmndi:BPMNShape>

         <!-- Task: Establish relationship (upper path) -->
         <bpmndi:BPMNShape bpmnElement="task_establish_relationship" id="shape_task_establish_relationship">
            <omgdc:Bounds height="80.0" width="140.0" x="460.0" y="90.0"/>
         </bpmndi:BPMNShape>

         <!-- Task: Complete verification during establishment (lower path) -->
         <bpmndi:BPMNShape bpmnElement="task_complete_verification_during" id="shape_task_complete_verification_during">
            <omgdc:Bounds height="80.0" width="140.0" x="460.0" y="260.0"/>
         </bpmndi:BPMNShape>

         <!-- Task: Complete ASAP -->
         <bpmndi:BPMNShape bpmnElement="task_complete_asap" id="shape_task_complete_asap">
            <omgdc:Bounds height="80.0" width="140.0" x="640.0" y="260.0"/>
         </bpmndi:BPMNShape>

         <!-- Gateway: Merge derogation -->
         <bpmndi:BPMNShape bpmnElement="gw_merge_derogation" id="shape_gw_merge_derogation" isMarkerVisible="true">
            <omgdc:Bounds height="40.0" width="40.0" x="820.0" y="190.0"/>
         </bpmndi:BPMNShape>

         <!-- Gateway: CDD met -->
         <bpmndi:BPMNShape bpmnElement="gw_cdd_met" id="shape_gw_cdd_met" isMarkerVisible="true">
            <omgdc:Bounds height="40.0" width="40.0" x="900.0" y="190.0"/>
         </bpmndi:BPMNShape>

         <!-- Task: Open account (upper/compliant path) -->
         <bpmndi:BPMNShape bpmnElement="task_open_account" id="shape_task_open_account">
            <omgdc:Bounds height="80.0" width="140.0" x="980.0" y="90.0"/>
         </bpmndi:BPMNShape>

         <!-- Task: Ensure no transactions -->
         <bpmndi:BPMNShape bpmnElement="task_ensure_no_transactions" id="shape_task_ensure_no_transactions">
            <omgdc:Bounds height="80.0" width="140.0" x="1150.0" y="90.0"/>
         </bpmndi:BPMNShape>

         <!-- Task: Require CDD -->
         <bpmndi:BPMNShape bpmnElement="task_require_cdd" id="shape_task_require_cdd">
            <omgdc:Bounds height="80.0" width="140.0" x="1320.0" y="90.0"/>
         </bpmndi:BPMNShape>

         <!-- End OK -->
         <bpmndi:BPMNShape bpmnElement="end_ms_ok" id="shape_end_ms_ok">
            <omgdc:Bounds height="28.0" width="28.0" x="1500.0" y="116.0"/>
         </bpmndi:BPMNShape>

         <!-- Task: Refuse transaction (lower/non-compliant path) -->
         <bpmndi:BPMNShape bpmnElement="task_refuse_transaction" id="shape_task_refuse_transaction">
            <omgdc:Bounds height="80.0" width="140.0" x="980.0" y="340.0"/>
         </bpmndi:BPMNShape>

         <!-- Task: Terminate relationship -->
         <bpmndi:BPMNShape bpmnElement="task_terminate_relationship" id="shape_task_terminate_relationship">
            <omgdc:Bounds height="80.0" width="140.0" x="1150.0" y="340.0"/>
         </bpmndi:BPMNShape>

         <!-- Task: Consider STR -->
         <bpmndi:BPMNShape bpmnElement="task_consider_str" id="shape_task_consider_str">
            <omgdc:Bounds height="80.0" width="140.0" x="1320.0" y="340.0"/>
         </bpmndi:BPMNShape>

         <!-- End Fail -->
         <bpmndi:BPMNShape bpmnElement="end_ms_fail" id="shape_end_ms_fail">
            <omgdc:Bounds height="28.0" width="28.0" x="1500.0" y="366.0"/>
         </bpmndi:BPMNShape>

         <!-- Obliged Entity nodes -->
         <bpmndi:BPMNShape bpmnElement="start_oe" id="shape_start_oe">
            <omgdc:Bounds height="30.0" width="30.0" x="130.0" y="605.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_apply_cdd" id="shape_task_apply_cdd">
            <omgdc:Bounds height="80.0" width="140.0" x="1320.0" y="580.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="end_oe" id="shape_end_oe">
            <omgdc:Bounds height="28.0" width="28.0" x="1500.0" y="606.0"/>
         </bpmndi:BPMNShape>

         <!-- ====== EDGES: Member States ====== -->

         <!-- sf_1: start -> verify identity -->
         <bpmndi:BPMNEdge bpmnElement="sf_1" id="edge_sf_1">
            <omgdi:waypoint x="160.0" y="210.0"/>
            <omgdi:waypoint x="200.0" y="210.0"/>
         </bpmndi:BPMNEdge>

         <!-- sf_2: verify identity -> gw_derogation -->
         <bpmndi:BPMNEdge bpmnElement="sf_2" id="edge_sf_2">
            <omgdi:waypoint x="340.0" y="210.0"/>
            <omgdi:waypoint x="380.0" y="210.0"/>
         </bpmndi:BPMNEdge>

         <!-- sf_3: gw_derogation -> establish relationship (up) -->
         <bpmndi:BPMNEdge bpmnElement="sf_3" id="edge_sf_3">
            <omgdi:waypoint x="400.0" y="190.0"/>
            <omgdi:waypoint x="400.0" y="130.0"/>
            <omgdi:waypoint x="460.0" y="130.0"/>
         </bpmndi:BPMNEdge>

         <!-- sf_4: gw_derogation -> complete verification during (down) -->
         <bpmndi:BPMNEdge bpmnElement="sf_4" id="edge_sf_4">
            <omgdi:waypoint x="400.0" y="230.0"/>
            <omgdi:waypoint x="400.0" y="300.0"/>
            <omgdi:waypoint x="460.0" y="300.0"/>
         </bpmndi:BPMNEdge>

         <!-- sf_5: establish relationship -> gw_merge -->
         <bpmndi:BPMNEdge bpmnElement="sf_5" id="edge_sf_5">
            <omgdi:waypoint x="600.0" y="130.0"/>
            <omgdi:waypoint x="840.0" y="130.0"/>
            <omgdi:waypoint x="840.0" y="190.0"/>
         </bpmndi:BPMNEdge>

         <!-- sf_6: complete verification during -> complete asap -->
         <bpmndi:BPMNEdge bpmnElement="sf_6" id="edge_sf_6">
            <omgdi:waypoint x="600.0" y="300.0"/>
            <omgdi:waypoint x="640.0" y="300.0"/>
         </bpmndi:BPMNEdge>

         <!-- sf_7: complete asap -> gw_merge -->
         <bpmndi:BPMNEdge bpmnElement="sf_7" id="edge_sf_7">
            <omgdi:waypoint x="780.0" y="300.0"/>
            <omgdi:waypoint x="840.0" y="300.0"/>
            <omgdi:waypoint x="840.0" y="230.0"/>
         </bpmndi:BPMNEdge>

         <!-- sf_8: gw_merge -> gw_cdd_met -->
         <bpmndi:BPMNEdge bpmnElement="sf_8" id="edge_sf_8">
            <omgdi:waypoint x="860.0" y="210.0"/>
            <omgdi:waypoint x="900.0" y="210.0"/>
         </bpmndi:BPMNEdge>

         <!-- sf_9: gw_cdd_met -> open account (up) -->
         <bpmndi:BPMNEdge bpmnElement="sf_9" id="edge_sf_9">
            <omgdi:waypoint x="920.0" y="190.0"/>
            <omgdi:waypoint x="920.0" y="130.0"/>
            <omgdi:waypoint x="980.0" y="130.0"/>
         </bpmndi:BPMNEdge>

         <!-- sf_10: open account -> ensure no transactions -->
         <bpmndi:BPMNEdge bpmnElement="sf_10" id="edge_sf_10">
            <omgdi:waypoint x="1120.0" y="130.0"/>
            <omgdi:waypoint x="1150.0" y="130.0"/>
         </bpmndi:BPMNEdge>

         <!-- sf_11: ensure no transactions -> require CDD -->
         <bpmndi:BPMNEdge bpmnElement="sf_11" id="edge_sf_11">
            <omgdi:waypoint x="1290.0" y="130.0"/>
            <omgdi:waypoint x="1320.0" y="130.0"/>
         </bpmndi:BPMNEdge>

         <!-- sf_12: require CDD -> end OK -->
         <bpmndi:BPMNEdge bpmnElement="sf_12" id="edge_sf_12">
            <omgdi:waypoint x="1460.0" y="130.0"/>
            <omgdi:waypoint x="1500.0" y="130.0"/>
         </bpmndi:BPMNEdge>

         <!-- sf_13: gw_cdd_met -> refuse transaction (down) -->
         <bpmndi:BPMNEdge bpmnElement="sf_13" id="edge_sf_13">
            <omgdi:waypoint x="920.0" y="230.0"/>
            <omgdi:waypoint x="920.0" y="380.0"/>
            <omgdi:waypoint x="980.0" y="380.0"/>
         </bpmndi:BPMNEdge>

         <!-- sf_14: refuse -> terminate -->
         <bpmndi:BPMNEdge bpmnElement="sf_14" id="edge_sf_14">
            <omgdi:waypoint x="1120.0" y="380.0"/>
            <omgdi:waypoint x="1150.0" y="380.0"/>
         </bpmndi:BPMNEdge>

         <!-- sf_15: terminate -> consider STR -->
         <bpmndi:BPMNEdge bpmnElement="sf_15" id="edge_sf_15">
            <omgdi:waypoint x="1290.0" y="380.0"/>
            <omgdi:waypoint x="1320.0" y="380.0"/>
         </bpmndi:BPMNEdge>

         <!-- sf_16: consider STR -> end fail -->
         <bpmndi:BPMNEdge bpmnElement="sf_16" id="edge_sf_16">
            <omgdi:waypoint x="1460.0" y="380.0"/>
            <omgdi:waypoint x="1500.0" y="380.0"/>
         </bpmndi:BPMNEdge>

         <!-- ====== EDGES: Obliged Entity ====== -->
         <bpmndi:BPMNEdge bpmnElement="sf_oe_1" id="edge_sf_oe_1">
            <omgdi:waypoint x="160.0" y="620.0"/>
            <omgdi:waypoint x="1320.0" y="620.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf_oe_2" id="edge_sf_oe_2">
            <omgdi:waypoint x="1460.0" y="620.0"/>
            <omgdi:waypoint x="1500.0" y="620.0"/>
         </bpmndi:BPMNEdge>

         <!-- ====== MESSAGE FLOW ====== -->
         <bpmndi:BPMNEdge bpmnElement="mf_1" id="edge_mf_1">
            <omgdi:waypoint x="1390.0" y="170.0"/>
            <omgdi:waypoint x="1390.0" y="580.0"/>
         </bpmndi:BPMNEdge>

      </bpmndi:BPMNPlane>
   </bpmndi:BPMNDiagram>
</definitions>
