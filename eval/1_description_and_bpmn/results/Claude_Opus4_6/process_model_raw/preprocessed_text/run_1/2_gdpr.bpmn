<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             id="definitions_1"
             targetNamespace="http://www.signavio.com"
             expressionLanguage="http://www.w3.org/TR/XPath"
             typeLanguage="http://www.w3.org/2001/XMLSchema"
             xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd">

   <!-- ===== COLLABORATION ===== -->
   <collaboration id="collab_1">
      <participant id="pool_processor" name="Processor" processRef="process_processor"/>
      <participant id="pool_controller" name="Controller" processRef="process_controller"/>
      <participant id="pool_supervisory" name="Supervisory Authority" processRef="process_supervisory"/>

      <!-- Message flows between pools -->
      <messageFlow id="mf_processor_to_controller" name="Breach notification" sourceRef="task_proc_notify_controller" targetRef="start_ctrl_msg"/>
      <messageFlow id="mf_ctrl_to_sa" name="Breach notification to SA" sourceRef="task_notify_sa" targetRef="start_sa_msg"/>
      <messageFlow id="mf_ctrl_to_sa_delayed" name="Delayed notification with reasons" sourceRef="task_notify_sa_delayed" targetRef="start_sa_msg"/>
      <messageFlow id="mf_sa_require" name="Require communication" sourceRef="task_sa_require_communication" targetRef="task_ctrl_communicate_if_required"/>
   </collaboration>

   <!-- ===== PROCESSOR PROCESS ===== -->
   <process id="process_processor" name="Processor" isExecutable="false" isClosed="false" processType="None">
      <laneSet id="ls_processor">
         <lane id="lane_processor" name="Processor">
            <flowNodeRef>start_proc</flowNodeRef>
            <flowNodeRef>task_proc_become_aware</flowNodeRef>
            <flowNodeRef>task_proc_notify_controller</flowNodeRef>
            <flowNodeRef>end_proc</flowNodeRef>
         </lane>
      </laneSet>

      <startEvent id="start_proc" name="Personal data breach occurs">
         <outgoing>sf_proc_1</outgoing>
      </startEvent>
      <task id="task_proc_become_aware" name="Become aware of personal data breach">
         <incoming>sf_proc_1</incoming>
         <outgoing>sf_proc_2</outgoing>
      </task>
      <task id="task_proc_notify_controller" name="Notify controller of personal data breach">
         <incoming>sf_proc_2</incoming>
         <outgoing>sf_proc_3</outgoing>
      </task>
      <endEvent id="end_proc" name="End">
         <incoming>sf_proc_3</incoming>
      </endEvent>

      <sequenceFlow id="sf_proc_1" sourceRef="start_proc" targetRef="task_proc_become_aware"/>
      <sequenceFlow id="sf_proc_2" sourceRef="task_proc_become_aware" targetRef="task_proc_notify_controller"/>
      <sequenceFlow id="sf_proc_3" sourceRef="task_proc_notify_controller" targetRef="end_proc"/>
   </process>

   <!-- ===== CONTROLLER PROCESS ===== -->
   <process id="process_controller" name="Controller" isExecutable="false" isClosed="false" processType="None">
      <laneSet id="ls_controller">
         <lane id="lane_controller" name="Controller">
            <flowNodeRef>start_ctrl_msg</flowNodeRef>
            <flowNodeRef>xgw_72h</flowNodeRef>
            <flowNodeRef>task_notify_sa</flowNodeRef>
            <flowNodeRef>task_notify_sa_delayed</flowNodeRef>
            <flowNodeRef>xgw_72h_merge</flowNodeRef>
            <flowNodeRef>pgw_notif_split</flowNodeRef>
            <flowNodeRef>task_describe_nature</flowNodeRef>
            <flowNodeRef>task_communicate_dpo</flowNodeRef>
            <flowNodeRef>task_describe_consequences</flowNodeRef>
            <flowNodeRef>task_describe_measures</flowNodeRef>
            <flowNodeRef>pgw_notif_join</flowNodeRef>
            <flowNodeRef>xgw_info_phase</flowNodeRef>
            <flowNodeRef>task_provide_in_phases</flowNodeRef>
            <flowNodeRef>xgw_info_phase_merge</flowNodeRef>
            <flowNodeRef>task_document_breach</flowNodeRef>
            <flowNodeRef>xgw_high_risk</flowNodeRef>
            <flowNodeRef>task_communicate_to_subject</flowNodeRef>
            <flowNodeRef>task_describe_plain_language</flowNodeRef>
            <flowNodeRef>pgw_exemption_split</flowNodeRef>
            <flowNodeRef>task_check_protection_measures</flowNodeRef>
            <flowNodeRef>task_check_subsequent_measures</flowNodeRef>
            <flowNodeRef>task_check_disproportionate_effort</flowNodeRef>
            <flowNodeRef>pgw_exemption_join</flowNodeRef>
            <flowNodeRef>task_ctrl_communicate_if_required</flowNodeRef>
            <flowNodeRef>xgw_high_risk_merge</flowNodeRef>
            <flowNodeRef>end_ctrl</flowNodeRef>
         </lane>
      </laneSet>

      <startEvent id="start_ctrl_msg" name="Receive breach notification from processor">
         <outgoing>sf_ctrl_1</outgoing>
         <messageEventDefinition id="msgdef_ctrl_start"/>
      </startEvent>

      <!-- XOR: Within 72 hours? -->
      <exclusiveGateway id="xgw_72h" name="Notification within 72 hours feasible?" gatewayDirection="Diverging">
         <incoming>sf_ctrl_1</incoming>
         <outgoing>sf_ctrl_72h_yes</outgoing>
         <outgoing>sf_ctrl_72h_no</outgoing>
      </exclusiveGateway>

      <task id="task_notify_sa" name="Notify personal data breach to supervisory authority">
         <incoming>sf_ctrl_72h_yes</incoming>
         <outgoing>sf_ctrl_notify_sa_done</outgoing>
      </task>

      <task id="task_notify_sa_delayed" name="Notify supervisory authority with reasons for delay">
         <incoming>sf_ctrl_72h_no</incoming>
         <outgoing>sf_ctrl_notify_sa_delayed_done</outgoing>
      </task>

      <exclusiveGateway id="xgw_72h_merge" gatewayDirection="Converging">
         <incoming>sf_ctrl_notify_sa_done</incoming>
         <incoming>sf_ctrl_notify_sa_delayed_done</incoming>
         <outgoing>sf_ctrl_to_par</outgoing>
      </exclusiveGateway>

      <!-- Parallel: Notification content (Art 33.3) -->
      <parallelGateway id="pgw_notif_split" name="Prepare notification content" gatewayDirection="Diverging">
         <incoming>sf_ctrl_to_par</incoming>
         <outgoing>sf_par_a</outgoing>
         <outgoing>sf_par_b</outgoing>
         <outgoing>sf_par_c</outgoing>
         <outgoing>sf_par_d</outgoing>
      </parallelGateway>

      <task id="task_describe_nature" name="Describe nature of breach, categories and number of data subjects and records">
         <incoming>sf_par_a</incoming>
         <outgoing>sf_par_a_done</outgoing>
      </task>
      <task id="task_communicate_dpo" name="Communicate name and contact details of data protection officer">
         <incoming>sf_par_b</incoming>
         <outgoing>sf_par_b_done</outgoing>
      </task>
      <task id="task_describe_consequences" name="Describe likely consequences of the personal data breach">
         <incoming>sf_par_c</incoming>
         <outgoing>sf_par_c_done</outgoing>
      </task>
      <task id="task_describe_measures" name="Describe measures taken or proposed to address the breach">
         <incoming>sf_par_d</incoming>
         <outgoing>sf_par_d_done</outgoing>
      </task>

      <parallelGateway id="pgw_notif_join" gatewayDirection="Converging">
         <incoming>sf_par_a_done</incoming>
         <incoming>sf_par_b_done</incoming>
         <incoming>sf_par_c_done</incoming>
         <incoming>sf_par_d_done</incoming>
         <outgoing>sf_par_join_out</outgoing>
      </parallelGateway>

      <!-- XOR: Can provide all info at same time? (Art 33.4) -->
      <exclusiveGateway id="xgw_info_phase" name="Possible to provide all information at same time?" gatewayDirection="Diverging">
         <incoming>sf_par_join_out</incoming>
         <outgoing>sf_phase_yes</outgoing>
         <outgoing>sf_phase_no</outgoing>
      </exclusiveGateway>

      <task id="task_provide_in_phases" name="Provide information in phases without undue further delay">
         <incoming>sf_phase_no</incoming>
         <outgoing>sf_phase_no_done</outgoing>
      </task>

      <exclusiveGateway id="xgw_info_phase_merge" gatewayDirection="Converging">
         <incoming>sf_phase_yes</incoming>
         <incoming>sf_phase_no_done</incoming>
         <outgoing>sf_to_document</outgoing>
      </exclusiveGateway>

      <!-- Document breach (Art 33.5) -->
      <task id="task_document_breach" name="Document personal data breach, effects and remedial action taken">
         <incoming>sf_to_document</incoming>
         <outgoing>sf_to_high_risk</outgoing>
      </task>

      <!-- XOR: High risk? (Art 34.1) -->
      <exclusiveGateway id="xgw_high_risk" name="Breach likely to result in high risk to rights and freedoms?" gatewayDirection="Diverging">
         <incoming>sf_to_high_risk</incoming>
         <outgoing>sf_hr_yes</outgoing>
         <outgoing>sf_hr_no</outgoing>
      </exclusiveGateway>

      <task id="task_communicate_to_subject" name="Communicate personal data breach to data subject">
         <incoming>sf_hr_yes</incoming>
         <outgoing>sf_comm_subj_done</outgoing>
      </task>

      <task id="task_describe_plain_language" name="Describe breach in clear and plain language with information from points (b), (c) and (d)">
         <incoming>sf_comm_subj_done</incoming>
         <outgoing>sf_to_exemption</outgoing>
      </task>

      <!-- Parallel: Check exemptions (Art 34.3) -->
      <parallelGateway id="pgw_exemption_split" name="Assess exemption conditions" gatewayDirection="Diverging">
         <incoming>sf_to_exemption</incoming>
         <outgoing>sf_ex_a</outgoing>
         <outgoing>sf_ex_b</outgoing>
         <outgoing>sf_ex_c</outgoing>
      </parallelGateway>

      <task id="task_check_protection_measures" name="Assess if appropriate technical and organisational protection measures were applied">
         <incoming>sf_ex_a</incoming>
         <outgoing>sf_ex_a_done</outgoing>
      </task>
      <task id="task_check_subsequent_measures" name="Assess if subsequent measures ensure high risk no longer likely to materialise">
         <incoming>sf_ex_b</incoming>
         <outgoing>sf_ex_b_done</outgoing>
      </task>
      <task id="task_check_disproportionate_effort" name="Assess if communication would involve disproportionate effort, consider public communication">
         <incoming>sf_ex_c</incoming>
         <outgoing>sf_ex_c_done</outgoing>
      </task>

      <parallelGateway id="pgw_exemption_join" gatewayDirection="Converging">
         <incoming>sf_ex_a_done</incoming>
         <incoming>sf_ex_b_done</incoming>
         <incoming>sf_ex_c_done</incoming>
         <outgoing>sf_exemption_to_require</outgoing>
      </parallelGateway>

      <!-- Art 34.4: SA may require communication -->
      <task id="task_ctrl_communicate_if_required" name="Communicate breach to data subject if required by supervisory authority">
         <incoming>sf_exemption_to_require</incoming>
         <outgoing>sf_require_done</outgoing>
      </task>

      <exclusiveGateway id="xgw_high_risk_merge" gatewayDirection="Converging">
         <incoming>sf_hr_no</incoming>
         <incoming>sf_require_done</incoming>
         <outgoing>sf_to_end_ctrl</outgoing>
      </exclusiveGateway>

      <endEvent id="end_ctrl" name="End">
         <incoming>sf_to_end_ctrl</incoming>
      </endEvent>

      <!-- Sequence Flows -->
      <sequenceFlow id="sf_ctrl_1" sourceRef="start_ctrl_msg" targetRef="xgw_72h"/>
      <sequenceFlow id="sf_ctrl_72h_yes" name="Yes, within 72 hours" sourceRef="xgw_72h" targetRef="task_notify_sa"/>
      <sequenceFlow id="sf_ctrl_72h_no" name="No, exceeds 72 hours" sourceRef="xgw_72h" targetRef="task_notify_sa_delayed"/>
      <sequenceFlow id="sf_ctrl_notify_sa_done" sourceRef="task_notify_sa" targetRef="xgw_72h_merge"/>
      <sequenceFlow id="sf_ctrl_notify_sa_delayed_done" sourceRef="task_notify_sa_delayed" targetRef="xgw_72h_merge"/>
      <sequenceFlow id="sf_ctrl_to_par" sourceRef="xgw_72h_merge" targetRef="pgw_notif_split"/>
      <sequenceFlow id="sf_par_a" sourceRef="pgw_notif_split" targetRef="task_describe_nature"/>
      <sequenceFlow id="sf_par_b" sourceRef="pgw_notif_split" targetRef="task_communicate_dpo"/>
      <sequenceFlow id="sf_par_c" sourceRef="pgw_notif_split" targetRef="task_describe_consequences"/>
      <sequenceFlow id="sf_par_d" sourceRef="pgw_notif_split" targetRef="task_describe_measures"/>
      <sequenceFlow id="sf_par_a_done" sourceRef="task_describe_nature" targetRef="pgw_notif_join"/>
      <sequenceFlow id="sf_par_b_done" sourceRef="task_communicate_dpo" targetRef="pgw_notif_join"/>
      <sequenceFlow id="sf_par_c_done" sourceRef="task_describe_consequences" targetRef="pgw_notif_join"/>
      <sequenceFlow id="sf_par_d_done" sourceRef="task_describe_measures" targetRef="pgw_notif_join"/>
      <sequenceFlow id="sf_par_join_out" sourceRef="pgw_notif_join" targetRef="xgw_info_phase"/>
      <sequenceFlow id="sf_phase_yes" name="Yes" sourceRef="xgw_info_phase" targetRef="xgw_info_phase_merge"/>
      <sequenceFlow id="sf_phase_no" name="No, provide in phases" sourceRef="xgw_info_phase" targetRef="task_provide_in_phases"/>
      <sequenceFlow id="sf_phase_no_done" sourceRef="task_provide_in_phases" targetRef="xgw_info_phase_merge"/>
      <sequenceFlow id="sf_to_document" sourceRef="xgw_info_phase_merge" targetRef="task_document_breach"/>
      <sequenceFlow id="sf_to_high_risk" sourceRef="task_document_breach" targetRef="xgw_high_risk"/>
      <sequenceFlow id="sf_hr_yes" name="Yes, high risk" sourceRef="xgw_high_risk" targetRef="task_communicate_to_subject"/>
      <sequenceFlow id="sf_hr_no" name="No high risk" sourceRef="xgw_high_risk" targetRef="xgw_high_risk_merge"/>
      <sequenceFlow id="sf_comm_subj_done" sourceRef="task_communicate_to_subject" targetRef="task_describe_plain_language"/>
      <sequenceFlow id="sf_to_exemption" sourceRef="task_describe_plain_language" targetRef="pgw_exemption_split"/>
      <sequenceFlow id="sf_ex_a" sourceRef="pgw_exemption_split" targetRef="task_check_protection_measures"/>
      <sequenceFlow id="sf_ex_b" sourceRef="pgw_exemption_split" targetRef="task_check_subsequent_measures"/>
      <sequenceFlow id="sf_ex_c" sourceRef="pgw_exemption_split" targetRef="task_check_disproportionate_effort"/>
      <sequenceFlow id="sf_ex_a_done" sourceRef="task_check_protection_measures" targetRef="pgw_exemption_join"/>
      <sequenceFlow id="sf_ex_b_done" sourceRef="task_check_subsequent_measures" targetRef="pgw_exemption_join"/>
      <sequenceFlow id="sf_ex_c_done" sourceRef="task_check_disproportionate_effort" targetRef="pgw_exemption_join"/>
      <sequenceFlow id="sf_exemption_to_require" sourceRef="pgw_exemption_join" targetRef="task_ctrl_communicate_if_required"/>
      <sequenceFlow id="sf_require_done" sourceRef="task_ctrl_communicate_if_required" targetRef="xgw_high_risk_merge"/>
      <sequenceFlow id="sf_to_end_ctrl" sourceRef="xgw_high_risk_merge" targetRef="end_ctrl"/>
   </process>

   <!-- ===== SUPERVISORY AUTHORITY PROCESS ===== -->
   <process id="process_supervisory" name="Supervisory Authority" isExecutable="false" isClosed="false" processType="None">
      <laneSet id="ls_supervisory">
         <lane id="lane_supervisory" name="Supervisory Authority">
            <flowNodeRef>start_sa_msg</flowNodeRef>
            <flowNodeRef>task_sa_verify_compliance</flowNodeRef>
            <flowNodeRef>xgw_sa_require</flowNodeRef>
            <flowNodeRef>task_sa_require_communication</flowNodeRef>
            <flowNodeRef>xgw_sa_require_merge</flowNodeRef>
            <flowNodeRef>end_sa</flowNodeRef>
         </lane>
      </laneSet>

      <startEvent id="start_sa_msg" name="Receive breach notification from controller">
         <outgoing>sf_sa_1</outgoing>
         <messageEventDefinition id="msgdef_sa_start"/>
      </startEvent>

      <task id="task_sa_verify_compliance" name="Verify compliance with Article 33 using controller documentation">
         <incoming>sf_sa_1</incoming>
         <outgoing>sf_sa_2</outgoing>
      </task>

      <exclusiveGateway id="xgw_sa_require" name="Controller has not communicated breach to data subject and high risk exists?" gatewayDirection="Diverging">
         <incoming>sf_sa_2</incoming>
         <outgoing>sf_sa_require_yes</outgoing>
         <outgoing>sf_sa_require_no</outgoing>
      </exclusiveGateway>

      <task id="task_sa_require_communication" name="Require controller to communicate breach to data subject">
         <incoming>sf_sa_require_yes</incoming>
         <outgoing>sf_sa_require_done</outgoing>
      </task>

      <exclusiveGateway id="xgw_sa_require_merge" gatewayDirection="Converging">
         <incoming>sf_sa_require_done</incoming>
         <incoming>sf_sa_require_no</incoming>
         <outgoing>sf_sa_to_end</outgoing>
      </exclusiveGateway>

      <endEvent id="end_sa" name="End">
         <incoming>sf_sa_to_end</incoming>
      </endEvent>

      <sequenceFlow id="sf_sa_1" sourceRef="start_sa_msg" targetRef="task_sa_verify_compliance"/>
      <sequenceFlow id="sf_sa_2" sourceRef="task_sa_verify_compliance" targetRef="xgw_sa_require"/>
      <sequenceFlow id="sf_sa_require_yes" name="Yes, require communication" sourceRef="xgw_sa_require" targetRef="task_sa_require_communication"/>
      <sequenceFlow id="sf_sa_require_no" name="No" sourceRef="xgw_sa_require" targetRef="xgw_sa_require_merge"/>
      <sequenceFlow id="sf_sa_require_done" sourceRef="task_sa_require_communication" targetRef="xgw_sa_require_merge"/>
      <sequenceFlow id="sf_sa_to_end" sourceRef="xgw_sa_require_merge" targetRef="end_sa"/>
   </process>

   <!-- ===== DIAGRAM (DI) ===== -->
   <bpmndi:BPMNDiagram id="diagram_1">
      <bpmndi:BPMNPlane bpmnElement="collab_1" id="plane_1">

         <!-- ===== PROCESSOR POOL (y=50, height=150) ===== -->
         <bpmndi:BPMNShape bpmnElement="pool_processor" id="pool_processor_gui" isHorizontal="true">
            <omgdc:Bounds height="150.0" width="750.0" x="60.0" y="50.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="lane_processor" id="lane_processor_gui" isHorizontal="true">
            <omgdc:Bounds height="150.0" width="720.0" x="90.0" y="50.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="start_proc" id="start_proc_gui">
            <omgdc:Bounds height="30.0" width="30.0" x="140.0" y="110.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_proc_become_aware" id="task_proc_become_aware_gui">
            <omgdc:Bounds height="80.0" width="100.0" x="220.0" y="85.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_proc_notify_controller" id="task_proc_notify_controller_gui">
            <omgdc:Bounds height="80.0" width="100.0" x="380.0" y="85.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="end_proc" id="end_proc_gui">
            <omgdc:Bounds height="28.0" width="28.0" x="540.0" y="111.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNEdge bpmnElement="sf_proc_1" id="sf_proc_1_gui">
            <omgdi:waypoint x="170.0" y="125.0"/>
            <omgdi:waypoint x="220.0" y="125.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf_proc_2" id="sf_proc_2_gui">
            <omgdi:waypoint x="320.0" y="125.0"/>
            <omgdi:waypoint x="380.0" y="125.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf_proc_3" id="sf_proc_3_gui">
            <omgdi:waypoint x="480.0" y="125.0"/>
            <omgdi:waypoint x="540.0" y="125.0"/>
         </bpmndi:BPMNEdge>

         <!-- ===== CONTROLLER POOL (y=250, height=700) ===== -->
         <bpmndi:BPMNShape bpmnElement="pool_controller" id="pool_controller_gui" isHorizontal="true">
            <omgdc:Bounds height="700.0" width="2200.0" x="60.0" y="250.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="lane_controller" id="lane_controller_gui" isHorizontal="true">
            <omgdc:Bounds height="700.0" width="2170.0" x="90.0" y="250.0"/>
         </bpmndi:BPMNShape>

         <!-- Start -->
         <bpmndi:BPMNShape bpmnElement="start_ctrl_msg" id="start_ctrl_msg_gui">
            <omgdc:Bounds height="30.0" width="30.0" x="140.0" y="465.0"/>
         </bpmndi:BPMNShape>

         <!-- XOR 72h -->
         <bpmndi:BPMNShape bpmnElement="xgw_72h" id="xgw_72h_gui" isMarkerVisible="true">
            <omgdc:Bounds height="40.0" width="40.0" x="230.0" y="460.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_notify_sa" id="task_notify_sa_gui">
            <omgdc:Bounds height="80.0" width="100.0" x="320.0" y="370.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_notify_sa_delayed" id="task_notify_sa_delayed_gui">
            <omgdc:Bounds height="80.0" width="100.0" x="320.0" y="530.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="xgw_72h_merge" id="xgw_72h_merge_gui" isMarkerVisible="true">
            <omgdc:Bounds height="40.0" width="40.0" x="470.0" y="460.0"/>
         </bpmndi:BPMNShape>

         <!-- Parallel split for notification content -->
         <bpmndi:BPMNShape bpmnElement="pgw_notif_split" id="pgw_notif_split_gui">
            <omgdc:Bounds height="40.0" width="40.0" x="560.0" y="460.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_describe_nature" id="task_describe_nature_gui">
            <omgdc:Bounds height="80.0" width="140.0" x="650.0" y="290.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_communicate_dpo" id="task_communicate_dpo_gui">
            <omgdc:Bounds height="80.0" width="140.0" x="650.0" y="400.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_describe_consequences" id="task_describe_consequences_gui">
            <omgdc:Bounds height="80.0" width="140.0" x="650.0" y="510.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_describe_measures" id="task_describe_measures_gui">
            <omgdc:Bounds height="80.0" width="140.0" x="650.0" y="620.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="pgw_notif_join" id="pgw_notif_join_gui">
            <omgdc:Bounds height="40.0" width="40.0" x="840.0" y="460.0"/>
         </bpmndi:BPMNShape>

         <!-- XOR info phase -->
         <bpmndi:BPMNShape bpmnElement="xgw_info_phase" id="xgw_info_phase_gui" isMarkerVisible="true">
            <omgdc:Bounds height="40.0" width="40.0" x="930.0" y="460.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_provide_in_phases" id="task_provide_in_phases_gui">
            <omgdc:Bounds height="80.0" width="100.0" x="1000.0" y="560.0"/>
         </bpmndi:BPMNShape>
