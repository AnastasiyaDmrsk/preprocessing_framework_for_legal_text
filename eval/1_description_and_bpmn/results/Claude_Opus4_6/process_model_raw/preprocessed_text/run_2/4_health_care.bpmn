<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             id="sid-definitions-1"
             targetNamespace="http://www.signavio.com"
             expressionLanguage="http://www.w3.org/TR/XPath"
             typeLanguage="http://www.w3.org/2001/XMLSchema"
             xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd">

   <!-- ============================================================ -->
   <!-- COLLABORATION                                                 -->
   <!-- ============================================================ -->
   <collaboration id="collab-1">
      <participant id="pool-transferring" name="Transferring Member State" processRef="proc-transferring"/>
      <participant id="pool-responsible" name="Member State Responsible" processRef="proc-responsible"/>
      <participant id="pool-commission" name="Commission" processRef="proc-commission"/>
      <participant id="pool-healthprof" name="Health Professional" processRef="proc-healthprof"/>

      <!-- Message flows between pools -->
      <messageFlow id="mf-1" name="special needs information" sourceRef="task-transmit-info" targetRef="start-responsible"/>
      <messageFlow id="mf-2" name="health certificate with documents" sourceRef="task-transfer-certificate" targetRef="task-ensure-needs"/>
      <messageFlow id="mf-3" name="common health certificate template" sourceRef="task-draw-up-certificate" targetRef="task-transfer-certificate"/>
      <messageFlow id="mf-4" name="personal health data" sourceRef="task-ensure-needs" targetRef="start-healthprof"/>
   </collaboration>

   <!-- ============================================================ -->
   <!-- PROCESS: Transferring Member State                            -->
   <!-- ============================================================ -->
   <process id="proc-transferring" name="Transferring Member State" isExecutable="false" isClosed="false" processType="None">
      <laneSet id="ls-transferring">
         <lane id="lane-transferring" name="Corresponding Authority">
            <flowNodeRef>start-transferring</flowNodeRef>
            <flowNodeRef>task-obtain-consent</flowNodeRef>
            <flowNodeRef>gw-consent</flowNodeRef>
            <flowNodeRef>task-transmit-info</flowNodeRef>
            <flowNodeRef>task-transfer-certificate</flowNodeRef>
            <flowNodeRef>end-transferring</flowNodeRef>
            <flowNodeRef>end-transferring-noconsent</flowNodeRef>
         </lane>
      </laneSet>

      <startEvent id="start-transferring" name="Transfer planned">
         <outgoing>sf-t1</outgoing>
      </startEvent>

      <task id="task-obtain-consent" name="Obtain explicit consent of applicant" completionQuantity="1" startQuantity="1" isForCompensation="false">
         <incoming>sf-t1</incoming>
         <outgoing>sf-t2</outgoing>
      </task>

      <exclusiveGateway id="gw-consent" name="Consent given?" gatewayDirection="Diverging">
         <incoming>sf-t2</incoming>
         <outgoing>sf-t3</outgoing>
         <outgoing>sf-t3b</outgoing>
      </exclusiveGateway>

      <task id="task-transmit-info" name="Transmit information on special needs to Member State responsible" completionQuantity="1" startQuantity="1" isForCompensation="false">
         <incoming>sf-t3</incoming>
         <outgoing>sf-t4</outgoing>
      </task>

      <task id="task-transfer-certificate" name="Transfer information in common health certificate" completionQuantity="1" startQuantity="1" isForCompensation="false">
         <incoming>sf-t4</incoming>
         <outgoing>sf-t5</outgoing>
      </task>

      <endEvent id="end-transferring" name="Information transmitted">
         <incoming>sf-t5</incoming>
      </endEvent>

      <endEvent id="end-transferring-noconsent" name="Transfer without health data">
         <incoming>sf-t3b</incoming>
      </endEvent>

      <sequenceFlow id="sf-t1" sourceRef="start-transferring" targetRef="task-obtain-consent"/>
      <sequenceFlow id="sf-t2" sourceRef="task-obtain-consent" targetRef="gw-consent"/>
      <sequenceFlow id="sf-t3" name="Yes" sourceRef="gw-consent" targetRef="task-transmit-info"/>
      <sequenceFlow id="sf-t3b" name="No (no vital interest exception)" sourceRef="gw-consent" targetRef="end-transferring-noconsent"/>
      <sequenceFlow id="sf-t4" sourceRef="task-transmit-info" targetRef="task-transfer-certificate"/>
      <sequenceFlow id="sf-t5" sourceRef="task-transfer-certificate" targetRef="end-transferring"/>
   </process>

   <!-- ============================================================ -->
   <!-- PROCESS: Member State Responsible                             -->
   <!-- ============================================================ -->
   <process id="proc-responsible" name="Member State Responsible" isExecutable="false" isClosed="false" processType="None">
      <laneSet id="ls-responsible">
         <lane id="lane-responsible">
            <flowNodeRef>start-responsible</flowNodeRef>
            <flowNodeRef>task-ensure-needs</flowNodeRef>
            <flowNodeRef>end-responsible</flowNodeRef>
         </lane>
      </laneSet>

      <startEvent id="start-responsible" name="Receive special needs information">
         <outgoing>sf-r1</outgoing>
         <messageEventDefinition id="med-responsible"/>
      </startEvent>

      <task id="task-ensure-needs" name="Ensure special needs are adequately addressed" completionQuantity="1" startQuantity="1" isForCompensation="false">
         <incoming>sf-r1</incoming>
         <outgoing>sf-r2</outgoing>
      </task>

      <endEvent id="end-responsible" name="Needs addressed">
         <incoming>sf-r2</incoming>
      </endEvent>

      <sequenceFlow id="sf-r1" sourceRef="start-responsible" targetRef="task-ensure-needs"/>
      <sequenceFlow id="sf-r2" sourceRef="task-ensure-needs" targetRef="end-responsible"/>
   </process>

   <!-- ============================================================ -->
   <!-- PROCESS: Commission                                           -->
   <!-- ============================================================ -->
   <process id="proc-commission" name="Commission" isExecutable="false" isClosed="false" processType="None">
      <laneSet id="ls-commission">
         <lane id="lane-commission">
            <flowNodeRef>start-commission</flowNodeRef>
            <flowNodeRef>task-draw-up-certificate</flowNodeRef>
            <flowNodeRef>task-adopt-conditions</flowNodeRef>
            <flowNodeRef>task-adopt-impl-acts</flowNodeRef>
            <flowNodeRef>end-commission</flowNodeRef>
         </lane>
      </laneSet>

      <startEvent id="start-commission" name="Start">
         <outgoing>sf-c1</outgoing>
      </startEvent>

      <task id="task-draw-up-certificate" name="Draw up common health certificate" completionQuantity="1" startQuantity="1" isForCompensation="false">
         <incoming>sf-c1</incoming>
         <outgoing>sf-c2</outgoing>
      </task>

      <task id="task-adopt-conditions" name="Adopt uniform conditions and practical arrangements for exchanging information" completionQuantity="1" startQuantity="1" isForCompensation="false">
         <incoming>sf-c2</incoming>
         <outgoing>sf-c3</outgoing>
      </task>

      <task id="task-adopt-impl-acts" name="Adopt implementing acts IAW examination procedure" completionQuantity="1" startQuantity="1" isForCompensation="false">
         <incoming>sf-c3</incoming>
         <outgoing>sf-c4</outgoing>
      </task>

      <endEvent id="end-commission" name="Implementing acts adopted">
         <incoming>sf-c4</incoming>
      </endEvent>

      <sequenceFlow id="sf-c1" sourceRef="start-commission" targetRef="task-draw-up-certificate"/>
      <sequenceFlow id="sf-c2" sourceRef="task-draw-up-certificate" targetRef="task-adopt-conditions"/>
      <sequenceFlow id="sf-c3" sourceRef="task-adopt-conditions" targetRef="task-adopt-impl-acts"/>
      <sequenceFlow id="sf-c4" sourceRef="task-adopt-impl-acts" targetRef="end-commission"/>
   </process>

   <!-- ============================================================ -->
   <!-- PROCESS: Health Professional                                  -->
   <!-- ============================================================ -->
   <process id="proc-healthprof" name="Health Professional" isExecutable="false" isClosed="false" processType="None">
      <laneSet id="ls-healthprof">
         <lane id="lane-healthprof">
            <flowNodeRef>start-healthprof</flowNodeRef>
            <flowNodeRef>task-process-data</flowNodeRef>
            <flowNodeRef>task-exchange-info</flowNodeRef>
            <flowNodeRef>end-healthprof</flowNodeRef>
         </lane>
      </laneSet>

      <startEvent id="start-healthprof" name="Receive health data">
         <outgoing>sf-h1</outgoing>
         <messageEventDefinition id="med-healthprof"/>
      </startEvent>

      <task id="task-process-data" name="Process personal health data" completionQuantity="1" startQuantity="1" isForCompensation="false">
         <incoming>sf-h1</incoming>
         <outgoing>sf-h2</outgoing>
      </task>

      <task id="task-exchange-info" name="Exchange information with other health professionals" completionQuantity="1" startQuantity="1" isForCompensation="false">
         <incoming>sf-h2</incoming>
         <outgoing>sf-h3</outgoing>
      </task>

      <endEvent id="end-healthprof" name="Processing complete">
         <incoming>sf-h3</incoming>
      </endEvent>

      <sequenceFlow id="sf-h1" sourceRef="start-healthprof" targetRef="task-process-data"/>
      <sequenceFlow id="sf-h2" sourceRef="task-process-data" targetRef="task-exchange-info"/>
      <sequenceFlow id="sf-h3" sourceRef="task-exchange-info" targetRef="end-healthprof"/>
   </process>

   <!-- ============================================================ -->
   <!-- DIAGRAM (DI)                                                  -->
   <!-- ============================================================ -->
   <bpmndi:BPMNDiagram id="diagram-1">
      <bpmndi:BPMNPlane bpmnElement="collab-1" id="plane-1">

         <!-- Pool: Transferring Member State -->
         <bpmndi:BPMNShape bpmnElement="pool-transferring" id="shape-pool-transferring" isHorizontal="true">
            <omgdc:Bounds height="200.0" width="900.0" x="60.0" y="60.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="lane-transferring" id="shape-lane-transferring" isHorizontal="true">
            <omgdc:Bounds height="200.0" width="870.0" x="90.0" y="60.0"/>
         </bpmndi:BPMNShape>

         <bpmndi:BPMNShape bpmnElement="start-transferring" id="shape-start-transferring">
            <omgdc:Bounds height="30.0" width="30.0" x="120.0" y="145.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task-obtain-consent" id="shape-task-obtain-consent">
            <omgdc:Bounds height="80.0" width="120.0" x="200.0" y="120.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="gw-consent" id="shape-gw-consent" isMarkerVisible="true">
            <omgdc:Bounds height="40.0" width="40.0" x="370.0" y="140.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task-transmit-info" id="shape-task-transmit-info">
            <omgdc:Bounds height="80.0" width="140.0" x="460.0" y="120.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task-transfer-certificate" id="shape-task-transfer-certificate">
            <omgdc:Bounds height="80.0" width="140.0" x="650.0" y="120.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="end-transferring" id="shape-end-transferring">
            <omgdc:Bounds height="28.0" width="28.0" x="840.0" y="146.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="end-transferring-noconsent" id="shape-end-transferring-noconsent">
            <omgdc:Bounds height="28.0" width="28.0" x="376.0" y="220.0"/>
         </bpmndi:BPMNShape>

         <bpmndi:BPMNEdge bpmnElement="sf-t1" id="edge-sf-t1">
            <omgdi:waypoint x="150.0" y="160.0"/>
            <omgdi:waypoint x="200.0" y="160.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf-t2" id="edge-sf-t2">
            <omgdi:waypoint x="320.0" y="160.0"/>
            <omgdi:waypoint x="370.0" y="160.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf-t3" id="edge-sf-t3">
            <omgdi:waypoint x="410.0" y="160.0"/>
            <omgdi:waypoint x="460.0" y="160.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf-t3b" id="edge-sf-t3b">
            <omgdi:waypoint x="390.0" y="180.0"/>
            <omgdi:waypoint x="390.0" y="220.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf-t4" id="edge-sf-t4">
            <omgdi:waypoint x="600.0" y="160.0"/>
            <omgdi:waypoint x="650.0" y="160.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf-t5" id="edge-sf-t5">
            <omgdi:waypoint x="790.0" y="160.0"/>
            <omgdi:waypoint x="840.0" y="160.0"/>
         </bpmndi:BPMNEdge>

         <!-- Pool: Member State Responsible -->
         <bpmndi:BPMNShape bpmnElement="pool-responsible" id="shape-pool-responsible" isHorizontal="true">
            <omgdc:Bounds height="160.0" width="900.0" x="60.0" y="300.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="lane-responsible" id="shape-lane-responsible" isHorizontal="true">
            <omgdc:Bounds height="160.0" width="870.0" x="90.0" y="300.0"/>
         </bpmndi:BPMNShape>

         <bpmndi:BPMNShape bpmnElement="start-responsible" id="shape-start-responsible">
            <omgdc:Bounds height="30.0" width="30.0" x="200.0" y="365.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task-ensure-needs" id="shape-task-ensure-needs">
            <omgdc:Bounds height="80.0" width="140.0" x="320.0" y="340.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="end-responsible" id="shape-end-responsible">
            <omgdc:Bounds height="28.0" width="28.0" x="540.0" y="366.0"/>
         </bpmndi:BPMNShape>

         <bpmndi:BPMNEdge bpmnElement="sf-r1" id="edge-sf-r1">
            <omgdi:waypoint x="230.0" y="380.0"/>
            <omgdi:waypoint x="320.0" y="380.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf-r2" id="edge-sf-r2">
            <omgdi:waypoint x="460.0" y="380.0"/>
            <omgdi:waypoint x="540.0" y="380.0"/>
         </bpmndi:BPMNEdge>

         <!-- Pool: Commission -->
         <bpmndi:BPMNShape bpmnElement="pool-commission" id="shape-pool-commission" isHorizontal="true">
            <omgdc:Bounds height="160.0" width="900.0" x="60.0" y="500.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="lane-commission" id="shape-lane-commission" isHorizontal="true">
            <omgdc:Bounds height="160.0" width="870.0" x="90.0" y="500.0"/>
         </bpmndi:BPMNShape>

         <bpmndi:BPMNShape bpmnElement="start-commission" id="shape-start-commission">
            <omgdc:Bounds height="30.0" width="30.0" x="120.0" y="565.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task-draw-up-certificate" id="shape-task-draw-up-certificate">
            <omgdc:Bounds height="80.0" width="140.0" x="210.0" y="540.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task-adopt-conditions" id="shape-task-adopt-conditions">
            <omgdc:Bounds height="80.0" width="160.0" x="410.0" y="540.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task-adopt-impl-acts" id="shape-task-adopt-impl-acts">
            <omgdc:Bounds height="80.0" width="140.0" x="630.0" y="540.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="end-commission" id="shape-end-commission">
            <omgdc:Bounds height="28.0" width="28.0" x="830.0" y="566.0"/>
         </bpmndi:BPMNShape>

         <bpmndi:BPMNEdge bpmnElement="sf-c1" id="edge-sf-c1">
            <omgdi:waypoint x="150.0" y="580.0"/>
            <omgdi:waypoint x="210.0" y="580.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf-c2" id="edge-sf-c2">
            <omgdi:waypoint x="350.0" y="580.0"/>
            <omgdi:waypoint x="410.0" y="580.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf-c3" id="edge-sf-c3">
            <omgdi:waypoint x="570.0" y="580.0"/>
            <omgdi:waypoint x="630.0" y="580.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf-c4" id="edge-sf-c4">
            <omgdi:waypoint x="770.0" y="580.0"/>
            <omgdi:waypoint x="830.0" y="580.0"/>
         </bpmndi:BPMNEdge>

         <!-- Pool: Health Professional -->
         <bpmndi:BPMNShape bpmnElement="pool-healthprof" id="shape-pool-healthprof" isHorizontal="true">
            <omgdc:Bounds height="160.0" width="900.0" x="60.0" y="700.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="lane-healthprof" id="shape-lane-healthprof" isHorizontal="true">
            <omgdc:Bounds height="160.0" width="870.0" x="90.0" y="700.0"/>
         </bpmndi:BPMNShape>

         <bpmndi:BPMNShape bpmnElement="start-healthprof" id="shape-start-healthprof">
            <omgdc:Bounds height="30.0" width="30.0" x="200.0" y="765.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task-process-data" id="shape-task-process-data">
            <omgdc:Bounds height="80.0" width="140.0" x="320.0" y="740.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task-exchange-info" id="shape-task-exchange-info">
            <omgdc:Bounds height="80.0" width="160.0" x="530.0" y="740.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="end-healthprof" id="shape-end-healthprof">
            <omgdc:Bounds height="28.0" width="28.0" x="760.0" y="766.0"/>
         </bpmndi:BPMNShape>

         <bpmndi:BPMNEdge bpmnElement="sf-h1" id="edge-sf-h1">
            <omgdi:waypoint x="230.0" y="780.0"/>
            <omgdi:waypoint x="320.0" y="780.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf-h2" id="edge-sf-h2">
            <omgdi:waypoint x="460.0" y="780.0"/>
            <omgdi:waypoint x="530.0" y="780.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf-h3" id="edge-sf-h3">
            <omgdi:waypoint x="690.0" y="780.0"/>
            <omgdi:waypoint x="760.0" y="780.0"/>
         </bpmndi:BPMNEdge>

         <!-- Message Flows -->
         <bpmndi:BPMNEdge bpmnElement="mf-1" id="edge-mf-1">
            <omgdi:waypoint x="530.0" y="200.0"/>
            <omgdi:waypoint x="530.0" y="282.0"/>
            <omgdi:waypoint x="215.0" y="282.0"/>
            <omgdi:waypoint x="215.0" y="365.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="mf-2" id="edge-mf-2">
            <omgdi:waypoint x="720.0" y="200.0"/>
            <omgdi:waypoint x="720.0" y="270.0"/>
            <omgdi:waypoint x="390.0" y="270.0"/>
            <omgdi:waypoint x="390.0" y="340.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="mf-3" id="edge-mf-3">
            <omgdi:waypoint x="280.0" y="540.0"/>
            <omgdi:waypoint x="280.0" y="470.0"/>
            <omgdi:waypoint x="720.0" y="470.0"/>
            <omgdi:waypoint x="720.0" y="200.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="mf-4" id="edge-mf-4">
            <omgdi:waypoint x="390.0" y="420.0"/>
            <omgdi:waypoint x="390.0" y="680.0"/>
            <omgdi:waypoint x="215.0" y="680.0"/>
            <omgdi:waypoint x="215.0" y="765.0"/>
         </bpmndi:BPMNEdge>

      </bpmndi:BPMNPlane>
   </bpmndi:BPMNDiagram>
</definitions>
