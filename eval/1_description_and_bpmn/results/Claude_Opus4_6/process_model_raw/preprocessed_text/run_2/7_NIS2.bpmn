<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             id="definitions_1"
             targetNamespace="http://www.signavio.com"
             expressionLanguage="http://www.w3.org/TR/XPath"
             typeLanguage="http://www.w3.org/2001/XMLSchema"
             xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd">

   <!-- ==================== COLLABORATION ==================== -->
   <collaboration id="collab_1">
      <participant id="pool_entities" name="Essential / Important Entities" processRef="proc_entities"/>
      <participant id="pool_csirt" name="CSIRT / Competent Authority" processRef="proc_csirt"/>
      <participant id="pool_spoc" name="Single Point of Contact" processRef="proc_spoc"/>
      <participant id="pool_enisa" name="ENISA" processRef="proc_enisa"/>
      <participant id="pool_commission" name="Commission" processRef="proc_commission"/>

      <!-- Message flows between pools -->
      <messageFlow id="mf_notify_csirt" name="" sourceRef="task_notify_csirt" targetRef="start_csirt"/>
      <messageFlow id="mf_early_warning" name="" sourceRef="task_early_warning" targetRef="task_provide_response"/>
      <messageFlow id="mf_incident_notif" name="" sourceRef="task_incident_notification" targetRef="task_provide_response"/>
      <messageFlow id="mf_forward_spoc" name="" sourceRef="task_inform_ms" targetRef="start_spoc"/>
      <messageFlow id="mf_summary_enisa" name="" sourceRef="task_submit_summary" targetRef="start_enisa"/>
      <messageFlow id="mf_csirt_to_commission" name="" sourceRef="task_provide_info_ca" targetRef="start_commission"/>
   </collaboration>

   <!-- ==================== PROCESS: ENTITIES ==================== -->
   <process id="proc_entities" name="Essential / Important Entities" isExecutable="false" isClosed="false" processType="None">
      <laneSet id="ls_entities">
         <lane id="lane_entities" name="">
            <flowNodeRef>start_entities</flowNodeRef>
            <flowNodeRef>task_notify_csirt</flowNodeRef>
            <flowNodeRef>task_notify_recipients</flowNodeRef>
            <flowNodeRef>task_report_crossborder</flowNodeRef>
            <flowNodeRef>task_communicate_measures</flowNodeRef>
            <flowNodeRef>gw_par_split_assess</flowNodeRef>
            <flowNodeRef>task_assess_disruption</flowNodeRef>
            <flowNodeRef>task_assess_damage</flowNodeRef>
            <flowNodeRef>gw_par_join_assess</flowNodeRef>
            <flowNodeRef>gw_par_split_submit</flowNodeRef>
            <flowNodeRef>task_early_warning</flowNodeRef>
            <flowNodeRef>task_incident_notification</flowNodeRef>
            <flowNodeRef>task_intermediate_report</flowNodeRef>
            <flowNodeRef>task_final_report</flowNodeRef>
            <flowNodeRef>task_progress_report</flowNodeRef>
            <flowNodeRef>gw_par_join_submit</flowNodeRef>
            <flowNodeRef>end_entities</flowNodeRef>
         </lane>
      </laneSet>

      <startEvent id="start_entities" name="Significant incident detected">
         <outgoing>sf_e1</outgoing>
      </startEvent>
      <task id="task_notify_csirt" name="Notify CSIRT / competent authority of significant incident">
         <incoming>sf_e1</incoming>
         <outgoing>sf_e2</outgoing>
      </task>
      <task id="task_notify_recipients" name="Notify recipients of significant incidents">
         <incoming>sf_e2</incoming>
         <outgoing>sf_e3</outgoing>
      </task>
      <task id="task_report_crossborder" name="Report cross-border impact information">
         <incoming>sf_e3</incoming>
         <outgoing>sf_e4</outgoing>
      </task>
      <task id="task_communicate_measures" name="Communicate measures / remedies to affected recipients">
         <incoming>sf_e4</incoming>
         <outgoing>sf_e5</outgoing>
      </task>

      <!-- Parallel: Assess significance (3a, 3b) -->
      <parallelGateway id="gw_par_split_assess" name="" gatewayDirection="Diverging">
         <incoming>sf_e5</incoming>
         <outgoing>sf_e6a</outgoing>
         <outgoing>sf_e6b</outgoing>
      </parallelGateway>
      <task id="task_assess_disruption" name="Assess severe operational disruption or financial loss (3a)">
         <incoming>sf_e6a</incoming>
         <outgoing>sf_e7a</outgoing>
      </task>
      <task id="task_assess_damage" name="Assess impact on other persons causing material or non-material damage (3b)">
         <incoming>sf_e6b</incoming>
         <outgoing>sf_e7b</outgoing>
      </task>
      <parallelGateway id="gw_par_join_assess" name="" gatewayDirection="Converging">
         <incoming>sf_e7a</incoming>
         <incoming>sf_e7b</incoming>
         <outgoing>sf_e8</outgoing>
      </parallelGateway>

      <!-- Parallel: Submit reports (4a-4e) -->
      <parallelGateway id="gw_par_split_submit" name="" gatewayDirection="Diverging">
         <incoming>sf_e8</incoming>
         <outgoing>sf_e9a</outgoing>
         <outgoing>sf_e9b</outgoing>
         <outgoing>sf_e9c</outgoing>
         <outgoing>sf_e9d</outgoing>
         <outgoing>sf_e9e</outgoing>
      </parallelGateway>
      <task id="task_early_warning" name="Submit early warning within 24 hours (4a)">
         <incoming>sf_e9a</incoming>
         <outgoing>sf_e10a</outgoing>
      </task>
      <task id="task_incident_notification" name="Submit incident notification within 72 hours (4b)">
         <incoming>sf_e9b</incoming>
         <outgoing>sf_e10b</outgoing>
      </task>
      <task id="task_intermediate_report" name="Submit intermediate report on request (4c)">
         <incoming>sf_e9c</incoming>
         <outgoing>sf_e10c</outgoing>
      </task>
      <task id="task_final_report" name="Submit final report within one month (4d)">
         <incoming>sf_e9d</incoming>
         <outgoing>sf_e10d</outgoing>
      </task>
      <task id="task_progress_report" name="Submit progress report if incident ongoing (4e)">
         <incoming>sf_e9e</incoming>
         <outgoing>sf_e10e</outgoing>
      </task>
      <parallelGateway id="gw_par_join_submit" name="" gatewayDirection="Converging">
         <incoming>sf_e10a</incoming>
         <incoming>sf_e10b</incoming>
         <incoming>sf_e10c</incoming>
         <incoming>sf_e10d</incoming>
         <incoming>sf_e10e</incoming>
         <outgoing>sf_e11</outgoing>
      </parallelGateway>

      <endEvent id="end_entities" name="End">
         <incoming>sf_e11</incoming>
      </endEvent>

      <sequenceFlow id="sf_e1" sourceRef="start_entities" targetRef="task_notify_csirt"/>
      <sequenceFlow id="sf_e2" sourceRef="task_notify_csirt" targetRef="task_notify_recipients"/>
      <sequenceFlow id="sf_e3" sourceRef="task_notify_recipients" targetRef="task_report_crossborder"/>
      <sequenceFlow id="sf_e4" sourceRef="task_report_crossborder" targetRef="task_communicate_measures"/>
      <sequenceFlow id="sf_e5" sourceRef="task_communicate_measures" targetRef="gw_par_split_assess"/>
      <sequenceFlow id="sf_e6a" sourceRef="gw_par_split_assess" targetRef="task_assess_disruption"/>
      <sequenceFlow id="sf_e6b" sourceRef="gw_par_split_assess" targetRef="task_assess_damage"/>
      <sequenceFlow id="sf_e7a" sourceRef="task_assess_disruption" targetRef="gw_par_join_assess"/>
      <sequenceFlow id="sf_e7b" sourceRef="task_assess_damage" targetRef="gw_par_join_assess"/>
      <sequenceFlow id="sf_e8" sourceRef="gw_par_join_assess" targetRef="gw_par_split_submit"/>
      <sequenceFlow id="sf_e9a" sourceRef="gw_par_split_submit" targetRef="task_early_warning"/>
      <sequenceFlow id="sf_e9b" sourceRef="gw_par_split_submit" targetRef="task_incident_notification"/>
      <sequenceFlow id="sf_e9c" sourceRef="gw_par_split_submit" targetRef="task_intermediate_report"/>
      <sequenceFlow id="sf_e9d" sourceRef="gw_par_split_submit" targetRef="task_final_report"/>
      <sequenceFlow id="sf_e9e" sourceRef="gw_par_split_submit" targetRef="task_progress_report"/>
      <sequenceFlow id="sf_e10a" sourceRef="task_early_warning" targetRef="gw_par_join_submit"/>
      <sequenceFlow id="sf_e10b" sourceRef="task_incident_notification" targetRef="gw_par_join_submit"/>
      <sequenceFlow id="sf_e10c" sourceRef="task_intermediate_report" targetRef="gw_par_join_submit"/>
      <sequenceFlow id="sf_e10d" sourceRef="task_final_report" targetRef="gw_par_join_submit"/>
      <sequenceFlow id="sf_e10e" sourceRef="task_progress_report" targetRef="gw_par_join_submit"/>
      <sequenceFlow id="sf_e11" sourceRef="gw_par_join_submit" targetRef="end_entities"/>
   </process>

   <!-- ==================== PROCESS: CSIRT / COMPETENT AUTHORITY ==================== -->
   <process id="proc_csirt" name="CSIRT / Competent Authority" isExecutable="false" isClosed="false" processType="None">
      <laneSet id="ls_csirt">
         <lane id="lane_csirt" name="">
            <flowNodeRef>start_csirt</flowNodeRef>
            <flowNodeRef>task_forward_to_csirt</flowNodeRef>
            <flowNodeRef>task_provide_response</flowNodeRef>
            <flowNodeRef>task_provide_tech_support</flowNodeRef>
            <flowNodeRef>task_guidance_law_enforcement</flowNodeRef>
            <flowNodeRef>task_inform_ms</flowNodeRef>
            <flowNodeRef>task_inform_public</flowNodeRef>
            <flowNodeRef>task_provide_info_ca</flowNodeRef>
            <flowNodeRef>end_csirt</flowNodeRef>
         </lane>
      </laneSet>

      <startEvent id="start_csirt" name="Notification received">
         <outgoing>sf_c1</outgoing>
         <messageEventDefinition id="msg_def_csirt"/>
      </startEvent>
      <task id="task_forward_to_csirt" name="Forward notification to CSIRT upon receipt">
         <incoming>sf_c1</incoming>
         <outgoing>sf_c2</outgoing>
      </task>
      <task id="task_provide_response" name="Provide response and initial feedback within 24 hours (5)">
         <incoming>sf_c2</incoming>
         <outgoing>sf_c3</outgoing>
      </task>
      <task id="task_provide_tech_support" name="Provide additional technical support">
         <incoming>sf_c3</incoming>
         <outgoing>sf_c4</outgoing>
      </task>
      <task id="task_guidance_law_enforcement" name="Provide guidance on reporting to law enforcement">
         <incoming>sf_c4</incoming>
         <outgoing>sf_c5</outgoing>
      </task>
      <task id="task_inform_ms" name="Inform other affected Member States and ENISA (6)">
         <incoming>sf_c5</incoming>
         <outgoing>sf_c6</outgoing>
      </task>
      <task id="task_inform_public" name="Inform public about significant incident (7)">
         <incoming>sf_c6</incoming>
         <outgoing>sf_c7</outgoing>
      </task>
      <task id="task_provide_info_ca" name="Provide information on incidents to competent authorities (10)">
         <incoming>sf_c7</incoming>
         <outgoing>sf_c8</outgoing>
      </task>
      <endEvent id="end_csirt" name="End">
         <incoming>sf_c8</incoming>
      </endEvent>

      <sequenceFlow id="sf_c1" sourceRef="start_csirt" targetRef="task_forward_to_csirt"/>
      <sequenceFlow id="sf_c2" sourceRef="task_forward_to_csirt" targetRef="task_provide_response"/>
      <sequenceFlow id="sf_c3" sourceRef="task_provide_response" targetRef="task_provide_tech_support"/>
      <sequenceFlow id="sf_c4" sourceRef="task_provide_tech_support" targetRef="task_guidance_law_enforcement"/>
      <sequenceFlow id="sf_c5" sourceRef="task_guidance_law_enforcement" targetRef="task_inform_ms"/>
      <sequenceFlow id="sf_c6" sourceRef="task_inform_ms" targetRef="task_inform_public"/>
      <sequenceFlow id="sf_c7" sourceRef="task_inform_public" targetRef="task_provide_info_ca"/>
      <sequenceFlow id="sf_c8" sourceRef="task_provide_info_ca" targetRef="end_csirt"/>
   </process>

   <!-- ==================== PROCESS: SINGLE POINT OF CONTACT ==================== -->
   <process id="proc_spoc" name="Single Point of Contact" isExecutable="false" isClosed="false" processType="None">
      <laneSet id="ls_spoc">
         <lane id="lane_spoc" name="">
            <flowNodeRef>start_spoc</flowNodeRef>
            <flowNodeRef>task_forward_notifications</flowNodeRef>
            <flowNodeRef>task_submit_summary</flowNodeRef>
            <flowNodeRef>end_spoc</flowNodeRef>
         </lane>
      </laneSet>

      <startEvent id="start_spoc" name="Information received from CSIRT">
         <outgoing>sf_s1</outgoing>
         <messageEventDefinition id="msg_def_spoc"/>
      </startEvent>
      <task id="task_forward_notifications" name="Forward notifications to single points of contact of other affected Member States (8)">
         <incoming>sf_s1</incoming>
         <outgoing>sf_s2</outgoing>
      </task>
      <task id="task_submit_summary" name="Submit summary report to ENISA every three months (9)">
         <incoming>sf_s2</incoming>
         <outgoing>sf_s3</outgoing>
      </task>
      <endEvent id="end_spoc" name="End">
         <incoming>sf_s3</incoming>
      </endEvent>

      <sequenceFlow id="sf_s1" sourceRef="start_spoc" targetRef="task_forward_notifications"/>
      <sequenceFlow id="sf_s2" sourceRef="task_forward_notifications" targetRef="task_submit_summary"/>
      <sequenceFlow id="sf_s3" sourceRef="task_submit_summary" targetRef="end_spoc"/>
   </process>

   <!-- ==================== PROCESS: ENISA ==================== -->
   <process id="proc_enisa" name="ENISA" isExecutable="false" isClosed="false" processType="None">
      <laneSet id="ls_enisa">
         <lane id="lane_enisa" name="">
            <flowNodeRef>start_enisa</flowNodeRef>
            <flowNodeRef>task_adopt_guidance</flowNodeRef>
            <flowNodeRef>task_inform_coop_group</flowNodeRef>
            <flowNodeRef>end_enisa</flowNodeRef>
         </lane>
      </laneSet>

      <startEvent id="start_enisa" name="Summary report received">
         <outgoing>sf_n1</outgoing>
         <messageEventDefinition id="msg_def_enisa"/>
      </startEvent>
      <task id="task_adopt_guidance" name="Adopt technical guidance on information parameters (9)">
         <incoming>sf_n1</incoming>
         <outgoing>sf_n2</outgoing>
      </task>
      <task id="task_inform_coop_group" name="Inform Cooperation Group and CSIRTs network every six months (9)">
         <incoming>sf_n2</incoming>
         <outgoing>sf_n3</outgoing>
      </task>
      <endEvent id="end_enisa" name="End">
         <incoming>sf_n3</incoming>
      </endEvent>

      <sequenceFlow id="sf_n1" sourceRef="start_enisa" targetRef="task_adopt_guidance"/>
      <sequenceFlow id="sf_n2" sourceRef="task_adopt_guidance" targetRef="task_inform_coop_group"/>
      <sequenceFlow id="sf_n3" sourceRef="task_inform_coop_group" targetRef="end_enisa"/>
   </process>

   <!-- ==================== PROCESS: COMMISSION ==================== -->
   <process id="proc_commission" name="Commission" isExecutable="false" isClosed="false" processType="None">
      <laneSet id="ls_commission">
         <lane id="lane_commission" name="">
            <flowNodeRef>start_commission</flowNodeRef>
            <flowNodeRef>task_adopt_implementing_acts</flowNodeRef>
            <flowNodeRef>task_exchange_advice</flowNodeRef>
            <flowNodeRef>end_commission</flowNodeRef>
         </lane>
      </laneSet>

      <startEvent id="start_commission" name="Information received">
         <outgoing>sf_m1</outgoing>
         <messageEventDefinition id="msg_def_commission"/>
      </startEvent>
      <task id="task_adopt_implementing_acts" name="Adopt implementing acts specifying information type, format and procedure (11)">
         <incoming>sf_m1</incoming>
         <outgoing>sf_m2</outgoing>
      </task>
      <task id="task_exchange_advice" name="Exchange advice and cooperate with Cooperation Group (11)">
         <incoming>sf_m2</incoming>
         <outgoing>sf_m3</outgoing>
      </task>
      <endEvent id="end_commission" name="End">
         <incoming>sf_m3</incoming>
      </endEvent>

      <sequenceFlow id="sf_m1" sourceRef="start_commission" targetRef="task_adopt_implementing_acts"/>
      <sequenceFlow id="sf_m2" sourceRef="task_adopt_implementing_acts" targetRef="task_exchange_advice"/>
      <sequenceFlow id="sf_m3" sourceRef="task_exchange_advice" targetRef="end_commission"/>
   </process>

   <!-- ==================== DIAGRAM (DI) ==================== -->
   <bpmndi:BPMNDiagram id="diagram_1">
      <bpmndi:BPMNPlane bpmnElement="collab_1" id="plane_1">

         <!-- ===== POOL: Entities (y=60, height=340) ===== -->
         <bpmndi:BPMNShape bpmnElement="pool_entities" id="pool_entities_gui" isHorizontal="true">
            <omgdc:Bounds height="340.0" width="1920.0" x="60.0" y="60.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="lane_entities" id="lane_entities_gui" isHorizontal="true">
            <omgdc:Bounds height="340.0" width="1890.0" x="90.0" y="60.0"/>
         </bpmndi:BPMNShape>

         <!-- Start -->
         <bpmndi:BPMNShape bpmnElement="start_entities" id="start_entities_gui">
            <omgdc:Bounds height="30.0" width="30.0" x="130.0" y="145.0"/>
         </bpmndi:BPMNShape>
         <!-- Sequential tasks -->
         <bpmndi:BPMNShape bpmnElement="task_notify_csirt" id="task_notify_csirt_gui">
            <omgdc:Bounds height="80.0" width="120.0" x="200.0" y="120.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_notify_recipients" id="task_notify_recipients_gui">
            <omgdc:Bounds height="80.0" width="120.0" x="360.0" y="120.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_report_crossborder" id="task_report_crossborder_gui">
            <omgdc:Bounds height="80.0" width="120.0" x="520.0" y="120.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_communicate_measures" id="task_communicate_measures_gui">
            <omgdc:Bounds height="80.0" width="120.0" x="680.0" y="120.0"/>
         </bpmndi:BPMNShape>

         <!-- Parallel assess -->
         <bpmndi:BPMNShape bpmnElement="gw_par_split_assess" id="gw_par_split_assess_gui" isMarkerVisible="true">
            <omgdc:Bounds height="40.0" width="40.0" x="840.0" y="140.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_assess_disruption" id="task_assess_disruption_gui">
            <omgdc:Bounds height="80.0" width="140.0" x="920.0" y="80.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_assess_damage" id="task_assess_damage_gui">
            <omgdc:Bounds height="80.0" width="140.0" x="920.0" y="200.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="gw_par_join_assess" id="gw_par_join_assess_gui" isMarkerVisible="true">
            <omgdc:Bounds height="40.0" width="40.0" x="1100.0" y="140.0"/>
         </bpmndi:BPMNShape>

         <!-- Parallel submit -->
         <bpmndi:BPMNShape bpmnElement="gw_par_split_submit" id="gw_par_split_submit_gui" isMarkerVisible="true">
            <omgdc:Bounds height="40.0" width="40.0" x="1180.0" y="140.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_early_warning" id="task_early_warning_gui">
            <omgdc:Bounds height="60.0" width="140.0" x="1270.0" y="70.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_incident_notification" id="task_incident_notification_gui">
            <omgdc:Bounds height="60.0" width="140.0" x="1270.0" y="140.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_intermediate_report" id="task_intermediate_report_gui">
            <omgdc:Bounds height="60.0" width="140.0" x="1270.0" y="210.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_final_report" id="task_final_report_gui">
            <omgdc:Bounds height="60.0" width="140.0" x="1270.0" y="280.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="task_progress_report" id="task_progress_report_gui">
            <omgdc:Bounds height="60.0" width="140.0" x="1270.0" y="350.0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="gw_par_join_submit" id="gw_par_join_submit_gui" isMarkerVisible="true">
            <omgdc:Bounds height="40.0" width="40.0" x="1460.0" y="140.0"/>
         </bpmndi:BPMNShape>

         <!-- End entities -->
         <bpmndi:BPMNShape bpmnElement="end_entities" id="end_entities_gui">
            <omgdc:Bounds height="28.0" width="28.0" x="1540.0" y="146.0"/>
         </bpmndi:BPMNShape>

         <!-- Sequence flows - Entities -->
         <bpmndi:BPMNEdge bpmnElement="sf_e1" id="sf_e1_gui">
            <omgdi:waypoint x="160.0" y="160.0"/>
            <omgdi:waypoint x="200.0" y="160.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf_e2" id="sf_e2_gui">
            <omgdi:waypoint x="320.0" y="160.0"/>
            <omgdi:waypoint x="360.0" y="160.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf_e3" id="sf_e3_gui">
            <omgdi:waypoint x="480.0" y="160.0"/>
            <omgdi:waypoint x="520.0" y="160.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf_e4" id="sf_e4_gui">
            <omgdi:waypoint x="640.0" y="160.0"/>
            <omgdi:waypoint x="680.0" y="160.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf_e5" id="sf_e5_gui">
            <omgdi:waypoint x="800.0" y="160.0"/>
            <omgdi:waypoint x="840.0" y="160.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf_e6a" id="sf_e6a_gui">
            <omgdi:waypoint x="860.0" y="140.0"/>
            <omgdi:waypoint x="860.0" y="120.0"/>
            <omgdi:waypoint x="920.0" y="120.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf_e6b" id="sf_e6b_gui">
            <omgdi:waypoint x="860.0" y="180.0"/>
            <omgdi:waypoint x="860.0" y="240.0"/>
            <omgdi:waypoint x="920.0" y="240.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf_e7a" id="sf_e7a_gui">
            <omgdi:waypoint x="1060.0" y="120.0"/>
            <omgdi:waypoint x="1120.0" y="120.0"/>
            <omgdi:waypoint x="1120.0" y="140.0"/>
         </bpmndi:BPMNEdge>
         <bpmndi:BPMNEdge bpmnElement="sf_e7b" id="sf_e7b_gui">
