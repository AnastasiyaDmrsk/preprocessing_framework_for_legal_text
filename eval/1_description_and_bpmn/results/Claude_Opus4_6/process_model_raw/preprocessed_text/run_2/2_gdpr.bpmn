<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             id="definitions_1"
             targetNamespace="http://bpmn.io/schema/bpmn"
             exporter="Claude"
             exporterVersion="1.0"
             expressionLanguage="http://www.w3.org/TR/XPath"
             typeLanguage="http://www.w3.org/2001/XMLSchema"
             xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd">

  <!-- ============================================================ -->
  <!-- COLLABORATION                                                 -->
  <!-- ============================================================ -->
  <collaboration id="collab_1">
    <participant id="pool_proc" name="Processor" processRef="proc_processor"/>
    <participant id="pool_ctrl" name="Controller" processRef="proc_controller"/>
    <participant id="pool_sa" name="Supervisory Authority" processRef="proc_sa"/>
    <messageFlow id="mf_1" name="Breach notification" sourceRef="task_p2" targetRef="start_c"/>
    <messageFlow id="mf_2" name="Breach notification to authority" sourceRef="task_c1" targetRef="start_sa"/>
  </collaboration>

  <!-- ============================================================ -->
  <!-- PROCESS: Processor                                            -->
  <!-- ============================================================ -->
  <process id="proc_processor" name="Processor" isExecutable="false" isClosed="false" processType="None">
    <laneSet id="ls_proc">
      <lane id="lane_proc">
        <flowNodeRef>start_p</flowNodeRef>
        <flowNodeRef>task_p1</flowNodeRef>
        <flowNodeRef>task_p2</flowNodeRef>
        <flowNodeRef>end_p</flowNodeRef>
      </lane>
    </laneSet>
    <startEvent id="start_p" name="Start">
      <outgoing>flow_p1</outgoing>
    </startEvent>
    <task id="task_p1" name="Become aware of personal data breach">
      <incoming>flow_p1</incoming>
      <outgoing>flow_p2</outgoing>
    </task>
    <task id="task_p2" name="Notify controller of breach">
      <incoming>flow_p2</incoming>
      <outgoing>flow_p3</outgoing>
    </task>
    <endEvent id="end_p" name="End">
      <incoming>flow_p3</incoming>
    </endEvent>
    <sequenceFlow id="flow_p1" sourceRef="start_p" targetRef="task_p1"/>
    <sequenceFlow id="flow_p2" sourceRef="task_p1" targetRef="task_p2"/>
    <sequenceFlow id="flow_p3" sourceRef="task_p2" targetRef="end_p"/>
  </process>

  <!-- ============================================================ -->
  <!-- PROCESS: Controller                                           -->
  <!-- ============================================================ -->
  <process id="proc_controller" name="Controller" isExecutable="false" isClosed="false" processType="None">
    <laneSet id="ls_ctrl">
      <lane id="lane_ctrl">
        <flowNodeRef>start_c</flowNodeRef>
        <flowNodeRef>task_c1</flowNodeRef>
        <flowNodeRef>gw_c1</flowNodeRef>
        <flowNodeRef>task_c2</flowNodeRef>
        <flowNodeRef>gw_c2</flowNodeRef>
        <flowNodeRef>gw_c3</flowNodeRef>
        <flowNodeRef>task_c3a</flowNodeRef>
        <flowNodeRef>task_c3b</flowNodeRef>
        <flowNodeRef>task_c3c</flowNodeRef>
        <flowNodeRef>task_c3d</flowNodeRef>
        <flowNodeRef>gw_c4</flowNodeRef>
        <flowNodeRef>gw_c5</flowNodeRef>
        <flowNodeRef>gw_c6</flowNodeRef>
        <flowNodeRef>task_c5a</flowNodeRef>
        <flowNodeRef>task_c5b</flowNodeRef>
        <flowNodeRef>task_c5c</flowNodeRef>
        <flowNodeRef>gw_c7</flowNodeRef>
        <flowNodeRef>gw_c8</flowNodeRef>
        <flowNodeRef>task_c6</flowNodeRef>
        <flowNodeRef>gw_merge1</flowNodeRef>
        <flowNodeRef>task_c7</flowNodeRef>
        <flowNodeRef>end_c</flowNodeRef>
      </lane>
    </laneSet>

    <startEvent id="start_c" name="Receive breach notification">
      <outgoing>flow_c1</outgoing>
      <messageEventDefinition id="msgdef_start_c"/>
    </startEvent>

    <task id="task_c1" name="Notify breach to supervisory authority">
      <incoming>flow_c1</incoming>
      <outgoing>flow_c2</outgoing>
    </task>

    <exclusiveGateway id="gw_c1" name="Notification within 72 hours?" gatewayDirection="Diverging">
      <incoming>flow_c2</incoming>
      <outgoing>flow_c3</outgoing>
      <outgoing>flow_c4</outgoing>
    </exclusiveGateway>

    <task id="task_c2" name="Provide reasons for delay">
      <incoming>flow_c3</incoming>
      <outgoing>flow_c5</outgoing>
    </task>

    <exclusiveGateway id="gw_c2" name="" gatewayDirection="Converging">
      <incoming>flow_c4</incoming>
      <incoming>flow_c5</incoming>
      <outgoing>flow_c6</outgoing>
    </exclusiveGateway>

    <parallelGateway id="gw_c3" name="" gatewayDirection="Diverging">
      <incoming>flow_c6</incoming>
      <outgoing>flow_c7</outgoing>
      <outgoing>flow_c8</outgoing>
      <outgoing>flow_c9</outgoing>
      <outgoing>flow_c10</outgoing>
    </parallelGateway>

    <task id="task_c3a" name="Describe nature of breach and number of data subjects">
      <incoming>flow_c7</incoming>
      <outgoing>flow_c11</outgoing>
    </task>

    <task id="task_c3b" name="Communicate DPO contact details">
      <incoming>flow_c8</incoming>
      <outgoing>flow_c12</outgoing>
    </task>

    <task id="task_c3c" name="Describe likely consequences of breach">
      <incoming>flow_c9</incoming>
      <outgoing>flow_c13</outgoing>
    </task>

    <task id="task_c3d" name="Describe measures taken or proposed">
      <incoming>flow_c10</incoming>
      <outgoing>flow_c14</outgoing>
    </task>

    <parallelGateway id="gw_c4" name="" gatewayDirection="Converging">
      <incoming>flow_c11</incoming>
      <incoming>flow_c12</incoming>
      <incoming>flow_c13</incoming>
      <incoming>flow_c14</incoming>
      <outgoing>flow_c15</outgoing>
    </parallelGateway>

    <exclusiveGateway id="gw_c5" name="High risk to data subjects?" gatewayDirection="Diverging">
      <incoming>flow_c15</incoming>
      <outgoing>flow_c16</outgoing>
      <outgoing>flow_c17</outgoing>
    </exclusiveGateway>

    <parallelGateway id="gw_c6" name="" gatewayDirection="Diverging">
      <incoming>flow_c16</incoming>
      <outgoing>flow_c18</outgoing>
      <outgoing>flow_c19</outgoing>
      <outgoing>flow_c20</outgoing>
    </parallelGateway>

    <task id="task_c5a" name="Check technical protection measures applied">
      <incoming>flow_c18</incoming>
      <outgoing>flow_c21</outgoing>
    </task>

    <task id="task_c5b" name="Check subsequent risk mitigation measures">
      <incoming>flow_c19</incoming>
      <outgoing>flow_c22</outgoing>
    </task>

    <task id="task_c5c" name="Assess if communication involves disproportionate effort">
      <incoming>flow_c20</incoming>
      <outgoing>flow_c23</outgoing>
    </task>

    <parallelGateway id="gw_c7" name="" gatewayDirection="Converging">
      <incoming>flow_c21</incoming>
      <incoming>flow_c22</incoming>
      <incoming>flow_c23</incoming>
      <outgoing>flow_c24</outgoing>
    </parallelGateway>

    <exclusiveGateway id="gw_c8" name="Exemption conditions met?" gatewayDirection="Diverging">
      <incoming>flow_c24</incoming>
      <outgoing>flow_c25</outgoing>
      <outgoing>flow_c26</outgoing>
    </exclusiveGateway>

    <task id="task_c6" name="Communicate breach to data subject">
      <incoming>flow_c26</incoming>
      <outgoing>flow_c27</outgoing>
    </task>

    <exclusiveGateway id="gw_merge1" name="" gatewayDirection="Converging">
      <incoming>flow_c17</incoming>
      <incoming>flow_c25</incoming>
      <incoming>flow_c27</incoming>
      <outgoing>flow_c28</outgoing>
    </exclusiveGateway>

    <task id="task_c7" name="Document personal data breach">
      <incoming>flow_c28</incoming>
      <outgoing>flow_c29</outgoing>
    </task>

    <endEvent id="end_c" name="End">
      <incoming>flow_c29</incoming>
    </endEvent>

    <sequenceFlow id="flow_c1" sourceRef="start_c" targetRef="task_c1"/>
    <sequenceFlow id="flow_c2" sourceRef="task_c1" targetRef="gw_c1"/>
    <sequenceFlow id="flow_c3" name="No" sourceRef="gw_c1" targetRef="task_c2"/>
    <sequenceFlow id="flow_c4" name="Yes" sourceRef="gw_c1" targetRef="gw_c2"/>
    <sequenceFlow id="flow_c5" sourceRef="task_c2" targetRef="gw_c2"/>
    <sequenceFlow id="flow_c6" sourceRef="gw_c2" targetRef="gw_c3"/>
    <sequenceFlow id="flow_c7" sourceRef="gw_c3" targetRef="task_c3a"/>
    <sequenceFlow id="flow_c8" sourceRef="gw_c3" targetRef="task_c3b"/>
    <sequenceFlow id="flow_c9" sourceRef="gw_c3" targetRef="task_c3c"/>
    <sequenceFlow id="flow_c10" sourceRef="gw_c3" targetRef="task_c3d"/>
    <sequenceFlow id="flow_c11" sourceRef="task_c3a" targetRef="gw_c4"/>
    <sequenceFlow id="flow_c12" sourceRef="task_c3b" targetRef="gw_c4"/>
    <sequenceFlow id="flow_c13" sourceRef="task_c3c" targetRef="gw_c4"/>
    <sequenceFlow id="flow_c14" sourceRef="task_c3d" targetRef="gw_c4"/>
    <sequenceFlow id="flow_c15" sourceRef="gw_c4" targetRef="gw_c5"/>
    <sequenceFlow id="flow_c16" name="Yes" sourceRef="gw_c5" targetRef="gw_c6"/>
    <sequenceFlow id="flow_c17" name="No" sourceRef="gw_c5" targetRef="gw_merge1"/>
    <sequenceFlow id="flow_c18" sourceRef="gw_c6" targetRef="task_c5a"/>
    <sequenceFlow id="flow_c19" sourceRef="gw_c6" targetRef="task_c5b"/>
    <sequenceFlow id="flow_c20" sourceRef="gw_c6" targetRef="task_c5c"/>
    <sequenceFlow id="flow_c21" sourceRef="task_c5a" targetRef="gw_c7"/>
    <sequenceFlow id="flow_c22" sourceRef="task_c5b" targetRef="gw_c7"/>
    <sequenceFlow id="flow_c23" sourceRef="task_c5c" targetRef="gw_c7"/>
    <sequenceFlow id="flow_c24" sourceRef="gw_c7" targetRef="gw_c8"/>
    <sequenceFlow id="flow_c25" name="Yes" sourceRef="gw_c8" targetRef="gw_merge1"/>
    <sequenceFlow id="flow_c26" name="No" sourceRef="gw_c8" targetRef="task_c6"/>
    <sequenceFlow id="flow_c27" sourceRef="task_c6" targetRef="gw_merge1"/>
    <sequenceFlow id="flow_c28" sourceRef="gw_merge1" targetRef="task_c7"/>
    <sequenceFlow id="flow_c29" sourceRef="task_c7" targetRef="end_c"/>
  </process>

  <!-- ============================================================ -->
  <!-- PROCESS: Supervisory Authority                                -->
  <!-- ============================================================ -->
  <process id="proc_sa" name="Supervisory Authority" isExecutable="false" isClosed="false" processType="None">
    <laneSet id="ls_sa">
      <lane id="lane_sa">
        <flowNodeRef>start_sa</flowNodeRef>
        <flowNodeRef>task_sa1</flowNodeRef>
        <flowNodeRef>task_sa2</flowNodeRef>
        <flowNodeRef>end_sa</flowNodeRef>
      </lane>
    </laneSet>
    <startEvent id="start_sa" name="Receive breach notification">
      <outgoing>flow_sa1</outgoing>
      <messageEventDefinition id="msgdef_start_sa"/>
    </startEvent>
    <task id="task_sa1" name="Assess breach notification">
      <incoming>flow_sa1</incoming>
      <outgoing>flow_sa2</outgoing>
    </task>
    <task id="task_sa2" name="Verify compliance with Article 33">
      <incoming>flow_sa2</incoming>
      <outgoing>flow_sa3</outgoing>
    </task>
    <endEvent id="end_sa" name="End">
      <incoming>flow_sa3</incoming>
    </endEvent>
    <sequenceFlow id="flow_sa1" sourceRef="start_sa" targetRef="task_sa1"/>
    <sequenceFlow id="flow_sa2" sourceRef="task_sa1" targetRef="task_sa2"/>
    <sequenceFlow id="flow_sa3" sourceRef="task_sa2" targetRef="end_sa"/>
  </process>

  <!-- ============================================================ -->
  <!-- DIAGRAM                                                       -->
  <!-- ============================================================ -->
  <bpmndi:BPMNDiagram id="diagram_1">
    <bpmndi:BPMNPlane bpmnElement="collab_1" id="plane_1">

      <!-- ======== PROCESSOR POOL ======== -->
      <bpmndi:BPMNShape bpmnElement="pool_proc" id="pool_proc_di" isHorizontal="true">
        <omgdc:Bounds x="60" y="60" width="620" height="130"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="lane_proc" id="lane_proc_di" isHorizontal="true">
        <omgdc:Bounds x="90" y="60" width="590" height="130"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="start_p" id="start_p_di">
        <omgdc:Bounds x="130" y="107" width="30" height="30"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="task_p1" id="task_p1_di">
        <omgdc:Bounds x="210" y="92" width="170" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="task_p2" id="task_p2_di">
        <omgdc:Bounds x="430" y="92" width="160" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="end_p" id="end_p_di">
        <omgdc:Bounds x="640" y="108" width="28" height="28"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge bpmnElement="flow_p1" id="flow_p1_di">
        <omgdi:waypoint x="160" y="122"/>
        <omgdi:waypoint x="210" y="122"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="flow_p2" id="flow_p2_di">
        <omgdi:waypoint x="380" y="122"/>
        <omgdi:waypoint x="430" y="122"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="flow_p3" id="flow_p3_di">
        <omgdi:waypoint x="590" y="122"/>
        <omgdi:waypoint x="640" y="122"/>
      </bpmndi:BPMNEdge>

      <!-- ======== CONTROLLER POOL ======== -->
      <bpmndi:BPMNShape bpmnElement="pool_ctrl" id="pool_ctrl_di" isHorizontal="true">
        <omgdc:Bounds x="60" y="230" width="1880" height="580"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="lane_ctrl" id="lane_ctrl_di" isHorizontal="true">
        <omgdc:Bounds x="90" y="230" width="1850" height="580"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape bpmnElement="start_c" id="start_c_di">
        <omgdc:Bounds x="125" y="475" width="30" height="30"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="task_c1" id="task_c1_di">
        <omgdc:Bounds x="200" y="455" width="180" height="70"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="gw_c1" id="gw_c1_di" isMarkerVisible="true">
        <omgdc:Bounds x="420" y="470" width="40" height="40"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="task_c2" id="task_c2_di">
        <omgdc:Bounds x="460" y="310" width="170" height="55"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="gw_c2" id="gw_c2_di" isMarkerVisible="true">
        <omgdc:Bounds x="570" y="470" width="40" height="40"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="gw_c3" id="gw_c3_di">
        <omgdc:Bounds x="650" y="470" width="40" height="40"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="task_c3a" id="task_c3a_di">
        <omgdc:Bounds x="730" y="280" width="170" height="55"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="task_c3b" id="task_c3b_di">
        <omgdc:Bounds x="730" y="370" width="170" height="55"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="task_c3c" id="task_c3c_di">
        <omgdc:Bounds x="730" y="460" width="170" height="55"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="task_c3d" id="task_c3d_di">
        <omgdc:Bounds x="730" y="550" width="170" height="55"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="gw_c4" id="gw_c4_di">
        <omgdc:Bounds x="940" y="470" width="40" height="40"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="gw_c5" id="gw_c5_di" isMarkerVisible="true">
        <omgdc:Bounds x="1020" y="470" width="40" height="40"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="gw_c6" id="gw_c6_di">
        <omgdc:Bounds x="1100" y="470" width="40" height="40"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="task_c5a" id="task_c5a_di">
        <omgdc:Bounds x="1180" y="320" width="180" height="55"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="task_c5b" id="task_c5b_di">
        <omgdc:Bounds x="1180" y="450" width="180" height="55"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="task_c5c" id="task_c5c_di">
        <omgdc:Bounds x="1180" y="575" width="180" height="55"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="gw_c7" id="gw_c7_di">
        <omgdc:Bounds x="1400" y="470" width="40" height="40"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="gw_c8" id="gw_c8_di" isMarkerVisible="true">
        <omgdc:Bounds x="1480" y="470" width="40" height="40"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="task_c6" id="task_c6_di">
        <omgdc:Bounds x="1468" y="580" width="180" height="55"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="gw_merge1" id="gw_merge1_di" isMarkerVisible="true">
        <omgdc:Bounds x="1600" y="470" width="40" height="40"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="task_c7" id="task_c7_di">
        <omgdc:Bounds x="1680" y="455" width="170" height="70"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="end_c" id="end_c_di">
        <omgdc:Bounds x="1890" y="476" width="28" height="28"/>
      </bpmndi:BPMNShape>

      <!-- Controller edges -->
      <bpmndi:BPMNEdge bpmnElement="flow_c1" id="flow_c1_di">
        <omgdi:waypoint x="155" y="490"/>
        <omgdi:waypoint x="200" y="490"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="flow_c2" id="flow_c2_di">
        <omgdi:waypoint x="380" y="490"/>
        <omgdi:waypoint x="420" y="490"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="flow_c3" id="flow_c3_di">
        <omgdi:waypoint x="440" y="470"/>
        <omgdi:waypoint x="440" y="337"/>
        <omgdi:waypoint x="460" y="337"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="flow_c4" id="flow_c4_di">
        <omgdi:waypoint x="460" y="490"/>
        <omgdi:waypoint x="570" y="490"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="flow_c5" id="flow_c5_di">
        <omgdi:waypoint x="630" y="337"/>
        <omgdi:waypoint x="590" y="337"/>
        <omgdi:waypoint x="590" y="470"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="flow_c6" id="flow_c6_di">
        <omgdi:waypoint x="610" y="490"/>
        <omgdi:waypoint x="650" y="490"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="flow_c7" id="flow_c7_di">
        <omgdi:waypoint x="670" y="470"/>
        <omgdi:waypoint x="670" y="307"/>
        <omgdi:waypoint x="730" y="307"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="flow_c8" id="flow_c8_di">
        <omgdi:waypoint x="670" y="470"/>
        <omgdi:waypoint x="670" y="397"/>
        <omgdi:waypoint x="730" y="397"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="flow_c9" id="flow_c9_di">
        <omgdi:waypoint x="690" y="490"/>
        <omgdi:waypoint x="730" y="487"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="flow_c10" id="flow_c10_di">
        <omgdi:waypoint x="670" y="510"/>
        <omgdi:waypoint x="670" y="577"/>
        <omgdi:waypoint x="730" y="577"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="flow_c11" id="flow_c11_di">
        <omgdi:waypoint x="900" y="307"/>
        <omgdi:waypoint x="960" y="307"/>
        <omgdi:waypoint x="960" y="470"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="flow_c12" id="flow_c12_di">
        <omgdi:waypoint x="900" y="397"/>
        <omgdi:waypoint x="960" y="397"/>
        <omgdi:waypoint x="960" y="470"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="flow_c13" id="flow_c13_di">
        <omgdi:waypoint x="900" y="487"/>
        <omgdi:waypoint x="940" y="490"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="flow_c14" id="flow_c14_di">
        <omgdi:waypoint x="900" y="577"/>
        <omgdi:waypoint x="960" y="577"/>
        <omgdi:waypoint x="960" y="510"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="flow_c15" id="flow_c15_di">
