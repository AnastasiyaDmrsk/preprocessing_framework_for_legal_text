<?xml version="1.0" encoding="UTF-8"?>
<tasks>

  <task id="t1">
    <label>require verification of the identity</label>
    <performers>
      <performer><unit>Member State</unit><role>Member State</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>before the establishment of a business relationship or the carrying out of the transaction</condition>
    </conditions>
    <exceptions/>
    <source-ref article="UNKNOWN" paragraph="1"/>
  </task>

  <task id="t2">
    <label>verify the identity</label>
    <performers>
      <performer><unit>Customer</unit><role>Customer</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>before the establishment of a business relationship or the carrying out of the transaction</condition>
    </conditions>
    <exceptions/>
    <source-ref article="UNKNOWN" paragraph="1"/>
  </task>

  <task id="t3">
    <label>verify the identity</label>
    <performers>
      <performer><unit>Customer</unit><role>Beneficial Owner</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>before the establishment of a business relationship or the carrying out of the transaction</condition>
    </conditions>
    <exceptions/>
    <source-ref article="UNKNOWN" paragraph="1"/>
  </task>

  <task id="t4">
    <label>allow verification of the identity to be completed during the establishment of a business relationship</label>
    <performers>
      <performer><unit>Member State</unit><role>Member State</role></performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>if necessary so as not to interrupt the normal conduct of business</condition>
      <condition>where there is little risk of money laundering or terrorist financing</condition>
    </conditions>
    <exceptions>
      <exception ref="t1" description="By way of derogation from paragraph 1, Member States may allow verification to be completed during the establishment of a business relationship rather than before it"/>
    </exceptions>
    <source-ref article="UNKNOWN" paragraph="2"/>
  </task>

  <task id="t5">
    <label>allow the opening of an account</label>
    <performers>
      <performer><unit>Member State</unit><role>Member State</role></performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>provided that there are adequate safeguards in place to ensure that transactions are not carried out by the customer or on its behalf until full compliance with the customer</condition>
    </conditions>
    <exceptions>
      <exception ref="t1" description="By way of derogation from paragraph 1, Member States may allow the opening of an account before full verification has been completed, subject to adequate safeguards"/>
    </exceptions>
    <source-ref article="UNKNOWN" paragraph="3"/>
  </task>

  <task id="t6">
    <label>carry out a transaction through a bank account</label>
    <performers>
      <performer><unit>Obliged Entity</unit><role>Obliged Entity</role></performer>
    </performers>
    <deontic type="prohibition" modality="shall not"/>
    <conditions>
      <condition>where an obliged entity is unable to comply with the customer due diligence requirements</condition>
    </conditions>
    <exceptions>
      <exception ref="t6" description="Notary"/>
      <exception ref="t6" description="Independent Legal Professional"/>
      <exception ref="t6" description="Auditor"/>
      <exception ref="t6" description="External Accountant"/>
      <exception ref="t6" description="Tax Advisor"/>
    </exceptions>
    <source-ref article="UNKNOWN" paragraph="4"/>
  </task>

  <task id="t7">
    <label>establish a business relationship</label>
    <performers>
      <performer><unit>Obliged Entity</unit><role>Obliged Entity</role></performer>
    </performers>
    <deontic type="prohibition" modality="shall not"/>
    <conditions>
      <condition>where an obliged entity is unable to comply with the customer due diligence requirements</condition>
    </conditions>
    <exceptions>
      <exception ref="t7" description="Notary"/>
      <exception ref="t7" description="Independent Legal Professional"/>
      <exception ref="t7" description="Auditor"/>
      <exception ref="t7" description="External Accountant"/>
      <exception ref="t7" description="Tax Advisor"/>
    </exceptions>
    <source-ref article="UNKNOWN" paragraph="4"/>
  </task>

  <task id="t8">
    <label>carry out the transaction</label>
    <performers>
      <performer><unit>Obliged Entity</unit><role>Obliged Entity</role></performer>
    </performers>
    <deontic type="prohibition" modality="shall not"/>
    <conditions>
      <condition>where an obliged entity is unable to comply with the customer due diligence requirements</condition>
    </conditions>
    <exceptions>
      <exception ref="t8" description="Notary"/>
      <exception ref="t8" description="Independent Legal Professional"/>
      <exception ref="t8" description="Auditor"/>
      <exception ref="t8" description="External Accountant"/>
      <exception ref="t8" description="Tax Advisor"/>
    </exceptions>
    <source-ref article="UNKNOWN" paragraph="4"/>
  </task>

  <task id="t9">
    <label>terminate the business relationship</label>
    <performers>
      <performer><unit>Obliged Entity</unit><role>Obliged Entity</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>where an obliged entity is unable to comply with the customer due diligence requirements</condition>
    </conditions>
    <exceptions>
      <exception ref="t9" description="Notary"/>
      <exception ref="t9" description="Independent Legal Professional"/>
      <exception ref="t9" description="Auditor"/>
      <exception ref="t9" description="External Accountant"/>
      <exception ref="t9" description="Tax Advisor"/>
    </exceptions>
    <source-ref article="UNKNOWN" paragraph="4"/>
  </task>

  <task id="t10">
    <label>consider making a suspicious transaction report to the FIU</label>
    <performers>
      <performer><unit>Obliged Entity</unit><role>Obliged Entity</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>where an obliged entity is unable to comply with the customer due diligence requirements laid down in point (a), (b) or (c) of the first subparagraph of Article 13(1)</condition>
    </conditions>
    <exceptions>
      <exception ref="t10" description="Notary"/>
      <exception ref="t10" description="Independent Legal Professional"/>
      <exception ref="t10" description="Auditor"/>
      <exception ref="t10" description="External Accountant"/>
      <exception ref="t10" description="Tax Advisor"/>
    </exceptions>
    <source-ref article="UNKNOWN" paragraph="4"/>
  </task>

  <task id="t11">
    <label>require that obliged entities apply the customer due diligence measures</label>
    <performers>
      <performer><unit>Member State</unit><role>Member State</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="UNKNOWN" paragraph="5"/>
  </task>

  <task id="t12">
    <label>apply the customer due diligence measures</label>
    <performers>
      <performer><unit>Obligation Entity</unit><role>Obligation Entity</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="UNKNOWN" paragraph="5"/>
  </task>

</tasks>
