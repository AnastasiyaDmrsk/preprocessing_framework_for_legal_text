<?xml version="1.0" encoding="UTF-8"?>
<tasks>

  <task id="t1">
    <label>ensure that devices have been designed and manufactured in accordance with the requirements of this Regulation</label>
    <performers>
      <performer><unit>Manufacturer</unit><role>Manufacturer</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>when placing their devices on the market or putting them into service</condition>
    </conditions>
    <exceptions/>
    <source-ref article="10" paragraph="1"/>
  </task>

  <task id="t2">
    <label>establish a system for risk management as described in Section 3 of Annex I</label>
    <performers>
      <performer><unit>Manufacturer</unit><role>Manufacturer</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="10" paragraph="2"/>
  </task>

  <task id="t3">
    <label>document a system for risk management as described in Section 3 of Annex I</label>
    <performers>
      <performer><unit>Manufacturer</unit><role>Manufacturer</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="10" paragraph="2"/>
  </task>

  <task id="t4">
    <label>implement a system for risk management as described in Section 3 of Annex I</label>
    <performers>
      <performer><unit>Manufacturer</unit><role>Manufacturer</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="10" paragraph="2"/>
  </task>

  <task id="t5">
    <label>maintain a system for risk management as described in Section 3 of Annex I</label>
    <performers>
      <performer><unit>Manufacturer</unit><role>Manufacturer</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="10" paragraph="2"/>
  </task>

  <task id="t6">
    <label>conduct a clinical evaluation in accordance with the requirements set out in Article 61 and Annex XIV, including a PMCF</label>
    <performers>
      <performer><unit>Manufacturer</unit><role>Manufacturer</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="10" paragraph="3"/>
  </task>

  <task id="t7">
    <label>draw up technical documentation</label>
    <performers>
      <performer><unit>Manufacturer</unit><role>Manufacturer</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions>
      <exception ref="t7" description="Manufacturer of custom-made devices"/>
    </exceptions>
    <source-ref article="10" paragraph="4"/>
  </task>

  <task id="t8">
    <label>keep up to date technical documentation</label>
    <performers>
      <performer><unit>Manufacturer</unit><role>Manufacturer</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions>
      <exception ref="t8" description="Manufacturer of custom-made devices"/>
    </exceptions>
    <source-ref article="10" paragraph="4"/>
  </task>

  <task id="t9">
    <label>draw up documentation in accordance with Section 2 of Annex XIII</label>
    <performers>
      <performer><unit>Manufacturer</unit><role>Manufacturer of custom-made devices</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="10" paragraph="5"/>
  </task>

  <task id="t10">
    <label>keep up to date documentation in accordance with Section 2 of Annex XIII</label>
    <performers>
      <performer><unit>Manufacturer</unit><role>Manufacturer of custom-made devices</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="10" paragraph="5"/>
  </task>

  <task id="t11">
    <label>keep available for competent authorities documentation in accordance with Section 2 of Annex XIII</label>
    <performers>
      <performer><unit>Manufacturer</unit><role>Manufacturer of custom-made devices</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="10" paragraph="5"/>
  </task>

  <task id="t12">
    <label>draw up an EU declaration of conformity in accordance with Article 19</label>
    <performers>
      <performer><unit>Manufacturer</unit><role>Manufacturer</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>where compliance with the applicable requirements has been demonstrated following the applicable conformity assessment procedure</condition>
    </conditions>
    <exceptions>
      <exception ref="t13" description="Manufacturer of custom-made devices"/>
        <exception ref="t13" description="Manufacturer of investigational devices"/>
    </exceptions>
    <source-ref article="10" paragraph="6"/>
  </task>

  <task id="t13">
    <label>affix the CE marking of conformity in accordance with Article 20</label>
    <performers>
      <performer><unit>Manufacturer</unit><role>Manufacturer</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>where compliance with the applicable requirements has been demonstrated following the applicable conformity assessment procedure</condition>
    </conditions>
    <exceptions>
      <exception  ref="t14" description="Manufacturer of custom-made devices"/>
        <exception ref="t14" description="Manufacturer of investigational devices"/>
    </exceptions>
    <source-ref article="10" paragraph="6"/>
  </task>

  <task id="t14">
    <label>comply with the obligations</label>
    <performers>
      <performer><unit>Manufacturer</unit><role>Manufacturer</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="10" paragraph="7"/>
  </task>

  <task id="t15">
    <label>keep the technical documentation, the EU declaration of conformity and a copy of any relevant certificate</label>
    <performers>
      <performer><unit>Manufacturer</unit><role>Manufacturer</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>for a period of at least 10 years after the last device has been placed on the market</condition>
    </conditions>
    <exceptions>
      <exception ref="t16" description="Manufacturer of implantable devices"/>
    </exceptions>
    <source-ref article="10" paragraph="8"/>
  </task>

  <task id="t16">
    <label>keep the technical documentation, the EU declaration of conformity and a copy of any relevant certificate</label>
    <performers>
      <performer><unit>Manufacturer</unit><role>Manufacturer of implantable devices</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>for a period of at least 15 years after the last device has been placed on the market</condition>
    </conditions>
    <source-ref article="10" paragraph="8"/>
  </task>

  <task id="t17">
    <label>request technical documentation</label>
    <performers>
      <performer><unit>Member State</unit><role>Competent Authority</role></performer>
    </performers>
    <deontic type="obligation" modality="may"/>
    <conditions/>
    <source-ref article="10" paragraph="8"/>
  </task>

  <task id="t18">
    <label>provide technical documentation in its entirety or a summary</label>
    <performers>
      <performer><unit>Manufacturer</unit><role>Manufacturer</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>upon request by a competent authority</condition>
    </conditions>
    <exceptions/>
    <source-ref article="10" paragraph="8"/>
  </task>

  <task id="t19">
    <label>ensure that the authorised representative has the necessary documentation permanently available</label>
    <performers>
      <performer><unit>Manufacturer</unit><role>Manufacturer</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>manufacturer has a registered place of business outside the Union</condition>
      <condition>allow the authorised representative to fulfil the tasks mentioned in Article 11(3)</condition>
    </conditions>
    <exceptions/>
    <source-ref article="10" paragraph="8"/>
  </task>

  <task id="t20">
    <label>ensure that procedures are in place to keep series production in conformity with the requirements</label>
    <performers>
      <performer><unit>Manufacturer</unit><role>Manufacturer</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="10" paragraph="9"/>
  </task>

  <task id="t21">
    <label>take into account changes in device design or characteristics and changes in the harmonised standards or CS by reference to which the conformity of a device is declared</label>
    <performers>
      <performer><unit>Manufacturer</unit><role>Manufacturer</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="10" paragraph="9"/>
  </task>

  <task id="t22">
    <label>establish a quality management system</label>
    <performers>
      <performer><unit>Manufacturer</unit><role>Manufacturer</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions>
      <exception ref="t23" description="Manufacturer of investigational devices"/>
    </exceptions>
    <source-ref article="10" paragraph="9"/>
  </task>

  <task id="t23">
    <label>document a quality management system</label>
    <performers>
      <performer><unit>Manufacturer</unit><role>Manufacturer</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions>
      <exception ref="t24" description="Manufacturer of investigational devices"/>
    </exceptions>
    <source-ref article="10" paragraph="9"/>
  </task>

  <task id="t24">
    <label>implement a quality management system</label>
    <performers>
      <performer><unit>Manufacturer</unit><role>Manufacturer</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions>
      <exception ref="t25" description="Manufacturer of investigational devices"/>
    </exceptions>
    <source-ref article="10" paragraph="9"/>
  </task>

  <task id="t25">
    <label>maintain a quality management system</label>
    <performers>
      <performer><unit>Manufacturer</unit><role>Manufacturer</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions>
      <exception ref="t26" description="Manufacturer of investigational devices"/>
    </exceptions>
    <source-ref article="10" paragraph="9"/>
  </task>

  <task id="t26">
    <label>keep up to date a quality management system</label>
    <performers>
      <performer><unit>Manufacturer</unit><role>Manufacturer</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions>
      <exception ref="t27" description="Manufacturer of investigational devices"/>
    </exceptions>
    <source-ref article="10" paragraph="9"/>
  </task>

  <task id="t27">
    <label>improve a quality management system</label>
    <performers>
      <performer><unit>Manufacturer</unit><role>Manufacturer</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions>
      <exception ref="t28" description="Manufacturer of investigational devices"/>
    </exceptions>
    <source-ref article="10" paragraph="9"/>
  </task>

  <task id="t28">
    <label>cover all parts and elements of a manufacturer's organisation dealing with the quality of processes, procedures and devices</label>
    <performers>
      <performer><unit>Manufacturer</unit><role>Quality Management System</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions>
      <exception ref="t29" description="Manufacturer of investigational devices"/>
    </exceptions>
    <source-ref article="10" paragraph="9"/>
  </task>

  <task id="t29">
    <label>govern the structure, responsibilities, procedures, processes and management resources</label>
    <performers>
      <performer><unit>Manufacturer</unit><role>Quality Management System</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
   <conditions/>
    <exceptions>
      <exception ref="t30" description="Manufacturer of investigational devices"/>
    </exceptions>
    <source-ref article="10" paragraph="9"/>
  </task>

  <task id="t30">
    <label>address at least the aspects set out in paragraph 9</label>
    <performers>
      <performer><unit>Manufacturer</unit><role>Quality Management System</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions>
      <exception ref="t31" description="Manufacturer of investigational devices"/>
    </exceptions>
    <source-ref article="10" paragraph="9"/>
  </task>

  <task id="t31">
    <label>implement the post-market surveillance system in accordance with Article 83</label>
    <performers>
      <performer><unit>Manufacturer</unit><role>Manufacturer</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="10" paragraph="10"/>
  </task>

  <task id="t32">
    <label>keep up to date the post-market surveillance system in accordance with Article 83</label>
    <performers>
      <performer><unit>Manufacturer</unit><role>Manufacturer</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="10" paragraph="10"/>
  </task>

  <task id="t33">
    <label>ensure that the device is accompanied by the information set out in Section 23 of Annex I</label>
    <performers>
      <performer><unit>Manufacturer</unit><role>Manufacturer</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="10" paragraph="11"/>
  </task>

  <task id="t34">
    <label>bring the device into conformity</label>
    <performers>
      <performer><unit>Manufacturer</unit><role>Manufacturer</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>where manufacturers consider or have reason to believe that a device which they have placed on the market or put into service is not in conformity with this Regulation</condition>
    </conditions>
    <exceptions/>
    <source-ref article="10" paragraph="12"/>
  </task>

  <task id="t35">
    <label>withdraw the device</label>
    <performers>
      <performer><unit>Manufacturer</unit><role>Manufacturer</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>where manufacturers consider or have reason to believe that a device which they have placed on the market or put into service is not in conformity with this Regulation</condition>
    </conditions>
    <exceptions/>
    <source-ref article="10" paragraph="12"/>
  </task>

  <task id="t36">
    <label>recall the device</label>
    <performers>
      <performer><unit>Manufacturer</unit><role>Manufacturer</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>where manufacturers consider or have reason to believe that a device which they have placed on the market or put into service is not in conformity with this Regulation</condition>
    </conditions>
    <exceptions/>
    <source-ref article="10" paragraph="12"/>
  </task>

  <task id="t37">
    <label>inform the distributors of the device, the authorised representative and importers</label>
    <performers>
      <performer><unit>Manufacturer</unit><role>Manufacturer</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>where manufacturers consider or have reason to believe that a device which they have placed on the market or put into service is not in conformity with this Regulation</condition>
    </conditions>
    <exceptions/>
    <source-ref article="10" paragraph="12"/>
  </task>

  <task id="t38">
    <label>inform the competent authorities and the notified body of the non-compliance and of any corrective action taken</label>
    <performers>
      <performer><unit>Manufacturer</unit><role>Manufacturer</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>where manufacturers consider or have reason to believe that a device which they have placed on the market or put into service is not in conformity with this Regulation</condition>
      <condition>where the device presents a serious risk</condition>
    </conditions>
    <exceptions/>
    <source-ref article="10" paragraph="12"/>
  </task>

  <task id="t39">
    <label>have a system for recording and reporting of incidents and field safety corrective actions</label>
    <performers>
      <performer><unit>Manufacturer</unit><role>Manufacturer</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="10" paragraph="13"/>
  </task>

  <task id="t40">
    <label>request documentation necessary to demonstrate the conformity of the device</label>
    <performers>
      <performer><unit>Member State</unit><role>Competent Authority</role></performer>
    </performers>
    <deontic type="obligation" modality="may"/>
    <conditions/>
    <exceptions/>
    <source-ref article="10" paragraph="14"/>
  </task>

  <task id="t41">
    <label>provide the competent authority with all the information and documentation necessary to demonstrate the conformity of the device</label>
    <performers>
      <performer><unit>Manufacturer</unit><role>Manufacturer</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>upon request by a competent authority</condition>
    </conditions>
    <exceptions/>
    <source-ref article="10" paragraph="14"/>
  </task>

  <task id="t42">
    <label>require that the manufacturer provide samples of the device free of charge</label>
    <performers>
      <performer><unit>Member State</unit><role>Competent Authority</role></performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions/>
    <exceptions/>
    <source-ref article="10" paragraph="14"/>
  </task>

  <task id="t43">
    <label>require to grant access to the device</label>
    <performers>
      <performer><unit>Member State</unit><role>Competent Authority</role></performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions/>
    <exceptions/>
    <source-ref article="10" paragraph="14"/>
  </task>

  <task id="t44">
    <label>request collaboration with manufacturer</label>
    <performers>
      <performer><unit>Member State</unit><role>Competent Authority</role></performer>
    </performers>
    <deontic type="obligation" modality="may"/>
    <conditions/>
    <exceptions/>
    <source-ref article="10" paragraph="14"/>
  </task>

  <task id="t45">
    <label>cooperate with a competent authority</label>
    <performers>
      <performer><unit>Manufacturer</unit><role>Manufacturer</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>at the request of a competent authority</condition>
    </conditions>
    <exceptions/>
    <source-ref article="10" paragraph="14"/>
  </task>

  <task id="t46">
    <label>take all appropriate measures to prohibit or restrict the device's being made available on its national market</label>
    <performers>
      <performer><unit>Member State</unit><role>Competent Authority</role></performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>if the manufacturer fails to cooperate or the information and documentation provided is incomplete or incorrect</condition>
    </conditions>
    <exceptions/>
    <source-ref article="10" paragraph="14"/>
  </task>

  <task id="t47">
    <label>withdraw the device from that market</label>
    <performers>
      <performer><unit>Member State</unit><role>Competent Authority</role></performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>if the manufacturer fails to cooperate or the information and documentation provided is incomplete or incorrect</condition>
    </conditions>
    <exceptions/>
    <source-ref article="10" paragraph="14"/>
  </task>

  <task id="t48">
    <label>recall the device until the manufacturer cooperates or provides complete and correct information</label>
    <performers>
      <performer><unit>Member State</unit><role>Competent Authority</role></performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions>
      <condition>if the manufacturer fails to cooperate or the information and documentation provided is incomplete or incorrect</condition>
    </conditions>
    <exceptions/>
    <source-ref article="10" paragraph="14"/>
  </task>

  <task id="t49">
    <label>facilitate the provision of the information and documentation to the potentially injured patient or user </label>
    <performers>
      <performer><unit>Member State</unit><role>Competent Authority</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>if a competent authority considers or has reason to believe that a device has caused damage</condition>
      <condition>upon request</condition>
      <condition>without prejudice to data protection rules</condition>
    </conditions>
    <exceptions>
      <exception ref="t51" description="there is an overriding public interest in disclosure"/>
      <exception ref="t51" description="The competent authority need not comply with this obligation where disclosure of the information and documentation referred to in the first subparagraph is ordinarily dealt with in the context of legal proceedings"/>
    </exceptions>
    <source-ref article="10" paragraph="14"/>
  </task>

  <task id="t50">
    <label>ensure that the information on the identity of the person who designed or manufactured the device is part of the information to be submitted in accordance with Article 30(1)</label>
    <performers>
      <performer><unit>Manufacturer</unit><role>Manufacturer</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>where manufacturers have their devices designed or manufactured by another legal or natural person</condition>
    </conditions>
    <exceptions/>
    <source-ref article="10" paragraph="15"/>
  </task>

  <task id="t51">
    <label>claim compensation for damage caused by a defective device</label>
    <performers>
      <performer><unit>Natural / Legal Person</unit><role>Patient / User</role></performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions/>
    <exceptions/>
    <source-ref article="10" paragraph="16"/>
  </task>

  <task id="t52">
    <label>have measures to provide sufficient financial coverage</label>
    <performers>
      <performer><unit>Manufacturer</unit><role>Manufacturer</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>in a manner that is proportionate to the risk class, type of device and the size of the enterprise</condition>
      <condition>without prejudice to more protective measures under national law</condition>
    </conditions>
    <exceptions/>
    <source-ref article="10" paragraph="16"/>
  </task>

</tasks>
