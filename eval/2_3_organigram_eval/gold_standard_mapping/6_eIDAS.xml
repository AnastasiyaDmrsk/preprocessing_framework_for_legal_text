<?xml version="1.0" encoding="UTF-8"?>
<tasks>

  <task id="t1">
    <label>designate a supervisory body</label>
    <performers>
      <performer><unit>Member State</unit><role>Member State</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="17" paragraph="1"/>
  </task>

  <task id="t2">
    <label>give the necessary powers and adequate resources to a supervisory body</label>
    <performers>
      <performer><unit>Member State</unit><role>Member State</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="17" paragraph="1"/>
  </task>

  <task id="t3">
    <label>notify to the Commission the names and the addresses of their respective designated supervisory bodies</label>
    <performers>
      <performer><unit>Member State</unit><role>Member State</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="17" paragraph="2"/>
  </task>

  <task id="t4">
    <label>supervise qualified trust service providers to ensure they meet the requirements</label>
    <performers>
      <performer><unit>Member State</unit><role>Supervisory Body</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="17" paragraph="3"/>
  </task>

  <task id="t5">
    <label>take action in relation to non-qualified trust service providers</label>
    <performers>
      <performer><unit>Supervisory Body</unit><role>Supervisory body</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>when informed that those non-qualified trust service providers or the trust services they provide allegedly do not meet the requirements laid down in this Regulation</condition>
    </conditions>
    <exceptions/>
    <source-ref article="17" paragraph="3"/>
  </task>

  <task id="t6">
    <label>cooperate with other supervisory bodies</label>
    <performers>
      <performer><unit>Member State</unit><role>Supervisory body</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="17" paragraph="4"/>
  </task>

  <task id="t7">
    <label>provide other supervisory bodies with assistance</label>
    <performers>
      <performer><unit>Member State</unit><role>Supervisory Body</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="17" paragraph="4"/>
  </task>

  <task id="t8">
    <label>analyse the conformity assessment reports</label>
    <performers>
      <performer><unit>Member State</unit><role>Supervisory Body</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="17" paragraph="4"/>
  </task>

  <task id="t9">
    <label>inform other supervisory bodies and the public about breaches of security or loss of integrity</label>
    <performers>
      <performer><unit>Member State</unit><role>Supervisory Body</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="17" paragraph="4"/>
  </task>

  <task id="t10">
    <label>report to the Commission about its main activities</label>
    <performers>
      <performer><unit>Member State</unit><role>Supervisory Body</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="17" paragraph="4"/>
  </task>

  <task id="t11">
    <label>carry out audits</label>
    <performers>
      <performer><unit>Member State</unit><role>Supervisory Body</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="17" paragraph="4"/>
  </task>

  <task id="t12">
    <label>request a conformity assessment body to perform a conformity assessment of the qualified trust service providers</label>
    <performers>
      <performer><unit>Member State</unit><role>Supervisory Body</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="17" paragraph="4"/>
  </task>

  <task id="t13">
    <label>perform a conformity assessment of the qualified trust service providers</label>
    <performers>
      <performer><unit>Conformity Assessment Body</unit><role>Conformity Assessment Body</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>upon request</condition>
    </conditions>
    <exceptions/>
    <source-ref article="17" paragraph="4"/>
  </task>

  <task id="t14">
    <label>cooperate with the data protection authorities</label>
    <performers>
      <performer><unit>Member State</unit><role>Supervisory Body</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="17" paragraph="4"/>
  </task>

  <task id="t15">
    <label>inform the data protection authorities about the results of audits of qualified trust service providers</label>
    <performers>
      <performer><unit>Member State</unit><role>Supervisory Body</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>where personal data protection rules appear to have been breached</condition>
    </conditions>
    <exceptions/>
    <source-ref article="17" paragraph="4"/>
  </task>

  <task id="t16">
    <label>grant qualified status to trust service providers and to the services they provide</label>
    <performers>
      <performer><unit>Member State</unit><role>Supervisory Body</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="17" paragraph="4"/>
  </task>

  <task id="t17">
    <label>withdraw qualified status from trust service providers and from the services they provide</label>
    <performers>
      <performer><unit>Member State</unit><role>Supervisory Body</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="17" paragraph="4"/>
  </task>

  <task id="t18">
    <label>inform the body responsible for the national trusted list about its decisions to grant or to withdraw qualified status</label>
    <performers>
      <performer><unit>Member State</unit><role>Supervisory Body</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions>
      <exception ref="t17" description="unless that body is also the supervisory body"/>
    </exceptions>
    <source-ref article="17" paragraph="4"/>
  </task>

  <task id="t19">
    <label>verify the existence and correct application of provisions on termination plans</label>
    <performers>
      <performer><unit>Member State</unit><role>Supervisory Body</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>in cases where the qualified trust service provider ceases its activities</condition>
    </conditions>
    <exceptions/>
    <source-ref article="17" paragraph="4"/>
  </task>

  <task id="t20">
    <label>require that trust service providers remedy any failure to fulfil the requirements</label>
    <performers>
      <performer><unit>Member State</unit><role>Supervisory Body</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="17" paragraph="4"/>
  </task>

  <task id="t21">
    <label>require the supervisory body to establish, maintain and update a trust infrastructure</label>
    <performers>
      <performer><unit>Member State</unit><role>Member State</role></performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions/>
    <exceptions/>
    <source-ref article="17" paragraph="5"/>
  </task>

  <task id="t22">
    <label>establish a trust infrastructure</label>
    <performers>
      <performer><unit>Member State</unit><role>Supervisory Body</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>if required by Member State</condition>
    </conditions>
    <exceptions/>
    <source-ref article="17" paragraph="5"/>
  </task>

  <task id="t23">
    <label>maintain a trust infrastructure</label>
    <performers>
      <performer><unit>Member State</unit><role>Supervisory Body</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>if required by Member State</condition>
    </conditions>
    <exceptions/>
    <source-ref article="17" paragraph="5"/>
  </task>

  <task id="t24">
    <label>update a trust infrastructure</label>
    <performers>
      <performer><unit>Member State</unit><role>Supervisory Body</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>if required by Member State</condition>
    </conditions>
    <exceptions/>
    <source-ref article="17" paragraph="5"/>
  </task>

  <task id="t25">
    <label>submit to the Commission a report on its previous calendar year's main activities with a summary of breach notifications received from trust service providers</label>
    <performers>
      <performer><unit>Member State</unit><role>Supervisory Body</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>by 31 March each year</condition>
    </conditions>
    <exceptions/>
    <source-ref article="17" paragraph="6"/>
  </task>

  <task id="t26">
    <label>make the annual report available to Member States</label>
    <performers>
      <performer><unit>Commission</unit><role>Commission</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="17" paragraph="7"/>
  </task>

  <task id="t27">
    <label>define the formats and procedures for the report</label>
    <performers>
      <performer><unit>Commission</unit><role>Commission</role></performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions/>
    <exceptions/>
    <source-ref article="17" paragraph="8"/>
  </task>

  <task id="t28">
    <label>adopt those implementing acts in accordance with the examination procedure referred to in Article 48(2)</label>
    <performers>
      <performer><unit>Commission</unit><role>Commission</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="17" paragraph="8"/>
  </task>

  <task id="t29">
    <label>cooperate with a view to exchanging good practice</label>
    <performers>
      <performer><unit>Member State</unit><role>Supervisory Body</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="18" paragraph="1"/>
  </task>

  <task id="t30">
    <label>request assistance</label>
    <performers>
      <performer><unit>Member State</unit><role>Another Supervisory Body</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="18" paragraph="1"/>
  </task>

  <task id="t31">
    <label>provide assistance</label>
    <performers>
      <performer><unit>Member State</unit><role>Supervisory Body</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>upon receipt of a justified request from another supervisory body</condition>
    </conditions>
    <exceptions/>
    <source-ref article="18" paragraph="1"/>
  </task>

  <task id="t32">
    <label>refuse assistance</label>
    <performers>
      <performer><unit>Member State</unit><role>Supervisory Body</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>the supervisory body is not competent to provide the requested assistance</condition>
      <condition>the requested assistance is not proportionate to supervisory activities of the supervisory body carried out in accordance with Article 17</condition>
      <condition>providing the requested assistance would be incompatible with this Regulation</condition>
    </conditions>
    <exceptions/>
    <source-ref article="18" paragraph="1"/>
  </task>

  <task id="t33">
    <label>authorise their supervisory bodies to carry out joint investigations</label>
    <performers>
      <performer><unit>Member State</unit><role>Member State</role></performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions/>
    <exceptions/>
    <source-ref article="18" paragraph="3"/>
  </task>

  <task id="t34">
    <label>carry out joint investigations</label>
    <performers>
      <performer><unit>Member State</unit><role>Supervisory Body</role></performer>
      <performer><unit>Member State</unit><role>Another Supervisory Body</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>if authorised</condition>
    </conditions>
    <exceptions/>
    <source-ref article="18" paragraph="3"/>
  </task>

  <task id="t35">
    <label>agree upon and establish the arrangements and procedures for such joint actions</label>
    <performers>
      <performer><unit>Member State</unit><role>Member State</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>where Member States authorise their supervisory bodies to carry out joint investigations</condition>
    </conditions>
    <exceptions/>
    <source-ref article="18" paragraph="3"/>
  </task>

  <task id="t36">
    <label>take appropriate technical and organisational measures to manage the risks posed to the security of the trust services</label>
    <performers>
      <performer><unit>Trust Service Provider</unit><role>Qualified Trust Service Provider</role></performer>
      <performer><unit>Trust Service Provider</unit><role>Non-qualified Trust Service Provider</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="19" paragraph="1"/>
  </task>

  <task id="t37">
    <label>take measures to prevent and minimise the impact of security incidents</label>
    <performers>
      <performer><unit>Trust Service Provider</unit><role>Qualified Trust Service Provider</role></performer>
      <performer><unit>Trust Service Provider</unit><role>Non-qualified Trust Service Provider</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="19" paragraph="1"/>
  </task>

  <task id="t38">
    <label>inform stakeholders of the adverse effects of any security incidents</label>
    <performers>
      <performer><unit>Trust Service Provider</unit><role>Qualified Trust Service Provider</role></performer>
      <performer><unit>Trust Service Provider</unit><role>Non-qualified Trust Service Provider</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="19" paragraph="1"/>
  </task>

  <task id="t39">
    <label>notify the supervisory body and other relevant bodies</label>
    <performers>
      <performer><unit>Trust Service Provider</unit><role>Qualified Trust Service Provider</role></performer>
      <performer><unit>Trust Service Provider</unit><role>Non-qualified Trust Service Provider</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>any breach of security or loss of integrity has a significant impact on the trust service provided or on the personal data maintained therein</condition>
      <condition>without undue delay but in any event within 24 hours after having become aware of it</condition>
    </conditions>
    <exceptions/>
    <source-ref article="19" paragraph="2"/>
  </task>

  <task id="t40">
    <label>notify the natural or legal person</label>
    <performers>
      <performer><unit>Trust Service Provider</unit><role>Qualified Trust Service Provider</role></performer>
      <performer><unit>Trust Service Provider</unit><role>Non-qualified Trust Service Provider</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>where the breach of security or loss of integrity is likely to adversely affect a natural or legal person to whom the trusted service has been provided</condition>
    </conditions>
    <exceptions/>
    <source-ref article="19" paragraph="2"/>
  </task>

  <task id="t41">
    <label>inform the supervisory bodies in other Member States concerned and ENISA of the significant incident</label>
    <performers>
      <performer><unit>Member State</unit><role>Supervisory Body</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>where appropriate, in particular if a breach of security or loss of integrity concerns two or more Member States</condition>
    </conditions>
    <exceptions/>
    <source-ref article="19" paragraph="2"/>
  </task>

  <task id="t42">
    <label>inform the public about the breach of security or loss of integrity</label>
    <performers>
      <performer><unit>Member State</unit><role>Supervisory Body</role></performer>
      <performer><unit>Trust Service Provider</unit><role>Qualified Trust Service Provider</role></performer>
      <performer><unit>Trust Service Provider</unit><role>Non-qualified Trust Service Provider</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>where it determines that disclosure of the breach of security or loss of integrity is in the public interest</condition>
    </conditions>
    <exceptions>
      <exception ref="t41" description="trust service provider should inform public only if required by supervisory body"/>
    </exceptions>
    <source-ref article="19" paragraph="2"/>
  </task>

  <task id="t43">
    <label>require the trust service provider to inform the public about the breach of security or loss of integrity</label>
    <performers>
      <performer><unit>Member State</unit><role>Supervisory Body</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>where it determines that disclosure of the breach of security or loss of integrity is in the public interest</condition>
    </conditions>
    <exceptions/>
    <source-ref article="19" paragraph="2"/>
  </task>

  <task id="t44">
    <label>provide ENISA with a summary of notifications of breach of security and loss of integrity</label>
    <performers>
      <performer><unit>Member State</unit><role>Supervisory body</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions>
      <condition>once a year</condition>
    </conditions>
    <exceptions/>
    <source-ref article="19" paragraph="3"/>
  </task>

  <task id="t45">
    <label>further specify the measures</label>
    <performers>
      <performer><unit>Commission</unit><role>Commission</role></performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions/>
    <exceptions/>
    <source-ref article="19" paragraph="4"/>
  </task>

  <task id="t46">
    <label>define the formats and procedures</label>
    <performers>
      <performer><unit>Commission</unit><role>Commission</role></performer>
    </performers>
    <deontic type="permission" modality="may"/>
    <conditions/>
    <exceptions/>
    <source-ref article="19" paragraph="4"/>
  </task>

  <task id="t47">
    <label>adopt those implementing acts in accordance with the examination procedure referred to in Article 48(2)</label>
    <performers>
      <performer><unit>Commission</unit><role>Commission</role></performer>
    </performers>
    <deontic type="obligation" modality="shall"/>
    <conditions/>
    <exceptions/>
    <source-ref article="19" paragraph="4"/>
  </task>

</tasks>
